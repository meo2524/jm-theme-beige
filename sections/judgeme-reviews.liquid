{% comment %} Judge.me Review Widget — added for JSON template support {% endcomment %}
<div class="judgeme-reviews-wrapper" style="max-width:1200px;margin:0 auto;padding:48px 20px;">
  <div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-id='{{ product.id }}'></div>
</div>

<style>
/* ── Judge.me widget mobile containment ──────────────────────
   The review photo gallery overflows horizontally on mobile.
   Contain it inside the page without clipping individual photos. */
.judgeme-reviews-wrapper {
  overflow-x: hidden;
  box-sizing: border-box;
  max-width: 100%;
}

@media (max-width: 767px) {
  .judgeme-reviews-wrapper {
    padding: 32px 16px !important;
  }

  /* Top-level containers */
  .jdgm-rev-widg__body,
  .jdgm-rev-widg__header,
  .jdgm-rev-widg__reviews {
    max-width: 100%;
    overflow-x: hidden;
  }

  /* Photo/media gallery: scroll within its own box, not the page */
  .jdgm-carousel-wrapper,
  .jdgm-carousel,
  .jdgm-media-preview-container {
    max-width: 100%;
    overflow-x: auto !important;
    -webkit-overflow-scrolling: touch;
  }

  /* Individual review cards */
  .jdgm-rev {
    max-width: 100%;
    box-sizing: border-box;
  }

  /* Action buttons — wrap on narrow screens */
  .jdgm-rev-widg__btn-container {
    flex-wrap: wrap;
    gap: 8px;
  }
}
</style>

{% schema %}
{
  "name": "Reviews (Judge.me)",
  "tag": "section",
  "class": "section-judgeme-reviews",
  "settings": []
}
{% endschema %}
