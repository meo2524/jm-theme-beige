<!-- ============================================================
     MEND & CO — HEADER
     Sticky nav: logo, main links, cart icon, mobile menu
     ============================================================ -->

{%- liquid
  assign main_menu = section.settings.menu | default: 'main-menu'
  assign logo      = section.settings.logo
  assign logo_width = section.settings.logo_width | default: 140
  assign logo_width_2x = logo_width | times: 2
  if logo != blank
    assign logo_src_1x = logo | image_url: width: logo_width
    assign logo_src_2x = logo | image_url: width: logo_width_2x
  endif
-%}

<header
  class="site-header"
  id="site-header"
  role="banner"
  data-header
>
  <div class="header__inner container">

    <!-- Logo / Wordmark -->
    <a href="{{ routes.root_url }}" class="header__logo wordmark" aria-label="{{ shop.name }}">
      {%- if logo != blank -%}
        <img
          src="{{ logo_src_1x }}"
          srcset="{{ logo_src_1x }} 1x, {{ logo_src_2x }} 2x"
          width="{{ logo_width }}"
          height="auto"
          alt="{{ shop.name }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- else -%}
        {%- comment -%}
          Mend & Co wordmark — italic gold ampersand. Shopify returns
          shop.name HTML-encoded ("Mend&amp;Co"), so decode it before
          splitting; otherwise the split produces literal "amp;" text.
        {%- endcomment -%}
        {%- assign clean_name = shop.name | replace: '&amp;', '&' -%}
        {%- assign name_parts = clean_name | split: '&' -%}
        {%- if name_parts.size == 2 -%}
          <span class="header__logo-text">{{ name_parts[0] | strip }}<em>&amp;</em>{{ name_parts[1] | strip }}</span>
        {%- else -%}
          <span class="header__logo-text">{{ clean_name }}</span>
        {%- endif -%}
      {%- endif -%}
    </a>

    <!-- Main nav — desktop -->
    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__nav-list" role="list">
        {%- for link in linklists[main_menu].links -%}
          {%- liquid
            assign is_active = false
            if link.active or link.child_active
              assign is_active = true
            endif
          -%}
          <li class="header__nav-item">
            <a
              href="{{ link.url }}"
              class="header__nav-link{% if is_active %} is-active{% endif %}"
              {% if link.current %}aria-current="page"{% endif %}
            >
              {{ link.title }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <!-- Right actions -->
    <div class="header__actions">

      <!-- Account -->
      {%- if shop.customer_accounts_enabled -%}
        {%- if customer -%}
          <a
            href="{{ routes.account_url }}"
            class="header__icon-btn"
            aria-label="Account"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
              <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2.5 18c0-4.142 3.358-7.5 7.5-7.5s7.5 3.358 7.5 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </a>
        {%- else -%}
          <div class="header__account-wrap">
            <button
              type="button"
              class="header__icon-btn"
              aria-label="Sign in"
              aria-expanded="false"
              aria-controls="account-popup"
              data-account-trigger
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
                <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M2.5 18c0-4.142 3.358-7.5 7.5-7.5s7.5 3.358 7.5 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>

            <div class="account-popup" id="account-popup" aria-hidden="true" data-account-popup role="dialog" aria-label="Sign in">
              <div class="account-popup__caret" aria-hidden="true"></div>

              <div class="account-popup__head">
                <p class="account-popup__title">{{ section.settings.account_popup_title | default: 'Sign in or create account' | escape }}</p>
                <button type="button" class="account-popup__close" aria-label="Close sign in" data-account-close>
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </button>
              </div>

              <a href="{{ routes.account_login_url }}" class="account-popup__shop-btn">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <rect width="18" height="18" rx="4" fill="white" fill-opacity="0.15"/>
                  <path d="M5 9a4 4 0 118 0 4 4 0 01-8 0z" fill="white"/>
                </svg>
                {{ section.settings.shop_signin_label | default: 'Sign in with shop' | escape }}
              </a>

              <div class="account-popup__or" aria-hidden="true"><span>{{ section.settings.or_divider | default: 'OR' | escape }}</span></div>

              <form action="{{ routes.account_login_url }}" method="get" class="account-popup__email-form">
                <div class="account-popup__email-wrap">
                  <label for="account-popup-email" class="visually-hidden">Email address</label>
                  <input
                    id="account-popup-email"
                    type="email"
                    name="checkout[email]"
                    placeholder="Email"
                    class="account-popup__email-input"
                    autocomplete="email"
                  >
                  <button type="submit" class="account-popup__email-submit" aria-label="Continue with email">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              </form>

              <div class="account-popup__quick">
                <a href="{{ routes.account_url }}" class="account-popup__quick-btn">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.3"/>
                    <path d="M5 6h6M5 9h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                  </svg>
                  {{ section.settings.orders_label | default: 'Orders' | escape }}
                </a>
                <a href="{{ routes.account_url }}" class="account-popup__quick-btn">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="8" cy="6" r="2.5" stroke="currentColor" stroke-width="1.3"/>
                    <path d="M2.5 14c0-3.038 2.462-5.5 5.5-5.5s5.5 2.462 5.5 5.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                  </svg>
                  {{ section.settings.profile_label | default: 'Profile' | escape }}
                </a>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}

      <!-- Cart -->
      <button
        class="header__icon-btn header__cart-btn"
        aria-label="Open cart"
        data-cart-toggle
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
          <path d="M2 2h2l2.5 9h9l1.5-6H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="17" r="1" fill="currentColor"/>
          <circle cx="15" cy="17" r="1" fill="currentColor"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count" aria-label="{{ cart.item_count }} items in cart" data-cart-count>
            {{ cart.item_count }}
          </span>
        {%- else -%}
          <span class="header__cart-count is-hidden" aria-hidden="true" data-cart-count>0</span>
        {%- endif -%}
      </button>

      <!-- Mobile menu toggle -->
      <button
        class="header__icon-btn header__menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <span class="header__hamburger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>

    </div>
    <!-- /header__actions -->

  </div>
  <!-- /header__inner -->


</header>

<!-- Mobile menu — full-screen editorial overlay -->
<div
  class="mobile-menu"
  id="mobile-menu"
  aria-hidden="true"
  data-mobile-menu
>
  <!-- Close button -->
  <button class="mobile-menu__close" aria-label="Close menu" data-menu-close>
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>


  <nav aria-label="Mobile navigation">
    <ul class="mobile-menu__list" role="list">
      {%- for link in linklists[main_menu].links -%}
        <li class="mobile-menu__item" style="--i:{{ forloop.index }}">
          <a
            href="{{ link.url }}"
            class="mobile-menu__link{% if link.active or link.child_active %} is-active{% endif %}"
          >
            {{ link.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>

  <div class="mobile-menu__footer">
    {%- if shop.customer_accounts_enabled -%}
      <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="mobile-menu__footer-link">
        {% if customer %}Account{% else %}Log in{% endif %}
      </a>
    {%- endif -%}
    <span class="mobile-menu__footer-tagline">Your body glowing. All day.</span>
  </div>
</div>
<!-- /mobile-menu -->

<!-- Overlay not needed for full-screen menu but kept for JS compatibility -->
<div class="nav-overlay" aria-hidden="true" data-nav-overlay></div>


<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
  /* ---- Header shell — dark luxury purple ---- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background-color: var(--cream-2);
    border-bottom: 1px solid rgba(107, 63, 160, 0.25);
    transition: border-color var(--transition-base),
                box-shadow var(--transition-base);
  }


  .site-header.is-scrolled {
    border-bottom-color: var(--line-strong);
    box-shadow: 0 1px 12px rgba(31, 29, 26, 0.06);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 84px;
    gap: var(--space-8);
  }

  /* ---- Logo ---- */
  .header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .header__logo img {
    display: block;
    width: {{ logo_width }}px;
    height: auto;
    max-width: 100%;
  }

  .header__logo-text {
    font-family: var(--font-body);
    font-size: 22px;
    font-weight: 800;
    color: #F7EFE3;
    background: #6B2FB3;
    letter-spacing: -0.04em;
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
    gap: 0.18em;
    padding: 0.38em 0.75em;
    border-radius: 999px;
    white-space: nowrap;
  }
  .header__logo-text em {
    font-style: normal;
    font-weight: 800;
    color: #FF3D8A;
  }

  /* ---- Desktop nav ---- */
  .header__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .header__nav-link {
    position: relative;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--char-soft);
    padding-block: var(--space-2);
    transition: color var(--transition-fast);
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  .header__nav-link:hover,
  .header__nav-link.is-active {
    color: var(--color-cta-hover);
  }

  .header__nav-link:hover::after,
  .header__nav-link:focus-visible::after,
  .header__nav-link.is-active::after {
    transform: scaleX(1);
  }

  /* ---- Actions ---- */
  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .header__icon-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--char-soft);
    border-radius: var(--radius-base);
    transition: color var(--transition-fast),
                background-color var(--transition-fast);
  }

  .header__icon-btn:hover {
    color: var(--color-cta-hover);
  }

  .header__icon-btn:focus-visible {
    outline: 2px solid var(--color-cta);
    outline-offset: 2px;
  }

  /* Account popup wrapper */
  .header__account-wrap {
    position: relative;
  }

  .account-popup {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    width: 290px;
    max-width: calc(100vw - 2rem);
    background: #2D2D2D;
    border: 1px solid rgba(242, 237, 228, 0.1);
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.45), 0 2px 8px rgba(0,0,0,0.3);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s 0.18s;
    z-index: 200;
  }

  .account-popup.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  /* Speech bubble caret */
  .account-popup__caret {
    position: absolute;
    top: -7px;
    right: 14px;
    width: 12px;
    height: 7px;
    overflow: visible;
  }

  .account-popup__caret::before,
  .account-popup__caret::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
  }

  .account-popup__caret::before {
    top: -1px;
    border-bottom: 7px solid rgba(242, 237, 228, 0.1);
  }

  .account-popup__caret::after {
    top: 1px;
    border-bottom: 7px solid #2D2D2D;
  }

  /* Popup header row */
  .account-popup__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .account-popup__title {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--cream);
    margin: 0;
  }

  .account-popup__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    border-radius: 6px;
    color: rgba(242, 237, 228, 0.5);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }

  .account-popup__close:hover {
    color: var(--cream);
    background: rgba(242, 237, 228, 0.08);
  }

  /* Sign in with Shop button */
  .account-popup__shop-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 11px 16px;
    background: #5433EB;
    border-radius: 8px;
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s;
  }

  .account-popup__shop-btn:hover {
    background: #4527CC;
  }

  /* OR divider */
  .account-popup__or {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 14px 0;
    color: rgba(242, 237, 228, 0.35);
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }

  .account-popup__or::before,
  .account-popup__or::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(242, 237, 228, 0.12);
  }

  /* Email input row */
  .account-popup__email-form {
    margin-bottom: 12px;
  }

  .account-popup__email-wrap {
    display: flex;
    align-items: center;
    border: 1px solid rgba(242, 237, 228, 0.18);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .account-popup__email-wrap:focus-within {
    border-color: rgba(242, 237, 228, 0.45);
  }

  .account-popup__email-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 11px 14px;
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 0.88rem;
  }

  .account-popup__email-input::placeholder {
    color: rgba(242, 237, 228, 0.4);
  }

  .account-popup__email-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: none;
    border: none;
    color: rgba(242, 237, 228, 0.5);
    cursor: pointer;
    transition: color 0.15s;
    flex-shrink: 0;
  }

  .account-popup__email-submit:hover {
    color: var(--cream);
  }

  /* Quick links row */
  .account-popup__quick {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .account-popup__quick-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    padding: 10px 12px;
    border: 1px solid rgba(242, 237, 228, 0.12);
    border-radius: 8px;
    color: rgba(242, 237, 228, 0.7);
    font-family: var(--font-body);
    font-size: 0.83rem;
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .account-popup__quick-btn:hover {
    border-color: rgba(242, 237, 228, 0.3);
    color: var(--cream);
    background: rgba(242, 237, 228, 0.05);
  }

  /* Cart count bubble */
  .header__cart-count {
    position: absolute;
    top: 6px;
    right: 6px;
    min-width: 16px;
    height: 16px;
    padding-inline: 3px;
    background-color: var(--gold-deep);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: var(--font-weight-medium);
    line-height: 16px;
    text-align: center;
    border-radius: 8px;
    pointer-events: none;
    transition: transform var(--transition-fast);
  }

  .header__cart-count.is-hidden {
    display: none;
  }

  .header__cart-count.is-bumping {
    animation: cart-bump 300ms ease;
  }

  @keyframes cart-bump {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.4); }
    100% { transform: scale(1); }
  }

  /* ---- Hamburger ---- */
  .header__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 20px;
  }

  .header__hamburger span {
    display: block;
    height: 1.5px;
    background-color: currentColor;
    transition: transform var(--transition-base),
                opacity var(--transition-base);
    transform-origin: center;
  }

  /* Hamburger → X when menu open */
  .header__menu-btn[aria-expanded="true"] .header__hamburger span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .header__menu-btn[aria-expanded="true"] .header__hamburger span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .header__menu-btn[aria-expanded="true"] .header__hamburger span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ---- Mobile menu — full-screen editorial overlay ---- */
  .mobile-menu {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    background: #0A0812;
    padding: 0 40px 48px;
    overflow-y: auto;
    z-index: var(--z-modal);
    display: flex;
    flex-direction: column;
    /* Hidden state */
    opacity: 0;
    pointer-events: none;
    transform: translateX(40px);
    transition: opacity 0.35s ease, transform 0.35s cubic-bezier(0.16,1,0.3,1);
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: all;
    transform: translateX(0);
  }

  /* Close button */
  .mobile-menu__close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(239,232,220,0.1);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(239,232,220,0.8);
    transition: background 0.2s, color 0.2s;
    flex-shrink: 0;
  }

  .mobile-menu__close:hover {
    background: rgba(239,232,220,0.18);
    color: var(--cream);
  }

  /* Brand row at top */
  .mobile-menu__brand {
    padding: 20px 0 48px;
    border-bottom: 1px solid rgba(239,232,220,0.1);
    margin-bottom: 48px;
  }

  .mobile-menu__brand-link {
    display: inline-block;
    text-decoration: none;
  }

  .mobile-menu__wordmark {
    font-family: var(--font-body);
    font-size: 22px;
    font-weight: 800;
    color: #F7EFE3;
    background: #6B2FB3;
    letter-spacing: -0.04em;
    display: inline-flex;
    align-items: baseline;
    gap: 0.18em;
    padding: 0.38em 0.75em;
    border-radius: 999px;
    white-space: nowrap;
  }

  .mobile-menu__wordmark em {
    font-style: normal;
    font-weight: 800;
    color: #FF3D8A;
  }

  .mobile-menu__logo-img {
    display: block;
    width: auto;
    max-width: 160px;
    height: auto;
    max-height: 40px;
  }

  /* Nav list */
  .mobile-menu__list {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .mobile-menu__item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    transition-delay: calc(var(--i, 1) * 55ms);
  }

  .mobile-menu.is-open .mobile-menu__item {
    opacity: 1;
    transform: translateY(0);
  }

  /* Editorial large serif links */
  .mobile-menu__link {
    display: block;
    padding: 18px 0;
    font-family: var(--font-body);
    font-size: clamp(36px, 8vw, 48px);
    font-weight: 400;
    line-height: 1.1;
    color: rgba(239,232,220,0.7);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    outline: none;
    transition: color 0.2s ease, letter-spacing 0.2s ease;
  }

  .mobile-menu__link:hover {
    color: var(--cream);
    letter-spacing: 0.01em;
  }

  .mobile-menu__link.is-active {
    color: var(--cream);
    font-style: italic;
  }

  /* Footer strip */
  .mobile-menu__footer {
    margin-top: auto;
    padding-top: 32px;
    border-top: 1px solid rgba(239,232,220,0.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .mobile-menu__footer-link {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(239,232,220,0.5);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .mobile-menu__footer-link:hover { color: var(--gold-light, #C9A16B); }

  .mobile-menu__footer-tagline {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 14px;
    color: rgba(239,232,220,0.3);
  }

  /* ---- Overlay ---- */
  .nav-overlay {
    position: fixed;
    inset: 0;
    top: 84px;
    background-color: rgba(31, 29, 26, 0.18);
    z-index: var(--z-overlay);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-slow);
  }

  .nav-overlay.is-visible {
    opacity: 1;
    pointer-events: all;
  }

  /* ---- Responsive ---- */
  @media (min-width: 1024px) {
    .header__menu-btn { display: none; }
    .mobile-menu      { display: none; }
    .nav-overlay      { display: none; }
  }

  @media (max-width: 1023px) {
    .header__nav { display: none; }
  }

  /* Account popup on narrow screens: pin it to a fixed position
     under the header so it doesn't overflow the viewport */
  @media (max-width: 480px) {
    .account-popup {
      position: fixed;
      top: 84px;
      right: 0.75rem;
      left: 0.75rem;
      width: auto;
      max-width: none;
      border-radius: 12px;
    }
  }
</style>


<!-- ============================================================
     SCRIPTS
     ============================================================ -->
<script>
  (function () {
    var trigger  = document.querySelector('[data-account-trigger]');
    var popup    = document.querySelector('[data-account-popup]');
    var closeBtn = document.querySelector('[data-account-close]');
    if (!trigger || !popup) return;

    function open() {
      popup.classList.add('is-open');
      popup.setAttribute('aria-hidden', 'false');
      trigger.setAttribute('aria-expanded', 'true');
    }

    function close() {
      popup.classList.remove('is-open');
      popup.setAttribute('aria-hidden', 'true');
      trigger.setAttribute('aria-expanded', 'false');
    }

    trigger.addEventListener('click', function (e) {
      e.stopPropagation();
      popup.classList.contains('is-open') ? close() : open();
    });

    if (closeBtn) closeBtn.addEventListener('click', close);

    document.addEventListener('click', function (e) {
      if (!popup.contains(e.target) && e.target !== trigger) close();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') close();
    });
  })();
</script>


