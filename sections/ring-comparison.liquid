{%- liquid
  assign heading    = section.settings.heading    | default: 'The N°01 vs the rest.'
  assign subheading = section.settings.subheading | default: 'Six reasons people who've tried both don't go back.'
  assign our_label  = section.settings.our_label  | default: 'Mend N°01'
  assign our_badge  = section.settings.our_badge  | default: 'Original'
  assign them_label = section.settings.them_label | default: 'Other Smart Rings'
  assign them_sub   = section.settings.them_sub   | default: '& Knock-offs'
-%}

<section class="rc-section" aria-label="{{ heading | escape }}">
  <div class="rc-inner">

    <header class="rc-header">
      <h2 class="rc-heading">{{ heading }}</h2>
      {%- if subheading != blank -%}
        <p class="rc-subheading">{{ subheading }}</p>
      {%- endif -%}
    </header>

    <div class="rc-table" role="table" aria-label="Ring comparison">

      {%- comment -%} Column headers {%- endcomment -%}
      <div class="rc-col-headers" role="row">
        <div class="rc-col-feature" role="columnheader" aria-label="Feature"></div>
        <div class="rc-col-ours" role="columnheader">
          <span class="rc-col-ours__name">{{ our_label }}</span>
          {%- if our_badge != blank -%}
            <span class="rc-badge">{{ our_badge }}</span>
          {%- endif -%}
        </div>
        <div class="rc-col-theirs" role="columnheader">
          <span class="rc-col-theirs__name">{{ them_label }}</span>
          {%- if them_sub != blank -%}
            <span class="rc-col-theirs__sub">{{ them_sub }}</span>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Rows {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'row' -%}
          {%- assign ours_val   = block.settings.ours_value   | default: '' -%}
          {%- assign theirs_val = block.settings.theirs_value | default: '' -%}
          {%- assign ours_yes   = block.settings.ours_yes -%}
          {%- assign theirs_yes = block.settings.theirs_yes -%}
          <div class="rc-row" role="row" {{ block.shopify_attributes }}>
            <div class="rc-cell rc-cell--feature" role="cell">
              {%- if block.settings.icon != blank -%}
                <span class="rc-row-icon" aria-hidden="true">{{ block.settings.icon }}</span>
              {%- endif -%}
              <span class="rc-row-label">{{ block.settings.feature }}</span>
            </div>
            <div class="rc-cell rc-cell--ours" role="cell">
              {%- if ours_val != blank -%}
                <span class="rc-value">{{ ours_val }}</span>
              {%- elsif ours_yes -%}
                <span class="rc-check" aria-label="Yes">
                  <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <circle cx="10" cy="10" r="9" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
                    <polyline points="6,10.5 9,13.5 14,7.5" stroke="rgba(255,255,255,0.95)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              {%- else -%}
                <span class="rc-cross rc-cross--ours" aria-label="No">
                  <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <circle cx="10" cy="10" r="9" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.18)" stroke-width="1"/>
                    <line x1="7" y1="7" x2="13" y2="13" stroke="rgba(255,255,255,0.45)" stroke-width="1.75" stroke-linecap="round"/>
                    <line x1="13" y1="7" x2="7" y2="13" stroke="rgba(255,255,255,0.45)" stroke-width="1.75" stroke-linecap="round"/>
                  </svg>
                </span>
              {%- endif -%}
            </div>
            <div class="rc-cell rc-cell--theirs" role="cell">
              {%- if theirs_val != blank -%}
                <span class="rc-value rc-value--theirs">{{ theirs_val }}</span>
              {%- elsif theirs_yes -%}
                <span class="rc-check rc-check--theirs" aria-label="Yes">
                  <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <circle cx="10" cy="10" r="9" fill="rgba(138,98,64,0.12)" stroke="rgba(138,98,64,0.3)" stroke-width="1"/>
                    <polyline points="6,10.5 9,13.5 14,7.5" stroke="#8A6240" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              {%- else -%}
                <span class="rc-cross" aria-label="No">
                  <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <circle cx="10" cy="10" r="9" fill="rgba(100,90,80,0.08)" stroke="rgba(100,90,80,0.18)" stroke-width="1"/>
                    <line x1="7" y1="7" x2="13" y2="13" stroke="rgba(100,90,80,0.45)" stroke-width="1.75" stroke-linecap="round"/>
                    <line x1="13" y1="7" x2="7" y2="13" stroke="rgba(100,90,80,0.45)" stroke-width="1.75" stroke-linecap="round"/>
                  </svg>
                </span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
    {%- comment -%} /rc-table {%- endcomment -%}

  </div>
</section>

<style>
/* ============================================================
   RING COMPARISON — Mend & Co
   Mend N°01 vs other smart rings
   ============================================================ */

.rc-section {
  background: var(--color-bone, #F2EDE4);
  padding: 5rem 1.5rem;
  overflow-x: hidden;
}

.rc-inner {
  max-width: 680px;
  margin: 0 auto;
}

/* Header */
.rc-header {
  text-align: center;
  margin-bottom: 2.5rem;
}

.rc-heading {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-size: clamp(1.875rem, 5vw, 2.75rem);
  font-weight: 300;
  line-height: 1.08;
  letter-spacing: -0.025em;
  color: var(--color-black, #1f1d1a);
  margin: 0 0 0.75rem;
}

.rc-subheading {
  font-family: var(--font-body, Inter, sans-serif);
  font-size: 0.9375rem;
  color: var(--color-olive, #6a6258);
  line-height: 1.5;
  margin: 0;
  max-width: 44ch;
  margin-inline: auto;
}

/* Table shell */
.rc-table {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--color-line, rgba(31,29,26,0.12));
  box-shadow: 0 4px 24px rgba(31,29,26,0.06);
}

/* Column header row */
.rc-col-headers {
  display: grid;
  grid-template-columns: 1fr 120px 100px;
  background: var(--color-paper, #f5efe4);
  border-bottom: 1px solid var(--color-line, rgba(31,29,26,0.12));
}

.rc-col-feature {
  padding: 1rem 1rem 1rem 1.25rem;
}

.rc-col-ours {
  background: var(--char, #1f1d1a);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1rem 0.5rem;
  gap: 0.375rem;
  border-radius: 8px 8px 0 0;
  margin: -1px;
}

.rc-col-ours__name {
  font-family: var(--font-label, monospace);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-bone, #f5efe4);
  text-align: center;
  line-height: 1.3;
}

.rc-badge {
  display: inline-block;
  font-family: var(--font-label, monospace);
  font-size: 0.5625rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--char, #1f1d1a);
  background: var(--color-gold-light, #c9a16b);
  border-radius: 100px;
  padding: 2px 8px;
  white-space: nowrap;
}

.rc-col-theirs {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1rem 0.5rem;
  gap: 0.25rem;
}

.rc-col-theirs__name {
  font-family: var(--font-label, monospace);
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-olive, #6a6258);
  text-align: center;
  line-height: 1.3;
}

.rc-col-theirs__sub {
  font-family: var(--font-body, Inter, sans-serif);
  font-size: 0.625rem;
  color: var(--color-olive, #6a6258);
  opacity: 0.7;
  text-align: center;
}

/* Data rows */
.rc-row {
  display: grid;
  grid-template-columns: 1fr 120px 100px;
  border-top: 1px solid var(--color-line, rgba(31,29,26,0.08));
  align-items: center;
}

.rc-row:first-of-type {
  border-top: none;
}

.rc-cell {
  padding: 0.875rem 0.75rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rc-cell--feature {
  justify-content: flex-start;
  gap: 0.5rem;
  padding-left: 1.25rem;
}

.rc-cell--ours {
  background: var(--char, #1f1d1a);
  border-left: 1px solid rgba(255,255,255,0.06);
  border-right: 1px solid rgba(255,255,255,0.06);
}

.rc-cell--theirs {
  background: transparent;
}

/* Feature label */
.rc-row-icon {
  font-size: 0.875rem;
  flex-shrink: 0;
  line-height: 1;
}

.rc-row-label {
  font-family: var(--font-body, Inter, sans-serif);
  font-size: 0.8125rem;
  color: var(--color-black, #1f1d1a);
  line-height: 1.35;
}

/* Check / cross */
.rc-check,
.rc-cross {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  flex-shrink: 0;
}

/* Text value inside a cell */
.rc-value {
  font-family: var(--font-label, monospace);
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-bone, #f5efe4);
  text-align: center;
  line-height: 1.3;
}

.rc-value--theirs {
  color: var(--color-olive, #6a6258);
}

/* Zebra tint on alternating rows */
.rc-row:nth-child(even) .rc-cell--feature,
.rc-row:nth-child(even) .rc-cell--theirs {
  background: rgba(31,29,26,0.025);
}

/* Mobile */
@media (max-width: 767px) {
  .rc-section {
    padding: 3rem 1rem;
  }

  .rc-col-headers {
    grid-template-columns: 1fr 90px 80px;
  }

  .rc-row {
    grid-template-columns: 1fr 90px 80px;
  }

  .rc-col-ours__name,
  .rc-col-theirs__name {
    font-size: 0.5625rem;
  }

  .rc-cell {
    padding: 0.75rem 0.5rem;
  }

  .rc-cell--feature {
    padding-left: 1rem;
  }

  .rc-row-label {
    font-size: 0.75rem;
  }
}
</style>

