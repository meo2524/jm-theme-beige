{%- if section.settings.show -%}
<div class="flash-bar" role="region" aria-label="Flash Sale Announcement">
  <div class="flash-bar__inner">
    <span class="flash-bar__text">
      {%- if section.settings.icon != blank -%}{{ section.settings.icon }} {%- endif -%}
      {{ section.settings.label }}
    </span>
    <div class="flash-bar__countdown" id="flashCountdown">
      <div class="flash-bar__unit">
        <span class="flash-bar__num" id="flashHrs">00</span>
        <span class="flash-bar__label">HRS</span>
      </div>
      <span class="flash-bar__sep">:</span>
      <div class="flash-bar__unit">
        <span class="flash-bar__num" id="flashMin">00</span>
        <span class="flash-bar__label">MIN</span>
      </div>
      <span class="flash-bar__sep">:</span>
      <div class="flash-bar__unit">
        <span class="flash-bar__num" id="flashSec">00</span>
        <span class="flash-bar__label">SEC</span>
      </div>
    </div>
  </div>
</div>

<style>
  .flash-bar {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 8px 16px;
    text-align: center;
  }

  .flash-bar__inner {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .flash-bar__text {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .flash-bar__countdown {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .flash-bar__unit {
    background: rgba(0, 0, 0, 0.18);
    border-radius: 4px;
    padding: 2px 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 36px;
  }

  .flash-bar__num {
    font-size: 15px;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }

  .flash-bar__label {
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.1em;
    opacity: 0.75;
    line-height: 1;
  }

  .flash-bar__sep {
    font-size: 15px;
    font-weight: 800;
    opacity: 0.6;
    margin-bottom: 8px;
  }
</style>

<script>
(function () {
  var KEY = 'flash_bar_end';
  var DURATION = 24 * 60 * 60 * 1000;

  function getEnd() {
    var stored = localStorage.getItem(KEY);
    var end = stored ? parseInt(stored, 10) : 0;
    if (!end || end <= Date.now()) {
      end = Date.now() + DURATION;
      localStorage.setItem(KEY, end);
    }
    return end;
  }

  function pad(n) {
    return n < 10 ? '0' + n : '' + n;
  }

  var hrsEl = document.getElementById('flashHrs');
  var minEl = document.getElementById('flashMin');
  var secEl = document.getElementById('flashSec');

  function tick() {
    var end = getEnd();
    var diff = end - Date.now();
    if (diff <= 0) {
      localStorage.removeItem(KEY);
      diff = 0;
    }
    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    hrsEl.textContent = pad(h);
    minEl.textContent = pad(m);
    secEl.textContent = pad(s);
  }

  tick();
  setInterval(tick, 1000);
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Flash Sale Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show",
      "label": "Show flash sale bar",
      "default": true
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Icon / emoji prefix",
      "default": "FLASH SALE"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sale label text",
      "default": "70% OFF Ends In:"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#b08850"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1007"
    }
  ]
}
{% endschema %}
