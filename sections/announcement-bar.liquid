{%- comment -%}
  Mend & Co — Promo bar (ledger marquee)
  Scrolling announcement strip below the header. The blurbs are editable
  section SETTINGS (item_1…item_6) — reliably editable on a static section,
  unlike blocks. Marks auto-cycle. Speed is configurable.
{%- endcomment -%}

{%- if section.settings.show -%}
  {%- liquid
    assign scroll_speed = section.settings.speed | default: 60
    assign marks = '◐|—|✶|·|◇|—' | split: '|'
    assign raw = section.settings.item_1 | append: '||' | append: section.settings.item_2 | append: '||' | append: section.settings.item_3 | append: '||' | append: section.settings.item_4 | append: '||' | append: section.settings.item_5 | append: '||' | append: section.settings.item_6
    assign items = raw | split: '||'
  -%}

  <div class="promo-bar" role="region" aria-label="Announcements">
    <div class="marquee promo-bar__marquee" style="animation-duration: {{ scroll_speed }}s;">
      {%- for cycle in (1..2) -%}
        {%- for text in items -%}
          {%- assign t = text | strip -%}
          {%- if t != blank -%}
            {%- assign mark_i = forloop.index0 | modulo: marks.size -%}
            <span class="promo-bar__item">
              <span class="promo-bar__mark">{{ marks[mark_i] }}</span>
              <span class="promo-bar__text">{{ t }}</span>
            </span>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<style>
  .promo-bar {
    background: var(--gold);
    border-bottom: 1px solid rgba(107, 63, 160, 0.4);
    height: 36px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
    contain: layout paint;
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-on-dark);
  }

  .promo-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    white-space: nowrap;
  }

  .promo-bar__mark {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 15px;
    color: var(--color-cta-hover);
    letter-spacing: 0.04em;
  }
</style>

{% schema %}
{
  "name": "Promo bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show",
      "label": "Show promo bar",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll duration (seconds — lower is faster)",
      "min": 15,
      "max": 120,
      "step": 5,
      "unit": "s",
      "default": 60
    },
    {
      "type": "header",
      "content": "Blurbs",
      "info": "Leave a field blank to hide it. They scroll continuously with auto-cycling marks."
    },
    { "type": "text", "id": "item_1", "label": "Blurb 1", "default": "Free shipping on orders over $60" },
    { "type": "text", "id": "item_2", "label": "Blurb 2", "default": "30-day money-back guarantee" },
    { "type": "text", "id": "item_3", "label": "Blurb 3", "default": "Loved by 30,000+ Menders worldwide" },
    { "type": "text", "id": "item_4", "label": "Blurb 4", "default": "Fast, tracked delivery" },
    { "type": "text", "id": "item_5", "label": "Blurb 5", "default": "Easy, hassle-free returns" },
    { "type": "text", "id": "item_6", "label": "Blurb 6", "default": "Secure checkout" }
  ]
}
{% endschema %}
