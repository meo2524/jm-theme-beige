{%- comment -%}
  Mend & Co — Promo bar (ledger marquee)
  Replaces the flash-sale countdown with brand-appropriate scrolling
  entries: journal posts, restocks, ritual notes. Each item has a
  short "mark" (N° XX, ✶, ◐) + text + optional link.
{%- endcomment -%}

{%- if section.settings.show -%}
  {%- assign items = section.blocks -%}
  {%- if items.size > 0 -%}
    <div class="promo-bar" role="region" aria-label="Announcements">
      <div class="marquee promo-bar__marquee">
        {%- comment -%} Render the items twice so the marquee loops seamlessly. {%- endcomment -%}
        {%- for cycle in (1..2) -%}
          {%- for block in items -%}
            <span class="promo-bar__item" {{ block.shopify_attributes }}>
              <span class="promo-bar__mark">{{ block.settings.mark | default: '✶' }}</span>
              <span class="promo-bar__text">{{ block.settings.text | default: 'New journal entry — read' | escape }}</span>
              {%- if block.settings.link_url != blank and block.settings.link_label != blank -%}
                <span class="promo-bar__sep" aria-hidden="true">·</span>
                <a class="promo-bar__link" href="{{ block.settings.link_url }}">{{ block.settings.link_label }}</a>
              {%- endif -%}
            </span>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

<style>
  .promo-bar {
    background: var(--cream-2);
    border-bottom: 1px solid var(--line);
    height: 32px;
    overflow: hidden;
    display: flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--char-soft);
  }

  .promo-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    white-space: nowrap;
  }

  .promo-bar__mark {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 13px;
    color: var(--gold-deep);
    letter-spacing: 0.04em;
  }

  .promo-bar__sep { opacity: 0.4; }

  .promo-bar__link {
    color: var(--gold-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(138, 102, 59, 0.45);
    transition: text-decoration-color 0.15s ease;
  }
  .promo-bar__link:hover { text-decoration-color: var(--gold-deep); }
</style>

{% schema %}
{
  "name": "Promo bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show",
      "label": "Show promo bar",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "Brand-appropriate ledger marquee. Add 3–6 items (journal entries, restocks, ritual notes). They scroll continuously."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee item",
      "settings": [
        {
          "type": "text",
          "id": "mark",
          "label": "Mark (e.g. N° 04, ✶, ◐)",
          "default": "✶"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Restocked — Restorative Elixir, 30ml"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "read"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "default": {
    "blocks": [
      {
        "type": "item",
        "settings": {
          "mark": "N° 04",
          "text": "Journal — On the slowness of skin",
          "link_label": "read"
        }
      },
      {
        "type": "item",
        "settings": {
          "mark": "✶",
          "text": "Restocked — Restorative Elixir, 30ml",
          "link_label": "read"
        }
      },
      {
        "type": "item",
        "settings": {
          "mark": "◐",
          "text": "New ritual guide enclosed with every order",
          "link_label": "read"
        }
      }
    ]
  },
  "presets": [
    {
      "name": "Promo bar"
    }
  ]
}
{% endschema %}
