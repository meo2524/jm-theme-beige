{%- comment -%}
  ──────────────────────────────────────────────────────────────────
  sections/product-video.liquid
  Mend & Co — "The ritual in motion" product-in-use video band.

  A square, silent autoplay-loop video in a soft rounded frame on a
  cream background, with an editorial eyebrow / heading / subtext.
  Reuses the theme reveal system (data-reveal) — no new JS.

  All copy and the video are theme-editor settings. Nothing hardcoded.
  Supports a Shopify-hosted video OR an external MP4 URL fallback.
  ──────────────────────────────────────────────────────────────────
{%- endcomment -%}

{%- liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign subtext = section.settings.subtext
  assign bg      = section.settings.bg_color | default: '#f5efe6'
  assign poster  = section.settings.poster
-%}

<section class="pvid" style="--pvid-bg: {{ bg }};">
  <div class="pvid__inner">
    {%- if eyebrow != blank -%}
      <p class="pvid__eyebrow" data-reveal data-reveal-delay="0">{{ eyebrow }}</p>
    {%- endif -%}
    {%- if heading != blank -%}
      <h2 class="pvid__heading" data-word-reveal>{{ heading }}</h2>
    {%- endif -%}
    {%- if subtext != blank -%}
      <p class="pvid__subtext" data-reveal data-reveal-delay="120">{{ subtext }}</p>
    {%- endif -%}

    <div class="pvid__frame" data-reveal data-reveal-delay="160">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: image_size: '1100x', autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'metadata' }}
      {%- elsif section.settings.video_url != blank -%}
        <video class="pvid__el" autoplay loop muted playsinline preload="metadata"
          {% if poster != blank %}poster="{{ poster | image_url: width: 1100 }}"{% endif %}>
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      {%- else -%}
        <div class="pvid__placeholder">Add a video in the theme editor.</div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .pvid {
    background: var(--pvid-bg, #f5efe6);
    padding: clamp(3rem, 7vw, 5.5rem) 1.25rem;
  }
  .pvid__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .pvid__eyebrow {
    font-family: var(--font-body, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 3.5px;
    text-transform: uppercase;
    color: var(--color-walnut, #8a6240);
    margin: 0 0 0.85rem;
  }
  .pvid__heading {
    font-family: var(--font-heading, 'JetBrains Mono', monospace);
    font-size: clamp(1.9rem, 4vw, 3rem);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--color-black, #1f1d1a);
    margin: 0 0 0.9rem;
  }
  .pvid__subtext {
    font-family: var(--font-body, 'JetBrains Mono', monospace);
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--char-soft, #5a4a3a);
    margin: 0 auto 2.25rem;
    max-width: 40ch;
  }
  .pvid__frame {
    position: relative;
    width: 100%;
    max-width: 540px;
    margin: 0 auto;
    aspect-ratio: 1 / 1;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 24px 60px -28px rgba(31, 29, 26, 0.45);
    background: #e8e0d8;
  }
  .pvid__frame video,
  .pvid__el {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pvid__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body, monospace);
    font-size: 0.8rem;
    color: #8a6240;
  }
  @media (prefers-reduced-motion: reduce) {
    .pvid__frame video,
    .pvid__el { /* browsers honour reduced-motion for autoplay where supported */ }
  }
</style>

{% schema %}
{
  "name": "Product video",
  "tag": "section",
  "class": "section-product-video",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "In motion" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A two-minute ritual." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Mist, massage and glide — the daily moment your hair looks forward to." },
    { "type": "video", "id": "video", "label": "Video (Shopify-hosted)" },
    { "type": "text", "id": "video_url", "label": "or external MP4 URL", "info": "Used only when no Shopify video is set." },
    { "type": "image_picker", "id": "poster", "label": "Poster image (for external URL)" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f5efe6" }
  ],
  "presets": [
    { "name": "Product video" }
  ]
}
{% endschema %}
