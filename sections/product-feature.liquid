{%- liquid
  assign eyebrow  = section.settings.eyebrow   | default: 'The science'
  assign heading  = section.settings.heading   | default: 'Most routines start too late.'
  assign body     = section.settings.body      | default: 'Most people don’t know what their body is doing while they sleep. The Smart Ring tracks HRV, recovery, and sleep architecture overnight, then tells you in the morning whether to push or rest.'
  assign cta_label = section.settings.cta_label | default: 'Learn more'
  assign cta_url   = section.settings.cta_url
  assign image     = section.settings.image
  assign video_url = section.settings.video_url
  assign reverse   = section.settings.reverse
-%}

{%- assign has_media = false -%}
{%- if video_url != blank or image != blank -%}{%- assign has_media = true -%}{%- endif -%}

<section class="product-feature section{% unless has_media %} product-feature--no-media{% endunless %}">
  <div class="container">

    <div class="product-feature__grid{% if reverse %} product-feature__grid--reverse{% endif %}{% unless has_media %} product-feature__grid--no-media{% endunless %}">

      <!-- Media (video takes priority over image) -->
      {%- if has_media -%}
      {%- assign video_y = section.settings.video_position_y | default: 50 -%}
      <div class="product-feature__media">
        {%- if video_url != blank -%}
          <video
            src="{{ video_url }}"
            {%- if image != blank %}
            poster="{{ image | image_url: width: 1200 }}"
            {%- endif %}
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            class="product-feature__video"
            style="object-position: 50% {{ video_y }}%;"
            aria-label="{{ heading | escape }}"
          >
            {%- if image != blank -%}
              <img
                src="{{ image | image_url: width: 1200 }}"
                alt="{{ image.alt | default: heading | escape }}"
                width="1200"
                height="1467"
                loading="lazy"
              >
            {%- endif -%}
          </video>
        {%- elsif image != blank -%}
          <img
            src="{{ image | image_url: width: 900 }}"
            srcset="
              {{ image | image_url: width: 600 }} 600w,
              {{ image | image_url: width: 900 }} 900w,
              {{ image | image_url: width: 1200 }} 1200w
            "
            sizes="(max-width: 767px) 100vw, 50vw"
            alt="{{ image.alt | default: heading | escape }}"
            width="900"
            height="1100"
            loading="lazy"
          >
        {%- endif -%}
      </div>
      {%- endif -%}

      <!-- Copy -->
      <div class="product-feature__copy">

        <span class="rule-above" aria-hidden="true"></span>

        {%- if eyebrow != blank -%}
          <p class="product-feature__eyebrow t-label" data-reveal data-reveal-delay="0">{{ eyebrow }}</p>
        {%- endif -%}

        <h2 class="product-feature__heading t-display-md" data-reveal data-reveal-delay="80">{{ heading }}</h2>

        {%- if body != blank -%}
          <div class="product-feature__body" data-reveal data-reveal-delay="160">
            <p>{{ body }}</p>
          </div>
        {%- endif -%}

        <!-- Optional bullet points -->
        {%- if section.blocks.size > 0 -%}
          <ul class="product-feature__bullets" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'bullet' -%}
                <li class="product-feature__bullet" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    <span class="product-feature__bullet-icon" aria-hidden="true">
                      {%- case block.settings.icon -%}
                        {%- when 'moon' -%}
                          <svg viewBox="0 0 48 48" width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M30 6a18 18 0 1012 22A14 14 0 0130 6z"/>
                            <path d="M14 36c2-2 4-2 6 0s4 2 6 0"/>
                          </svg>
                        {%- when 'heart-alert' -%}
                          <svg viewBox="0 0 48 48" width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M24 40s-12-8-12-18a8 8 0 0112-7 8 8 0 0112 7c0 10-12 18-12 18z"/>
                            <line x1="24" y1="20" x2="24" y2="26"/>
                            <circle cx="24" cy="30" r="0.5" fill="currentColor"/>
                          </svg>
                        {%- when 'gauge' -%}
                          <svg viewBox="0 0 48 48" width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M8 32a16 16 0 0132 0"/>
                            <line x1="24" y1="32" x2="34" y2="20"/>
                            <circle cx="24" cy="32" r="2" fill="currentColor"/>
                            <line x1="14" y1="32" x2="12" y2="32"/>
                            <line x1="34" y1="32" x2="36" y2="32"/>
                          </svg>
                        {%- when 'pulse-night' -%}
                          <svg viewBox="0 0 48 48" width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 28h8l4-10 6 18 4-12 4 4h14"/>
                            <circle cx="40" cy="10" r="3"/>
                          </svg>
                        {%- when 'temp-wave' -%}
                          <svg viewBox="0 0 48 48" width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 6v22a6 6 0 1012 0V6a3 3 0 00-12 0z"/>
                            <line x1="18" y1="14" x2="22" y2="14"/>
                            <line x1="18" y1="20" x2="22" y2="20"/>
                            <circle cx="24" cy="34" r="3" fill="currentColor"/>
                          </svg>
                        {%- when 'infinity' -%}
                          <svg viewBox="0 0 48 48" width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 24c0-4 3-8 8-8s8 8 12 8 8-4 8-8-3-8-8-8-8 8-12 8-8 4-8 8z" transform="translate(-2,0)"/>
                          </svg>
                      {%- endcase -%}
                    </span>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <h3 class="product-feature__bullet-headline">{{ block.settings.text }}</h3>
                  {%- endif -%}
                  {%- if block.settings.caption != blank -%}
                    <p class="product-feature__bullet-caption">{{ block.settings.caption }}</p>
                  {%- endif -%}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if cta_url != blank and cta_label != blank -%}
          <a href="{{ cta_url }}" class="btn btn--primary" style="margin-top: var(--space-8);" data-reveal data-reveal-delay="160">
            {{ cta_label }}
          </a>
        {%- endif -%}

      </div>
      <!-- /product-feature__copy -->

    </div>

  </div>
</section>

<style>
  .product-feature__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .product-feature__grid--no-media {
    grid-template-columns: 1fr;
    max-width: 900px;
    margin-inline: auto;
  }

  .product-feature__grid--no-media .product-feature__copy {
    text-align: center;
    align-items: center;
  }

  .product-feature__grid--no-media .product-feature__body p {
    max-width: 68ch;
    margin-inline: auto;
  }


  .product-feature__grid--reverse .product-feature__media {
    order: 2;
  }

  .product-feature__grid--reverse .product-feature__copy {
    order: 1;
  }

  /* ---- Media ---- */
  .product-feature__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius-base);
    background-color: var(--cream-3);
    box-shadow: var(--glow-soft);
  }

  .product-feature__media img,
  .product-feature__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .product-feature__media-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--cream-3);
    border: 1px dashed rgba(107, 63, 160, 0.3);
  }

  /* ---- Copy ---- */
  .product-feature__copy {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-block: var(--space-8);
  }

  .product-feature__eyebrow {
    color: var(--color-cta-hover);
    margin-bottom: var(--space-4);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 3.5px;
  }

  .product-feature__heading {
    margin-bottom: var(--space-3);
    color: var(--char);
  }

  .product-feature__body {
    color: var(--char-soft);
    line-height: var(--line-height-body);
    margin-bottom: var(--space-3);
  }

  .product-feature__body p {
    max-width: 52ch;
  }

  /* ---- Section: no-media dark mode ---- */
  .product-feature--no-media {
    background: #0A0812;
    padding-block: 80px;
  }

  .product-feature--no-media .product-feature__eyebrow {
    color: #C026D3;
  }

  .product-feature--no-media .product-feature__heading {
    color: #F3E8FF;
  }

  .product-feature--no-media .product-feature__body p {
    color: #C4A8E0;
  }

  /* ---- Bullets (visual icon cards) ---- */
  .product-feature .product-feature__bullets,
  .motion-on .product-feature .product-feature__bullets {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 1rem;
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    align-items: start;
  }

  .product-feature .product-feature__bullet,
  .motion-on .product-feature .product-feature__bullet {
    background: var(--cream-3) !important;
    border: 1px solid rgba(107, 63, 160, 0.3) !important;
    border-radius: 10px !important;
    padding: 1.25rem !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 0.6rem;
    text-align: left;
    box-shadow: none !important;
    min-height: unset !important;
  }

  /* No-media: bento dark cards — match specificity of .motion-on .product-feature .product-feature__bullet (0,3,0) */
  .product-feature--no-media .product-feature .product-feature__bullet,
  .motion-on .product-feature--no-media .product-feature__bullet,
  .product-feature--no-media .product-feature__bullet {
    background: linear-gradient(145deg, #1C1530 0%, #130F22 100%) !important;
    border: 1px solid rgba(107,63,160,0.22) !important;
    border-radius: 20px !important;
    padding: 2rem !important;
    align-items: center !important;
    text-align: center !important;
    gap: 1.25rem !important;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .product-feature--no-media .product-feature__bullet:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 48px rgba(192,38,211,0.15), 0 0 0 1px rgba(107,63,160,0.45);
    border-color: rgba(107,63,160,0.5) !important;
  }

  .product-feature .product-feature__bullet-icon,
  .motion-on .product-feature .product-feature__bullet-icon {
    color: var(--color-cta-hover);
    display: inline-flex !important;
    margin-bottom: 0;
    line-height: 0;
  }
  .product-feature__bullet-icon svg {
    width: 36px;
    height: 36px;
    display: block;
  }

  /* No-media: large glowing icon orb */
  .product-feature--no-media .product-feature__bullet-icon {
    width: 72px !important;
    height: 72px !important;
    border-radius: 50% !important;
    background: radial-gradient(circle at 40% 40%, rgba(192,38,211,0.18) 0%, rgba(107,63,160,0.12) 50%, transparent 100%) !important;
    border: 1px solid rgba(192,38,211,0.2) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: #C026D3 !important;
    flex-shrink: 0;
  }

  .product-feature--no-media .product-feature__bullet-icon svg {
    width: 32px !important;
    height: 32px !important;
  }

  .product-feature__bullet-headline {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.3;
    color: var(--char);
    font-weight: 600;
    margin: 0;
  }

  .product-feature--no-media .product-feature__bullet-headline {
    font-size: 1rem;
    color: #F3E8FF;
    letter-spacing: -0.01em;
  }

  .product-feature__bullet-caption {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--char-soft);
    margin: 0;
  }

  .product-feature--no-media .product-feature__bullet-caption {
    color: #9B7EC8;
    font-size: 0.85rem;
  }

  @media (max-width: 749px) {
    .product-feature .product-feature__bullets,
    .motion-on .product-feature .product-feature__bullets {
      grid-template-columns: repeat(2, 1fr) !important;
      align-items: stretch !important;
      gap: 0.75rem;
    }
    .product-feature .product-feature__bullet { padding: 0.75rem !important; }
    .product-feature--no-media .product-feature__bullet { padding: 1.25rem !important; justify-content: center !important; }
    .product-feature__bullet-icon svg { width: 30px; height: 30px; }
    .product-feature--no-media .product-feature__bullet-icon { width: 56px !important; height: 56px !important; }
    .product-feature--no-media .product-feature__bullet-icon svg { width: 26px !important; height: 26px !important; }
    .product-feature__bullet-headline { font-size: 0.95rem; }
    .product-feature__bullet-caption { font-size: 0.75rem; }
  }

  /* ---- Responsive ---- */
  @media (max-width: 767px) {
    .product-feature__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .product-feature__grid--reverse .product-feature__media,
    .product-feature__grid--reverse .product-feature__copy {
      order: unset;
    }

    .product-feature__media {
      aspect-ratio: 1 / 1;
      background-color: var(--cream-3);
    }

    .product-feature__video,
    .product-feature__media img {
      object-fit: contain !important;
      object-position: center center !important;
    }

    .product-feature.section {
      padding-bottom: 40px;
    }
  }
</style>

{% schema %}
{
  "name": "Product feature",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Paste a hosted MP4 URL. Takes priority over image. Plays silently on loop."
    },
    {
      "type": "range",
      "id": "video_position_y",
      "label": "Video vertical crop position",
      "info": "0 = show top of video, 50 = centred (default), 100 = show bottom. Lower this if too much of the bottom of the frame is showing.",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Used as poster (shown before/while video loads) when a video URL is set. Used as the visual when no video URL is set. Recommended size: 1200×1467 (tall portrait)."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The science"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "See what your body tells you."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Most people do not know what their body does while they sleep. The Smart Ring tracks sleep, recovery, and heart rate overnight. Each morning, it tells you if you should push hard or rest."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "checkbox",
      "id": "reverse",
      "label": "Reverse layout (image on right)",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet point",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "", "label": "None" },
            { "value": "moon", "label": "Moon (sleep)" },
            { "value": "heart-alert", "label": "Heart with alert" },
            { "value": "gauge", "label": "Gauge / score" },
            { "value": "pulse-night", "label": "Pulse at night" },
            { "value": "temp-wave", "label": "Temperature wave" },
            { "value": "infinity", "label": "Infinity (forever)" }
          ]
        },
        {
          "type": "text",
          "id": "text",
          "label": "Headline",
          "default": "5–7 day battery."
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption (under headline)"
        }
      ]
    }
  ],
  "presets": [{ "name": "Product feature" }]
}
{% endschema %}
