{%- liquid
  assign eyebrow    = section.settings.eyebrow    | default: 'Shop'
  assign heading    = section.settings.heading    | default: 'Start here.'
  assign collection = section.settings.collection
  assign limit      = section.settings.product_limit | default: 3
-%}

<section class="product-grid section">
  <div class="container">

    <!-- Section header -->
    <div class="product-grid__header">
      <div>
        <span class="rule-above" aria-hidden="true"></span>
        {%- if eyebrow != blank -%}
          <p class="product-grid__eyebrow t-label">{{ eyebrow }}</p>
        {%- endif -%}
        <h2 class="product-grid__heading t-display-md">{{ heading }}</h2>
      </div>

      {%- if collection != blank -%}
        <a href="{{ collection.url }}" class="btn btn--secondary product-grid__view-all">
          View all
        </a>
      {%- endif -%}
    </div>

    <!-- Grid -->
    <div class="product-grid__items">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: limit -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="card">
            <div class="card__media">
              {{ i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="card__info">
              <p class="card__title">Sample product {{ i }}</p>
              <p class="card__price">$49.00</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  .product-grid__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: var(--space-10);
    gap: var(--space-6);
  }

  .product-grid__eyebrow {
    color: var(--color-amber);
    margin-bottom: var(--space-3);
  }

  .product-grid__heading {
    color: var(--color-espresso);
  }

  .product-grid__view-all {
    flex-shrink: 0;
    margin-bottom: var(--space-2);
  }

  .product-grid__items {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  /* Placeholder SVG styling */
  .product-grid__items .placeholder-svg {
    width: 100%;
    height: 100%;
    fill: var(--color-mahogany);
    opacity: 0.08;
  }

  @media (max-width: 767px) {
    .product-grid__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .product-grid__items {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }

  @media (max-width: 480px) {
    .product-grid__items {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start here."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [{ "name": "Product grid" }]
}
{% endschema %}
