{%- comment -%} Product FAQ — Mend & Co {%- endcomment -%}

<section class="faq-section" id="faq">
  <div class="faq-container">

    <div class="faq-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="faq-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="faq-heading">{{ section.settings.heading | default: 'Everything you want to know.' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="faq-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="faq-list">
      {%- for block in section.blocks -%}
        {%- if block.settings.question != blank -%}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button
              class="faq-trigger"
              type="button"
              aria-expanded="false"
              aria-controls="faq-panel-{{ block.id }}"
            >
              <span>{{ block.settings.question }}</span>
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <div class="faq-panel" id="faq-panel-{{ block.id }}" hidden>
              <div class="faq-answer">{{ block.settings.answer }}</div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
.faq-section {
  background: var(--color-bone, #F2EDE4);
  padding: 6rem 0;
  border-top: 1px solid rgba(43,43,43,0.08);
}

.faq-container {
  max-width: 760px;
  margin: 0 auto;
  padding: 0 2rem;
}

.faq-header {
  text-align: center;
  margin-bottom: 3.5rem;
}

.faq-eyebrow {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--color-olive, #8A6240);
  margin: 0 auto 1rem;
  max-width: none;
}

.faq-heading {
  font-family: var(--font-heading);
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 400;
  color: var(--color-black, #1f1d1a);
  line-height: 1.2;
  letter-spacing: -0.015em;
  margin: 0 0 0.75rem;
}

.faq-subheading {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  color: var(--color-olive, #8A6240);
  margin: 0;
  line-height: 1.6;
}

.faq-list {
  display: flex;
  flex-direction: column;
  border-top: 1px solid rgba(43,43,43,0.1);
}

.faq-item {
  border-bottom: 1px solid rgba(43,43,43,0.1);
}

.faq-trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  padding: 1.375rem 0;
  background: transparent;
  border: none;
  font-family: var(--font-label);
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-black, #1f1d1a);
  cursor: pointer;
  text-align: left;
  line-height: 1.4;
  transition: color 0.15s;
}

.faq-trigger:focus-visible {
  outline: 1.5px solid var(--color-walnut, #8A6240);
  outline-offset: 2px;
  border-radius: 2px;
}

.faq-chevron {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  color: var(--color-olive, #8A6240);
  transition: transform 0.25s ease, color 0.15s;
}

.faq-trigger[aria-expanded="true"] .faq-chevron {
  transform: rotate(180deg);
  color: var(--color-walnut, #8A6240);
}

.faq-panel[hidden] { display: none; }

.faq-answer {
  padding: 0 0 1.375rem 0;
  font-family: var(--font-label);
  font-size: 0.9rem;
  line-height: 1.8;
  color: var(--color-olive, #8A6240);
  max-width: 620px;
}

.faq-answer p { margin: 0; }
.faq-answer p + p { margin-top: 0.75rem; }

@media (max-width: 640px) {
  .faq-section { padding: 4rem 0; }
  .faq-container { padding: 0 1.25rem; }
  .faq-trigger { font-size: 0.875rem; padding: 1.125rem 0; }
  .faq-header { margin-bottom: 2.5rem; }
}
</style>

<script>
(function () {
  var triggers = document.querySelectorAll('.faq-trigger');
  triggers.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      var panelId = btn.getAttribute('aria-controls');
      var panel = document.getElementById(panelId);
      if (!panel) return;
      btn.setAttribute('aria-expanded', String(!expanded));
      panel.hidden = expanded;
    });
    btn.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); btn.click(); }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Product FAQ",
  "tag": "section",
  "class": "section-product-faq",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Questions"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything you want to know."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Your answer here.</p>"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Product FAQ"
    }
  ]
}
{% endschema %}
