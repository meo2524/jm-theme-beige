{%- liquid
  assign eyebrow    = section.settings.eyebrow    | default: 'The routine before your routine.'
  assign heading    = section.settings.heading    | default: 'Your shower is'
  assign heading_em = section.settings.heading_em | default: 'undoing'
  assign heading_2  = section.settings.heading_2  | default: 'everything.'
  assign subtext    = section.settings.subtext    | default: 'Chlorine, heavy metals, sediment — every product you apply after is working against a contaminated baseline.'
  assign cta_label  = section.settings.cta_label  | default: 'Shop the filter'
  assign cta_url    = section.settings.cta_url    | default: '/collections/all'
  assign bg_image   = section.settings.bg_image
  assign show_scroll_cue = section.settings.show_scroll_cue
-%}

<section
  class="hero"
  id="hero"
  aria-label="Hero — {{ heading }} {{ heading_em }} {{ heading_2 }}"
  style="
    {%- if bg_image != blank -%}
      --hero-bg-image: url('{{ bg_image | image_url: width: 2000 }}');
    {%- endif -%}
  "
>

  <!-- Grain overlay -->
  <div class="hero__grain" aria-hidden="true"></div>

  <!-- Bg image layer -->
  {%- if bg_image != blank -%}
    <div class="hero__image-layer" aria-hidden="true">
      <img
        src="{{ bg_image | image_url: width: 2000 }}"
        srcset="
          {{ bg_image | image_url: width: 800  }} 800w,
          {{ bg_image | image_url: width: 1200 }} 1200w,
          {{ bg_image | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        alt=""
        width="2000"
        height="1200"
        loading="eager"
        fetchpriority="high"
      >
    </div>
  {%- endif -%}

  <!-- ===========================================================
       ORB SCENE — warm, restorative breathing-orb composition
       Drops in from above, draggable, springs back home.
       =========================================================== -->
  <div class="hero__scene" aria-hidden="true">

    <!-- Paper warm wash -->
    <div class="hero__paper"></div>

    <!-- Sun halo behind everything -->
    <div class="hero__halo"></div>

    <!-- Expanding breath rings from the sun position -->
    <div class="hero__rings">
      <span class="hero__ring"></span>
      <span class="hero__ring"></span>
      <span class="hero__ring"></span>
    </div>

    <!-- Horizon line -->
    <div class="hero__horizon"></div>

    <!-- Static SVG: concentric rings + horizon -->
    <svg class="hero__static" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid meet">
      <circle cx="1380" cy="540" r="540" fill="none" stroke="#8a663b" stroke-opacity="0.07" stroke-width="1"/>
      <circle cx="1380" cy="540" r="430" fill="none" stroke="#8a663b" stroke-opacity="0.10" stroke-width="1"/>
      <circle cx="1380" cy="540" r="340" fill="none" stroke="#8a663b" stroke-opacity="0.14" stroke-width="1"/>
      <circle cx="1380" cy="540" r="270" fill="none" stroke="#8a663b" stroke-opacity="0.20" stroke-width="1"/>
    </svg>

    <!-- Floating dust motes -->
    <div class="hero__motes" data-hero-motes></div>

    <!-- Cursor glow -->
    <div class="hero__cursor-glow" data-hero-cursor></div>

  </div>

  <!-- Interactive orb — sibling of .hero__inner so its z-index can
       sit above the content layer without being trapped inside the
       .hero__scene stacking context. -->
  <div class="hero__orb-stage" data-hero-orb-stage>
    <div class="hero__orb-shadow" data-hero-orb-shadow></div>
    <div class="hero__orb-halo"   data-hero-orb-halo></div>
    <div class="hero__orb"        data-hero-orb role="button" tabindex="0" aria-label="Drag to push the orb"></div>
  </div>

  <!-- Small mono annotation near the orb -->
  <span class="hero__orb-mark" aria-hidden="true">✶ Begin again ✶</span>

  <!-- Content -->
  <div class="hero__inner container">

    <div class="hero__content">

      <!-- Amber rule -->
      <span class="hero__rule" aria-hidden="true"></span>

      <!-- Eyebrow -->
      <p class="hero__eyebrow">{{ eyebrow }}</p>

      <!-- Heading -->
      <h1 class="hero__heading">
        <span class="hero__heading-line">{{ heading }}</span>
        <em class="hero__heading-em">{{ heading_em }}</em>
        <span class="hero__heading-line">{{ heading_2 }}</span>
      </h1>

      <!-- Subtext -->
      <p class="hero__subtext">{{ subtext }}</p>

      <!-- CTA -->
      <div class="hero__cta">
        <a href="{{ cta_url }}" class="btn btn--primary btn--lg">
          {{ cta_label }}
        </a>
      </div>

    </div>
    <!-- /hero__content -->

  </div>
  <!-- /hero__inner -->

  <!-- Scroll cue -->
  {%- if show_scroll_cue -%}
    <div class="hero__scroll-cue" aria-hidden="true">
      <span class="hero__scroll-label">Scroll</span>
      <span class="hero__scroll-line"></span>
    </div>
  {%- endif -%}

</section>


<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
  /* ---- Hero shell ---- */
  .hero {
    position: relative;
    min-height: 75vh;
    background-color: var(--color-bone);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* ---- Background image layer ---- */
  .hero__image-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.22;
    filter: saturate(0.6);
  }

  /* ---- Grain texture ---- */
  .hero__grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    opacity: 0.045;
    mix-blend-mode: overlay;
  }

  /* ---- Inner layout ---- */
  .hero__inner {
    position: relative;
    z-index: 2;
    padding-block: var(--space-32) var(--space-24);
    display: flex;
    align-items: flex-start;
  }

  .hero__content {
    max-width: 820px;
  }

  /* ---- Amber rule above eyebrow ---- */
  .hero__rule {
    display: block;
    width: 2.5rem;
    height: 1.5px;
    background-color: var(--color-walnut);
    margin-bottom: var(--space-5);

    /* Staggered reveal — 1st */
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    animation: hero-rule-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  /* ---- Eyebrow ---- */
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-deep);
    margin-bottom: var(--space-6);
    max-width: none;

    /* Staggered reveal — 2nd */
    opacity: 0;
    transform: translateY(12px);
    animation: hero-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.25s forwards;
  }

  /* ---- Heading — Cormorant Garamond, italic accent in gold ---- */
  .hero__heading {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8vw, 6.75rem);  /* up to 108px desktop */
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--char);
    margin-bottom: var(--space-8);
    max-width: none;

    /* Staggered reveal — 3rd */
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  .hero__heading-line {
    display: block;
  }

  .hero__heading-em {
    display: block;
    font-style: italic;
    color: var(--gold-deep);
    font-weight: 400;
  }

  /* ---- Subtext — serif lede ---- */
  .hero__subtext {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 1.7vw, 1.5rem);  /* up to 24px */
    line-height: 1.5;
    color: var(--char-soft);
    opacity: 0.92;
    max-width: 52ch;
    margin-bottom: var(--space-10);

    /* Staggered reveal — 4th */
    opacity: 0;
    transform: translateY(16px);
    animation: hero-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
  }

  /* Note: using opacity: 0 initially, then animation sets final value.
     The 0.62 opacity target is handled inside the keyframe. */

  /* ---- CTA ---- */
  .hero__cta {
    /* Staggered reveal — 5th */
    opacity: 0;
    transform: translateY(12px);
    animation: hero-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.78s forwards;
  }

  /* Typography override only — bg/color inherits from .btn--primary */
  .hero__cta .btn--primary {
    font-size: 11px;
    letter-spacing: 0.18em;
  }

  /* ---- Scroll cue ---- */
  .hero__scroll-cue {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    opacity: 0;
    animation: hero-fade-up 0.6s ease 1.2s forwards;
  }

  .hero__scroll-label {
    font-family: 'Inter', var(--font-label);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-olive);
    opacity: 0.4;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(42,35,32,0.25), transparent);
    animation: scroll-line 0.8s cubic-bezier(0.16, 1, 0.3, 1) 1.4s both;
  }

  /* ---- Animations ---- */
  @keyframes hero-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-rule-in {
    to {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  @keyframes scroll-line {
    from { transform: scaleY(0); transform-origin: top; opacity: 0; }
    to   { transform: scaleY(1); transform-origin: top; opacity: 1; }
  }

  /* Fix subtext final opacity — override initial opacity:0 from animation start */
  .hero__subtext {
    animation: hero-subtext-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
  }

  @keyframes hero-subtext-in {
    to {
      opacity: 0.92;
      transform: translateY(0);
    }
  }

  /* ---- Responsive ---- */
  @media (max-width: 767px) {
    .hero {
      min-height: 65vh;
      align-items: flex-end;
    }

    .hero__inner {
      padding-block: var(--space-16) var(--space-20);
    }

    .hero__heading {
      font-size: clamp(2.5rem, 11vw, 3.5rem);
    }

    .hero__subtext {
      font-size: var(--font-size-base);
      max-width: 42ch;
    }

    .hero__scroll-cue {
      display: none;
    }
  }

  /* ---- Orb annotation mark ---- */
  .hero__orb-mark {
    position: absolute;
    top: var(--space-8);
    right: var(--space-8);
    z-index: 4;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-mute);
    opacity: 0;
    animation: hero-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.95s forwards;
  }
  @media (max-width: 767px) {
    .hero__orb-mark { display: none; }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .hero__rule,
    .hero__eyebrow,
    .hero__heading,
    .hero__subtext,
    .hero__cta,
    .hero__scroll-cue {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .hero__subtext { opacity: 0.62; }
  }

  /* ============================================================
     ORB SCENE — warm restorative breathing-orb
     Anchored to the right side; behind text content.
     ============================================================ */
  .hero__scene {
    position: absolute;
    inset: 0;
    z-index: 1;          /* above grain (1) but below content (2) */
    pointer-events: none;
    overflow: hidden;
  }

  /* Warm paper wash + subtle radial warmth on right side */
  .hero__paper {
    position: absolute; inset: 0;
    background:
      radial-gradient(70% 60% at 70% 55%, rgba(217, 176, 121, 0.10), rgba(217, 176, 121, 0) 70%),
      radial-gradient(40% 50% at 90% 30%, rgba(201, 133, 104, 0.08), rgba(201, 133, 104, 0) 70%);
    pointer-events: none;
  }

  /* Sun halo behind everything */
  .hero__halo {
    position: absolute;
    left: 70%; top: 50%;
    width: 44%; aspect-ratio: 1 / 1;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(217,176,121,0.28), rgba(217,176,121,0) 65%);
    filter: blur(2px);
    pointer-events: none;
    animation: hero-halo-pulse 7s ease-in-out infinite;
  }
  @keyframes hero-halo-pulse {
    0%, 100% { opacity: 0.7; transform: translate(-50%,-50%) scale(0.96); }
    50%      { opacity: 1.0; transform: translate(-50%,-50%) scale(1.06); }
  }

  /* Static SVG concentric rings */
  .hero__static {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    opacity: 0.85;
  }

  /* Horizon line — barely-there tabletop */
  .hero__horizon {
    position: absolute;
    left: 0; right: 0;
    top: 75%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(74,66,58,0.10) 30%, rgba(74,66,58,0.16) 50%, rgba(74,66,58,0.10) 70%, transparent);
    pointer-events: none;
  }

  /* Expanding breath rings radiating from sun */
  .hero__rings {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero__ring {
    position: absolute;
    left: 70%; top: 50%;
    width: 200px; height: 200px;
    margin-left: -100px; margin-top: -100px;
    border: 1px solid rgba(168, 129, 79, 0.5);
    border-radius: 50%;
    opacity: 0;
    animation: hero-ring-expand 7s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    will-change: transform, opacity;
  }
  .hero__ring:nth-child(2) { animation-delay: -2.33s; }
  .hero__ring:nth-child(3) { animation-delay: -4.66s; }
  @keyframes hero-ring-expand {
    0%   { transform: scale(0.4); opacity: 0; }
    20%  { opacity: 0.45; }
    100% { transform: scale(2.6); opacity: 0; }
  }

  /* Floating dust motes */
  .hero__motes { position: absolute; inset: 0; pointer-events: none; }
  .hero__mote {
    position: absolute;
    width: 3px; height: 3px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,240,210,0.85), rgba(255,240,210,0) 70%);
    animation: hero-mote-drift linear infinite;
    will-change: transform, opacity;
  }
  @keyframes hero-mote-drift {
    0%   { transform: translate(0, 0) scale(0.6); opacity: 0; }
    15%  { opacity: 0.85; }
    85%  { opacity: 0.55; }
    100% { transform: translate(var(--dx, 0px), var(--dy, -180px)) scale(1.1); opacity: 0; }
  }

  /* Cursor glow follows pointer */
  .hero__cursor-glow {
    position: absolute;
    left: var(--cx, -200px); top: var(--cy, -200px);
    width: 360px; height: 360px;
    margin-left: -180px; margin-top: -180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,220,170,0.30), rgba(255,220,170,0) 65%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease;
    mix-blend-mode: screen;
  }
  .hero:hover .hero__cursor-glow { opacity: 1; }

  /* === Interactive orb ===
     Stage sits ABOVE the content layer so the orb is reachable
     to pointers. The stage itself is pointer-events: none —
     only the orb element captures clicks, so text/CTA below remain
     clickable everywhere except directly under the orb. */
  .hero__orb-stage {
    position: absolute; inset: 0;
    z-index: 3;
    pointer-events: none;
  }
  .hero__orb {
    position: absolute;
    left: 70%; top: 50%;
    width: 360px; height: 360px;
    margin-left: -180px; margin-top: -180px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 38% 32%,
        #fbeede 0%, #f1d4a5 22%, #d9a874 55%, #a8663b 85%, #6a3a1f 100%);
    box-shadow:
      0 0 0 1px rgba(255,250,240,0.35) inset,
      0 30px 80px -10px rgba(168,129,79,0.6),
      0 0 120px 12px rgba(217,168,116,0.45);
    cursor: grab;
    pointer-events: auto;
    touch-action: none;
    will-change: transform, filter;
    transform: translate3d(var(--ox, 0px), var(--oy, 0px), 0) scale(var(--os, 1));
    animation: hero-orb-breathe 7s ease-in-out infinite;
  }
  .hero__orb:active { cursor: grabbing; }
  .hero__orb::after {
    content: "";
    position: absolute;
    left: 22%; top: 16%;
    width: 28%; height: 22%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,250,240,0.92), rgba(255,250,240,0) 70%);
    filter: blur(2px);
    pointer-events: none;
  }
  .hero__orb-halo {
    position: absolute;
    left: 70%; top: 50%;
    width: 720px; height: 720px;
    margin-left: -360px; margin-top: -360px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(217,176,121,0.40), rgba(217,176,121,0) 65%);
    transform: translate3d(var(--ox, 0px), var(--oy, 0px), 0) scale(var(--os, 1));
    pointer-events: none;
    will-change: transform;
    mix-blend-mode: screen;
    animation: hero-orb-breathe 7s ease-in-out infinite;
  }
  .hero__orb-shadow {
    position: absolute;
    left: 70%; top: 50%;
    width: 320px; height: 38px;
    margin-left: -160px;
    margin-top: 160px;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(58,42,28,0.32), rgba(58,42,28,0) 70%);
    transform: translate3d(var(--sx, 0px), var(--sy, 0px), 0) scale(var(--ss, 1));
    opacity: var(--sop, 1);
    pointer-events: none;
    will-change: transform, opacity;
    filter: blur(2px);
  }
  @keyframes hero-orb-breathe {
    0%, 100% { filter: brightness(0.96); }
    50%      { filter: brightness(1.06); }
  }

  /* Tablet: shrink orb, shift right anchor a touch */
  @media (max-width: 1024px) {
    .hero__orb { width: 280px; height: 280px; margin-left: -140px; margin-top: -140px; }
    .hero__orb-halo { width: 560px; height: 560px; margin-left: -280px; margin-top: -280px; }
    .hero__orb-shadow { width: 240px; margin-left: -120px; }
  }

  /* Mobile: orb sits above content, smaller, centered horizontally */
  @media (max-width: 767px) {
    .hero__scene { opacity: 0.85; }
    .hero__halo,
    .hero__ring,
    .hero__orb,
    .hero__orb-halo,
    .hero__orb-shadow { left: 50%; }
    .hero__orb { width: 200px; height: 200px; margin-left: -100px; margin-top: -100px; top: 22%; }
    .hero__orb-halo { width: 400px; height: 400px; margin-left: -200px; margin-top: -200px; top: 22%; }
    .hero__orb-shadow { width: 170px; margin-left: -85px; top: 22%; }
    .hero__halo { top: 22%; }
    .hero__ring { top: 22%; }
  }

  /* Reduced motion: kill all orb animations */
  @media (prefers-reduced-motion: reduce) {
    .hero__halo,
    .hero__ring,
    .hero__orb,
    .hero__orb-halo,
    .hero__mote { animation: none; }
    .hero__cursor-glow { display: none; }
  }
</style>


<!-- ============================================================
     ORB PHYSICS — drop-in, drag-to-fling, spring back home
     ============================================================ -->
<script>
  (function () {
    if (window.__mcHeroOrbInit) return;
    window.__mcHeroOrbInit = true;

    function init() {
      var hero      = document.getElementById('hero');
      if (!hero) return;
      var stage     = hero.querySelector('[data-hero-orb-stage]');
      var orb       = hero.querySelector('[data-hero-orb]');
      var halo      = hero.querySelector('[data-hero-orb-halo]');
      var shadow    = hero.querySelector('[data-hero-orb-shadow]');
      var motesWrap = hero.querySelector('[data-hero-motes]');
      var cursor    = hero.querySelector('[data-hero-cursor]');
      if (!stage || !orb || !halo || !shadow) return;

      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ---- Dust motes ----
      function seedMotes(count) {
        if (!motesWrap || reduced) return;
        motesWrap.innerHTML = '';
        for (var i = 0; i < count; i++) {
          var m = document.createElement('div');
          m.className = 'hero__mote';
          var left = 40 + Math.random() * 55;          // weighted to right side
          var top  = 25 + Math.random() * 60;
          var dur  = 8 + Math.random() * 10;
          var delay = -Math.random() * dur;
          var dx = (Math.random() - 0.5) * 120;
          var dy = -120 - Math.random() * 200;
          m.style.left = left + '%';
          m.style.top  = top  + '%';
          m.style.animationDuration = dur + 's';
          m.style.animationDelay = delay + 's';
          m.style.setProperty('--dx', dx + 'px');
          m.style.setProperty('--dy', dy + 'px');
          m.style.opacity = 0.3 + Math.random() * 0.5;
          motesWrap.appendChild(m);
        }
      }
      seedMotes(16);

      // ---- Cursor parallax + glow ----
      hero.addEventListener('pointermove', function (e) {
        var rect = hero.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;
        if (cursor) {
          cursor.style.setProperty('--cx', x + 'px');
          cursor.style.setProperty('--cy', y + 'px');
        }
      });

      // ---- Orb physics ----
      var x = 0, y = 0, vx = 0, vy = 0;
      var dragging = false, dragId = null, lastPx = 0, lastPy = 0, lastT = 0;
      var restX = 0, restY = 0;
      var homeX = 0, homeY = 0;
      var dropping = false;
      var k    = 0.06;     // spring constant
      var damp = 0.86;     // friction
      var maxV = 60;

      function placeHome() {
        // Orb is positioned via CSS at left:70%/top:50% (mobile: top:22%/left:78%)
        // These translate offsets are deltas from that anchor — keep as 0 for resting state
        homeX = 0;
        homeY = 0;
      }

      function dropIn() {
        placeHome();
        if (reduced) {
          x = homeX; y = homeY; restX = homeX; restY = homeY;
          apply();
          return;
        }
        dropping = true;
        x = homeX;
        y = homeY - hero.getBoundingClientRect().height - 200;
        vx = 0; vy = 0;
        restX = homeX; restY = homeY;
      }

      function apply() {
        var lift = Math.max(0, restY - y);
        var sOp = Math.max(0.15, 1 - lift / 600);
        var sShadowScale = Math.max(0.45, 1 - lift / 800);
        var oScale = 1 + Math.min(0.05, Math.max(-0.04, (restY - y) / 4000));
        orb.style.setProperty('--ox', x + 'px');
        orb.style.setProperty('--oy', y + 'px');
        orb.style.setProperty('--os', oScale.toFixed(3));
        halo.style.setProperty('--ox', x + 'px');
        halo.style.setProperty('--oy', y + 'px');
        halo.style.setProperty('--os', oScale.toFixed(3));
        shadow.style.setProperty('--sx', x + 'px');
        shadow.style.setProperty('--sy', restY + 'px');
        shadow.style.setProperty('--ss', sShadowScale.toFixed(3));
        shadow.style.setProperty('--sop', sOp.toFixed(3));
      }

      function step() {
        if (!dragging) {
          var dx = restX - x;
          var dy = restY - y;
          vx += dx * k;
          vy += dy * k;
          if (dropping && y < restY - 5) {
            vy += 1.4;
          } else if (dropping) {
            dropping = false;
          }
          vx *= damp; vy *= damp;
          if (Math.abs(vx) > maxV) vx = Math.sign(vx) * maxV;
          if (Math.abs(vy) > maxV) vy = Math.sign(vy) * maxV;
          x += vx; y += vy;
        }
        apply();
        requestAnimationFrame(step);
      }

      orb.addEventListener('pointerdown', function (e) {
        dragging = true;
        dropping = false;
        dragId = e.pointerId;
        try { orb.setPointerCapture(dragId); } catch (_) {}
        lastPx = e.clientX; lastPy = e.clientY; lastT = performance.now();
      });
      window.addEventListener('pointermove', function (e) {
        if (!dragging || e.pointerId !== dragId) return;
        var dx = e.clientX - lastPx;
        var dy = e.clientY - lastPy;
        x += dx; y += dy;
        var now = performance.now();
        var dt = Math.max(1, now - lastT);
        vx = dx / dt * 16;
        vy = dy / dt * 16;
        lastPx = e.clientX; lastPy = e.clientY; lastT = now;
      });
      function endDrag(e) {
        if (!dragging) return;
        if (e && e.pointerId !== dragId) return;
        dragging = false;
        try { orb.releasePointerCapture(dragId); } catch (_) {}
      }
      window.addEventListener('pointerup', endDrag);
      window.addEventListener('pointercancel', endDrag);

      window.addEventListener('resize', function () {
        placeHome();
        restX = homeX; restY = homeY;
      });

      dropIn();
      requestAnimationFrame(step);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>


