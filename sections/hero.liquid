{%- liquid
  assign eyebrow    = section.settings.eyebrow    | default: 'Not wellness. Repair.'
  assign heading    = section.settings.heading    | default: 'Your body'
  assign heading_em = section.settings.heading_em | default: 'already'
  assign heading_2  = section.settings.heading_2  | default: 'knows.'
  assign subtext    = section.settings.subtext    | default: 'We make things worth keeping. Quiet tools for the long repair — not the quick fix.'
  assign cta_label  = section.settings.cta_label  | default: 'Shop the collection'
  assign cta_url    = section.settings.cta_url    | default: '/collections/all'
  assign bg_image   = section.settings.bg_image
  assign show_scroll_cue = section.settings.show_scroll_cue
-%}

<section
  class="hero"
  id="hero"
  aria-label="Hero — {{ heading }} {{ heading_em }} {{ heading_2 }}"
  style="
    {%- if bg_image != blank -%}
      --hero-bg-image: url('{{ bg_image | image_url: width: 2000 }}');
    {%- endif -%}
  "
>

  <!-- Grain overlay -->
  <div class="hero__grain" aria-hidden="true"></div>

  <!-- Bg image layer -->
  {%- if bg_image != blank -%}
    <div class="hero__image-layer" aria-hidden="true">
      <img
        src="{{ bg_image | image_url: width: 2000 }}"
        srcset="
          {{ bg_image | image_url: width: 800  }} 800w,
          {{ bg_image | image_url: width: 1200 }} 1200w,
          {{ bg_image | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        alt=""
        width="2000"
        height="1200"
        loading="eager"
        fetchpriority="high"
      >
    </div>
  {%- endif -%}

  <!-- ===========================================================
       ORB SCENE — warm, restorative breathing-orb composition
       Drops in from above, draggable, springs back home.
       =========================================================== -->
  <div class="hero__scene" aria-hidden="true">

    <!-- Paper warm wash -->
    <div class="hero__paper"></div>

    <!-- Sun halo behind everything -->
    <div class="hero__halo"></div>

    <!-- Expanding breath rings from the sun position -->
    <div class="hero__rings">
      <span class="hero__ring"></span>
      <span class="hero__ring"></span>
      <span class="hero__ring"></span>
    </div>

    <!-- Horizon line -->
    <div class="hero__horizon"></div>

    <!-- Static SVG: concentric rings + horizon -->
    <svg class="hero__static" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid meet">
      <circle cx="1380" cy="540" r="540" fill="none" stroke="#8a663b" stroke-opacity="0.07" stroke-width="1"/>
      <circle cx="1380" cy="540" r="430" fill="none" stroke="#8a663b" stroke-opacity="0.10" stroke-width="1"/>
      <circle cx="1380" cy="540" r="340" fill="none" stroke="#8a663b" stroke-opacity="0.14" stroke-width="1"/>
      <circle cx="1380" cy="540" r="270" fill="none" stroke="#8a663b" stroke-opacity="0.20" stroke-width="1"/>
    </svg>

    <!-- Floating dust motes -->
    <div class="hero__motes" data-hero-motes></div>

    <!-- Cursor glow -->
    <div class="hero__cursor-glow" data-hero-cursor></div>

  </div>

  <!-- Ring video — replaces orb -->
  <div class="hero__ring-stage" aria-hidden="true">
    <video
      class="hero__ring-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      data-src-hd="{{ section.settings.hero_video_url | default: 'https://cdn.shopify.com/videos/c/vp/ee10541771864ebc970ce82f9b7359bb/ee10541771864ebc970ce82f9b7359bb.HD-720p-4.5Mbps-83245518.mp4' }}"
      data-src-sd="https://cdn.shopify.com/videos/c/vp/ee10541771864ebc970ce82f9b7359bb/ee10541771864ebc970ce82f9b7359bb.SD-480p-1.5Mbps-83245518.mp4"
    ></video>
  </div>


  <!-- Content -->
  <div class="hero__inner container">

    <div class="hero__content">

      <!-- Amber rule -->
      <span class="hero__rule" aria-hidden="true"></span>

      <!-- Eyebrow -->
      <p class="hero__eyebrow">{{ eyebrow }}</p>

      <!-- Heading -->
      <h1 class="hero__heading">
        <span class="hero__heading-line">{{ heading }}</span>
        <em class="hero__heading-em">{{ heading_em }}</em>
        <span class="hero__heading-line">{{ heading_2 }}</span>
      </h1>

      <!-- Subtext -->
      <p class="hero__subtext">{{ subtext }}</p>

      <!-- CTA -->
      <div class="hero__cta">
        <a href="{{ cta_url }}" class="btn btn--primary btn--lg">
          {{ cta_label }}
        </a>
      </div>

    </div>
    <!-- /hero__content -->

  </div>
  <!-- /hero__inner -->

  <!-- Scroll cue -->
  {%- if show_scroll_cue -%}
    <div class="hero__scroll-cue" aria-hidden="true">
      <span class="hero__scroll-label">Scroll</span>
      <span class="hero__scroll-line"></span>
    </div>
  {%- endif -%}

</section>


<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
  /* ---- Hero shell ---- */
  .hero {
    position: relative;
    min-height: 75vh;
    background-color: var(--color-bone);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* ---- Background image layer ---- */
  .hero__image-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.22;
    filter: saturate(0.6);
  }

  /* ---- Grain texture ---- */
  .hero__grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    opacity: 0.045;
    mix-blend-mode: overlay;
  }

  /* ---- Inner layout ---- */
  .hero__inner {
    position: relative;
    z-index: 2;
    padding-block: var(--space-32) var(--space-24);
    display: flex;
    align-items: flex-start;
  }

  .hero__content {
    max-width: 820px;
  }

  /* ---- Amber rule above eyebrow ---- */
  .hero__rule {
    display: block;
    width: 2.5rem;
    height: 1.5px;
    background-color: var(--color-walnut);
    margin-bottom: var(--space-5);

    /* Staggered reveal — 1st */
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    animation: hero-rule-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  /* ---- Eyebrow ---- */
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-deep);
    margin-bottom: var(--space-6);
    max-width: none;

    /* Staggered reveal — 2nd */
    opacity: 0;
    transform: translateY(12px);
    animation: hero-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.25s forwards;
  }

  /* ---- Heading — Cormorant Garamond, italic accent in gold ---- */
  .hero__heading {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8vw, 6.75rem);  /* up to 108px desktop */
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--char);
    margin-bottom: var(--space-8);
    max-width: none;

    /* Staggered reveal — 3rd */
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  .hero__heading-line {
    display: block;
  }

  .hero__heading-em {
    display: block;
    font-style: italic;
    color: var(--gold-deep);
    font-weight: 400;
  }

  /* ---- Subtext — serif lede ---- */
  .hero__subtext {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 1.7vw, 1.5rem);  /* up to 24px */
    line-height: 1.5;
    color: var(--char-soft);
    opacity: 0.92;
    max-width: 52ch;
    margin-bottom: var(--space-10);

    /* Staggered reveal — 4th */
    opacity: 0;
    transform: translateY(16px);
    animation: hero-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
  }

  /* Note: using opacity: 0 initially, then animation sets final value.
     The 0.62 opacity target is handled inside the keyframe. */

  /* ---- CTA ---- */
  .hero__cta {
    /* Staggered reveal — 5th */
    opacity: 0;
    transform: translateY(12px);
    animation: hero-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.78s forwards;
  }

  /* Typography override only — bg/color inherits from .btn--primary */
  .hero__cta .btn--primary {
    font-size: 14px;
    letter-spacing: 0.2em;
    padding: 22px 40px;
    min-height: 64px;
  }
  @media (max-width: 767px) {
    .hero__cta .btn--primary {
      font-size: 13px;
      padding: 20px 32px;
      min-height: 58px;
    }
  }

  /* ---- Scroll cue ---- */
  .hero__scroll-cue {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    opacity: 0;
    animation: hero-fade-up 0.6s ease 1.2s forwards;
  }

  .hero__scroll-label {
    font-family: 'Inter', var(--font-label);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-olive);
    opacity: 0.4;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(42,35,32,0.25), transparent);
    animation: scroll-line 0.8s cubic-bezier(0.16, 1, 0.3, 1) 1.4s both;
  }

  /* ---- Animations ---- */
  @keyframes hero-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-rule-in {
    to {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  @keyframes scroll-line {
    from { transform: scaleY(0); transform-origin: top; opacity: 0; }
    to   { transform: scaleY(1); transform-origin: top; opacity: 1; }
  }

  /* Fix subtext final opacity — override initial opacity:0 from animation start */
  .hero__subtext {
    animation: hero-subtext-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
  }

  @keyframes hero-subtext-in {
    to {
      opacity: 0.92;
      transform: translateY(0);
    }
  }

  /* ---- Responsive ---- */
  @media (max-width: 767px) {
    /* Full-height hero so orb (top) and text (bottom) never overlap */
    .hero {
      min-height: 100svh;
      align-items: flex-end;
    }

    /* Text block sits in the lower ~45% of the viewport */
    .hero__inner {
      padding-block: var(--space-10) var(--space-16);
      position: relative;
      z-index: 4;
      /* Soft gradient lifts text off the background for readability */
      background: linear-gradient(to top, var(--color-bone) 70%, transparent);
      width: 100%;
    }

    .hero__heading {
      font-size: clamp(2.5rem, 11vw, 3.5rem);
    }

    .hero__subtext {
      font-size: var(--font-size-base);
      max-width: 42ch;
    }

    .hero__scroll-cue {
      display: none;
    }
  }

  /* ---- Ring video ---- */
  .hero__ring-stage {
    position: absolute;
    /* Centred in the right half — margins avoid conflicting with animation transforms */
    left: 70%; top: 50%;
    width: 560px; height: 560px;
    margin-left: -280px; margin-top: -280px;
    z-index: 3;
    pointer-events: none;
    opacity: 0;
    animation: hero-ring-in 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }
  @keyframes hero-ring-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .hero__ring-video {
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: 12px;
    display: block;
    filter: drop-shadow(0 32px 80px rgba(120, 90, 50, 0.30));
  }
  @media (max-width: 1280px) {
    .hero__ring-stage { width: 460px; height: 460px; margin-left: -230px; margin-top: -230px; }
  }
  @media (max-width: 1024px) {
    .hero__ring-stage { width: 360px; height: 360px; margin-left: -180px; margin-top: -180px; }
  }
  @media (max-width: 767px) {
    /* Full-width centred at top of screen, clear of text */
    .hero__ring-stage {
      left: 50%; top: 28%;
      width: 72vw; height: 72vw;
      max-width: 300px; max-height: 300px;
      margin-left: calc(-36vw); margin-top: calc(-36vw);
    }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .hero__rule,
    .hero__eyebrow,
    .hero__heading,
    .hero__subtext,
    .hero__cta,
    .hero__scroll-cue {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .hero__subtext { opacity: 0.62; }
  }

  /* ============================================================
     ORB SCENE — warm restorative breathing-orb
     Anchored to the right side; behind text content.
     ============================================================ */
  .hero__scene {
    position: absolute;
    inset: 0;
    z-index: 1;          /* above grain (1) but below content (2) */
    pointer-events: none;
    overflow: hidden;
  }

  /* Warm paper wash + subtle radial warmth on right side */
  .hero__paper {
    position: absolute; inset: 0;
    background:
      radial-gradient(70% 60% at 70% 55%, rgba(217, 176, 121, 0.10), rgba(217, 176, 121, 0) 70%),
      radial-gradient(40% 50% at 90% 30%, rgba(201, 133, 104, 0.08), rgba(201, 133, 104, 0) 70%);
    pointer-events: none;
  }

  /* Sun halo behind everything */
  .hero__halo {
    position: absolute;
    left: 70%; top: 50%;
    width: 44%; aspect-ratio: 1 / 1;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(217,176,121,0.28), rgba(217,176,121,0) 65%);
    filter: blur(2px);
    pointer-events: none;
    animation: hero-halo-pulse 7s ease-in-out infinite;
  }
  @keyframes hero-halo-pulse {
    0%, 100% { opacity: 0.7; transform: translate(-50%,-50%) scale(0.96); }
    50%      { opacity: 1.0; transform: translate(-50%,-50%) scale(1.06); }
  }

  /* Static SVG concentric rings */
  .hero__static {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    opacity: 0.85;
  }

  /* Horizon line — barely-there tabletop */
  .hero__horizon {
    position: absolute;
    left: 0; right: 0;
    top: 75%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(74,66,58,0.10) 30%, rgba(74,66,58,0.16) 50%, rgba(74,66,58,0.10) 70%, transparent);
    pointer-events: none;
  }

  /* Expanding breath rings radiating from sun */
  .hero__rings {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero__ring {
    position: absolute;
    left: 70%; top: 50%;
    width: 200px; height: 200px;
    margin-left: -100px; margin-top: -100px;
    border: 1px solid rgba(168, 129, 79, 0.5);
    border-radius: 50%;
    opacity: 0;
    animation: hero-ring-expand 7s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    will-change: transform, opacity;
  }
  .hero__ring:nth-child(2) { animation-delay: -2.33s; }
  .hero__ring:nth-child(3) { animation-delay: -4.66s; }
  @keyframes hero-ring-expand {
    0%   { transform: scale(0.4); opacity: 0; }
    20%  { opacity: 0.45; }
    100% { transform: scale(2.6); opacity: 0; }
  }

  /* Floating dust motes */
  .hero__motes { position: absolute; inset: 0; pointer-events: none; }
  .hero__mote {
    position: absolute;
    width: 3px; height: 3px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,240,210,0.85), rgba(255,240,210,0) 70%);
    animation: hero-mote-drift linear infinite;
    will-change: transform, opacity;
  }
  @keyframes hero-mote-drift {
    0%   { transform: translate(0, 0) scale(0.6); opacity: 0; }
    15%  { opacity: 0.85; }
    85%  { opacity: 0.55; }
    100% { transform: translate(var(--dx, 0px), var(--dy, -180px)) scale(1.1); opacity: 0; }
  }

  /* Cursor glow follows pointer */
  .hero__cursor-glow {
    position: absolute;
    left: var(--cx, -200px); top: var(--cy, -200px);
    width: 360px; height: 360px;
    margin-left: -180px; margin-top: -180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,220,170,0.30), rgba(255,220,170,0) 65%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease;
    mix-blend-mode: screen;
  }
  .hero:hover .hero__cursor-glow { opacity: 1; }

  /* Mobile: scene atmosphere tracks video position */
  @media (max-width: 767px) {
    .hero__scene { opacity: 0.85; }
    .hero__halo  { left: 50%; top: 28%; }
    .hero__ring  { left: 50%; top: 28%; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero__halo,
    .hero__ring,
    .hero__mote { animation: none; }
    .hero__cursor-glow { display: none; }
    .hero__ring-video { animation: none; }
  }
</style>


<script>
  (function () {
    var hero      = document.getElementById('hero');
    if (!hero) return;
    var cursor    = hero.querySelector('[data-hero-cursor]');
    var motesWrap = hero.querySelector('[data-hero-motes]');
    var video     = hero.querySelector('.hero__ring-video');
    var reduced   = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ---- Pick SD on mobile, HD on desktop ---- */
    if (video) {
      var isMobile = window.matchMedia('(max-width: 767px)').matches;
      var src = isMobile
        ? video.dataset.srcSd
        : video.dataset.srcHd;
      if (src) {
        video.src = src;
        video.load();
        video.play().catch(function () {});
      }
    }

    /* ---- Cursor glow ---- */
    if (cursor) {
      hero.addEventListener('pointermove', function (e) {
        var r = hero.getBoundingClientRect();
        cursor.style.setProperty('--cx', (e.clientX - r.left) + 'px');
        cursor.style.setProperty('--cy', (e.clientY - r.top)  + 'px');
      });
    }

    /* ---- Dust motes ---- */
    if (motesWrap && !reduced) {
      for (var i = 0; i < 16; i++) {
        var m = document.createElement('div');
        m.className = 'hero__mote';
        var dur = 8 + Math.random() * 10;
        m.style.cssText = 'left:' + (40 + Math.random() * 55) + '%;top:'
          + (25 + Math.random() * 60) + '%;animation-duration:' + dur
          + 's;animation-delay:' + (-Math.random() * dur) + 's;';
        m.style.setProperty('--dx', ((Math.random() - 0.5) * 120) + 'px');
        m.style.setProperty('--dy', (-120 - Math.random() * 200) + 'px');
        motesWrap.appendChild(m);
      }
    }
  })();
</script>


<!-- ============================================================
     SCHEMA
     ============================================================ -->
{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The routine before your routine."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading — line 1",
      "default": "Your shower is"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading — italic word",
      "default": "undoing",
      "info": "This word renders in italic and amber — the pivot of the sentence."
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading — line 3",
      "default": "everything."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Chlorine, heavy metals, sediment — every product you apply after is working against a contaminated baseline."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop the filter"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Hero video"
    },
    {
      "type": "url",
      "id": "hero_video_url",
      "label": "Ring video URL",
      "info": "Paste a Shopify CDN video URL. Autoplays looped, muted."
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image",
      "info": "Optional. Displays at low opacity over espresso background."
    },
    {
      "type": "header",
      "content": "Options"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_cue",
      "label": "Show scroll cue",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
