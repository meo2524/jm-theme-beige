{%- liquid
  assign eyebrow    = section.settings.eyebrow    | default: 'The routine before your routine.'
  assign heading    = section.settings.heading    | default: 'Your shower is'
  assign heading_em = section.settings.heading_em | default: 'undoing'
  assign heading_2  = section.settings.heading_2  | default: 'everything.'
  assign subtext    = section.settings.subtext    | default: 'Chlorine, heavy metals, sediment — every product you apply after is working against a contaminated baseline.'
  assign cta_label  = section.settings.cta_label  | default: 'Shop the filter'
  assign cta_url    = section.settings.cta_url    | default: '/collections/all'
  assign bg_image   = section.settings.bg_image
  assign show_scroll_cue = section.settings.show_scroll_cue
-%}

<section
  class="hero"
  id="hero"
  aria-label="Hero — {{ heading }} {{ heading_em }} {{ heading_2 }}"
  style="
    {%- if bg_image != blank -%}
      --hero-bg-image: url('{{ bg_image | image_url: width: 2000 }}');
    {%- endif -%}
  "
>

  <!-- Grain overlay -->
  <div class="hero__grain" aria-hidden="true"></div>

  <!-- Bg image layer -->
  {%- if bg_image != blank -%}
    <div class="hero__image-layer" aria-hidden="true">
      <img
        src="{{ bg_image | image_url: width: 2000 }}"
        srcset="
          {{ bg_image | image_url: width: 800  }} 800w,
          {{ bg_image | image_url: width: 1200 }} 1200w,
          {{ bg_image | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        alt=""
        width="2000"
        height="1200"
        loading="eager"
        fetchpriority="high"
      >
    </div>
  {%- endif -%}

  <!-- Content -->
  <div class="hero__inner container">

    <div class="hero__content">

      <!-- Amber rule -->
      <span class="hero__rule" aria-hidden="true"></span>

      <!-- Eyebrow -->
      <p class="hero__eyebrow">{{ eyebrow }}</p>

      <!-- Heading -->
      <h1 class="hero__heading">
        <span class="hero__heading-line">{{ heading }}</span>
        <em class="hero__heading-em">{{ heading_em }}</em>
        <span class="hero__heading-line">{{ heading_2 }}</span>
      </h1>

      <!-- Subtext -->
      <p class="hero__subtext">{{ subtext }}</p>

      <!-- CTA -->
      <div class="hero__cta">
        <a href="{{ cta_url }}" class="btn btn--primary btn--lg">
          {{ cta_label }}
        </a>
      </div>

    </div>
    <!-- /hero__content -->

  </div>
  <!-- /hero__inner -->

  <!-- Scroll cue -->
  {%- if show_scroll_cue -%}
    <div class="hero__scroll-cue" aria-hidden="true">
      <span class="hero__scroll-label">Scroll</span>
      <span class="hero__scroll-line"></span>
    </div>
  {%- endif -%}

</section>


<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
  /* ---- Hero shell ---- */
  .hero {
    position: relative;
    min-height: 100dvh;
    background-color: var(--color-espresso);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* ---- Background image layer ---- */
  .hero__image-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.22;
    filter: saturate(0.6);
  }

  /* ---- Grain texture ---- */
  .hero__grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    opacity: 0.045;
    mix-blend-mode: overlay;
  }

  /* ---- Inner layout ---- */
  .hero__inner {
    position: relative;
    z-index: 2;
    padding-block: var(--space-32) var(--space-24);
    display: flex;
    align-items: flex-start;
  }

  .hero__content {
    max-width: 820px;
  }

  /* ---- Amber rule above eyebrow ---- */
  .hero__rule {
    display: block;
    width: 2.5rem;
    height: 1.5px;
    background-color: var(--color-amber);
    margin-bottom: var(--space-5);

    /* Staggered reveal — 1st */
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    animation: hero-rule-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  /* ---- Eyebrow ---- */
  .hero__eyebrow {
    font-family: 'Inter', var(--font-label);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-amber);
    margin-bottom: var(--space-6);
    max-width: none;

    /* Staggered reveal — 2nd */
    opacity: 0;
    transform: translateY(12px);
    animation: hero-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.25s forwards;
  }

  /* ---- Heading ---- */
  .hero__heading {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 7.5vw, 5.5rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-gold);
    margin-bottom: var(--space-8);
    max-width: none;

    /* Staggered reveal — 3rd */
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  .hero__heading-line {
    display: block;
  }

  .hero__heading-em {
    display: block;
    font-style: italic;
    color: var(--color-amber);
  }

  /* ---- Subtext ---- */
  .hero__subtext {
    font-family: var(--font-body);
    font-size: clamp(var(--font-size-base), 1.2vw, var(--font-size-md));
    line-height: 1.7;
    color: var(--color-gold);
    opacity: 0.62;
    max-width: 52ch;
    margin-bottom: var(--space-10);

    /* Staggered reveal — 4th */
    opacity: 0;
    transform: translateY(16px);
    animation: hero-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
  }

  /* Note: using opacity: 0 initially, then animation sets final value.
     The 0.62 opacity target is handled inside the keyframe. */

  /* ---- CTA ---- */
  .hero__cta {
    /* Staggered reveal — 5th */
    opacity: 0;
    transform: translateY(12px);
    animation: hero-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.78s forwards;
  }

  /* Override btn defaults for dark context */
  .hero__cta .btn--primary {
    background-color: var(--color-amber);
    color: var(--color-espresso);
    border-color: var(--color-amber);
    font-size: 11px;
    letter-spacing: 0.18em;
  }

  .hero__cta .btn--primary:hover,
  .hero__cta .btn--primary:focus-visible {
    background-color: var(--color-gold);
    border-color: var(--color-gold);
    color: var(--color-espresso);
  }

  /* ---- Scroll cue ---- */
  .hero__scroll-cue {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    opacity: 0;
    animation: hero-fade-up 0.6s ease 1.2s forwards;
  }

  .hero__scroll-label {
    font-family: 'Inter', var(--font-label);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold);
    opacity: 0.4;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(232,201,154,0.4), transparent);
    animation: scroll-line 0.8s cubic-bezier(0.16, 1, 0.3, 1) 1.4s both;
  }

  /* ---- Animations ---- */
  @keyframes hero-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-rule-in {
    to {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  @keyframes scroll-line {
    from { transform: scaleY(0); transform-origin: top; opacity: 0; }
    to   { transform: scaleY(1); transform-origin: top; opacity: 1; }
  }

  /* Fix subtext final opacity — override initial opacity:0 from animation start */
  .hero__subtext {
    animation: hero-subtext-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
  }

  @keyframes hero-subtext-in {
    to {
      opacity: 0.70;
      transform: translateY(0);
    }
  }

  /* ---- Responsive ---- */
  @media (max-width: 767px) {
    .hero {
      min-height: 95dvh;
      align-items: flex-end;
    }

    .hero__inner {
      padding-block: var(--space-16) var(--space-20);
    }

    .hero__heading {
      font-size: clamp(2.5rem, 11vw, 3.5rem);
    }

    .hero__subtext {
      font-size: var(--font-size-base);
      max-width: 42ch;
    }

    .hero__scroll-cue {
      display: none;
    }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .hero__rule,
    .hero__eyebrow,
    .hero__heading,
    .hero__subtext,
    .hero__cta,
    .hero__scroll-cue {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .hero__subtext { opacity: 0.62; }
  }
</style>


<!-- ============================================================
     SCHEMA
     ============================================================ -->
{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The routine before your routine."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading — line 1",
      "default": "Your shower is"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading — italic word",
      "default": "undoing",
      "info": "This word renders in italic and amber — the pivot of the sentence."
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading — line 3",
      "default": "everything."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Chlorine, heavy metals, sediment — every product you apply after is working against a contaminated baseline."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop the filter"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image",
      "info": "Optional. Displays at low opacity over espresso background."
    },
    {
      "type": "header",
      "content": "Options"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_cue",
      "label": "Show scroll cue",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
