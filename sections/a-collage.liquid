{{ 'a-collage.css' | asset_url | stylesheet_tag }}
{{ 'a-component-modal-video.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign global_heading_size = settings.enable_global_heading_font_size
  assign global_body_size = settings.enable_global_body_font_size
  assign global_color = settings.enable_global_color
-%}
{% if request.visual_preview_mode %}
  {% assign section_id_selector = '' %}
  {% assign section_id_variable = 'id' %}
{% else %}
  {% assign section_id_selector = '#section-' | append: section.id %}
  {% assign section_id_variable = section.id %}
{% endif %}
<style>
  {%- if request.visual_preview_mode -%}
    {% comment %} don't want fade-in animation in preview mode because it messes up preview {% endcomment %}
    .animation_section,
    .animation_section * {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      will-change: auto !important;
    }
  {%- endif -%}

    .atlas-isolation-wrapper {{ section_id_selector }} .card__inner {
      --atlas-ratio-percent: 80% !important; /* Make the card's image 80% as tall */
    }

    .atlas-isolation-wrapper {{ section_id_selector }} .section__collage {
      padding: 5px 0;
    }

    .atlas-isolation-wrapper .section-{{ section_id_variable }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px !important;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px !important;
    }

    @media screen and (min-width: 750px) {
      .atlas-isolation-wrapper .section-{{ section_id_variable }}-padding {
        padding-top: {{ section.settings.padding_top }}px !important;
        padding-bottom: {{ section.settings.padding_bottom }}px !important;
      }
    }

    .atlas-isolation-wrapper #heading-{{ section_id_variable }} {
      text-align: {{ section.settings.text_alignment }};
      color: {% if global_color %}rgb(var(--atlas-color-base-heading)){% else %}{{ section.settings.heading_color }}{% endif %};
      font-size: {% if global_heading_size %}var(--atlas-font-heading-size){% else %}{{ section.settings.heading_size }}px{% endif %};
      line-height: {% if global_heading_size %}calc(var(--atlas-font-heading-size) + 8px){% else %}{{ section.settings.heading_size | plus: 8 }}px{% endif %};
      margin-bottom: {{ section.settings.heading_subheading_gap }}px;
    }
    .atlas-isolation-wrapper #heading-{{ section_id_variable }} p {
      margin: 0;
    }
    .atlas-isolation-wrapper #heading-{{ section_id_variable }} strong {
      {%- if section.settings.heading_use_gradient -%}
        background: {% if section.settings.heading_gradient_color != blank %}{{ section.settings.heading_gradient_color }}{% else %}var(--atlas-gradient-base-background-1){% endif %};
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      {% else %}
        color: {{ section.settings.bolded_heading_color }};
      {%- endif -%}
    }
    .atlas-isolation-wrapper #subheading-{{ section_id_variable }} {
      text-align: {{ section.settings.text_alignment }};
      font-size: {{ section.settings.subheading_size }}px;
      color: {{ section.settings.subheading_color }};
      line-height: 100%;
    }
    .atlas-isolation-wrapper #subheading-{{ section_id_variable }} p {
      margin:0;
    }
    .atlas-isolation-wrapper #subheading-{{ section_id_variable }} strong {
      {%- if section.settings.subheading_use_gradient -%}
        background: {% if section.settings.subheading_gradient_color != blank %}{{ section.settings.subheading_gradient_color }}{% else %}var(--atlas-gradient-base-background-1){% endif %};
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      {% else %}
        color: {{ section.settings.subheading_highlighted_color }};
      {%- endif -%}
    }
    @media (max-width: 768px) {
      .atlas-isolation-wrapper #heading-{{ section_id_variable }} {
        font-size: {% if global_heading_size %}var(--atlas-font-heading-mob-size){% else %}{{ section.settings.heading_mob_size }}px{% endif %};
        line-height: {% if global_heading_size %}calc(var(--atlas-font-heading-mob-size) + 8px){% else %}{{ section.settings.heading_mob_size | plus: 8 }}px{% endif %};
        margin-bottom: {{ section.settings.heading_subheading_gap_mobile }}px;
      }
      .atlas-isolation-wrapper #subheading-{{ section_id_variable }} {
        font-size: {{ section.settings.subheading_mob_size }}px;
      }
    }

    @media screen and (min-width: 768px) {
      .atlas-isolation-wrapper {{ section_id_selector }} .collage {
        grid-auto-flow: column;
        grid-column-gap: {{ section.settings.grid_column_gap_desktop }}px;
        grid-row-gap: {{ section.settings.grid_row_gap_desktop }}px;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        padding-top: {{ section.settings.content_gap_desktop }}px;
      }
    }
    @media (max-width: 768px) {
      .atlas-isolation-wrapper {{ section_id_selector }} .collage {
        padding-top: {{ section.settings.content_gap_mobile }}px;
      }
    }
</style>

<div
  id="section-{{ section_id_variable }}"
  class="gradient isolate section__collage"
  style="{% if section.settings.use_gradient_background %}background: {{ section.settings.section_background_gradient }};{% else %}background-color: {{ section.settings.section_background_color }};{% endif %}"
>
  <div
    class="page-width{% if section.settings.heading == blank %} no-heading{% endif %} section-{{ section_id_variable }}-padding"
    style="max-width: {{ section.settings.content_max_width_desktop }}px !important;"
  >
    <h2 id="heading-{{ section_id_variable }}" class="title collage-wrapper-title">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <div id="subheading-{{ section_id_variable }}" class="subheading">
        {{ section.settings.subheading }}
      </div>
    {%- endif -%}
    <div class="collage fade-in-child">
      {%- for block in section.blocks -%}
        <div
          class="collage__item collage__item--{{ block.type }} collage__item--{{ section.settings.desktop_layout }}"
          {{ block.shopify_attributes }}
        >
          {%- case block.type -%}
            {%- when 'image' -%}
              {% render 'a-collage-image',
                image: block.settings.image,
                card_styles: section.settings.card_styles,
                border_radius: block.settings.border_radius
              %}

            {%- when 'product' -%}
              {% render 'a-collage-card-product',
                card_product: block.settings.product,
                media_aspect_ratio: 'adapt',
                show_secondary_image: block.settings.second_image,
                extend_height: true,
                border_radius: block.settings.border_radius,
                card_background: block.settings.card_background,
                product_badge_text: block.settings.product_badge_text,
                product_badge_text_font_size: block.settings.product_badge_text_font_size,
                product_badge_text_color: block.settings.product_badge_text_color,
                product_badge_background_color: block.settings.product_badge_background_color,
                product_badge_border_radius: block.settings.product_badge_border_radius,
                product_badge_has_gradient: block.settings.product_badge_has_gradient,
                product_badge_gradient_color: block.settings.product_badge_gradient_color,
                product_badge_position: block.settings.product_badge_position,
                product_title_font_size: block.settings.product_title_font_size,
                product_title_color: block.settings.product_title_color,
                product_price_font_size: block.settings.product_price_font_size,
                product_price_color: block.settings.product_price_color,
                product_compare_at_price_font_size: block.settings.product_compare_at_price_font_size,
                product_compare_at_price_color: block.settings.product_compare_at_price_color
              %}

            {%- when 'collection' -%}
              {% render 'a-card-collection',
                card_collection: block.settings.collection,
                media_aspect_ratio: 'adapt',
                columns: 2,
                extend_height: true,
                wrapper_class: section.settings.card_styles,
                border_radius: block.settings.border_radius,
                is_collage: true,
                overlay_gradient_color: block.settings.overlay_gradient_color,
                text_color: block.settings.text_color,
                text_size: block.settings.text_size
              %}

            {%- when 'video' -%}
              {% render 'a-collage-video',
                video_url: block.settings.video_url,
                video_file: block.settings.video_file,
                cover_image: block.settings.cover_image,
                description: block.settings.description,
                card_styles: section.settings.card_styles,
                block_id: block.id,
                border_radius: block.settings.border_radius,
                icon_size: block.settings.icon_size,
                icon_background_color: block.settings.icon_background_color,
                icon_color: block.settings.icon_color
              %}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collage",
  "tag": "section",
  "class": "atlas-isolation-wrapper atlas-gradient section animation_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Multimedia collage",
      "label": "Section heading"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Section subheading",
      "default": "Subheading"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_max_width_desktop",
      "label": "Desktop content max width",
      "min": 400,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1100
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Desktop layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_gap_desktop",
      "min": 0,
      "max": 64,
      "step": 1,
      "unit": "px",
      "label": "Desktop content gap",
      "default": 21
    },
    {
      "type": "range",
      "id": "content_gap_mobile",
      "min": 0,
      "max": 64,
      "step": 1,
      "unit": "px",
      "label": "Mobile content gap",
      "default": 14
    },
    {
      "type": "range",
      "id": "grid_column_gap_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop grid column gap",
      "default": 20
    },
    {
      "type": "range",
      "id": "grid_row_gap_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop grid row gap",
      "default": 21
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 10,
      "max": 70,
      "step": 1,
      "unit": "px",
      "label": "Desktop heading size",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_mob_size",
      "min": 10,
      "max": 70,
      "step": 1,
      "unit": "px",
      "label": "Mobile heading size",
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bolded_heading_color",
      "label": "Bold text color in heading",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "heading_use_gradient",
      "label": "Use gradient for bold text in heading",
      "info": "Any text formatted as bold within the heading will be converted to a gradient.",
      "default": false
    },
    {
      "type": "color_background",
      "id": "heading_gradient_color",
      "label": "Heading gradient color",
