      "visible_if": "{{ section.settings.heading_use_gradient }}"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Desktop subheading size",
      "default": 16
    },
    {
      "type": "range",
      "id": "subheading_mob_size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Mobile subheading size",
      "default": 16
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading text color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "subheading_highlighted_color",
      "label": "Bold text color in subheading",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "subheading_use_gradient",
      "label": "Use gradient for bold text in subheading",
      "info": "Any text formatted as bold within the subheading will be converted to a gradient.",
      "default": false
    },
    {
      "type": "color_background",
      "id": "subheading_gradient_color",
      "label": "Subheading gradient color",
      "default": "linear-gradient(180deg, rgba(251, 51, 166, 1), rgba(127, 72, 176, 1) 50%, rgba(48, 145, 211, 1) 100%)",
      "visible_if": "{{ section.settings.subheading_use_gradient }}"
    },
    {
      "type": "range",
      "id": "heading_subheading_gap",
      "label": "Desktop gap between heading and subheading",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 7
    },
    {
      "type": "range",
      "id": "heading_subheading_gap_mobile",
      "label": "Mobile gap between heading and subheading",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 7
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "checkbox",
      "id": "use_gradient_background",
      "label": "Use gradient background",
      "default": false
    },
    {
      "type": "color_background",
      "id": "section_background_gradient",
      "label": "Section background gradient",
      "default": "linear-gradient(180deg, rgba(251, 51, 166, 1), rgba(127, 72, 176, 1) 50%, rgba(48, 145, 211, 1) 100%)",
      "visible_if": "{{ section.settings.use_gradient_background }}"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section background color",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.use_gradient_background == false }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "range",
          "id": "border_radius",
          "label": "Border radius",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px",
          "default": 6
        }
      ]
    },
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "checkbox",
          "id": "second_image",
          "default": false,
