        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "range",
          "id": "border_radius",
          "label": "Border radius",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px",
          "default": 6
        },
        {
          "type": "color",
          "id": "card_background",
          "label": "Card background color",
          "default": "#F9F9F9"
        },
        {
          "type": "header",
          "content": "Typography"
        },
        {
          "type": "range",
          "id": "product_title_font_size",
          "max": 32,
          "min": 8,
          "label": "Product title font size",
          "default": 20,
          "unit": "px"
        },
        {
          "type": "color",
          "id": "product_title_color",
          "label": "Product title color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "product_price_font_size",
          "max": 32,
          "min": 8,
          "label": "Product price font size",
          "default": 22,
          "unit": "px"
        },
        {
          "type": "color",
          "id": "product_price_color",
          "label": "Product price color",
          "default": "#1D1A2D"
        },
        {
          "type": "range",
          "id": "product_compare_at_price_font_size",
