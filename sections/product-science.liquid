{% comment %} Science / Evidence — on-brand: charcoal bg, bronze-gold accent {% endcomment %}

<style>
  .ps-wrap {
    padding: 96px 20px;
    background: #1f1d1a;
    color: #efe8dc;
    margin: 0;
    overflow: hidden;
    position: relative;
  }

  .ps-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 45% at 15% 15%, rgba(154,126,87,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 45% 55% at 85% 85%, rgba(154,126,87,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .ps-inner { max-width: 1100px; margin: 0 auto; position: relative; }

  /* ── Animations ── */
  @keyframes ps-fadein {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: none; }
  }
  .ps-anim {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .ps-anim.ps-visible { opacity: 1; transform: none; }

  /* ── Header ── */
  .ps-header { text-align: center; margin-bottom: 72px; }

  .ps-eyebrow {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #9a7e57;
    margin: 0 0 16px;
  }
  .ps-title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    margin: 0 0 18px;
    line-height: 1.15;
    color: #efe8dc;
  }
  .ps-subtitle {
    font-size: 15px;
    color: #8a7d6e;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.75;
  }

  /* ── Stat grid ── */
  .ps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1px;
    margin-bottom: 64px;
    background: rgba(239,232,220,0.08);
    border-radius: 16px;
    overflow: hidden;
  }

  .ps-stat {
    background: rgba(239,232,220,0.03);
    padding: 44px 32px;
    text-align: center;
    transition: background 0.3s;
  }
  .ps-stat:hover { background: rgba(154,126,87,0.09); }

  .ps-number {
    font-size: clamp(40px, 6vw, 60px);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 12px;
    background: linear-gradient(135deg, #efe8dc 0%, #9a7e57 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }
  .ps-stat-desc {
    font-size: 13px;
    color: #8a7d6e;
    margin: 0 0 16px;
    line-height: 1.65;
  }
  .ps-source-label {
    font-size: 10px;
    color: rgba(154,126,87,0.6);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Harvard quote ── */
  .ps-quote {
    margin: 0 0 64px;
    padding: 40px 44px;
    background: rgba(239,232,220,0.03);
    border-radius: 12px;
    border: 1px solid rgba(239,232,220,0.08);
    border-left: 3px solid #9a7e57;
    position: relative;
  }

  .ps-quote::before {
    content: '\201C';
    position: absolute;
    top: 14px; left: 22px;
    font-size: 80px;
    color: rgba(154,126,87,0.12);
    font-family: Georgia, serif;
    line-height: 1;
  }

  .ps-quote-text {
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.75;
    color: #c4b89e;
    margin: 0 0 20px;
    font-style: italic;
    padding-left: 20px;
  }
  .ps-quote-attr {
    font-size: 11px;
    color: #9a7e57;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0;
    padding-left: 20px;
  }

  /* ── Sources ── */
  .ps-sources { }

  .ps-sources-label {
    text-align: center;
    font-size: 10px;
    color: #4a423a;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0 0 24px;
    border-top: 1px solid rgba(239,232,220,0.08);
    padding-top: 32px;
  }

  .ps-sources-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    align-items: center;
  }

  .ps-source-badge {
    text-decoration: none;
    display: block;
    background: rgba(239,232,220,0.03);
    padding: 14px 22px;
    border-radius: 10px;
    border: 1px solid rgba(239,232,220,0.08);
    transition: border-color 0.25s, background 0.25s, transform 0.25s;
  }
  .ps-source-badge:hover {
    border-color: rgba(154,126,87,0.4);
    background: rgba(154,126,87,0.06);
    transform: translateY(-2px);
  }
  .ps-source-name {
    margin: 0;
    font-size: 12px;
    font-weight: 700;
    color: #c4b89e;
    letter-spacing: 0.04em;
  }
  .ps-source-sub {
    margin: 3px 0 0;
    font-size: 10px;
    color: #4a423a;
  }

  @media (max-width: 600px) {
    .ps-quote { padding: 28px 24px; }
    .ps-quote::before { display: none; }
    .ps-quote-text, .ps-quote-attr { padding-left: 0; }
  }
</style>

<div class="ps-wrap">
  <div class="ps-inner">

    <div class="ps-header">
      <h2 class="ps-title ps-anim" style="transition-delay:0.08s">The science behind the ring.</h2>
      <p class="ps-subtitle ps-anim" style="transition-delay:0.16s">Validated across 107 peer-reviewed studies and nearly 100,000 participants. Here's what the research says.</p>
    </div>

    <div class="ps-grid">

      <div class="ps-stat ps-anim" style="transition-delay:0s">
        <p class="ps-number" data-count="99.6" data-suffix="%">0%</p>
        <p class="ps-stat-desc">Heart rate correlation vs. medical-grade ECG devices</p>
        <p class="ps-source-label">NIH · PubMed Central</p>
      </div>

      <div class="ps-stat ps-anim" style="transition-delay:0.1s">
        <p class="ps-number" data-count="98" data-suffix="%">0%</p>
        <p class="ps-stat-desc">HRV accuracy against gold-standard electrocardiography</p>
        <p class="ps-source-label">NIH · PubMed Central</p>
      </div>

      <div class="ps-stat ps-anim" style="transition-delay:0.2s">
        <p class="ps-number">93–96%</p>
        <p class="ps-stat-desc">Sensitivity identifying sleep vs. wakefulness across validation studies</p>
        <p class="ps-source-label">NIH · PubMed Central</p>
      </div>

      <div class="ps-stat ps-anim" style="transition-delay:0.3s">
        <p class="ps-number" data-count="82" data-suffix="%">0%</p>
        <p class="ps-stat-desc">Detecting illness 2.75 days before symptoms appear</p>
        <p class="ps-source-label">NIH · 63,153 participants</p>
      </div>

    </div>

    <div class="ps-quote ps-anim">
      <p class="ps-quote-text">"Smart rings may be more accurate for sleep tracking than smartwatches — and their finger-based sensors offer better signal quality than wrist-worn devices."</p>
      <p class="ps-quote-attr">Harvard Health Publishing · Harvard Medical School</p>
    </div>

    <div class="ps-sources ps-anim">
      <p class="ps-sources-label">As cited in</p>
      <div class="ps-sources-row">

        <a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC12730986/" target="_blank" rel="noopener" class="ps-source-badge">
          <p class="ps-source-name">NIH · PubMed Central</p>
          <p class="ps-source-sub">107 studies · 100,000 participants</p>
        </a>

        <a href="https://www.health.harvard.edu/heart-health/device-of-the-month-smart-ring" target="_blank" rel="noopener" class="ps-source-badge">
          <p class="ps-source-name">Harvard Health Publishing</p>
          <p class="ps-source-sub">Harvard Medical School</p>
        </a>

        <a href="https://www.mdpi.com/2076-3417/14/23/10778" target="_blank" rel="noopener" class="ps-source-badge">
          <p class="ps-source-name">MDPI Applied Sciences</p>
          <p class="ps-source-sub">Peer-reviewed journal</p>
        </a>

        <a href="https://www.nature.com/articles/s41598-025-24312-0" target="_blank" rel="noopener" class="ps-source-badge">
          <p class="ps-source-name">Nature · Scientific Reports</p>
          <p class="ps-source-sub">Nature Publishing Group</p>
        </a>

      </div>
    </div>

  </div>
</div>

<script>
(function() {
  var animEls   = document.querySelectorAll('.section-product-science .ps-anim');
  var countEls  = document.querySelectorAll('.section-product-science [data-count]');

  function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

  function countUp(el) {
    var target   = parseFloat(el.dataset.count);
    var suffix   = el.dataset.suffix || '';
    var decimals = target % 1 !== 0 ? 1 : 0;
    var duration = 1400;
    var start    = performance.now();
    (function tick(now) {
      var elapsed = Math.min((now - start) / duration, 1);
      el.textContent = (easeOut(elapsed) * target).toFixed(decimals) + suffix;
      if (elapsed < 1) requestAnimationFrame(tick);
    })(start);
  }

  var counted = new WeakSet();

  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return;
      e.target.classList.add('ps-visible');
      if (e.target.dataset.count && !counted.has(e.target)) {
        counted.add(e.target);
        countUp(e.target);
      }
      io.unobserve(e.target);
    });
  }, { threshold: 0.15 });

  animEls.forEach(function(el) { io.observe(el); });
  countEls.forEach(function(el) { io.observe(el); });
})();
</script>

{% schema %}
{
  "name": "Science & Evidence",
  "tag": "section",
  "class": "section-product-science",
  "settings": []
}
{% endschema %}
