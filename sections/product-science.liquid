{% comment %} Science / Evidence — on-brand: charcoal bg, bronze-gold accent {% endcomment %}

<style>
  .ps-wrap {
    padding: 96px 20px;
    background: #1f1d1a;
    color: #efe8dc;
    margin: 0;
    overflow: hidden;
    position: relative;
  }

  .ps-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 45% at 15% 15%, rgba(154,126,87,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 45% 55% at 85% 85%, rgba(154,126,87,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .ps-inner { max-width: 1100px; margin: 0 auto; position: relative; }

  /* ── Animations ── */
  @keyframes ps-fadein {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: none; }
  }
  .ps-anim {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .ps-anim.ps-visible { opacity: 1; transform: none; }

  /* ── Header ── */
  .ps-header { text-align: center; margin-bottom: 72px; }

  .ps-eyebrow {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #9a7e57;
    margin: 0 0 16px;
  }
  .ps-title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    margin: 0 0 18px;
    line-height: 1.15;
    color: #efe8dc;
  }
  .ps-subtitle {
    font-size: 15px;
    color: #8a7d6e;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.75;
  }

  /* ── Stat grid ── */
  .ps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1px;
    margin-bottom: 64px;
    background: rgba(239,232,220,0.08);
    border-radius: 16px;
    overflow: hidden;
  }

  .ps-stat {
    background: rgba(239,232,220,0.03);
    padding: 44px 32px;
    text-align: center;
    transition: background 0.3s;
  }
  .ps-stat:hover { background: rgba(154,126,87,0.09); }

  .ps-number {
    font-size: clamp(40px, 6vw, 60px);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 12px;
    background: linear-gradient(135deg, #efe8dc 0%, #9a7e57 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }
  .ps-stat-desc {
    font-size: 13px;
    color: #b8aa92;          /* was #8a7d6e — tightened contrast on dark bg */
    margin: 0 0 16px;
    line-height: 1.65;
  }
  .ps-source-label {
    font-size: 10px;
    color: #9a7e57;          /* was rgba(154,126,87,0.6) — full opacity for readability */
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Harvard quote ── */
  .ps-quote {
    margin: 0 0 64px;
    padding: 40px 44px;
    background: rgba(239,232,220,0.03);
    border-radius: 12px;
    border: 1px solid rgba(239,232,220,0.08);
    border-left: 3px solid #9a7e57;
    position: relative;
  }

  .ps-quote::before {
    content: '\201C';
    position: absolute;
    top: 14px; left: 22px;
    font-size: 80px;
    color: rgba(154,126,87,0.12);
    font-family: Georgia, serif;
    line-height: 1;
  }

  .ps-quote-text {
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.75;
    color: #c4b89e;
    margin: 0 0 20px;
    font-style: italic;
    padding-left: 20px;
  }
  .ps-quote-attr {
    font-size: 11px;
    color: #9a7e57;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0;
    padding-left: 20px;
  }

  /* ── Sources ──
     Refactored 2026-05-05 for readability — earlier colours sat at #4a423a
     on near-black bg which dropped under WCAG AA. Now uses warm-bone tones
     consistent with the quote-attr (#9a7e57) and stat-desc (#b8aa92). */
  .ps-sources {
    margin-top: 64px;
    border-top: 1px solid rgba(239,232,220,0.14);
    padding-top: 44px;
  }

  .ps-sources-label {
    text-align: center;
    font-size: 11px;
    font-weight: 500;
    color: #9a7e57;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    /* margin auto + max-width:none override the global `p { max-width:
       68ch }` rule. Without this, the label inherited a 482px cap and
       sat at the parent's left edge instead of centring under the
       badge below it. */
    margin: 0 auto 28px;
    max-width: none;
  }

  .ps-sources-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    align-items: center;
  }

  .ps-source-badge {
    text-decoration: none;
    display: block;
    background: rgba(239,232,220,0.05);
    padding: 22px 32px;
    border-radius: 12px;
    border: 1px solid rgba(239,232,220,0.14);
    transition: border-color 0.25s, background 0.25s, transform 0.25s;
    min-width: 280px;
    text-align: center;
  }
  .ps-source-badge:hover {
    border-color: rgba(154,126,87,0.5);
    background: rgba(154,126,87,0.08);
    transform: translateY(-2px);
  }
  .ps-source-name {
    margin: 0;
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-size: 18px;
    font-weight: 500;
    color: #e8dec5;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }
  .ps-source-sub {
    margin: 6px 0 0;
    font-size: 12px;
    color: #b8aa92;
    letter-spacing: 0.02em;
    line-height: 1.45;
  }

  /* ── See the science toggle ── */
  .ps-toggle {
    width: 100%;
  }

  .ps-toggle__trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1rem;
    background: rgba(239, 232, 220, 0.06);
    border: 1px solid rgba(239, 232, 220, 0.18);
    border-radius: 8px;
    color: #c4b89e;
    font-family: var(--font-label, sans-serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    list-style: none;
    user-select: none;
    margin-bottom: 0;
  }

  .ps-toggle__trigger::-webkit-details-marker { display: none; }

  .ps-toggle__chevron {
    margin-left: auto;
    transition: transform 0.25s ease;
    color: #9a7e57;
  }

  .ps-toggle[open] .ps-toggle__trigger {
    margin-bottom: 1.5rem;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    border-bottom-color: transparent;
  }

  .ps-toggle[open] .ps-toggle__chevron {
    transform: rotate(180deg);
  }

  /* Desktop: always open, hide the trigger */
  @media (min-width: 768px) {
    .ps-toggle { display: contents; }
    .ps-toggle__trigger { display: none; }
  }

  @media (max-width: 600px) {
    .ps-wrap { padding: 48px 20px; }

    .ps-quote { padding: 28px 24px; }
    .ps-quote::before { display: none; }
    .ps-quote-text, .ps-quote-attr { padding-left: 0; }

    .ps-sources-row {
      flex-direction: column;
      align-items: stretch;
    }

    .ps-source-badge {
      width: 100%;
      box-sizing: border-box;
      text-align: center;
    }
  }
</style>

<div class="ps-wrap">
  <details class="ps-toggle" id="ps-toggle">
  <summary class="ps-toggle__trigger">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
    See the science
    <svg class="ps-toggle__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
  </summary>
  <div class="ps-inner">

    <div class="ps-header">
      <h2 class="ps-title ps-anim" style="transition-delay:0.08s">How the sensors work.</h2>
      <p class="ps-subtitle ps-anim" style="transition-delay:0.16s">The N°01 uses the same sensor class found across modern smart rings — proven to read physiological signals overnight when worn on a finger.</p>
    </div>

    <div class="ps-grid">

      <div class="ps-stat ps-anim" style="transition-delay:0s">
        <p class="ps-number">PPG</p>
        <p class="ps-stat-desc">Optical heart rate &amp; SpO₂ sensor on the inner ring</p>
        <p class="ps-source-label">Reads pulse and blood oxygen continuously</p>
      </div>

      <div class="ps-stat ps-anim" style="transition-delay:0.1s">
        <p class="ps-number">Accel</p>
        <p class="ps-stat-desc">3-axis accelerometer for movement, sleep stages, activity</p>
        <p class="ps-source-label">Distinguishes deep sleep, REM, light, awake</p>
      </div>

      <div class="ps-stat ps-anim" style="transition-delay:0.2s">
        <p class="ps-number">Temp</p>
        <p class="ps-stat-desc">Skin-temperature sensor for overnight baseline</p>
        <p class="ps-source-label">Detects deviation from your normal</p>
      </div>

      <div class="ps-stat ps-anim" style="transition-delay:0.3s">
        <p class="ps-number">HRV</p>
        <p class="ps-stat-desc">Heart-rate variability derived from PPG signal</p>
        <p class="ps-source-label">Recovery, stress, autonomic balance</p>
      </div>

    </div>

    <div class="ps-quote ps-anim">
      <p class="ps-quote-text">"Smart rings may be more accurate for sleep tracking than smartwatches — and their finger-based sensors offer better signal quality than wrist-worn devices."</p>
      <p class="ps-quote-attr">Harvard Health Publishing · Harvard Medical School</p>
    </div>

    <div class="ps-sources ps-anim">
      <p class="ps-sources-label">Sensor-class endorsement</p>
      <div class="ps-sources-row">
        <a href="https://www.health.harvard.edu/heart-health/device-of-the-month-smart-ring" target="_blank" rel="noopener" class="ps-source-badge">
          <p class="ps-source-name">Harvard Health Publishing</p>
          <p class="ps-source-sub">Harvard Medical School — smart rings as a class</p>
        </a>
      </div>
    </div>

  </div>
  </details>
</div>

<script>
(function() {
  // Reveal-on-scroll only. Count-up removed 2026-05-05 — static numbers
  // read more authoritatively for credibility data, and prevent screenshots
  // from catching the animation mid-frame (UX audit finding).
  var animEls = document.querySelectorAll('.section-product-science .ps-anim');
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return;
      e.target.classList.add('ps-visible');
      io.unobserve(e.target);
    });
  }, { threshold: 0.15 });
  animEls.forEach(function(el) { io.observe(el); });
})();
</script>

{% schema %}
{
  "name": "Science & Evidence",
  "tag": "section",
  "class": "section-product-science",
  "settings": []
}
{% endschema %}
