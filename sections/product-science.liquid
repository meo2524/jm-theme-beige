{% comment %} Science / Evidence section for smart ring product pages {% endcomment %}

<div class="product-science" style="padding:64px 20px;background:#0d0d0d;color:#fff;margin:0;">

  <div style="max-width:1100px;margin:0 auto;">

    <!-- Header -->
    <div style="text-align:center;margin-bottom:56px;">
      <p style="font-size:12px;letter-spacing:0.18em;text-transform:uppercase;color:#666;margin:0 0 12px;">Peer-reviewed research</p>
      <h2 style="font-size:clamp(26px,4vw,40px);font-weight:700;margin:0 0 16px;line-height:1.2;">The science behind the ring.</h2>
      <p style="font-size:15px;color:#888;max-width:540px;margin:0 auto;line-height:1.7;">Smart ring technology has been validated across 107 peer-reviewed studies involving nearly 100,000 participants. Here's what the research says.</p>
    </div>

    <!-- Stat callouts -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:2px;margin-bottom:56px;">

      <div style="background:#161616;padding:36px 28px;text-align:center;">
        <p style="font-size:clamp(36px,6vw,56px);font-weight:800;margin:0 0 8px;letter-spacing:-0.02em;color:#fff;">99.6%</p>
        <p style="font-size:13px;color:#aaa;margin:0 0 16px;line-height:1.6;">Heart rate correlation vs. medical-grade ECG devices</p>
        <p style="font-size:11px;color:#555;letter-spacing:0.1em;text-transform:uppercase;">NIH / PubMed Central</p>
      </div>

      <div style="background:#161616;padding:36px 28px;text-align:center;">
        <p style="font-size:clamp(36px,6vw,56px);font-weight:800;margin:0 0 8px;letter-spacing:-0.02em;color:#fff;">98%</p>
        <p style="font-size:13px;color:#aaa;margin:0 0 16px;line-height:1.6;">HRV accuracy against gold-standard electrocardiography</p>
        <p style="font-size:11px;color:#555;letter-spacing:0.1em;text-transform:uppercase;">NIH / PubMed Central</p>
      </div>

      <div style="background:#161616;padding:36px 28px;text-align:center;">
        <p style="font-size:clamp(36px,6vw,56px);font-weight:800;margin:0 0 8px;letter-spacing:-0.02em;color:#fff;">93–96%</p>
        <p style="font-size:13px;color:#aaa;margin:0 0 16px;line-height:1.6;">Sensitivity identifying sleep vs. wakefulness across validation studies</p>
        <p style="font-size:11px;color:#555;letter-spacing:0.1em;text-transform:uppercase;">NIH / PubMed Central</p>
      </div>

      <div style="background:#161616;padding:36px 28px;text-align:center;">
        <p style="font-size:clamp(36px,6vw,56px);font-weight:800;margin:0 0 8px;letter-spacing:-0.02em;color:#fff;">82%</p>
        <p style="font-size:13px;color:#aaa;margin:0 0 16px;line-height:1.6;">Sensitivity detecting illness 2.75 days before symptoms appear</p>
        <p style="font-size:11px;color:#555;letter-spacing:0.1em;text-transform:uppercase;">NIH / 63,153 participants</p>
      </div>

    </div>

    <!-- Harvard pull quote -->
    <div style="border-left:3px solid #444;padding:24px 32px;margin-bottom:56px;background:#111;">
      <p style="font-size:18px;line-height:1.7;color:#ccc;margin:0 0 16px;font-style:italic;">"Smart rings may be more accurate for sleep tracking than smartwatches — and their finger-based sensors offer better signal quality than wrist-worn devices."</p>
      <p style="font-size:12px;color:#555;margin:0;letter-spacing:0.1em;text-transform:uppercase;">Harvard Health Publishing · Harvard Medical School</p>
    </div>

    <!-- Source logos row -->
    <div style="border-top:1px solid #222;padding-top:36px;">
      <p style="text-align:center;font-size:11px;color:#555;letter-spacing:0.15em;text-transform:uppercase;margin:0 0 28px;">As cited in</p>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:32px;align-items:center;">

        <a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC12730986/" target="_blank" rel="noopener" style="text-decoration:none;">
          <div style="background:#1a1a1a;padding:14px 24px;border-radius:8px;border:1px solid #2a2a2a;transition:border-color 0.2s;">
            <p style="margin:0;font-size:13px;font-weight:700;color:#aaa;letter-spacing:0.05em;">NIH · PubMed Central</p>
            <p style="margin:2px 0 0;font-size:10px;color:#555;">107 studies · 100,000 participants</p>
          </div>
        </a>

        <a href="https://www.health.harvard.edu/heart-health/device-of-the-month-smart-ring" target="_blank" rel="noopener" style="text-decoration:none;">
          <div style="background:#1a1a1a;padding:14px 24px;border-radius:8px;border:1px solid #2a2a2a;">
            <p style="margin:0;font-size:13px;font-weight:700;color:#aaa;letter-spacing:0.05em;">Harvard Health Publishing</p>
            <p style="margin:2px 0 0;font-size:10px;color:#555;">Harvard Medical School</p>
          </div>
        </a>

        <a href="https://www.mdpi.com/2076-3417/14/23/10778" target="_blank" rel="noopener" style="text-decoration:none;">
          <div style="background:#1a1a1a;padding:14px 24px;border-radius:8px;border:1px solid #2a2a2a;">
            <p style="margin:0;font-size:13px;font-weight:700;color:#aaa;letter-spacing:0.05em;">MDPI Applied Sciences</p>
            <p style="margin:2px 0 0;font-size:10px;color:#555;">Peer-reviewed journal</p>
          </div>
        </a>

        <a href="https://www.nature.com/articles/s41598-025-24312-0" target="_blank" rel="noopener" style="text-decoration:none;">
          <div style="background:#1a1a1a;padding:14px 24px;border-radius:8px;border:1px solid #2a2a2a;">
            <p style="margin:0;font-size:13px;font-weight:700;color:#aaa;letter-spacing:0.05em;">Nature · Scientific Reports</p>
            <p style="margin:2px 0 0;font-size:10px;color:#555;">Nature Publishing Group</p>
          </div>
        </a>

      </div>
    </div>

  </div>
</div>

