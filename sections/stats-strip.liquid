{%- liquid
  assign stat_1_value = section.settings.stat_1_value | default: '99%'
  assign stat_1_label = section.settings.stat_1_label | default: 'Chlorine removed'
  assign stat_2_value = section.settings.stat_2_value | default: '15+'
  assign stat_2_label = section.settings.stat_2_label | default: 'Contaminants filtered'
  assign stat_3_value = section.settings.stat_3_value | default: '6 months'
  assign stat_3_label = section.settings.stat_3_label | default: 'Filter lifespan'
-%}

<section class="stats-strip" aria-label="Product statistics">
  <div class="stats-strip__inner container">

    <div class="stats-strip__grid">

      {%- for i in (1..3) -%}
        {%- liquid
          assign val   = 'stat_' | append: i | append: '_value'
          assign label = 'stat_' | append: i | append: '_label'
          assign val   = section.settings[val]
          assign label = section.settings[label]
        -%}
        <div class="stats-strip__item" data-reveal data-reveal-delay="{{ forloop.index0 | times: 80 }}">
          <span class="stats-strip__value" aria-label="{{ val }} — {{ label }}">{{ val }}</span>
          <span class="stats-strip__rule" aria-hidden="true"></span>
          <span class="stats-strip__label">{{ label }}</span>
        </div>
        {%- unless forloop.last -%}
          <span class="stats-strip__divider" aria-hidden="true"></span>
        {%- endunless -%}
      {%- endfor -%}

    </div>

  </div>
</section>

<style>
  .stats-strip {
    background-color: var(--char);
    padding: 44px 56px;
  }

  .stats-strip__grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .stats-strip__item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding-inline: var(--space-8);
    text-align: center;
  }

  .stats-strip__value {
    font-family: var(--font-serif);
    font-size: clamp(2.75rem, 4.5vw, 3.5rem);  /* up to 56px */
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--cream);
  }

  /* Decorative micro-rule between number and label — keep subtle */
  .stats-strip__rule {
    display: block;
    width: 1.25rem;
    height: 1px;
    background-color: var(--gold-light);
    opacity: 0.45;
  }

  .stats-strip__label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-light);
  }

  .stats-strip__divider {
    display: block;
    width: 1px;
    height: 56px;
    background-color: rgba(239, 232, 220, 0.2);
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .stats-strip__grid {
      flex-direction: column;
      gap: var(--space-8);
    }

    .stats-strip__divider {
      width: 60px;
      height: 1px;
    }

    .stats-strip__item {
      padding-inline: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Stats strip",
  "settings": [
    { "type": "text", "id": "stat_1_value", "label": "Stat 1 — value", "default": "5–7 days" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 — label", "default": "Battery life" },
    { "type": "text", "id": "stat_2_value", "label": "Stat 2 — value", "default": "4.9 ★" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 — label", "default": "2,100+ reviews" },
    { "type": "text", "id": "stat_3_value", "label": "Stat 3 — value", "default": "$0" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 — label", "default": "Subscription, ever" }
  ],
  "presets": [{ "name": "Stats strip" }]
}
{% endschema %}
