<!-- ============================================================
     MEND & CO — FOOTER
     Dark espresso bg, 3-col layout, newsletter, social links
     ============================================================ -->

{%- liquid
  assign footer_menu   = section.settings.footer_menu   | default: 'footer'
  assign legal_menu    = section.settings.legal_menu    | default: 'footer-legal'
  assign show_social   = section.settings.show_social
  assign show_payment  = section.settings.show_payment
-%}

<footer class="site-footer" role="contentinfo">

  <!-- Amber rule at top -->
  <div class="footer__rule"></div>

  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">

        <!-- Col 1 — Brand -->
        <div class="footer__col footer__col--brand">
          <a href="{{ routes.root_url }}" class="footer__logo" aria-label="{{ shop.name }}">
            {%- if section.settings.logo != blank -%}
              <img
                src="{{ section.settings.logo | image_url: width: 160 }}"
                width="160"
                height="auto"
                alt="{{ shop.name }}"
                loading="lazy"
              >
            {%- else -%}
              <span class="footer__logo-text">{{ shop.name }}</span>
            {%- endif -%}
          </a>

          {%- if section.settings.tagline != blank -%}
            <p class="footer__tagline">{{ section.settings.tagline }}</p>
          {%- endif -%}

          {%- if section.settings.brand_statement != blank -%}
            <p class="footer__brand-statement">{{ section.settings.brand_statement }}</p>
          {%- endif -%}

          <!-- Social links -->
          {%- if show_social -%}
            <div class="footer__social">
              {%- if settings.social_instagram_link != blank -%}
                <a href="{{ settings.social_instagram_link }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/>
                    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
                    <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <a href="{{ settings.social_tiktok_link }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <a href="{{ settings.social_facebook_link }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <!-- Col 2 — Navigation -->
        <div class="footer__col footer__col--nav">
          <p class="footer__col-heading">Explore</p>
          <ul class="footer__nav-list" role="list">
            {%- for link in linklists[footer_menu].links -%}
              <li>
                <a href="{{ link.url }}" class="footer__nav-link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </div>

        <!-- Col 3 — Newsletter -->
        <div class="footer__col footer__col--newsletter">
          <p class="footer__col-heading">{{ section.settings.newsletter_heading | default: 'Stay in the loop' }}</p>
          <p class="footer__newsletter-subtext">
            {{ section.settings.newsletter_subtext | default: 'Water quality guides, launch updates, and no noise.' }}
          </p>

          {%- form 'customer', class: 'footer__newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">

            <div class="footer__newsletter-row">
              <label for="footer-email" class="visually-hidden">Email address</label>
              <input
                type="email"
                id="footer-email"
                name="contact[email]"
                class="footer__newsletter-input"
                placeholder="your@email.com"
                required
                autocomplete="email"
                aria-required="true"
              >
              <button type="submit" class="btn btn--primary btn--sm">
                Subscribe
              </button>
            </div>

            {%- if form.posted_successfully? -%}
              <p class="footer__newsletter-success" role="status">You're in.</p>
            {%- endif -%}

          {%- endform -%}
        </div>

      </div>
      <!-- /footer__grid -->
    </div>
  </div>
  <!-- /footer__main -->

  <!-- Footer bottom bar -->
  <div class="footer__bottom">
    <div class="container">
      <div class="footer__bottom-inner">

        <!-- Legal nav -->
        <nav class="footer__legal-nav" aria-label="Legal navigation">
          <ul class="footer__legal-list" role="list">
            <li>
              <span class="footer__copyright">
                &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
              </span>
            </li>
            {%- for link in linklists[legal_menu].links -%}
              <li>
                <a href="{{ link.url }}" class="footer__legal-link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>

        <!-- Payment icons -->
        {%- if show_payment and shop.enabled_payment_types != empty -%}
          <div class="footer__payment">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
  <!-- /footer__bottom -->

</footer>


<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
  /* ---- Footer shell ---- */
  .site-footer {
    background-color: var(--color-espresso);
    color: var(--color-gold);
  }

  /* Amber rule at very top */
  .footer__rule {
    height: 1.5px;
    background-color: var(--color-amber);
    opacity: 0.5;
  }

  /* ---- Main section ---- */
  .footer__main {
    padding-block: var(--space-16) var(--space-12);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.4fr;
    gap: var(--space-12);
    align-items: start;
  }

  /* ---- Brand col ---- */
  .footer__logo {
    display: inline-block;
    margin-bottom: var(--space-5);
  }

  .footer__logo img {
    height: 32px;
    width: auto;
    filter: brightness(0) saturate(100%) invert(80%) sepia(30%) saturate(400%) hue-rotate(5deg);
    /* approximates --color-gold tint on logo */
  }

  .footer__logo-text {
    font-family: var(--font-heading);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-normal);
    color: var(--color-gold);
  }

  .footer__tagline {
    font-family: var(--font-label);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: var(--color-amber);
    margin-bottom: var(--space-4);
  }

  .footer__brand-statement {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-body);
    color: var(--color-gold);
    opacity: 0.65;
    max-width: 30ch;
    margin-bottom: var(--space-6);
  }

  /* Social */
  .footer__social {
    display: flex;
    gap: var(--space-3);
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-gold);
    opacity: 0.6;
    border: 1px solid rgba(232, 201, 154, 0.25);
    border-radius: var(--radius-base);
    transition: opacity var(--transition-fast),
                border-color var(--transition-fast),
                color var(--transition-fast);
  }

  .footer__social-link:hover {
    opacity: 1;
    color: var(--color-amber);
    border-color: var(--color-amber);
  }

  .footer__social-link:focus-visible {
    outline: 2px solid var(--color-amber);
    outline-offset: 2px;
  }

  /* ---- Nav col ---- */
  .footer__col-heading {
    font-family: var(--font-label);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: var(--color-amber);
    margin-bottom: var(--space-5);
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__nav-link {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    color: var(--color-gold);
    opacity: 0.7;
    transition: opacity var(--transition-fast),
                color var(--transition-fast);
  }

  .footer__nav-link:hover {
    opacity: 1;
    color: var(--color-amber);
  }

  /* ---- Newsletter col ---- */
  .footer__newsletter-subtext {
    font-size: var(--font-size-sm);
    color: var(--color-gold);
    opacity: 0.6;
    margin-bottom: var(--space-5);
    max-width: 28ch;
    line-height: var(--line-height-body);
  }

  .footer__newsletter-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__newsletter-row {
    display: flex;
    gap: var(--space-2);
  }

  .footer__newsletter-input {
    flex: 1;
    min-width: 0;
    padding: var(--space-3) var(--space-4);
    background-color: rgba(232, 201, 154, 0.08);
    border: 1px solid rgba(232, 201, 154, 0.2);
    border-radius: var(--radius-base);
    color: var(--color-gold);
    font-size: var(--font-size-sm);
    transition: border-color var(--transition-fast);
    min-height: 44px;
  }

  .footer__newsletter-input::placeholder {
    color: var(--color-gold);
    opacity: 0.35;
  }

  .footer__newsletter-input:focus {
    border-color: var(--color-amber);
    outline: none;
  }

  .footer__newsletter-success {
    font-size: var(--font-size-sm);
    color: var(--color-amber);
    letter-spacing: var(--letter-spacing-wide);
  }

  /* ---- Bottom bar ---- */
  .footer__bottom {
    border-top: 1px solid rgba(232, 201, 154, 0.1);
    padding-block: var(--space-5);
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer__legal-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
  }

  .footer__copyright,
  .footer__legal-link {
    font-family: var(--font-body);
    font-size: var(--font-size-xs);
    color: var(--color-gold);
    opacity: 0.45;
  }

  .footer__legal-link {
    transition: opacity var(--transition-fast);
  }

  .footer__legal-link:hover {
    opacity: 0.9;
  }

  /* Payment icons */
  .footer__payment {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .footer__payment-icon {
    height: 22px;
    width: auto;
    border-radius: 3px;
    opacity: 0.5;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1023px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }

    .footer__col--newsletter {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 767px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .footer__col--newsletter {
      grid-column: auto;
    }

    .footer__newsletter-row {
      flex-direction: column;
    }

    .footer__newsletter-input {
      width: 100%;
    }
  }
</style>


<!-- ============================================================
     SCHEMA
     ============================================================ -->
{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image (footer)"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "The routine before your routine."
    },
    {
      "type": "textarea",
      "id": "brand_statement",
      "label": "Brand statement",
      "default": "Most skin and hair problems start in the shower. Mend fixes the step the beauty industry won't talk about."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal menu",
      "default": "footer-legal"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter subtext",
      "default": "Water quality guides, launch updates, and no noise."
    },
    {
      "type": "header",
      "content": "Options"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "Show payment icons",
      "default": true
    }
  ]
}
{% endschema %}
