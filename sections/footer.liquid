<!-- footer.liquid - Mend & Co -->

{%- liquid
  assign footer_menu    = section.settings.footer_menu | default: 'footer'
  assign legal_menu     = section.settings.legal_menu  | default: 'footer-legal'
  assign tagline_text   = section.settings.tagline | default: 'Mend what matters.'
  assign brand_text     = section.settings.brand_statement | default: 'Every day, your routine either builds you up or breaks you down. We make the products that tip the balance.'
-%}

<footer class="site-footer" role="contentinfo">

  <div class="footer__rule" aria-hidden="true"></div>

  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">

        <!-- Brand -->
        <div class="footer__col footer__col--brand">

          <a href="{{ routes.root_url }}" class="footer__logo-link" aria-label="{{ shop.name }}">
            {%- if section.settings.logo != blank -%}
              <img
                src="{{ section.settings.logo | image_url: width: 160 }}"
                width="160"
                height="auto"
                alt="{{ shop.name }}"
                loading="lazy"
                class="footer__logo-img"
              >
            {%- else -%}
              {%- assign name_parts = shop.name | default: 'Mend & Co' | split: '&' -%}
              {%- if name_parts.size == 2 -%}
                <span class="footer__logo-text">{{ name_parts[0] | strip }}<em>&amp;</em>{{ name_parts[1] | strip }}</span>
              {%- else -%}
                <span class="footer__logo-text">{{ shop.name }}</span>
              {%- endif -%}
            {%- endif -%}
          </a>

          {%- if brand_text != blank -%}
            <p class="footer__brand-statement">{{ brand_text }}</p>
          {%- endif -%}

          {%- if tagline_text != blank -%}
            <p class="footer__tagline">
              <span class="pulse-dot" aria-hidden="true"></span>
              <span class="footer__tagline-text">{{ tagline_text }}</span>
            </p>
          {%- endif -%}

          {%- if section.settings.show_social -%}
            <nav class="footer__social" aria-label="Social media links">
              {%- if settings.social_instagram_link != blank -%}
                <a href="{{ settings.social_instagram_link }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <a href="{{ settings.social_tiktok_link }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <a href="{{ settings.social_facebook_link }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_youtube_link != blank -%}
                <a href="{{ settings.social_youtube_link }}" class="footer__social-link" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z" stroke="currentColor" stroke-width="1.5"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                </a>
              {%- endif -%}
            </nav>
          {%- endif -%}

        </div>

        <!-- Navigation -->
        <div class="footer__col footer__col--nav">
          <p class="footer__col-heading">{{ section.settings.nav_heading | default: 'Navigation' | escape }}</p>
          <ul class="footer__nav-list" role="list">
            <li><a href="{{ routes.all_products_collection_url }}" class="footer__nav-link">Products</a></li>
            {%- if pages.contact != empty -%}
              <li><a href="{{ pages.contact.url }}" class="footer__nav-link">Contact</a></li>
            {%- endif -%}
          </ul>
        </div>

        <!-- Support -->
        <div class="footer__col footer__col--support">
          <p class="footer__col-heading">{{ section.settings.support_heading | default: 'Support' | escape }}</p>
          <ul class="footer__nav-list" role="list">
            {%- for link in linklists[footer_menu].links -%}
              {%- unless link.url contains '/search' or link.url contains '/policies/' or link.url contains '/pages/contact' or link.url contains routes.all_products_collection_url -%}
                <li><a href="{{ link.url }}" class="footer__nav-link">{{ link.title }}</a></li>
              {%- endunless -%}
            {%- endfor -%}
            {%- if shop.shipping_policy.body != blank -%}
              <li><a href="{{ shop.shipping_policy.url }}" class="footer__nav-link">{{ shop.shipping_policy.title }}</a></li>
            {%- endif -%}
            {%- if shop.refund_policy.body != blank -%}
              <li><a href="{{ shop.refund_policy.url }}" class="footer__nav-link">{{ shop.refund_policy.title }}</a></li>
            {%- endif -%}
            {%- if shop.terms_of_service.body != blank -%}
              <li><a href="{{ shop.terms_of_service.url }}" class="footer__nav-link">{{ shop.terms_of_service.title }}</a></li>
            {%- endif -%}
          </ul>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container">
      <div class="footer__bottom-inner">
        <nav aria-label="Legal">
          <ul class="footer__legal-list" role="list">
            <li><span class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</span></li>
            {%- for link in linklists[legal_menu].links -%}
              <li><a href="{{ link.url }}" class="footer__legal-link">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </nav>
        {%- if section.settings.show_payment and shop.enabled_payment_types != empty -%}
          <div class="footer__payment" aria-label="Accepted payment methods">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

</footer>

<style>
.site-footer {
  background-color: var(--char);
  color: var(--cream);
}
.footer__rule {
  height: 1px;
  background-color: rgba(239, 232, 220, 0.12);
}
.footer__main {
  padding: 72px 0 36px;
}
.footer__grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 48px;
  align-items: start;
}
.footer__logo-link {
  display: inline-block;
  margin-bottom: 24px;
  text-decoration: none;
}
.footer__logo-img {
  height: 32px;
  width: auto;
  filter: brightness(0) saturate(100%) invert(95%) sepia(7%) saturate(420%) hue-rotate(2deg);
}
/* Wordmark: italic gold ampersand on cream */
.footer__logo-text {
  font-family: var(--font-serif);
  font-size: 26px;
  font-weight: 500;
  color: var(--cream);
  letter-spacing: 0.01em;
  display: inline-flex;
  align-items: baseline;
}
.footer__logo-text em {
  font-style: italic;
  font-weight: 400;
  margin: 0 1px;
  color: var(--gold-light);
}

/* Italic serif quote — primary brand statement */
.footer__brand-statement {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 22px;
  line-height: 1.35;
  color: rgba(239, 232, 220, 0.85);
  max-width: 360px;
  margin: 0 0 28px;
}

/* Pulse-dot row — secondary tagline like "Mended in small batches · Brooklyn" */
.footer__tagline {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0 0 24px;
  font-family: var(--font-mono);
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-light);
}
.footer__tagline .pulse-dot {
  background: var(--gold-light);
}
.footer__tagline-text { display: inline-block; }
.footer__social {
  display: flex;
  gap: 0.5rem;
}
.footer__social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  color: rgba(239, 232, 220, 0.55);
  border: 1px solid rgba(239, 232, 220, 0.15);
  border-radius: 4px;
  transition: color 0.15s ease, border-color 0.15s ease;
}
.footer__social-link:hover { color: var(--gold-light); border-color: rgba(201, 161, 107, 0.5); }
.footer__social-link:focus-visible { outline: 2px solid var(--gold-light); outline-offset: 2px; }

/* Column headings — mono uppercase in gold-light */
.footer__col-heading {
  font-family: var(--font-mono);
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-light);
  margin-bottom: 18px;
}
.footer__nav-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  list-style: none;
  margin: 0;
  padding: 0;
}

/* Footer nav links — Cormorant serif at 17px (per design) */
.footer__nav-link {
  position: relative;
  font-family: var(--font-serif);
  font-size: 17px;
  color: rgba(239, 232, 220, 0.88);
  text-decoration: none;
  transition: color 0.15s ease;
}

.footer__nav-link::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 100%;
  height: 1.5px;
  background: currentColor;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.2s ease;
}

.footer__nav-link:hover { color: var(--gold-light); }

.footer__nav-link:hover::after,
.footer__nav-link:focus-visible::after {
  transform: scaleX(1);
}
.footer__nav-link:focus-visible { outline: 2px solid var(--gold-light); outline-offset: 2px; border-radius: 1px; }
.footer__bottom {
  border-top: 1px solid rgba(239, 232, 220, 0.15);
  padding: 24px 0;
}
.footer__bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer__legal-list {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem 1.5rem;
  list-style: none;
  margin: 0;
  padding: 0;
}
.footer__copyright,
.footer__legal-link {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(239, 232, 220, 0.6);
  text-decoration: none;
}
.footer__legal-link { transition: color 0.15s ease; }
.footer__legal-link:hover { color: var(--gold-light); }
.footer__legal-link:focus-visible { outline: 2px solid var(--gold-light); outline-offset: 2px; border-radius: 1px; }
.footer__payment { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
.footer__payment-icon { height: 22px; width: auto; border-radius: 3px; opacity: 0.55; }
@media (max-width: 1023px) {
  .footer__grid { grid-template-columns: 1fr 1fr; gap: 3rem; }
  .footer__col--brand { grid-column: 1 / -1; }
}
@media (max-width: 767px) {
  .footer__grid { grid-template-columns: 1fr; gap: 2.5rem; }
  .footer__bottom-inner { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
}
@media (prefers-reduced-motion: reduce) {
  .footer__social-link,
  .footer__nav-link,
  .footer__legal-link { transition: none; }
}
</style>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (footer)"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Mend what matters."
    },
    {
      "type": "textarea",
      "id": "brand_statement",
      "label": "Brand statement",
      "default": "Every day, your routine either builds you up or breaks you down. We make the products that tip the balance."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal menu"
    },
    {
      "type": "text",
      "id": "nav_heading",
      "label": "Navigation column heading",
      "default": "Navigation"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support column heading",
      "default": "Support"
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "Show payment icons",
      "default": true
    }
  ]
}
{% endschema %}
