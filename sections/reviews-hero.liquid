{%- liquid
  assign heading    = section.settings.heading    | default: 'Trusted by thousands of wearers.'
  assign subheading = section.settings.subheading | default: 'Real people. Real data. No filters.'

  assign jm_rating = product.metafields.judgeme.rating | round: 1
  assign jm_count  = product.metafields.judgeme.rating_count

  if section.settings.badge_text != blank
    assign badge_text = section.settings.badge_text
  elsif jm_rating and jm_count and jm_count > 0
    assign badge_text = jm_rating | append: ' / 5 · ' | append: jm_count | append: ' verified reviews'
  else
    assign badge_text = '4.9 / 5 · Verified reviews'
  endif
-%}

<div class="rh-section">
  <div class="rh-inner">
    <span class="rh-badge">
      <span class="rh-badge__stars" aria-hidden="true">★★★★★</span>
      <span class="rh-badge__text">{{ badge_text }}</span>
    </span>
    <h2 class="rh-heading">{{ heading }}</h2>
    {%- if subheading != blank -%}
      <p class="rh-subheading">{{ subheading }}</p>
    {%- endif -%}
  </div>
</div>

<style>
.rh-section {
  background: var(--color-walnut, #735b3f);
  padding: 4rem 1.5rem 0;
  text-align: center;
}

.rh-inner {
  max-width: 680px;
  margin: 0 auto;
}

.rh-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 100px;
  padding: 0.375rem 1rem;
  margin-bottom: 1.25rem;
}

.rh-badge__stars {
  color: #e8c98a;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
}

.rh-badge__text {
  font-family: var(--font-label, monospace);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.9);
}

.rh-heading {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-size: clamp(2rem, 6vw, 3.25rem);
  font-weight: 300;
  line-height: 1.06;
  letter-spacing: -0.02em;
  color: #fff;
  margin: 0 0 0.875rem;
}

.rh-subheading {
  font-family: var(--font-body, Inter, sans-serif);
  font-size: 0.9375rem;
  color: rgba(255,255,255,0.7);
  line-height: 1.5;
  margin: 0;
}

@media (max-width: 767px) {
  .rh-section {
    padding: 3rem 1.25rem 0;
  }
}
</style>

{% schema %}
{
  "name": "Reviews hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by thousands of wearers."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real people. Real data. No filters."
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text (leave blank to use live Judge.me rating + count)"
    }
  ],
  "presets": [
    { "name": "Reviews hero" }
  ]
}
{% endschema %}
