<style>
.pr-wrap {
  background: var(--color-bone, #f5efe6);
  padding: 5rem 0 4rem;
  overflow: hidden;
}
.pr-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding-inline: clamp(1rem, 4vw, 2rem);
}

/* Header */
.pr-head { margin-bottom: 1.75rem; max-width: 560px; }

/* Tabs (Women / Men) */
.pr-tabs {
  display: inline-flex;
  gap: 4px;
  background: rgba(43,43,43,0.06);
  border-radius: 999px;
  padding: 4px;
  margin-bottom: 1.5rem;
}
.pr-tab {
  appearance: none;
  border: none;
  background: transparent;
  color: var(--color-olive, #5a4a3a);
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  padding: 0.5rem 1.125rem;
  border-radius: 999px;
  cursor: pointer;
  transition: background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
}
.pr-tab.is-active {
  background: #fff;
  color: var(--color-black, #1f1d1a);
  box-shadow: 0 2px 6px rgba(31,29,26,0.08);
}
.pr-tab:focus-visible {
  outline: 2px solid var(--color-walnut, #8a6240);
  outline-offset: 2px;
}

/* Track visibility — actual rules below the original .pr-track block */
.pr-head__rule {
  width: 40px; height: 1.5px;
  background: var(--color-walnut, #8a6240);
  opacity: 0.6; margin-bottom: 1.25rem;
}
.pr-head__eyebrow {
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.6875rem; font-weight: 600;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--color-walnut, #8a6240); margin: 0 0 0.75rem;
}
.pr-head__heading {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  font-weight: 400; color: var(--color-black, #1f1d1a);
  line-height: 1.15; margin: 0 0 0.75rem;
}
.pr-head__sub {
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.9375rem; color: var(--color-olive, #5a4a3a);
  opacity: 0.8; margin: 0;
}

/* Carousel wrapper */
.pr-carousel-wrap {
  position: relative;
}

/* Track — scroll-snap on mobile */
.pr-track {
  display: flex;
  gap: 1.25rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 4px;
  /* peek: show ~10% of next card */
  scroll-padding-inline: clamp(1rem, 4vw, 2rem);
}
.pr-track::-webkit-scrollbar { display: none; }

/* Toggle visibility — only the active set renders. Placed AFTER the
   .pr-track display:flex rule so source-order cascade wins. */
.pr-track:not(.is-active) { display: none !important; }

/* Cards */
.pr-card {
  flex: 0 0 calc(85vw - 2rem); /* mobile: 1 card + peek */
  max-width: 340px;
  scroll-snap-align: start;
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid rgba(43,43,43,0.16);
  box-shadow: 0 6px 20px rgba(31,29,26,0.08), 0 1px 3px rgba(31,29,26,0.04);
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.22s ease, transform 0.22s ease;
}
.pr-card:hover {
  box-shadow: 0 14px 36px rgba(31,29,26,0.14), 0 2px 6px rgba(31,29,26,0.06);
  transform: translateY(-2px);
}

@media (min-width: 600px) {
  .pr-card { flex: 0 0 calc(50% - 0.75rem); max-width: 400px; }
}
@media (min-width: 1024px) {
  .pr-card { flex: 0 0 calc(33.333% - 0.875rem); max-width: none; }
}

/* Photo — 4:5 portrait. Subtle inner border for separation from body. */
.pr-card__photo-wrap {
  width: 100%; aspect-ratio: 4 / 5;
  overflow: hidden; background: #e8e1d9;
  border-bottom: 1px solid rgba(43,43,43,0.06);
}
.pr-card__photo {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center center;
  display: block;
  transition: transform 0.5s ease;
}
.pr-card:hover .pr-card__photo { transform: scale(1.03); }

/* Body — tighter padding for cleaner frame around square photos */
.pr-card__body {
  padding: 1.125rem 1.25rem 1rem;
  display: flex; flex-direction: column; gap: 0.5rem; flex: 1;
}
.pr-stars {
  color: var(--color-walnut, #8a6240);
  font-size: 12px; letter-spacing: 2px; line-height: 1;
}
.pr-card__title {
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.9375rem; font-weight: 700;
  color: var(--color-black, #1f1d1a); line-height: 1.3; margin: 0;
}
.pr-card__text {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-size: 1.0625rem; font-style: italic; font-weight: 400;
  line-height: 1.65; color: var(--color-black, #1f1d1a); margin: 0; flex: 1;
}
.pr-card__footer {
  display: flex; align-items: flex-end; justify-content: space-between;
  gap: 0.5rem; padding-top: 0.875rem;
  border-top: 1px solid rgba(43,43,43,0.08); flex-wrap: wrap; margin-top: auto;
}
.pr-card__meta { display: flex; flex-direction: column; gap: 0.3rem; }
.pr-card__name {
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.8125rem; font-weight: 700; color: var(--color-black, #1f1d1a);
}
.pr-verified {
  display: inline-flex; align-items: center; gap: 0.3rem;
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.6875rem; font-weight: 500; color: #5a8a60; letter-spacing: 0.02em;
}
.pr-card__date {
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.6875rem; color: var(--color-olive, #5a4a3a);
  opacity: 0.5; text-align: right;
}

/* Nav buttons */
.pr-btn {
  display: none; /* JS shows these */
  position: absolute; top: 40%;
  transform: translateY(-50%);
  width: 42px; height: 42px; border-radius: 50%;
  border: 1.5px solid rgba(138,98,64,0.3);
  background: rgba(245,239,230,0.92);
  backdrop-filter: blur(4px);
  cursor: pointer;
  align-items: center; justify-content: center;
  color: var(--color-walnut, #8a6240);
  transition: background 0.18s, border-color 0.18s, opacity 0.18s;
  z-index: 2;
}
.pr-btn:hover { background: rgba(138,98,64,0.12); border-color: var(--color-walnut, #8a6240); }
.pr-btn:disabled { opacity: 0.2; pointer-events: none; }
.pr-btn--prev { left: -16px; }
.pr-btn--next { right: -16px; }

@media (min-width: 768px) {
  .pr-btn { display: flex; }
}

/* Dots */
.pr-dots {
  display: flex; justify-content: center; gap: 7px;
  margin-top: 1.75rem;
}
.pr-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: rgba(138,98,64,0.22);
  border: none; padding: 0; cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.pr-dot.is-active {
  background: var(--color-walnut, #8a6240);
  transform: scale(1.35);
}

@media (max-width: 599px) {
  .pr-wrap { padding: 3rem 0 3rem; }
  /* Smaller card on mobile so each review fits the viewport */
  .pr-card {
    flex: 0 0 calc(72vw - 1rem);
    max-width: 280px;
  }
  .pr-card__body {
    padding: 0.875rem 1rem 0.875rem;
    gap: 0.4rem;
  }
  .pr-card__title { font-size: 0.875rem; }
  .pr-card__text { font-size: 0.9375rem; line-height: 1.5; }
  .pr-card__footer { padding-top: 0.625rem; }
  .pr-card__name { font-size: 0.75rem; }
  .pr-verified { font-size: 0.625rem; }
  .pr-card__date { font-size: 0.625rem; }
  .pr-stars { font-size: 11px; }
}
@media (prefers-reduced-motion: reduce) {
  .pr-card__photo { transition: none; }
}
</style>

<script>
(function() {
  var section  = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;

  var dotsWrap = document.getElementById('pr-dots-{{ section.id }}');
  var btnPrev  = document.getElementById('pr-prev-{{ section.id }}');
  var btnNext  = document.getElementById('pr-next-{{ section.id }}');
  var tabs     = section.querySelectorAll('.pr-tab');
  var tracks   = section.querySelectorAll('.pr-track');

  /* State for the active track. Rebuilt when user switches tabs. */
  var current = { track: null, cards: [], dots: [] };

  function buildDots(count) {
    dotsWrap.innerHTML = '';
    for (var i = 0; i < count; i++) {
      var d = document.createElement('button');
      d.className = 'pr-dot' + (i === 0 ? ' is-active' : '');
      d.setAttribute('aria-label', 'Review ' + (i + 1));
      d.dataset.idx = i;
      dotsWrap.appendChild(d);
    }
    return Array.from(dotsWrap.querySelectorAll('.pr-dot'));
  }

  function scrollTo(idx) {
    var card = current.cards[idx];
    if (!card || !current.track) return;
    current.track.scrollTo({ left: card.offsetLeft - current.track.offsetLeft, behavior: 'smooth' });
  }

  function getActive() {
    if (!current.track) return 0;
    var scrollLeft = current.track.scrollLeft;
    var best = 0, bestDist = Infinity;
    current.cards.forEach(function(c, i) {
      var dist = Math.abs(c.offsetLeft - current.track.offsetLeft - scrollLeft);
      if (dist < bestDist) { bestDist = dist; best = i; }
    });
    return best;
  }

  function update() {
    var active = getActive();
    current.dots.forEach(function(d, i) { d.classList.toggle('is-active', i === active); });
    btnPrev.disabled = active === 0;
    btnNext.disabled = active >= current.cards.length - 1;
  }

  function activateTrack(set) {
    tracks.forEach(function(t) {
      var match = t.dataset.set === set;
      t.classList.toggle('is-active', match);
      t.hidden = !match;
    });
    tabs.forEach(function(b) {
      var match = b.dataset.set === set;
      b.classList.toggle('is-active', match);
      b.setAttribute('aria-selected', match ? 'true' : 'false');
    });
    var newTrack = section.querySelector('.pr-track[data-set="' + set + '"]');
    if (!newTrack) return;
    current.track = newTrack;
    current.cards = Array.from(newTrack.querySelectorAll('.pr-card'));
    current.dots  = buildDots(current.cards.length);
    newTrack.scrollLeft = 0;
    update();
  }

  /* Wire tabs */
  tabs.forEach(function(b) {
    b.addEventListener('click', function() { activateTrack(b.dataset.set); });
  });

  /* Wire prev/next + dots (use current state) */
  btnPrev.addEventListener('click', function() { scrollTo(Math.max(0, getActive() - 1)); });
  btnNext.addEventListener('click', function() { scrollTo(Math.min(current.cards.length - 1, getActive() + 1)); });
  dotsWrap.addEventListener('click', function(e) {
    var d = e.target.closest('.pr-dot');
    if (d) scrollTo(parseInt(d.dataset.idx));
  });

  /* Listen for scroll on whichever track is active */
  tracks.forEach(function(t) {
    t.addEventListener('scroll', function() { if (t === current.track) update(); }, { passive: true });
  });
  window.addEventListener('resize', update, { passive: true });

  /* Initialize on the women set */
  activateTrack('women');
})();
</script>

{% schema %}
{
  "name": "Photo reviews",
  "tag": "section",
  "class": "section-photo-reviews",
  "settings": [
    { "type": "text", "id": "eyebrow",    "label": "Eyebrow",    "default": "Verified Menders" },
    { "type": "text", "id": "heading",    "label": "Heading",    "default": "Real people. Real results." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Join thousands of Menders who track their health from their finger." }
  ],
  "presets": [{ "name": "Photo reviews" }]
}
{% endschema %}
