<style>
.pr-wrap {
  background: var(--cream-3);
  padding: 5rem 0 4rem;
  overflow: hidden;
}
.pr-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding-inline: clamp(1rem, 4vw, 2rem);
}

/* Header */
.pr-head { margin-bottom: 1.75rem; max-width: 560px; }

/* Track visibility */
.pr-head__rule {
  width: 40px; height: 1.5px;
  background: var(--gold-deep);
  opacity: 0.6; margin-bottom: 1.25rem;
}
.pr-head__eyebrow {
  font-family: var(--font-body);
  font-size: 0.6875rem; font-weight: 600;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--gold-deep); margin: 0 0 0.75rem;
}
.pr-head__heading {
  font-family: var(--font-body);
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  font-weight: 700; color: var(--color-black, #1f1d1a);
  line-height: 1.15; margin: 0 0 0.75rem;
}
.pr-head__sub {
  font-family: var(--font-body);
  font-size: 0.9375rem; color: var(--color-olive, #5a4a3a);
  opacity: 0.8; margin: 0;
}

/* Gender filter toggle */
.pr-filter {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1.75rem;
}
.pr-filter__btn {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.45rem 1.25rem;
  border-radius: 100px;
  border: 1.5px solid rgba(43,43,43,0.18);
  background: transparent;
  color: var(--color-olive, #5a4a3a);
  cursor: pointer;
  transition: background 0.18s, border-color 0.18s, color 0.18s;
}
.pr-filter__btn:hover {
  border-color: var(--gold-deep);
  color: var(--color-black, #1f1d1a);
}
.pr-filter__btn.is-active {
  background: var(--gold-deep);
  border-color: var(--gold-deep);
  color: var(--cream-2, #faf6f0);
}

/* Carousel wrapper */
.pr-carousel-wrap {
  position: relative;
}

/* Track — scroll-snap on mobile */
.pr-track {
  display: flex;
  gap: 1.25rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 4px;
  /* peek: show ~10% of next card */
  scroll-padding-inline: clamp(1rem, 4vw, 2rem);
}
.pr-track::-webkit-scrollbar { display: none; }

/* Cards */
.pr-card {
  flex: 0 0 calc(85vw - 2rem); /* mobile: 1 card + peek */
  max-width: 340px;
  scroll-snap-align: start;
  background: var(--cream-2);
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid rgba(43,43,43,0.16);
  box-shadow: 0 6px 20px rgba(10,8,18,0.08), 0 1px 3px rgba(10,8,18,0.04);
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.22s ease, transform 0.22s ease;
}
.pr-card:hover {
  box-shadow: 0 14px 36px rgba(10,8,18,0.14), 0 2px 6px rgba(10,8,18,0.06);
  transform: translateY(-2px);
}

@media (min-width: 600px) {
  .pr-card { flex: 0 0 calc(50% - 0.75rem); max-width: 400px; }
}
@media (min-width: 1024px) {
  .pr-card { flex: 0 0 calc(33.333% - 0.875rem); max-width: none; }
}

/* Photo — 4:5 portrait. Subtle inner border for separation from body. */
.pr-card__photo-wrap {
  width: 100%; aspect-ratio: 4 / 5;
  overflow: hidden; background: var(--cream-3);
  border-bottom: 1px solid rgba(43,43,43,0.06);
}
.pr-card__photo {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center center;
  display: block;
  transition: transform 0.5s ease;
}
.pr-card:hover .pr-card__photo { transform: scale(1.03); }

/* Body — tighter padding for cleaner frame around square photos */
.pr-card__body {
  padding: 1.125rem 1.25rem 1rem;
  display: flex; flex-direction: column; gap: 0.5rem; flex: 1;
}
.pr-stars {
  color: var(--gold-deep);
  font-size: 12px; letter-spacing: 2px; line-height: 1;
}
.pr-card__title {
  font-family: var(--font-body);
  font-size: 0.9375rem; font-weight: 700;
  color: var(--color-black, #1f1d1a); line-height: 1.3; margin: 0;
}
.pr-card__text {
  font-family: var(--font-body, 'Nunito', system-ui, sans-serif);
  font-size: 0.9375rem; font-style: normal; font-weight: 400;
  line-height: 1.65; color: var(--color-black, #1f1d1a); margin: 0; flex: 1;
}
.pr-card__footer {
  display: flex; align-items: flex-end; justify-content: space-between;
  gap: 0.5rem; padding-top: 0.875rem;
  border-top: 1px solid rgba(43,43,43,0.08); flex-wrap: wrap; margin-top: auto;
}
.pr-card__meta { display: flex; flex-direction: column; gap: 0.3rem; }
.pr-card__name {
  font-family: var(--font-body);
  font-size: 0.8125rem; font-weight: 700; color: var(--color-black, #1f1d1a);
}
.pr-verified {
  display: inline-flex; align-items: center; gap: 0.3rem;
  font-family: var(--font-body);
  font-size: 0.6875rem; font-weight: 500; color: #5a8a60; letter-spacing: 0.02em;
}
.pr-card__date {
  font-family: var(--font-body);
  font-size: 0.6875rem; color: var(--color-olive, #5a4a3a);
  opacity: 0.5; text-align: right;
}

/* Nav buttons */
.pr-btn {
  display: none !important;
  position: absolute !important;
  top: 40% !important;
  transform: translateY(-50%);
  width: 42px; height: 42px; border-radius: 50%;
  border: 1.5px solid rgba(107, 63, 160,0.3);
  background: var(--cream-2);
  backdrop-filter: blur(4px);
  cursor: pointer;
  align-items: center; justify-content: center;
  color: var(--gold-deep);
  transition: background 0.18s, border-color 0.18s, opacity 0.18s;
  z-index: 10;
}
.pr-btn:hover { background: rgba(107, 63, 160,0.15); border-color: var(--gold-deep); }
.pr-btn:disabled { opacity: 0.2; pointer-events: none; }
.pr-btn--prev { left: -16px !important; }
.pr-btn--next { right: -16px !important; }

@media (min-width: 768px) {
  .pr-btn { display: flex !important; }
}

/* Dots */
.pr-dots {
  display: flex; justify-content: center; gap: 7px;
  margin-top: 1.75rem;
}
.pr-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: rgba(107, 63, 160,0.22);
  border: none; padding: 0; cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.pr-dot.is-active {
  background: var(--gold-deep);
  transform: scale(1.35);
}

@media (max-width: 599px) {
  .pr-wrap { padding: 3rem 0 3rem; }
  /* Smaller card on mobile so each review fits the viewport */
  .pr-card {
    flex: 0 0 calc(72vw - 1rem);
    max-width: 280px;
  }
  .pr-card__body {
    padding: 0.875rem 1rem 0.875rem;
    gap: 0.4rem;
  }
  .pr-card__title { font-size: 0.875rem; }
  .pr-card__text { font-size: 0.9375rem; line-height: 1.5; }
  .pr-card__footer { padding-top: 0.625rem; }
  .pr-card__name { font-size: 0.75rem; }
  .pr-verified { font-size: 0.625rem; }
  .pr-card__date { font-size: 0.625rem; }
  .pr-stars { font-size: 11px; }
}
@media (prefers-reduced-motion: reduce) {
  .pr-card__photo { transition: none; }
}
</style>

<script>
(function() {
  var section    = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;

  var dotsWrap   = document.getElementById('pr-dots-{{ section.id }}');
  var btnPrev    = document.getElementById('pr-prev-{{ section.id }}');
  var btnNext    = document.getElementById('pr-next-{{ section.id }}');
  var track      = document.getElementById('pr-track-{{ section.id }}');
  var filterWrap = document.getElementById('pr-filter-{{ section.id }}');
  var allCards   = Array.from(track.querySelectorAll('.pr-card'));
  var cards      = allCards.slice(); // active (visible) subset
  var dots       = [];

  /* ── Filter ── */
  function applyFilter(gender) {
    allCards.forEach(function(c) {
      var show = gender === 'all' || c.dataset.gender === gender;
      c.style.display = show ? '' : 'none';
    });
    cards = allCards.filter(function(c) { return c.style.display !== 'none'; });
    track.scrollTo({ left: 0, behavior: 'instant' });
    buildDots();
    update();
  }

  filterWrap.addEventListener('click', function(e) {
    var btn = e.target.closest('.pr-filter__btn');
    if (!btn) return;
    filterWrap.querySelectorAll('.pr-filter__btn').forEach(function(b) {
      b.classList.toggle('is-active', b === btn);
    });
    applyFilter(btn.dataset.filter);
  });

  /* ── Dots ── */
  function buildDots() {
    dotsWrap.innerHTML = '';
    dots = cards.map(function(_, i) {
      var d = document.createElement('button');
      d.className = 'pr-dot' + (i === 0 ? ' is-active' : '');
      d.setAttribute('aria-label', 'Review ' + (i + 1));
      d.dataset.idx = i;
      dotsWrap.appendChild(d);
      return d;
    });
  }

  /* ── Scroll helpers ── */
  function scrollTo(idx) {
    var card = cards[idx];
    if (!card) return;
    track.scrollTo({ left: card.offsetLeft - track.offsetLeft, behavior: 'smooth' });
  }

  function getActive() {
    var best = 0, bestDist = Infinity;
    cards.forEach(function(c, i) {
      var dist = Math.abs(c.offsetLeft - track.offsetLeft - track.scrollLeft);
      if (dist < bestDist) { bestDist = dist; best = i; }
    });
    return best;
  }

  function update() {
    var active = getActive();
    dots.forEach(function(d, i) { d.classList.toggle('is-active', i === active); });
    btnPrev.disabled = active === 0;
    btnNext.disabled = active >= cards.length - 1;
  }

  btnPrev.addEventListener('click', function() { scrollTo(Math.max(0, getActive() - 1)); });
  btnNext.addEventListener('click', function() { scrollTo(Math.min(cards.length - 1, getActive() + 1)); });
  dotsWrap.addEventListener('click', function(e) {
    var d = e.target.closest('.pr-dot');
    if (d) scrollTo(parseInt(d.dataset.idx));
  });
  track.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update, { passive: true });

  buildDots();
  update();
})();
</script>

