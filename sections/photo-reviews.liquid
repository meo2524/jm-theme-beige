{% comment %} photo-reviews.liquid — Photo-driven social proof carousel {% endcomment %}

{%- liquid
  assign eyebrow    = section.settings.eyebrow    | default: 'Verified buyers'
  assign heading    = section.settings.heading    | default: 'Real people. Real results.'
  assign subheading = section.settings.subheading | default: 'Join thousands of people who track their health from their finger.'
-%}

<section class="pr-wrap" data-section-id="{{ section.id }}">
  <div class="pr-inner">

    <header class="pr-head">
      <div class="pr-head__rule" aria-hidden="true"></div>
      <p class="pr-head__eyebrow">{{ eyebrow }}</p>
      <h2 class="pr-head__heading">{{ heading }}</h2>
      <p class="pr-head__sub">{{ subheading }}</p>
    </header>

    <!-- Gender filter toggle -->
    <div class="pr-filter" id="pr-filter-{{ section.id }}" role="group" aria-label="Filter reviews by gender">
      <button class="pr-filter__btn is-active" data-filter="all">All</button>
      <button class="pr-filter__btn" data-filter="women">Women</button>
      <button class="pr-filter__btn" data-filter="men">Men</button>
    </div>

    <div class="pr-carousel-wrap">
      <div class="pr-track is-active" id="pr-track-{{ section.id }}">

        <!-- Card 1 — Taylor M. -->
        <article class="pr-card" data-gender="women">
          <div class="pr-card__photo-wrap">
            <img src="{{ 'Woman_1.png' | file_url }}" alt="Taylor M. wearing Mend & Co N°01 Smart Ring" class="pr-card__photo" loading="lazy" width="600" height="750"/>
          </div>
          <div class="pr-card__body">
            <div class="pr-stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="pr-card__title">Looks good enough to never take off.</p>
            <p class="pr-card__text">I've tried bulky trackers before — always ended up in my drawer. This one goes with everything. The sleep data is genuinely useful too. Two weeks in and I've already adjusted my whole evening routine.</p>
            <footer class="pr-card__footer">
              <div class="pr-card__meta">
                <span class="pr-card__name">Taylor M.</span>
                <span class="pr-verified">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="6" fill="#5a8a60"/><polyline points="3.5,6 5.2,7.8 8.5,4.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified Purchase
                </span>
              </div>
              <span class="pr-card__date">April 28, 2026</span>
            </footer>
          </div>
        </article>

