{% comment %} photo-reviews.liquid — Photo-driven social proof carousel {% endcomment %}

{%- liquid
  assign eyebrow    = section.settings.eyebrow    | default: 'Verified Menders'
  assign heading    = section.settings.heading    | default: 'Real people. Real results.'
  assign subheading = section.settings.subheading | default: 'Join thousands of Menders who track their health from their finger.'
-%}

<section class="pr-wrap" data-section-id="{{ section.id }}">
  <div class="pr-inner">

    <header class="pr-head">
      <div class="pr-head__rule" aria-hidden="true"></div>
      <p class="pr-head__eyebrow">{{ eyebrow }}</p>
      <h2 class="pr-head__heading">{{ heading }}</h2>
      <p class="pr-head__sub">{{ subheading }}</p>
    </header>

    <!-- Tabs: women / men -->
    <div class="pr-tabs" role="tablist" aria-label="Filter reviews">
      <button class="pr-tab is-active" type="button" role="tab" aria-selected="true" data-set="women">Women</button>
      <button class="pr-tab" type="button" role="tab" aria-selected="false" data-set="men">Men</button>
    </div>

    <div class="pr-carousel-wrap">
      <div class="pr-track is-active" id="pr-track-women-{{ section.id }}" data-set="women" role="tabpanel">

        <!-- Card 1 — Keisha M. -->
        <article class="pr-card">
          <div class="pr-card__photo-wrap">
            <img src="{{ 'Social_Proof_1.png' | file_url }}" alt="Keisha M. wearing Marrow Ring N°01" class="pr-card__photo" loading="lazy" width="600" height="750"/>
          </div>
          <div class="pr-card__body">
            <div class="pr-stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="pr-card__title">I didn't believe it until I tested it myself.</p>
            <p class="pr-card__text">Was skeptical honestly. But noticed my deep sleep was getting cut in half on nights I had wine. Tested it a few times. Yep. Changed that habit fast.</p>
            <footer class="pr-card__footer">
              <div class="pr-card__meta">
                <span class="pr-card__name">Keisha M.</span>
                <span class="pr-verified">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="6" fill="#5a8a60"/><polyline points="3.5,6 5.2,7.8 8.5,4.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified Purchase
                </span>
              </div>
              <span class="pr-card__date">January 14, 2026</span>
            </footer>
          </div>
        </article>

        <!-- Card 2 — Sarah T. -->
        <article class="pr-card">
          <div class="pr-card__photo-wrap">
