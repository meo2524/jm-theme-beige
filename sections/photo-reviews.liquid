{% comment %} photo-reviews.liquid — Photo-driven social proof carousel {% endcomment %}

{%- liquid
  assign eyebrow    = section.settings.eyebrow    | default: 'Verified Menders'
  assign heading    = section.settings.heading    | default: 'Real people. Real results.'
  assign subheading = section.settings.subheading | default: 'Join thousands of Menders who track their health from their finger.'
-%}

<section class="pr-wrap" data-section-id="{{ section.id }}">
  <div class="pr-inner">

    <header class="pr-head">
      <div class="pr-head__rule" aria-hidden="true"></div>
      <p class="pr-head__eyebrow">{{ eyebrow }}</p>
      <h2 class="pr-head__heading">{{ heading }}</h2>
      <p class="pr-head__sub">{{ subheading }}</p>
    </header>

    <div class="pr-carousel-wrap">
      <div class="pr-track" id="pr-track-{{ section.id }}">

        <!-- Card 1 — Keisha M. -->
        <article class="pr-card">
          <div class="pr-card__photo-wrap">
            <img src="{{ 'Social_Proof_1.png' | file_url }}" alt="Keisha M. wearing Marrow Ring N°01" class="pr-card__photo" loading="lazy" width="600" height="750"/>
          </div>
          <div class="pr-card__body">
            <div class="pr-stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="pr-card__title">I didn't believe it until I tested it myself.</p>
            <p class="pr-card__text">Was skeptical honestly. But after about 10 days I noticed my deep sleep was getting cut almost in half on nights I had a glass of wine. Didn't believe it so I tested it a few times. Yep. Changed that habit pretty fast. Sleep has been completely different since.</p>
            <footer class="pr-card__footer">
              <div class="pr-card__meta">
                <span class="pr-card__name">Keisha M.</span>
                <span class="pr-verified">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="6" fill="#5a8a60"/><polyline points="3.5,6 5.2,7.8 8.5,4.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified Purchase
                </span>
              </div>
              <span class="pr-card__date">January 14, 2026</span>
            </footer>
          </div>
        </article>

        <!-- Card 2 — Sarah T. -->
        <article class="pr-card">
          <div class="pr-card__photo-wrap">
            <img src="{{ 'Social_Proof_2.png' | file_url }}" alt="Sarah T. wearing Marrow Ring N°01" class="pr-card__photo" loading="lazy" width="600" height="750"/>
          </div>
          <div class="pr-card__body">
            <div class="pr-stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="pr-card__title">I check this before I check my phone now.</p>
            <p class="pr-card__text">Which is saying something lol. Had a week where I kept pushing through workouts feeling off and the scores were red every single day. Finally took a rest day and felt completely different the next morning. Wish I'd just listened sooner honestly.</p>
            <footer class="pr-card__footer">
              <div class="pr-card__meta">
                <span class="pr-card__name">Sarah T.</span>
                <span class="pr-verified">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="6" fill="#5a8a60"/><polyline points="3.5,6 5.2,7.8 8.5,4.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified Purchase
                </span>
              </div>
              <span class="pr-card__date">February 3, 2026</span>
            </footer>
          </div>
        </article>

        <!-- Card 3 — Kayla R. -->
        <article class="pr-card">
          <div class="pr-card__photo-wrap">
            <img src="{{ 'Social_Proof_3.png' | file_url }}" alt="Kayla R. wearing Marrow Ring N°01" class="pr-card__photo" loading="lazy" width="600" height="750"/>
          </div>
          <div class="pr-card__body">
            <div class="pr-stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="pr-card__title">3 trackers in 2 years. This is the one I kept.</p>
            <p class="pr-card__text">Either the data was off, battery died mid-week, or it just looked wrong on my hand. This one I actually forget I'm wearing. My HRV was terrible for two weeks straight and turns out I had a cold coming. Caught it before it actually hit.</p>
            <footer class="pr-card__footer">
              <div class="pr-card__meta">
                <span class="pr-card__name">Kayla R.</span>
                <span class="pr-verified">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="6" fill="#5a8a60"/><polyline points="3.5,6 5.2,7.8 8.5,4.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified Purchase
                </span>
              </div>
              <span class="pr-card__date">March 11, 2026</span>
            </footer>
          </div>
        </article>

        <!-- Card 4 — Jessica H. -->
        <article class="pr-card">
          <div class="pr-card__photo-wrap">
            <img src="{{ 'Social_Proof_4.png' | file_url }}" alt="Jessica H. wearing Marrow Ring N°01" class="pr-card__photo" loading="lazy" width="600" height="750"/>
          </div>
          <div class="pr-card__body">
            <div class="pr-stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="pr-card__title">My husband got one after watching me for a month.</p>
            <p class="pr-card__text">Got it for sleep, ended up caring about everything else too. My resting heart rate has dropped since I started actually paying attention to the data — not sure if it's coincidence but I'm choosing to believe it's not. He was making fun of me at first. Now he checks his every morning too.</p>
            <footer class="pr-card__footer">
              <div class="pr-card__meta">
                <span class="pr-card__name">Jessica H.</span>
                <span class="pr-verified">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="6" fill="#5a8a60"/><polyline points="3.5,6 5.2,7.8 8.5,4.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified Purchase
                </span>
              </div>
              <span class="pr-card__date">January 22, 2026</span>
            </footer>
          </div>
        </article>

        <!-- Card 5 — Amanda W. -->
        <article class="pr-card">
          <div class="pr-card__photo-wrap">
            <img src="{{ 'Social_Proof_5.png' | file_url }}" alt="Amanda W. wearing Marrow Ring N°01" class="pr-card__photo" loading="lazy" width="600" height="750"/>
          </div>
          <div class="pr-card__body">
            <div class="pr-stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="pr-card__title">The battery life is what actually got me.</p>
            <p class="pr-card__text">Had an Oura for a year and was always running out right before a trip or something. This genuinely lasts the whole week. I charge it Sunday morning while I have coffee and that's it. Small thing but it's the reason I actually wear it every day instead of it sitting on my nightstand.</p>
            <footer class="pr-card__footer">
              <div class="pr-card__meta">
                <span class="pr-card__name">Amanda W.</span>
                <span class="pr-verified">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="6" fill="#5a8a60"/><polyline points="3.5,6 5.2,7.8 8.5,4.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified Purchase
                </span>
              </div>
              <span class="pr-card__date">February 17, 2026</span>
            </footer>
          </div>
        </article>

        <!-- Card 6 — Mei L. -->
        <article class="pr-card">
          <div class="pr-card__photo-wrap">
            <img src="{{ 'Social_Proof_6.png' | file_url }}" alt="Mei L. wearing Marrow Ring N°01" class="pr-card__photo" loading="lazy" width="600" height="750"/>
          </div>
          <div class="pr-card__body">
            <div class="pr-stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="pr-card__title">When you're up every 2 hours you lose track completely.</p>
            <p class="pr-card__text">Got it while I was still pregnant thinking it'd help with sleep. Had no idea how much I'd need it after. Having the actual number — even when it was terrible — made me feel less crazy. My OB asked me to bring the data in at my 6 week checkup. That felt validating.</p>
            <footer class="pr-card__footer">
              <div class="pr-card__meta">
                <span class="pr-card__name">Mei L.</span>
                <span class="pr-verified">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="6" fill="#5a8a60"/><polyline points="3.5,6 5.2,7.8 8.5,4.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified Purchase
                </span>
              </div>
              <span class="pr-card__date">April 19, 2026</span>
            </footer>
          </div>
        </article>

      </div>

      <!-- Nav buttons -->
      <button class="pr-btn pr-btn--prev" id="pr-prev-{{ section.id }}" aria-label="Previous review">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="pr-btn pr-btn--next" id="pr-next-{{ section.id }}" aria-label="Next review">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><polyline points="9 6 15 12 9 18"/></svg>
      </button>
    </div>

    <!-- Dots -->
    <div class="pr-dots" id="pr-dots-{{ section.id }}" aria-label="Review navigation"></div>

  </div>
</section>

<style>
.pr-wrap {
  background: var(--color-bone, #f5efe6);
  padding: 5rem 0 4rem;
  overflow: hidden;
}
.pr-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding-inline: clamp(1rem, 4vw, 2rem);
}

/* Header */
.pr-head { margin-bottom: 2.5rem; max-width: 560px; }
.pr-head__rule {
  width: 40px; height: 1.5px;
  background: var(--color-walnut, #8a6240);
  opacity: 0.6; margin-bottom: 1.25rem;
}
.pr-head__eyebrow {
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.6875rem; font-weight: 600;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--color-walnut, #8a6240); margin: 0 0 0.75rem;
}
.pr-head__heading {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  font-weight: 400; color: var(--color-black, #1f1d1a);
  line-height: 1.15; margin: 0 0 0.75rem;
}
.pr-head__sub {
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.9375rem; color: var(--color-olive, #5a4a3a);
  opacity: 0.8; margin: 0;
}

/* Carousel wrapper */
.pr-carousel-wrap {
  position: relative;
}

/* Track — scroll-snap on mobile */
.pr-track {
  display: flex;
  gap: 1.25rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 4px;
  /* peek: show ~10% of next card */
  scroll-padding-inline: clamp(1rem, 4vw, 2rem);
}
.pr-track::-webkit-scrollbar { display: none; }

/* Cards */
.pr-card {
  flex: 0 0 calc(85vw - 2rem); /* mobile: 1 card + peek */
  max-width: 340px;
  scroll-snap-align: start;
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid rgba(43,43,43,0.07);
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.22s ease;
}
.pr-card:hover { box-shadow: 0 10px 28px rgba(31,29,26,0.09); }

@media (min-width: 600px) {
  .pr-card { flex: 0 0 calc(50% - 0.75rem); max-width: 400px; }
}
@media (min-width: 1024px) {
  .pr-card { flex: 0 0 calc(33.333% - 0.875rem); max-width: none; }
}

/* Photo */
.pr-card__photo-wrap {
  width: 100%; aspect-ratio: 4 / 5;
  overflow: hidden; background: #e8e1d9;
}
.pr-card__photo {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
  display: block;
  transition: transform 0.5s ease;
}
.pr-card:hover .pr-card__photo { transform: scale(1.03); }

/* Body */
.pr-card__body {
  padding: 1.375rem 1.375rem 1.125rem;
  display: flex; flex-direction: column; gap: 0.6rem; flex: 1;
}
.pr-stars {
  color: var(--color-walnut, #8a6240);
  font-size: 12px; letter-spacing: 2px; line-height: 1;
}
.pr-card__title {
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.9375rem; font-weight: 700;
  color: var(--color-black, #1f1d1a); line-height: 1.3; margin: 0;
}
.pr-card__text {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-size: 1.0625rem; font-style: italic; font-weight: 400;
  line-height: 1.65; color: var(--color-black, #1f1d1a); margin: 0; flex: 1;
}
.pr-card__footer {
  display: flex; align-items: flex-end; justify-content: space-between;
  gap: 0.5rem; padding-top: 0.875rem;
  border-top: 1px solid rgba(43,43,43,0.08); flex-wrap: wrap; margin-top: auto;
}
.pr-card__meta { display: flex; flex-direction: column; gap: 0.3rem; }
.pr-card__name {
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.8125rem; font-weight: 700; color: var(--color-black, #1f1d1a);
}
.pr-verified {
  display: inline-flex; align-items: center; gap: 0.3rem;
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.6875rem; font-weight: 500; color: #5a8a60; letter-spacing: 0.02em;
}
.pr-card__date {
  font-family: var(--font-label, 'Inter', sans-serif);
  font-size: 0.6875rem; color: var(--color-olive, #5a4a3a);
  opacity: 0.5; text-align: right;
}

/* Nav buttons */
.pr-btn {
  display: none; /* JS shows these */
  position: absolute; top: 40%;
  transform: translateY(-50%);
  width: 42px; height: 42px; border-radius: 50%;
  border: 1.5px solid rgba(138,98,64,0.3);
  background: rgba(245,239,230,0.92);
  backdrop-filter: blur(4px);
  cursor: pointer;
  align-items: center; justify-content: center;
  color: var(--color-walnut, #8a6240);
  transition: background 0.18s, border-color 0.18s, opacity 0.18s;
  z-index: 2;
}
.pr-btn:hover { background: rgba(138,98,64,0.12); border-color: var(--color-walnut, #8a6240); }
.pr-btn:disabled { opacity: 0.2; pointer-events: none; }
.pr-btn--prev { left: -16px; }
.pr-btn--next { right: -16px; }

@media (min-width: 768px) {
  .pr-btn { display: flex; }
}

/* Dots */
.pr-dots {
  display: flex; justify-content: center; gap: 7px;
  margin-top: 1.75rem;
}
.pr-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: rgba(138,98,64,0.22);
  border: none; padding: 0; cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.pr-dot.is-active {
  background: var(--color-walnut, #8a6240);
  transform: scale(1.35);
}

@media (max-width: 599px) {
  .pr-wrap { padding: 3rem 0 3rem; }
  .pr-card__body { padding: 1.125rem 1.125rem 1rem; }
}
@media (prefers-reduced-motion: reduce) {
  .pr-card__photo { transition: none; }
}
</style>

<script>
(function() {
  var section  = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;

  var track    = document.getElementById('pr-track-{{ section.id }}');
  var dotsWrap = document.getElementById('pr-dots-{{ section.id }}');
  var btnPrev  = document.getElementById('pr-prev-{{ section.id }}');
  var btnNext  = document.getElementById('pr-next-{{ section.id }}');
  var cards    = Array.from(track.querySelectorAll('.pr-card'));
  var total    = cards.length;

  /* Build dots */
  cards.forEach(function(_, i) {
    var d = document.createElement('button');
    d.className = 'pr-dot' + (i === 0 ? ' is-active' : '');
    d.setAttribute('aria-label', 'Review ' + (i + 1));
    d.dataset.idx = i;
    dotsWrap.appendChild(d);
  });
  var dots = Array.from(dotsWrap.querySelectorAll('.pr-dot'));

  function getVisible() {
    var w = track.clientWidth;
    var cw = cards[0] ? cards[0].offsetWidth + 20 : w; /* card + gap */
    return Math.max(1, Math.round(w / cw));
  }

  function scrollTo(idx) {
    var card = cards[idx];
    if (!card) return;
    track.scrollTo({ left: card.offsetLeft - track.offsetLeft, behavior: 'smooth' });
  }

  function getActive() {
    var scrollLeft = track.scrollLeft;
    var best = 0, bestDist = Infinity;
    cards.forEach(function(c, i) {
      var dist = Math.abs(c.offsetLeft - track.offsetLeft - scrollLeft);
      if (dist < bestDist) { bestDist = dist; best = i; }
    });
    return best;
  }

  function update() {
    var active = getActive();
    var vis    = getVisible();
    dots.forEach(function(d, i) { d.classList.toggle('is-active', i === active); });
    btnPrev.disabled = active === 0;
    btnNext.disabled = active >= total - 1;
  }

  btnPrev.addEventListener('click', function() { scrollTo(Math.max(0, getActive() - 1)); });
  btnNext.addEventListener('click', function() { scrollTo(Math.min(total - 1, getActive() + 1)); });

  dotsWrap.addEventListener('click', function(e) {
    var d = e.target.closest('.pr-dot');
    if (d) scrollTo(parseInt(d.dataset.idx));
  });

  track.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update, { passive: true });

  update();
})();
</script>

{% schema %}
{
  "name": "Photo reviews",
  "tag": "section",
  "class": "section-photo-reviews",
  "settings": [
    { "type": "text", "id": "eyebrow",    "label": "Eyebrow",    "default": "Verified Menders" },
    { "type": "text", "id": "heading",    "label": "Heading",    "default": "Real people. Real results." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Join thousands of Menders who track their health from their finger." }
  ],
  "presets": [{ "name": "Photo reviews" }]
}
{% endschema %}
