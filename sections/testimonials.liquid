<!-- testimonials.liquid - Mend & Co -->

{%- liquid
  assign eyebrow       = section.settings.eyebrow | default: 'Real results'
  assign heading       = section.settings.heading | default: 'From people who stopped guessing.'
  assign reviews_count = section.settings.reviews_count | default: 6
-%}

<section class="testimonials" aria-label="Customer reviews" data-section-id="{{ section.id }}">
  <div class="container">

    <div class="testimonials__header">
      <div class="testimonials__rule" aria-hidden="true"></div>
      <p class="testimonials__eyebrow" data-reveal data-reveal-delay="0">{{ eyebrow }}</p>
      <h2 class="testimonials__heading" data-reveal data-reveal-delay="80">{{ heading }}</h2>
    </div>

    <div
      class="testimonials__grid"
      id="TestimonialsGrid-{{ section.id }}"
      data-shop="{{ shop.permanent_domain }}"
      data-count="{{ reviews_count }}"
      role="list"
      aria-live="polite"
      aria-busy="true"
    >
      <div class="testimonials__skeleton" aria-hidden="true">
        <div class="t-skeleton-card"></div>
        <div class="t-skeleton-card"></div>
        <div class="t-skeleton-card"></div>
      </div>
    </div>

  </div>
</section>

<!-- Fallback schema blocks (read by JS if API unavailable) -->
{%- if section.blocks.size > 0 -%}
  <template id="TestimonialsFallback-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- if block.type == 'testimonial' -%}
        {%- assign stars = block.settings.stars | default: 5 -%}
        <blockquote class="t-card" role="listitem" {{ block.shopify_attributes }}>
          <div class="t-stars" aria-label="{{ stars }} out of 5 stars">
            {%- for i in (1..5) -%}
              <span class="t-star{% if i > stars %} t-star--empty{% endif %}" aria-hidden="true">&#9733;</span>
            {%- endfor -%}
          </div>
          <p class="t-card__body">{{ block.settings.quote | escape }}</p>
          <footer class="t-card__footer">
            <div class="t-card__author-wrap">
              <span class="t-card__name">{{ block.settings.author | escape }}</span>
              {%- if block.settings.verified -%}
                <span class="t-card__badge">Verified</span>
              {%- endif -%}
            </div>
            {%- if block.settings.author_detail != blank -%}
              <span class="t-card__date">{{ block.settings.author_detail | escape }}</span>
            {%- endif -%}
          </footer>
        </blockquote>
      {%- endif -%}
    {%- endfor -%}
  </template>
{%- endif -%}

<script>
(function () {
  var grid = document.getElementById('TestimonialsGrid-{{ section.id }}');
  if (!grid) return;

  var shop  = grid.dataset.shop;
  var count = parseInt(grid.dataset.count, 10) || 6;

  function esc(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function stars(rating) {
    var s = '<div class="t-stars" aria-label="' + rating + ' out of 5 stars">';
    for (var i = 1; i <= 5; i++) {
      s += '<span class="t-star' + (i > rating ? ' t-star--empty' : '') + '" aria-hidden="true">&#9733;</span>';
    }
    return s + '</div>';
  }

  function formatDate(str) {
    try {
      return new Date(str).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch (e) { return ''; }
  }

  function buildCard(r) {
    var name     = (r.reviewer && r.reviewer.name) ? esc(r.reviewer.name) : 'Verified customer';
    var verified = r.reviewer && r.reviewer.verified_buyer;
    var title    = r.title ? esc(r.title) : '';
    var body     = r.body  ? esc(r.body)  : '';
    var date     = r.created_at ? formatDate(r.created_at) : '';

    return '<blockquote class="t-card" role="listitem">'
      + stars(r.rating || 5)
      + (title ? '<p class="t-card__title">' + title + '</p>' : '')
      + '<p class="t-card__body">' + body + '</p>'
      + '<footer class="t-card__footer">'
      +   '<div class="t-card__author-wrap">'
      +     '<span class="t-card__name">' + name + '</span>'
      +     (verified ? '<span class="t-card__badge">Verified</span>' : '')
      +   '</div>'
      +   (date ? '<time class="t-card__date">' + date + '</time>' : '')
      + '</footer>'
      + '</blockquote>';
  }

  function render(reviews) {
    grid.setAttribute('aria-busy', 'false');
    if (!reviews || !reviews.length) { fallback(); return; }
    grid.innerHTML = reviews.slice(0, count).map(buildCard).join('');
  }

  function fallback() {
    grid.setAttribute('aria-busy', 'false');
    var tpl = document.getElementById('TestimonialsFallback-{{ section.id }}');
    if (tpl && tpl.content && tpl.content.children.length) {
      var clone = document.importNode(tpl.content, true);
      grid.innerHTML = '';
      grid.appendChild(clone);
    } else {
      grid.closest('.testimonials').style.display = 'none';
    }
  }

  fetch('/a/judgeme/reviews?shop_domain=' + encodeURIComponent(shop) + '&per_page=' + count + '&page=1')
    .then(function (res) { if (!res.ok) throw new Error(); return res.json(); })
    .then(function (data) { render(data && data.reviews); })
    .catch(fallback);
})();
</script>

<style>
/* ---- Section shell ---- */
.testimonials {
  background-color: var(--cream-2);
  padding: 6rem 0 7rem;
}

/* ---- Header ---- */
.testimonials__rule {
  width: 40px;
  height: 1.5px;
  background-color: var(--color-cta);
  opacity: 0.7;
  margin-bottom: 1.25rem;
}
.testimonials__eyebrow {
  font-family: var(--font-body);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold-light);
  margin-bottom: 0.875rem;
}
.testimonials__heading {
  font-family: var(--font-body);
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  font-weight: 900;
  color: var(--char);
  max-width: 26ch;
  line-height: 1.2;
  margin-bottom: 3.5rem;
}

/* ---- Grid ---- */
.testimonials__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
}

/* ---- Cards ---- */
.t-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 2.25rem 2rem;
  background-color: var(--cream-3);
  border: 1px solid rgba(107, 63, 160, 0.25);
  border-radius: 3px;
  margin: 0;
  quotes: none;
  transition: background-color 0.2s ease, border-color 0.2s ease;
}
.t-card:hover {
  background-color: var(--gold-deep);
  border-color: rgba(124, 58, 237, 0.45);
  color: var(--color-text-on-dark);
}

/* ---- Stars ---- */
.t-stars {
  display: flex;
  gap: 3px;
}
.t-star {
  font-size: 13px;
  color: var(--color-cta-hover);
  line-height: 1;
}
.t-star--empty {
  opacity: 0.2;
}

/* ---- Hover text overrides (card bg flips dark) ---- */
.t-card:hover .t-card__title,
.t-card:hover .t-card__name,
.t-card:hover .t-card__badge { color: var(--color-text-on-dark); }
.t-card:hover .t-card__body  { color: rgba(255,255,255,0.85); }
.t-card:hover .t-card__date  { color: rgba(255,255,255,0.55); }

/* ---- Text ---- */
.t-card__title {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--char);
  line-height: 1.4;
}
.t-card__body {
  font-family: var(--font-body);
  font-size: 1rem;
  font-style: italic;
  font-weight: 400;
  line-height: 1.65;
  color: var(--char-soft);
  flex: 1;
}

/* ---- Footer ---- */
.t-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(107, 63, 160, 0.2);
  flex-wrap: wrap;
}
.t-card__author-wrap {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.t-card__name {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--char);
  font-style: normal;
}
.t-card__badge {
  font-family: var(--font-body);
  font-size: 0.5625rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  background-color: rgba(107, 63, 160, 0.6);
  color: var(--char);
  padding: 2px 6px;
  border-radius: 2px;
}
.t-card__date {
  font-family: var(--font-body);
  font-size: 0.75rem;
  color: var(--char-soft);
  opacity: 0.6;
  white-space: nowrap;
}

/* ---- Loading skeleton ---- */
.testimonials__skeleton {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  width: 100%;
  grid-column: 1 / -1;
}
.t-skeleton-card {
  height: 220px;
  background: linear-gradient(
    90deg,
    rgba(107, 63, 160, 0.04) 0%,
    rgba(107, 63, 160, 0.10) 50%,
    rgba(107, 63, 160, 0.04) 100%
  );
  background-size: 200% 100%;
  animation: shimmer 1.6s infinite;
  border-radius: 3px;
  border: 1px solid rgba(107, 63, 160, 0.1);
}
@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ---- Responsive ---- */
@media (max-width: 1023px) {
  .testimonials__grid,
  .testimonials__skeleton { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 767px) {
  .testimonials { padding: 48px 0 48px; }
}
@media (max-width: 599px) {
  .testimonials__grid,
  .testimonials__skeleton { grid-template-columns: 1fr; }
  .t-card { padding: 1.75rem 1.5rem; }
}
@media (prefers-reduced-motion: reduce) {
  .t-skeleton-card { animation: none; }
  .t-card { transition: none; }
}
</style>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Real results"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "From people who stopped guessing."
    },
    {
      "type": "range",
      "id": "reviews_count",
      "label": "Number of reviews to show",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial (fallback)",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "I sleep better than I have in years. The ring shows me exactly why."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "author_detail",
          "label": "Detail (age, location, etc.)",
          "default": "Verified customer"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}
