{%- liquid
  assign eyebrow = section.settings.eyebrow | default: 'Results'
  assign heading = section.settings.heading | default: 'From people who stopped guessing.'
-%}

<section class="testimonials section--lg" aria-label="Customer testimonials">
  <div class="testimonials__inner container">

    <!-- Header -->
    <div class="testimonials__header">
      <span class="rule-above" style="background-color: var(--color-amber); opacity: 0.5;" aria-hidden="true"></span>
      <p class="testimonials__eyebrow t-label">{{ eyebrow }}</p>
      <h2 class="testimonials__heading t-display-md t-on-dark">{{ heading }}</h2>
    </div>

    <!-- Testimonials -->
    {%- if section.blocks.size > 0 -%}
      <div class="testimonials__grid" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
            <blockquote
              class="testimonials__item"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              <!-- Stars -->
              {%- assign stars = block.settings.stars | default: 5 -%}
              <div class="testimonials__stars" aria-label="{{ stars }} out of 5 stars">
                {%- for i in (1..5) -%}
                  <span class="testimonials__star{% if i > stars %} testimonials__star--empty{% endif %}" aria-hidden="true">★</span>
                {%- endfor -%}
              </div>

              <!-- Quote -->
              <p class="testimonials__quote">&ldquo;{{ block.settings.quote }}&rdquo;</p>

              <!-- Author -->
              <footer class="testimonials__author">
                {%- if block.settings.author_image != blank -%}
                  <img
                    src="{{ block.settings.author_image | image_url: width: 48 }}"
                    width="48"
                    height="48"
                    alt="{{ block.settings.author | escape }}"
                    loading="lazy"
                    class="testimonials__author-img"
                  >
                {%- endif -%}
                <div>
                  <cite class="testimonials__author-name">{{ block.settings.author }}</cite>
                  {%- if block.settings.author_detail != blank -%}
                    <p class="testimonials__author-detail">{{ block.settings.author_detail }}</p>
                  {%- endif -%}
                </div>
              </footer>

            </blockquote>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <!-- Default placeholder quotes -->
      <div class="testimonials__grid" role="list">
        {%- assign default_quotes = "My skin stopped breaking out two weeks after installing it. I'd spent $300 on new products thinking it was my routine.,My hair stopped being brittle after a month. The difference was faster than I expected.,I was sceptical, but my dermatologist actually recommended filtering shower water. Wish I'd done this earlier." | split: ',' -%}
        {%- assign default_authors = "Sarah M., 34,James K., 29,Priya D., 41" | split: ',' -%}
        {%- for quote in default_quotes -%}
          {%- assign ai = forloop.index0 | times: 2 -%}
          <blockquote class="testimonials__item" role="listitem">
            <div class="testimonials__stars" aria-label="5 out of 5 stars">
              {%- for i in (1..5) -%}<span class="testimonials__star" aria-hidden="true">★</span>{%- endfor -%}
            </div>
            <p class="testimonials__quote">&ldquo;{{ quote }}&rdquo;</p>
            <footer class="testimonials__author">
              <cite class="testimonials__author-name">{{ default_authors[ai] }}</cite>
              <p class="testimonials__author-detail">{{ default_authors[ai | plus: 1] }}</p>
            </footer>
          </blockquote>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .testimonials {
    background-color: var(--color-espresso);
    padding-block: var(--space-24);
  }

  .testimonials__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  /* ---- Header ---- */
  .testimonials__eyebrow {
    color: var(--color-amber);
    margin-bottom: var(--space-4);
  }

  .testimonials__heading {
    max-width: 22ch;
    color: var(--color-gold);
  }

  /* ---- Grid ---- */
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-1);
  }

  /* ---- Item ---- */
  .testimonials__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-8);
    background-color: rgba(232, 201, 154, 0.04);
    border: 1px solid rgba(232, 201, 154, 0.08);
    border-radius: var(--radius-base);
    quotes: none;
    margin: 0;
    transition: background-color var(--transition-base),
                border-color var(--transition-base);
  }

  .testimonials__item:hover {
    background-color: rgba(232, 201, 154, 0.07);
    border-color: rgba(200, 135, 74, 0.2);
  }

  /* ---- Stars ---- */
  .testimonials__stars {
    display: flex;
    gap: 2px;
  }

  .testimonials__star {
    font-size: 14px;
    color: var(--color-amber);
    line-height: 1;
  }

  .testimonials__star--empty {
    opacity: 0.2;
  }

  /* ---- Quote ---- */
  .testimonials__quote {
    font-family: var(--font-heading);
    font-size: var(--font-size-md);
    font-weight: 400;
    font-style: italic;
    line-height: 1.55;
    color: var(--color-gold);
    flex: 1;
    max-width: none;
  }

  /* ---- Author ---- */
  .testimonials__author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-5);
    border-top: 1px solid rgba(232, 201, 154, 0.1);
  }

  .testimonials__author-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .testimonials__author-name {
    display: block;
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    font-style: normal;
    font-weight: 500;
    color: var(--color-gold);
  }

  .testimonials__author-detail {
    font-size: var(--font-size-xs);
    color: var(--color-gold);
    opacity: 0.45;
    margin-top: 2px;
    max-width: none;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1023px) {
    .testimonials__grid {
      grid-template-columns: 1fr 1fr;
    }

    .testimonials__item:last-child {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 767px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }

    .testimonials__item:last-child {
      grid-column: auto;
    }
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Results"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "From people who stopped guessing."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "My skin stopped breaking out two weeks after installing it."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "author_detail",
          "label": "Author detail (age, location, etc.)",
          "default": "Verified customer"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author photo (optional)"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}
