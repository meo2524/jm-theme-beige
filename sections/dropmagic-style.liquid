  /* Radius */
  --radius: 8px;

  /* Family */
  --title-family: Montserrat;
  --content-family: Inter;

  /* Text transform */
  --title-transform: none;

  /* Font size */
  --title-size: 40px;
  --content-size: 16px;


  /*  Line height */
  --title-line-height: 105%;
  --content-line-height: 150%;
 
  /* Letter spacing */
  --title-letter-spacing: -1px;
  --content-letter-spacing: 0px;
  
  /* Base spacing */
  --spacing: 4px;

  /* Shadow properties */
  --shadow-color: 0 0% 0%;
  --shadow-opacity: 0.1;
  --shadow-blur: 6px;
  --shadow-spread: 0px;
  --shadow-offset-x: 0px;
  --shadow-offset-y: 4px;

}

