{%- comment -%}
  ──────────────────────────────────────────────────────────────────
  sections/ingredient-core.liquid
  Mend & Co — Ingredient Core (scroll-story panel 2 of 3)

  Charcoal panel. Pure-CSS glass "orbs" (no images), gentle float,
  numbered actives that stagger-reveal on scroll. Zigzag layout on
  desktop, stacked on mobile. Reuses base.css §16 reveal + motion.js.

  Float lives on the inner .ic__orb so it never collides with the
  reveal transform on the outer .ic__row.
  ──────────────────────────────────────────────────────────────────
{%- endcomment -%}

{%- liquid
  assign eyebrow = section.settings.eyebrow | default: 'The repair core'
  assign heading = section.settings.heading | default: 'The science salons call hair botox.'
  assign lede    = section.settings.lede
  assign bg      = section.settings.bg_color | default: '#1f1d1a'
  assign accent  = section.settings.accent_color | default: '#c9a36b'
-%}

<section class="ic" style="--ic-bg: {{ bg }}; --ic-accent: {{ accent }};">
  <div class="ic__inner">

    <div class="ic__head">
      {%- if eyebrow != blank -%}
        <p class="ic__eyebrow" data-reveal data-reveal-delay="0">{{ eyebrow }}</p>
      {%- endif -%}
      <h2 class="ic__heading" data-word-reveal>{{ heading }}</h2>
      {%- if lede != blank -%}
        <p class="ic__lede" data-reveal data-reveal-delay="120">{{ lede }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="ic__rows">
        {%- for block in section.blocks -%}
          {%- assign num = forloop.index | prepend: '0' | slice: -2, 2 -%}
          {%- assign delay = forloop.index0 | times: 80 -%}
          <div class="ic__row" data-reveal data-reveal-delay="{{ delay }}" {{ block.shopify_attributes }}>
            <div class="ic__orbwrap">
              <div class="ic__orb">
                <span class="ic__orb-num">{{ num }}</span>
              </div>
            </div>
            <div class="ic__text">
              <span class="ic__rownum">{{ num }}</span>
              {%- if block.settings.name != blank -%}
                <h3 class="ic__name">{{ block.settings.name }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="ic__desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .ic {
    background: var(--ic-bg, #1f1d1a);
    padding: clamp(4.5rem, 10vw, 8rem) 0;
    overflow: hidden;
    position: relative;
  }
  .ic__inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .ic__head { text-align: center; max-width: 30ch; margin: 0 auto clamp(3rem, 7vw, 5rem); }
  .ic__eyebrow {
    font-family: var(--font-body, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 3.5px;
    text-transform: uppercase;
    color: var(--ic-accent, #c9a36b);
    margin: 0 0 1rem;
  }
  .ic__heading {
    font-family: var(--font-heading, 'JetBrains Mono', monospace);
    font-size: clamp(1.75rem, 3.6vw, 2.75rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #f8f3ea;
    margin: 0 auto;
  }
  .ic__lede {
    font-family: var(--font-body, 'JetBrains Mono', monospace);
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(248, 243, 234, 0.62);
    margin: 1.25rem auto 0;
    max-width: 46ch;
  }

  .ic__rows { display: flex; flex-direction: column; gap: clamp(2.5rem, 6vw, 4.5rem); }
  .ic__row {
    display: grid;
    grid-template-columns: minmax(140px, 240px) 1fr;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 4rem);
  }
  /* zigzag: even rows put the orb on the right */
  .ic__row:nth-child(even) { grid-template-columns: 1fr minmax(140px, 240px); }
  .ic__row:nth-child(even) .ic__orbwrap { order: 2; }
  .ic__row:nth-child(even) .ic__text { order: 1; text-align: right; }
  .ic__row:nth-child(even) .ic__desc { margin-left: auto; }

  /* ── CSS-art glass orb ─────────────────────────────────── */
  .ic__orbwrap {
    display: flex;
    justify-content: center;
    aspect-ratio: 1;
    width: 100%;
    max-width: 240px;
    margin: 0 auto;
  }
  .ic__orb {
    position: relative;
    width: 78%;
    aspect-ratio: 1;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(38% 34% at 32% 26%, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0) 40%),
      radial-gradient(120% 120% at 70% 80%, rgba(138, 98, 64, 0.55) 0%, rgba(31, 29, 26, 0) 60%),
      radial-gradient(100% 100% at 50% 50%, rgba(201, 163, 107, 0.30) 0%, rgba(60, 50, 40, 0.55) 70%, rgba(20, 18, 16, 0.85) 100%);
    box-shadow:
      inset 0 2px 12px rgba(255, 255, 255, 0.25),
      inset 0 -16px 36px rgba(0, 0, 0, 0.55),
      0 0 60px -10px var(--ic-accent, #c9a36b),
      0 30px 50px -24px rgba(0, 0, 0, 0.8);
    border: 1px solid rgba(201, 163, 107, 0.35);
    animation: ic-float 7s ease-in-out infinite;
    will-change: transform;
  }
  .ic__row:nth-child(2) .ic__orb { animation-duration: 8.5s; animation-delay: -1.5s; }
  .ic__row:nth-child(3) .ic__orb { animation-duration: 9.5s; animation-delay: -3s; }
  .ic__orb-num {
    font-family: var(--font-heading, 'JetBrains Mono', monospace);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    color: #f8f3ea;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
    letter-spacing: 0.02em;
  }
  @keyframes ic-float {
    0%, 100% { transform: translateY(-6px); }
    50%      { transform: translateY(6px); }
  }

  .ic__text { min-width: 0; }
  .ic__rownum {
    font-family: var(--font-body, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--ic-accent, #c9a36b);
    display: block;
    margin-bottom: 0.6rem;
  }
  .ic__name {
    font-family: var(--font-heading, 'JetBrains Mono', monospace);
    font-size: clamp(1.1rem, 2.2vw, 1.4rem);
    font-weight: 600;
    color: #f8f3ea;
    margin: 0 0 0.6rem;
  }
  .ic__desc {
    font-family: var(--font-body, 'JetBrains Mono', monospace);
    font-size: 0.875rem;
    line-height: 1.75;
    color: rgba(248, 243, 234, 0.66);
    margin: 0;
    max-width: 42ch;
  }

  @media (max-width: 767px) {
    .ic__inner { padding: 0 1.25rem; }
    .ic__row,
    .ic__row:nth-child(even) { grid-template-columns: 1fr; gap: 1.25rem; text-align: center; }
    .ic__row:nth-child(even) .ic__orbwrap { order: 0; }
    .ic__row:nth-child(even) .ic__text { order: 0; text-align: center; }
    .ic__row:nth-child(even) .ic__desc { margin-left: auto; margin-right: auto; }
    .ic__orbwrap { max-width: 168px; }
    .ic__desc { margin-left: auto; margin-right: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ic__orb { animation: none; }
  }
</style>

{% schema %}
{
  "name": "Ingredient Core",
  "tag": "section",
  "class": "section-ingredient-core",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The repair core" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The science salons call hair botox." },
    { "type": "textarea", "id": "lede", "label": "Intro paragraph", "default": "No needles, no toxins — just a targeted complex that rebuilds damaged hair from the core out." },
    { "type": "header", "content": "Colour" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#1f1d1a" },
    { "type": "color", "id": "accent_color", "label": "Accent / glow", "default": "#c9a36b" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Acetyl Hexapeptide-8" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Strengthens the hair's structure, reducing breakage and split ends." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Ingredient Core",
      "blocks": [
        { "type": "ingredient", "settings": { "name": "Acetyl Hexapeptide-8", "description": "Strengthens the hair's structure, reducing breakage and split ends." } },
        { "type": "ingredient", "settings": { "name": "Hydrolysed Collagen + Keratin", "description": "Fills hair gaps and rebuilds the strand's protein network." } },
        { "type": "ingredient", "settings": { "name": "Biotin", "description": "Boosts hair resilience and nourishes against future damage." } }
      ]
    }
  ]
}
{% endschema %}
