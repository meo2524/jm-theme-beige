{% comment %} QRing App Modal — same rsm shell as ring-size-modal {% endcomment %}

<div id="app-modal" class="rsm-overlay" role="dialog" aria-modal="true" aria-label="The App" hidden>
  <div class="rsm-backdrop"></div>
  <div class="rsm-panel">

    <button class="rsm-close" aria-label="Close app panel">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="rsm-scroll">

      <!-- Header -->
      <div class="rsm-header">
        <p class="rsm-eyebrow">Free · iOS & Android</p>
        <h2 class="rsm-title">The QRing app</h2>
        <p class="rsm-intro">Sync the N°01 to see your sleep, heart, and movement on one clean dashboard. No subscription. Ever.</p>
      </div>

      <!-- Feature cards -->
      <div class="apm-features">

        <div class="apm-feature">
          <div class="apm-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <div class="apm-feature-copy">
            <h3 class="apm-feature-heading">Sleep</h3>
            <p class="apm-feature-body">Deep, light, and REM breakdown every morning. Your sleep score in one number.</p>
          </div>
        </div>

        <div class="apm-feature">
          <div class="apm-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <div class="apm-feature-copy">
            <h3 class="apm-feature-heading">Heart rate</h3>
            <p class="apm-feature-body">Resting heart rate and HRV tracked 24/7. The reads you'd never catch yourself.</p>
          </div>
        </div>

        <div class="apm-feature">
          <div class="apm-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <div class="apm-feature-copy">
            <h3 class="apm-feature-heading">Activity</h3>
            <p class="apm-feature-body">Steps, distance, and automatic workout detection. The small movement that adds up.</p>
          </div>
        </div>

        <div class="apm-feature">
          <div class="apm-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div class="apm-feature-copy">
            <h3 class="apm-feature-heading">Blood oxygen</h3>
            <p class="apm-feature-body">Overnight SpO₂ monitoring. Flags dips your body doesn't tell you about.</p>
          </div>
        </div>

      </div>

      <!-- How to connect -->
      <div class="apm-steps-wrap">
        <h3 class="apm-steps-heading">Connect in 60 seconds</h3>
        <ol class="apm-steps">
          <li><strong>Download QRing</strong> — free on the App Store or Google Play.</li>
          <li><strong>Open Bluetooth</strong> on your phone and power on the ring.</li>
          <li><strong>Tap 'Add Device'</strong> in the app — pairs in under 30 seconds.</li>
          <li><strong>Wear it to sleep</strong> — your overnight data syncs by morning.</li>
        </ol>
      </div>

      <!-- App store buttons -->
      <div class="apm-cta">
        <a class="apm-btn" href="https://apps.apple.com/nz/app/qring/id6473672621" target="_blank" rel="noopener" aria-label="Download QRing on the App Store">
          <svg viewBox="0 0 22 26" width="18" height="20" fill="currentColor" aria-hidden="true"><path d="M18.05 13.77c-.03-3.2 2.62-4.75 2.74-4.82-1.5-2.19-3.82-2.49-4.64-2.52-1.97-.2-3.86 1.17-4.86 1.17-1.01 0-2.57-1.14-4.23-1.11C4.9 6.52 2.87 7.7 1.76 9.57c-2.27 3.94-.58 9.76 1.63 12.95 1.08 1.56 2.36 3.31 4.04 3.25 1.63-.07 2.24-1.05 4.2-1.05 1.96 0 2.52 1.05 4.24 1.02 1.75-.03 2.85-1.59 3.92-3.16 1.24-1.81 1.75-3.57 1.77-3.66-.04-.02-3.48-1.33-3.51-5.15zM14.78 4.28C15.67 3.2 16.27 1.7 16.1 0c-1.47.06-3.27.98-4.32 2.04-.95.99-1.77 2.57-1.55 4.08 1.63.13 3.3-.83 4.55-1.84z"/></svg>
          <span class="apm-btn-copy">
            <span class="apm-btn-sub">Download on the</span>
            <span class="apm-btn-name">App Store</span>
          </span>
        </a>
        <a class="apm-btn" href="https://play.google.com/store/apps/details?id=com.app.cq.ring&hl=en_NZ" target="_blank" rel="noopener" aria-label="Get QRing on Google Play">
          <svg viewBox="0 0 22 24" width="18" height="20" fill="currentColor" aria-hidden="true"><path d="M1.22.48C.8.7.5 1.18.5 1.8v20.4c0 .62.3 1.1.72 1.32l.1.06 11.42-11.42v-.27L1.32.42l-.1.06zm15.56 15.7l-3.8-3.8v-.27l3.8-3.8.09.05 4.5 2.56c1.28.73 1.28 1.92 0 2.65l-4.5 2.56-.09.05zM16.88 16.28L13 12.39 1.22 24.17c.42.24.98.2 1.67-.2l14-7.69"/><path d="M16.88 8.52L2.89.83C2.2.43 1.64.39 1.22.63L13 12.41l3.88-3.89z"/></svg>
          <span class="apm-btn-copy">
            <span class="apm-btn-sub">Get it on</span>
            <span class="apm-btn-name">Google Play</span>
          </span>
        </a>
      </div>

      <p class="apm-privacy">
        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.5C17.25 22.15 21 17.25 21 12V7L12 2z"/></svg>
        Your health data stays on your device.
      </p>

    </div>
  </div>
</div>

<style>
  /* Feature list */
  .apm-features {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 28px;
    border: 1px solid rgba(31,29,26,0.08);
    border-radius: 12px;
    overflow: hidden;
  }

  .apm-feature {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 18px 20px;
    border-bottom: 1px solid rgba(31,29,26,0.07);
    transition: background 0.2s;
  }
  .apm-feature:last-child { border-bottom: none; }
  .apm-feature:hover { background: rgba(31,29,26,0.03); }

  .apm-feature-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: rgba(154,126,87,0.1);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9a7e57;
  }

  .apm-feature-heading {
    font-size: 14px;
    font-weight: 700;
    color: #111;
    margin: 0 0 4px;
  }

  .apm-feature-body {
    font-size: 13px;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }

  /* Steps */
  .apm-steps-wrap {
    background: #f8f4ef;
    border-radius: 12px;
    padding: 22px 20px;
    margin-bottom: 28px;
  }

  .apm-steps-heading {
    font-size: 13px;
    font-weight: 700;
    color: #111;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
  }

  .apm-steps {
    padding-left: 18px;
    margin: 0;
    color: #444;
    font-size: 13px;
    line-height: 1.7;
  }
  .apm-steps li { margin-bottom: 5px; }
  .apm-steps li:last-child { margin-bottom: 0; }

  /* CTA buttons */
  .apm-cta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .apm-btn {
    flex: 1;
    min-width: 140px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 0.75rem 1.25rem;
    background: #1f1d1a;
    color: #f5efe4;
    text-decoration: none;
    border-radius: 10px;
    transition: background 0.18s;
  }
  .apm-btn:hover { background: #9a7e57; }

  .apm-btn-copy {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .apm-btn-sub {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 2px;
  }
  .apm-btn-name {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  /* Privacy */
  .apm-privacy {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888;
    margin: 0;
  }
</style>

<script>
(function() {
  var modal    = document.getElementById('app-modal');
  var backdrop = modal.querySelector('.rsm-backdrop');
  var closeBtn = modal.querySelector('.rsm-close');

  function openModal() {
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }
  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
  }

  backdrop.addEventListener('click', closeModal);
  closeBtn.addEventListener('click', closeModal);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });

  /* Intercept "The app" / "Install the app" accordion trigger */
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.accordion__trigger');
    if (!btn) return;
    var text = btn.textContent.trim().toLowerCase();
    if (text.indexOf('the app') !== -1 || text.indexOf('install the app') !== -1 || text.indexOf('qring app') !== -1) {
      e.preventDefault();
      e.stopImmediatePropagation();
      openModal();
    }
  }, true);
})();
</script>

{% schema %}
{
  "name": "App Modal",
  "tag": "section",
  "class": "section-app-modal",
  "settings": []
}
{% endschema %}
