<link rel="stylesheet" href="{{ 'component-before-after.css' | asset_url }}" media="print" onload="this.media='all'">
{%- render 'section-padding', section: section -%}

<div class="before-after-section section-{{ section.id }}-padding">
  <div class="container">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="before-after__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="before-after__title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="before-after__subtitle">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="before-after__list" role="list">
        {%- content_for 'blocks' -%}
      </ul>
    {%- endif -%}

  </div>
</div>

<script src="{{ 'component-before-after.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Before and After",
  "disabled_on": { "groups": ["aside"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the Transformation"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Experience remarkable results with filtered water."
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "select",
      "id": "initial_direction",
      "label": "Drag direction",
      "default": "horizontal",
      "options": [
        { "value": "horizontal", "label": "Horizontal" },
        { "value": "vertical", "label": "Vertical" }
      ]
    },
    {
      "type": "range",
      "id": "initial_position",
      "label": "Initial handle position",
      "default": 50,
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "default": 500,
      "min": 200,
      "max": 900,
      "step": 20,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "Top padding",
      "default": "medium",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "custom", "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "label": "Custom top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "Bottom padding",
      "default": "medium",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "custom", "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "label": "Custom bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    { "type": "_before-after-block" }
  ],
  "presets": [
    {
      "name": "Before and After",
      "blocks": [
        { "type": "_before-after-block" },
        { "type": "_before-after-block" }
      ]
    }
  ]
}
{% endschema %}
