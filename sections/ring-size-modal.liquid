{% comment %} Ring Size Guide Modal — metric / imperial toggle {% endcomment %}

<div id="ring-size-modal" class="rsm-overlay" role="dialog" aria-modal="true" aria-label="Ring Size Guide" hidden>
  <div class="rsm-backdrop"></div>
  <div class="rsm-panel">

    <button class="rsm-close" aria-label="Close size guide">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="rsm-scroll">

      <!-- Header -->
      <div class="rsm-header">
        <p class="rsm-eyebrow">N°01 Smart Ring</p>
        <h2 class="rsm-title">Find your size</h2>
        <p class="rsm-intro">Measure in under a minute. Two methods — pick whichever is easier.</p>

        <!-- Unit toggle -->
        <div class="rsm-unit-toggle" role="group" aria-label="Unit system">
          <button class="rsm-unit-btn is-active" data-unit="mm" aria-pressed="true">mm</button>
          <button class="rsm-unit-btn" data-unit="in" aria-pressed="false">in</button>
        </div>
      </div>

      <!-- Diagram methods (visual-first) -->
      <div class="rsm-diagrams">
        <div class="rsm-diagram-card">
          <div class="rsm-diagram-svg">
            <svg viewBox="0 0 200 200" width="100%" height="100%" fill="none" stroke="#1f1d1a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <!-- Finger silhouette -->
              <path d="M70 195 L70 90 Q70 55 100 55 Q130 55 130 90 L130 195 Z" fill="#f0ede8" stroke="#1f1d1a"/>
              <!-- Fingernail hint -->
              <path d="M86 62 Q100 56 114 62" stroke="#9a7e57" stroke-width="1"/>
              <!-- String wrapped around base -->
              <ellipse cx="100" cy="150" rx="32" ry="9" fill="none" stroke="#9a7e57" stroke-width="2.2"/>
              <!-- String tail crossing over (overlap mark) -->
              <path d="M128 146 Q146 142 152 132" stroke="#9a7e57" stroke-width="2.2" fill="none"/>
              <path d="M132 154 Q150 158 158 168" stroke="#9a7e57" stroke-width="2.2" fill="none"/>
              <!-- Overlap mark dot -->
              <circle cx="130" cy="150" r="3" fill="#9a7e57" stroke="none"/>
              <!-- Mark label line -->
              <line x1="138" y1="150" x2="170" y2="150" stroke="#9a7e57" stroke-width="1" stroke-dasharray="2 3"/>
              <text x="172" y="153" font-family="inherit" font-size="11" fill="#9a7e57" stroke="none">mark</text>
            </svg>
          </div>
          <p class="rsm-diagram-caption">Wrap a string around your finger. Mark where it meets. Measure that length in <span data-mm="mm" data-in="inches" class="rsm-unit-word">mm</span>.</p>
        </div>

        <div class="rsm-diagram-card">
          <div class="rsm-diagram-svg">
            <svg viewBox="0 0 200 200" width="100%" height="100%" fill="none" stroke="#1f1d1a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <!-- Outer ring -->
              <circle cx="100" cy="100" r="68" fill="#f0ede8" stroke="#1f1d1a" stroke-width="1.5"/>
              <!-- Inner ring (hole) -->
              <circle cx="100" cy="100" r="42" fill="#f5efe4" stroke="#1f1d1a" stroke-width="1.5"/>
              <!-- Diameter dashed measurement line -->
              <line x1="58" y1="100" x2="142" y2="100" stroke="#9a7e57" stroke-width="2" stroke-dasharray="4 4"/>
              <!-- Arrow caps -->
              <polyline points="64,94 58,100 64,106" stroke="#9a7e57" stroke-width="2" fill="none"/>
              <polyline points="136,94 142,100 136,106" stroke="#9a7e57" stroke-width="2" fill="none"/>
              <!-- Diameter symbol label -->
              <text x="100" y="84" font-family="inherit" font-size="14" font-weight="600" fill="#9a7e57" stroke="none" text-anchor="middle">&#216;</text>
            </svg>
          </div>
          <p class="rsm-diagram-caption">Measure the inside diameter of a ring that already fits.</p>
        </div>
      </div>
      <p class="rsm-diagram-footer">Match your number in the sizer below.</p>

      <!-- Visual ring sizer (hero) -->
      <div class="rsm-sizer-wrap">
        <h3 class="rsm-sizer-heading">Pick the circle that fits your ring.</h3>
        <p class="rsm-sizer-note">Hold a ring to your screen. Each circle is the inside-diameter at actual size.</p>
        <div class="rsm-sizer-row">
          {%- assign sizes      = "5,6,7,8,9,10,11,12,13"                                           | split: "," -%}
          {%- assign dias_mm    = "15.7,16.5,17.3,18.3,19.1,20.0,20.8,21.6,22.4"                   | split: "," -%}
          {%- assign dias_in    = "0.618,0.650,0.681,0.720,0.752,0.787,0.819,0.850,0.882"           | split: "," -%}
          {%- for size in sizes -%}
            {%- assign dia_mm = dias_mm[forloop.index0] | times: 1.0 -%}
            {%- assign dia_in = dias_in[forloop.index0] -%}
            {%- assign px = dia_mm | times: 3.78 | round -%}
            <button class="rsm-circle-btn"
                    data-size="{{ size }}"
                    data-dia-mm="{{ dia_mm }}"
                    data-dia-in="{{ dia_in }}"
                    style="width:{{ px }}px;height:{{ px }}px;"
                    aria-label="Size {{ size }}, {{ dia_mm }}mm">
              <span class="rsm-circle-size">{{ size }}</span>
              <span class="rsm-circle-dia" data-mm="{{ dia_mm }}mm" data-in='{{ dia_in }}"'>{{ dia_mm }}mm</span>
            </button>
          {%- endfor -%}
        </div>

        <div class="rsm-result" data-result hidden>
          <div class="rsm-result-text">
            <span class="rsm-result-label">Your size</span>
            <span class="rsm-result-size" data-result-size>—</span>
            <span class="rsm-result-sep">·</span>
            <span class="rsm-result-dia" data-result-dia>—</span>
          </div>
          <button class="rsm-result-cta" type="button" data-use-size>Use this size</button>
        </div>
      </div>

      <!-- Size chart (collapsed by default) -->
      <details class="rsm-chart-details">
        <summary class="rsm-chart-summary">See full size chart <span aria-hidden="true">→</span></summary>
        <div class="rsm-chart-wrap">
          <div class="rsm-table-wrap">
            <table class="rsm-table">
              <thead>
                <tr>
                  <th>Size</th>
                  <th class="rsm-th-dia">Inner diameter</th>
                  <th class="rsm-th-circ">Circumference</th>
                </tr>
              </thead>
              <tbody>
                {%- assign circs_mm = "49.3,51.9,54.4,57.5,60.0,62.8,65.3,67.9,70.4" | split: "," -%}
                {%- assign circs_in = "1.94,2.04,2.14,2.26,2.36,2.47,2.57,2.67,2.77" | split: "," -%}
                {%- for size in sizes -%}
                  {%- assign dia_mm  = dias_mm[forloop.index0] -%}
                  {%- assign dia_in  = dias_in[forloop.index0] -%}
                  {%- assign circ_mm = circs_mm[forloop.index0] -%}
                  {%- assign circ_in = circs_in[forloop.index0] -%}
                  <tr>
                    <td>{{ size }}</td>
                    <td><span class="rsm-val" data-mm="{{ dia_mm }} mm" data-in='{{ dia_in }}"'>{{ dia_mm }} mm</span></td>
                    <td><span class="rsm-val" data-mm="{{ circ_mm }} mm" data-in='{{ circ_in }}"'>{{ circ_mm }} mm</span></td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          </div>
        </div>
      </details>

      <!-- Tips (3 icon cards) -->
      <div class="rsm-tips">
        <ul class="rsm-tips-list">
          <li class="rsm-tip-card">
            <span class="rsm-tip-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
                <path d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z"/>
              </svg>
            </span>
            <span class="rsm-tip-text">Measure at end of day. Fingers swell.</span>
          </li>
          <li class="rsm-tip-card">
            <span class="rsm-tip-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
                <polyline points="6 15 12 9 18 15"/>
              </svg>
            </span>
            <span class="rsm-tip-text">Between sizes? Go up one.</span>
          </li>
          <li class="rsm-tip-card">
            <span class="rsm-tip-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
                <path d="M9 11V5.5a1.5 1.5 0 013 0V11"/>
                <path d="M12 11V4a1.5 1.5 0 013 0v7"/>
                <path d="M15 11V6a1.5 1.5 0 013 0v8a7 7 0 01-7 7h-1a5 5 0 01-5-5v-2l-2-3a1.5 1.5 0 012.5-1.7L9 13"/>
              </svg>
            </span>
            <span class="rsm-tip-text">Wear on index or middle finger for best accuracy.</span>
          </li>
        </ul>
      </div>

    </div>
  </div>
</div>

<style>
  /* Overlay */
  .rsm-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .rsm-overlay[hidden] { display: none !important; }

  .rsm-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(31,29,26,0.60);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    cursor: pointer;
    animation: rsmFadeIn 0.25s ease;
  }

  @keyframes rsmFadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes rsmSlideUp {
    from { transform: translateY(32px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  /* Panel */
  .rsm-panel {
    position: relative;
    background: #f5efe4;
    width: 100%;
    max-width: 680px;
    max-height: 90vh;
    border-radius: 20px 20px 0 0;
    display: flex;
    flex-direction: column;
    animation: rsmSlideUp 0.3s cubic-bezier(0.34,1.1,0.64,1);
    box-shadow: 0 -8px 48px rgba(0,0,0,0.18);
    z-index: 1;
  }

  @media (min-width: 700px) {
    .rsm-overlay { align-items: center; }
    .rsm-panel {
      border-radius: 20px;
      max-height: 88vh;
      animation: rsmFadeIn 0.25s ease, rsmSlideUp 0.3s cubic-bezier(0.34,1.1,0.64,1);
    }
  }

  .rsm-close {
    position: absolute;
    top: 18px; right: 18px;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(31,29,26,0.07);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .rsm-close:hover { background: rgba(31,29,26,0.13); }

  .rsm-scroll {
    overflow-y: auto;
    padding: 44px 32px 40px;
    -webkit-overflow-scrolling: touch;
  }

  /* Header */
  .rsm-eyebrow {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #9a7e57;
    margin: 0 0 8px;
  }
  .rsm-title {
    font-size: clamp(22px, 4vw, 30px);
    font-weight: 700;
    margin: 0 0 10px;
    color: #111;
    line-height: 1.15;
  }
  .rsm-intro {
    font-size: 14px;
    color: #666;
    margin: 0 0 20px;
  }

  /* ── Unit toggle ─────────────────────────────────────── */
  .rsm-unit-toggle {
    display: inline-flex;
    background: rgba(31,29,26,0.06);
    border-radius: 8px;
    padding: 3px;
    gap: 2px;
    margin-bottom: 32px;
  }

  .rsm-unit-btn {
    height: 32px;
    padding: 0 18px;
    border: none;
    border-radius: 6px;
    background: transparent;
    font-family: inherit;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(31,29,26,0.5);
    cursor: pointer;
    transition: background 0.18s, color 0.18s;
  }

  .rsm-unit-btn.is-active {
    background: #1f1d1a;
    color: #f5efe4;
  }

  .rsm-unit-btn:not(.is-active):hover {
    background: rgba(31,29,26,0.1);
    color: #1f1d1a;
  }

  /* Diagrams (replaces text methods) */
  .rsm-diagrams {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-bottom: 14px;
  }
  @media (max-width: 560px) {
    .rsm-diagrams { grid-template-columns: 1fr; }
  }
  .rsm-diagram-card {
    background: #fff;
    border: 1px solid #e8e3db;
    border-radius: 14px;
    padding: 18px 16px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .rsm-diagram-svg {
    width: 100%;
    max-width: 200px;
    aspect-ratio: 1 / 1;
    margin-bottom: 12px;
  }
  .rsm-diagram-svg svg { display: block; width: 100%; height: 100%; }
  .rsm-diagram-caption {
    font-size: 13.5px;
    color: #333;
    line-height: 1.5;
    margin: 0;
  }
  .rsm-diagram-footer {
    text-align: center;
    font-size: 12px;
    color: #888;
    margin: 0 0 32px;
    font-style: italic;
  }

  /* Visual sizer */
  .rsm-sizer-wrap {
    background: #fff;
    border: 1px solid #e8e3db;
    border-radius: 14px;
    padding: 28px 24px;
    margin-bottom: 32px;
  }
  .rsm-sizer-heading {
    font-size: 14px;
    font-weight: 700;
    margin: 0 0 6px;
    color: #111;
  }
  .rsm-sizer-note {
    font-size: 12px;
    color: #999;
    margin: 0 0 20px;
    line-height: 1.6;
  }
  .rsm-sizer-row {
    display: flex;
    align-items: flex-end;
    gap: 14px;
    flex-wrap: wrap;
  }
  .rsm-circle-btn {
    border-radius: 50%;
    border: 2px solid #d0cbc3;
    background: #f5efe4;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
    flex-shrink: 0;
  }
  .rsm-circle-btn:hover {
    border-color: #9a7e57;
    background: rgba(154,126,87,0.06);
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 6px 14px rgba(154,126,87,0.18);
  }
  .rsm-circle-btn.is-active {
    border-color: #9a7e57;
    border-width: 3px;
    background: rgba(154,126,87,0.12);
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 4px 12px rgba(154,126,87,0.22);
  }
  .rsm-circle-size {
    font-size: 13px;
    font-weight: 700;
    color: #111;
    line-height: 1;
  }
  .rsm-circle-dia {
    font-size: 9px;
    color: #999;
    line-height: 1;
    transition: opacity 0.15s;
  }

  /* Result callout */
  .rsm-result {
    margin-top: 22px;
    padding: 16px 18px;
    background: #1f1d1a;
    color: #f5efe4;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    animation: rsmFadeIn 0.25s ease;
  }
  .rsm-result[hidden] { display: none; }
  .rsm-result-text {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }
  .rsm-result-label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c8b388;
    font-weight: 600;
  }
  .rsm-result-size {
    font-size: 22px;
    font-weight: 700;
    color: #f5efe4;
    line-height: 1;
  }
  .rsm-result-sep { color: #6b6660; }
  .rsm-result-dia {
    font-size: 14px;
    color: #d8d2c6;
  }
  .rsm-result-cta {
    background: #f5efe4;
    color: #1f1d1a;
    border: none;
    padding: 10px 18px;
    border-radius: 8px;
    font-family: inherit;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.18s, transform 0.15s;
  }
  .rsm-result-cta:hover {
    background: #fff;
    transform: translateY(-1px);
  }

  /* Chart details (collapsed by default) */
  .rsm-chart-details {
    margin: 28px 0 32px;
    border-top: 1px solid #e5e0d8;
    border-bottom: 1px solid #e5e0d8;
  }
  .rsm-chart-summary {
    list-style: none;
    cursor: pointer;
    padding: 14px 0;
    font-size: 13px;
    font-weight: 600;
    color: #1f1d1a;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .rsm-chart-summary::-webkit-details-marker { display: none; }
  .rsm-chart-summary span { color: #9a7e57; transition: transform 0.2s; display: inline-block; }
  .rsm-chart-details[open] .rsm-chart-summary span { transform: rotate(90deg); }

  /* Table */
  .rsm-chart-wrap { padding-bottom: 18px; }
  .rsm-table-wrap { overflow-x: auto; }
  .rsm-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
  }
  .rsm-table th {
    text-align: left;
    padding: 10px 16px;
    background: #f0ede8;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #666;
    font-weight: 600;
    border-bottom: 1px solid #e5e0d8;
  }
  .rsm-table td {
    padding: 12px 16px;
    border-bottom: 1px solid #f0ede8;
    color: #333;
  }
  .rsm-table tbody tr:last-child td { border-bottom: none; }
  .rsm-table tbody tr:hover td { background: rgba(154,126,87,0.04); }
  .rsm-table td:first-child { font-weight: 700; color: #111; }

  /* Value swap animation */
  .rsm-val, .rsm-circle-dia, .rsm-unit-word {
    transition: opacity 0.12s ease;
  }
  .rsm-swapping .rsm-val,
  .rsm-swapping .rsm-circle-dia,
  .rsm-swapping .rsm-unit-word {
    opacity: 0;
  }

  /* Tips (3 icon cards) */
  .rsm-tips { margin-top: 8px; }
  .rsm-tips-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 560px) {
    .rsm-tips-list { grid-template-columns: 1fr; }
  }
  .rsm-tip-card {
    background: #fff;
    border: 1px solid #e8e3db;
    border-radius: 12px;
    padding: 14px 14px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: 0;
  }
  .rsm-tip-icon {
    flex-shrink: 0;
    width: 32px; height: 32px;
    border-radius: 8px;
    background: #f0ede8;
    color: #9a7e57;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rsm-tip-text {
    font-size: 13px;
    color: #333;
    line-height: 1.45;
  }

  @media (max-width: 480px) {
    .rsm-scroll { padding: 36px 20px 32px; }
  }
</style>

<script>
(function() {
  var modal      = document.getElementById('ring-size-modal');
  var backdrop   = modal.querySelector('.rsm-backdrop');
  var closeBtn   = modal.querySelector('.rsm-close');
  var circleBtns = modal.querySelectorAll('.rsm-circle-btn');
  var unitBtns   = modal.querySelectorAll('.rsm-unit-btn');
  var panel      = modal.querySelector('.rsm-panel');

  /* ── Unit system ────────────────────────────────────────── */
  var currentUnit = 'mm';

  try {
    var saved = localStorage.getItem('rsm-unit');
    if (saved === 'mm' || saved === 'in') currentUnit = saved;
  } catch(e) {}

  function applyUnit(unit, animate) {
    if (animate) panel.classList.add('rsm-swapping');

    function swap() {
      /* Values: data-mm / data-in on .rsm-val and .rsm-circle-dia */
      modal.querySelectorAll('[data-mm][data-in]').forEach(function(el) {
        el.textContent = el.getAttribute('data-' + unit);
      });

      /* aria-label on circle buttons */
      circleBtns.forEach(function(btn) {
        var size = btn.dataset.size;
        var dia  = btn.querySelector('.rsm-circle-dia');
        if (dia) btn.setAttribute('aria-label', 'Size ' + size + ', ' + dia.getAttribute('data-' + unit));
      });

      /* Toggle button states */
      unitBtns.forEach(function(b) {
        var active = b.dataset.unit === unit;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      currentUnit = unit;
      try { localStorage.setItem('rsm-unit', unit); } catch(e) {}

      if (animate) {
        requestAnimationFrame(function() {
          panel.classList.remove('rsm-swapping');
        });
      }
    }

    if (animate) {
      setTimeout(swap, 120); /* wait for fade-out */
    } else {
      swap();
    }
  }

  /* Apply saved preference immediately (no animation) */
  applyUnit(currentUnit, false);

  unitBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (btn.dataset.unit !== currentUnit) {
        applyUnit(btn.dataset.unit, true);
      }
    });
  });

  /* ── Open / close ───────────────────────────────────────── */
  function openModal() {
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }
  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
  }

  backdrop.addEventListener('click', closeModal);
  closeBtn.addEventListener('click', closeModal);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });

  /* Intercept any "Find your size" link/button across the page */
  document.addEventListener('click', function(e) {
    var el = e.target.closest('[data-size-guide], .rsm-trigger, a[href="#size-guide"]');
    if (el) { e.preventDefault(); openModal(); }
  });

  /* Also intercept the accordion trigger labelled "Find your size" */
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.accordion__trigger');
    if (!btn) return;
    var text = btn.textContent.trim().toLowerCase();
    if (text.indexOf('find your size') !== -1 || text.indexOf('size guide') !== -1) {
      e.preventDefault();
      e.stopImmediatePropagation();
      openModal();
    }
  }, true);

  /* Circle button highlight + result callout */
  var resultEl     = modal.querySelector('[data-result]');
  var resultSize   = modal.querySelector('[data-result-size]');
  var resultDia    = modal.querySelector('[data-result-dia]');
  var useSizeBtn   = modal.querySelector('[data-use-size]');
  var selectedSize = null;

  function renderResult() {
    if (!selectedSize || !resultEl) return;
    var btn = modal.querySelector('.rsm-circle-btn[data-size="' + selectedSize + '"]');
    if (!btn) return;
    var diaMm = btn.getAttribute('data-dia-mm');
    var diaIn = btn.getAttribute('data-dia-in');
    resultSize.textContent = selectedSize;
    resultDia.textContent = currentUnit === 'mm' ? (diaMm + ' mm') : (diaIn + '"');
    resultEl.hidden = false;
  }

  circleBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      circleBtns.forEach(function(b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      selectedSize = btn.dataset.size;
      renderResult();
    });
  });

  /* Re-render result on unit toggle */
  unitBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      setTimeout(renderResult, 140);
    });
  });

  /* Use this size — synchronise both the theme variant picker and any
     Kaching Bundles app pickers, then close the modal and scroll the
     theme picker into view. Defensive: each selector pass is wrapped so
     a missing pattern can't break the others. */
  function applySizeToPage(size) {
    var sizeStr = String(size);

    /* 1. Theme .variant-fieldset radio (Dawn-style: input[type=radio] inside <label class="variant-card">) */
    try {
      var fieldsets = document.querySelectorAll('fieldset.variant-fieldset');
      fieldsets.forEach(function(fs) {
        var legend = fs.querySelector('legend');
        if (!legend || legend.textContent.trim().toLowerCase() !== 'size') return;
        var radio = fs.querySelector('input[type="radio"][value="' + sizeStr + '"]');
        if (radio) {
          if (!radio.checked) {
            radio.checked = true;
            radio.dispatchEvent(new Event('input',  { bubbles: true }));
            radio.dispatchEvent(new Event('change', { bubbles: true }));
          }
          /* Visual state — Dawn applies is-selected on the parent <label> */
          var labels = fs.querySelectorAll('label.variant-card');
          labels.forEach(function(l) { l.classList.remove('is-selected'); });
          var lbl = radio.closest('label.variant-card');
          if (lbl) lbl.classList.add('is-selected');
        } else {
          /* Fallback: text match on a button/label inside the fieldset */
          var clickable = Array.from(fs.querySelectorAll('button, label, [role="button"]'))
            .filter(function(el) { return el.textContent.trim() === sizeStr; });
          if (clickable[0]) clickable[0].click();
        }
      });
    } catch(err) { /* noop */ }

    /* 2. Kaching Bundles native <select> pickers — set value + fire change */
    try {
      var kSelects = document.querySelectorAll('select.kaching-bundles__bar-variant-select');
      kSelects.forEach(function(s) {
        var name = s.getAttribute('data-name') || '';
        if (name && name.toLowerCase() !== 'size') return;
        var match = Array.from(s.options).find(function(o) { return o.value === sizeStr; });
        if (!match) return;
        s.value = sizeStr;
        s.dispatchEvent(new Event('input',  { bubbles: true }));
        s.dispatchEvent(new Event('change', { bubbles: true }));
      });
    } catch(err) { /* noop */ }

    /* 3. Kaching button-style size pickers (if a future template uses them) */
    try {
      var kBtns = Array.from(document.querySelectorAll(
        '.kaching-bundles__bar-variants button, ' +
        '.kaching-bundles__bar-variants [role="button"], ' +
        '.kaching-bundles__bar-variants label, ' +
        '.kaching-bundles__bar-variants [data-value]'
      )).filter(function(el) {
        if (el.tagName === 'OPTION') return false;
        if (el.dataset && el.dataset.value === sizeStr) return true;
        return el.textContent.trim() === sizeStr;
      });
      kBtns.forEach(function(el) { try { el.click(); } catch(e) {} });
    } catch(err) { /* noop */ }
  }

  if (useSizeBtn) {
    useSizeBtn.addEventListener('click', function() {
      if (selectedSize) applySizeToPage(selectedSize);
      closeModal();
      /* Scroll theme size fieldset into view so the user sees it highlighted */
      try {
        var fieldsets = document.querySelectorAll('fieldset.variant-fieldset');
        fieldsets.forEach(function(fs) {
          var legend = fs.querySelector('legend');
          if (legend && legend.textContent.trim().toLowerCase() === 'size') {
            fs.scrollIntoView({ block: 'center', behavior: 'smooth' });
          }
        });
      } catch(err) {}
    });
  }
})();
</script>

{% schema %}
{
  "name": "Ring Size Guide Modal",
  "tag": "section",
  "class": "section-ring-size-modal",
  "settings": []
}
{% endschema %}
