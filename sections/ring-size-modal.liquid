{% comment %} Ring Size Guide Modal {% endcomment %}

<div id="ring-size-modal" class="rsm-overlay" role="dialog" aria-modal="true" aria-label="Ring Size Guide" hidden>
  <div class="rsm-backdrop"></div>
  <div class="rsm-panel">

    <button class="rsm-close" aria-label="Close size guide">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="rsm-scroll">

      <!-- Header -->
      <div class="rsm-header">
        <p class="rsm-eyebrow">N°01 Smart Band</p>
        <h2 class="rsm-title">Find your size</h2>
        <p class="rsm-intro">Measure in under a minute. Two methods — pick whichever is easier.</p>
      </div>

      <!-- Methods -->
      <div class="rsm-methods">

        <div class="rsm-method">
          <div class="rsm-method-icon">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40">
              <rect x="8" y="20" width="32" height="12" rx="2"/>
              <path d="M16 20v-4a8 8 0 0116 0v4"/>
              <line x1="18" y1="26" x2="18" y2="26" stroke-linecap="round" stroke-width="2"/>
              <line x1="24" y1="26" x2="24" y2="26" stroke-linecap="round" stroke-width="2"/>
              <line x1="30" y1="26" x2="30" y2="26" stroke-linecap="round" stroke-width="2"/>
            </svg>
          </div>
          <div class="rsm-method-body">
            <h3 class="rsm-method-title">Method 1 — String or paper strip</h3>
            <ol class="rsm-steps">
              <li>Cut a thin strip of paper or use a piece of string.</li>
              <li>Wrap it snugly around the base of the finger you'll wear the ring on.</li>
              <li>Mark where the strip meets itself, then measure that length in millimetres.</li>
              <li>That measurement is your <strong>circumference</strong> — match it in the table below.</li>
            </ol>
          </div>
        </div>

        <div class="rsm-divider"><span>or</span></div>

        <div class="rsm-method">
          <div class="rsm-method-icon">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40">
              <circle cx="24" cy="24" r="14"/>
              <circle cx="24" cy="24" r="8"/>
              <line x1="24" y1="4" x2="24" y2="10"/>
              <line x1="24" y1="38" x2="24" y2="44"/>
              <line x1="4" y1="24" x2="10" y2="24"/>
              <line x1="38" y1="24" x2="44" y2="24"/>
            </svg>
          </div>
          <div class="rsm-method-body">
            <h3 class="rsm-method-title">Method 2 — Existing ring</h3>
            <ol class="rsm-steps">
              <li>Find a ring that already fits the finger you'll wear this on.</li>
              <li>Measure the <strong>inside diameter</strong> (across the centre of the ring, inside edge to inside edge).</li>
              <li>Match that diameter in the table below.</li>
            </ol>
          </div>
        </div>

      </div>

      <!-- Visual ring sizer -->
      <div class="rsm-sizer-wrap">
        <h3 class="rsm-sizer-heading">Visual ring sizer</h3>
        <p class="rsm-sizer-note">Hold a ruler to your screen. Each circle shows the inside diameter at actual size (96 DPI reference). Use for guidance only — measure for accuracy.</p>
        <div class="rsm-sizer-row">
          {%- assign sizes = "5,6,7,8,9,10,11,12,13" | split: "," -%}
          {%- assign diameters = "15.7,16.5,17.3,18.3,19.1,20.0,20.8,21.6,22.4" | split: "," -%}
          {%- for size in sizes -%}
            {%- assign dia = diameters[forloop.index0] | times: 1.0 -%}
            {%- assign px = dia | times: 3.78 | round -%}
            <button class="rsm-circle-btn" data-size="{{ size }}" style="width:{{ px }}px;height:{{ px }}px;" aria-label="Size {{ size }}, {{ dia }}mm">
              <span class="rsm-circle-size">{{ size }}</span>
              <span class="rsm-circle-dia">{{ dia }}mm</span>
            </button>
          {%- endfor -%}
        </div>
      </div>

      <!-- Size chart -->
      <div class="rsm-chart-wrap">
        <h3 class="rsm-chart-heading">Size chart</h3>
        <div class="rsm-table-wrap">
          <table class="rsm-table">
            <thead>
              <tr>
                <th>Size</th>
                <th>Inner diameter</th>
                <th>Circumference</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>5</td><td>15.7 mm</td><td>49.3 mm</td></tr>
              <tr><td>6</td><td>16.5 mm</td><td>51.9 mm</td></tr>
              <tr><td>7</td><td>17.3 mm</td><td>54.4 mm</td></tr>
              <tr><td>8</td><td>18.3 mm</td><td>57.5 mm</td></tr>
              <tr><td>9</td><td>19.1 mm</td><td>60.0 mm</td></tr>
              <tr><td>10</td><td>20.0 mm</td><td>62.8 mm</td></tr>
              <tr><td>11</td><td>20.8 mm</td><td>65.3 mm</td></tr>
              <tr><td>12</td><td>21.6 mm</td><td>67.9 mm</td></tr>
              <tr><td>13</td><td>22.4 mm</td><td>70.4 mm</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Tips -->
      <div class="rsm-tips">
        <h3 class="rsm-tips-heading">Tips for an accurate fit</h3>
        <ul class="rsm-tips-list">
          <li>Measure at the <strong>end of the day</strong> — fingers are slightly larger then.</li>
          <li>If you're between sizes, <strong>go up one size</strong>.</li>
          <li>The ring should slide on snugly but come off without effort.</li>
          <li>For best sensor accuracy, wear on your <strong>index or middle finger</strong>.</li>
          <li>Avoid measuring when you're very cold or hot.</li>
        </ul>
      </div>

    </div>
  </div>
</div>

<style>
  /* Overlay */
  .rsm-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .rsm-overlay[hidden] { display: none !important; }

  .rsm-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(31,29,26,0.60);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    cursor: pointer;
    animation: rsmFadeIn 0.25s ease;
  }

  @keyframes rsmFadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes rsmSlideUp {
    from { transform: translateY(32px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  /* Panel */
  .rsm-panel {
    position: relative;
    background: #f5efe4;
    width: 100%;
    max-width: 680px;
    max-height: 90vh;
    border-radius: 20px 20px 0 0;
    display: flex;
    flex-direction: column;
    animation: rsmSlideUp 0.3s cubic-bezier(0.34,1.1,0.64,1);
    box-shadow: 0 -8px 48px rgba(0,0,0,0.18);
    z-index: 1;
  }

  @media (min-width: 700px) {
    .rsm-overlay {
      align-items: center;
    }
    .rsm-panel {
      border-radius: 20px;
      max-height: 88vh;
      animation: rsmFadeIn 0.25s ease, rsmSlideUp 0.3s cubic-bezier(0.34,1.1,0.64,1);
    }
  }

  .rsm-close {
    position: absolute;
    top: 18px; right: 18px;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(31,29,26,0.07);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .rsm-close:hover { background: rgba(31,29,26,0.13); }

  .rsm-scroll {
    overflow-y: auto;
    padding: 44px 32px 40px;
    -webkit-overflow-scrolling: touch;
  }

  /* Header */
  .rsm-eyebrow {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #9a7e57;
    margin: 0 0 8px;
  }
  .rsm-title {
    font-size: clamp(22px, 4vw, 30px);
    font-weight: 700;
    margin: 0 0 10px;
    color: #111;
    line-height: 1.15;
  }
  .rsm-intro {
    font-size: 14px;
    color: #666;
    margin: 0 0 36px;
  }

  /* Methods */
  .rsm-methods { margin-bottom: 40px; }

  .rsm-method {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .rsm-method-icon {
    flex-shrink: 0;
    width: 52px; height: 52px;
    background: #f0ede8;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9a7e57;
  }
  .rsm-method-title {
    font-size: 14px;
    font-weight: 700;
    margin: 0 0 10px;
    color: #111;
  }
  .rsm-steps {
    padding-left: 18px;
    margin: 0;
    color: #444;
    font-size: 13.5px;
    line-height: 1.7;
  }
  .rsm-steps li { margin-bottom: 4px; }

  .rsm-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 24px 0;
    color: #bbb;
    font-size: 12px;
  }
  .rsm-divider::before, .rsm-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e5e0d8;
  }

  /* Visual sizer */
  .rsm-sizer-wrap {
    background: #fff;
    border: 1px solid #e8e3db;
    border-radius: 14px;
    padding: 28px 24px;
    margin-bottom: 32px;
  }
  .rsm-sizer-heading {
    font-size: 14px;
    font-weight: 700;
    margin: 0 0 6px;
    color: #111;
  }
  .rsm-sizer-note {
    font-size: 12px;
    color: #999;
    margin: 0 0 20px;
    line-height: 1.6;
  }
  .rsm-sizer-row {
    display: flex;
    align-items: flex-end;
    gap: 14px;
    flex-wrap: wrap;
  }
  .rsm-circle-btn {
    border-radius: 50%;
    border: 2px solid #d0cbc3;
    background: #f5efe4;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
    flex-shrink: 0;
  }
  .rsm-circle-btn:hover,
  .rsm-circle-btn.is-active {
    border-color: #9a7e57;
    background: rgba(16,132,116,0.06);
    transform: scale(1.05);
  }
  .rsm-circle-size {
    font-size: 13px;
    font-weight: 700;
    color: #111;
    line-height: 1;
  }
  .rsm-circle-dia {
    font-size: 9px;
    color: #999;
    line-height: 1;
  }

  /* Table */
  .rsm-chart-wrap { margin-bottom: 32px; }
  .rsm-chart-heading {
    font-size: 14px;
    font-weight: 700;
    margin: 0 0 14px;
    color: #111;
  }
  .rsm-table-wrap { overflow-x: auto; }
  .rsm-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
  }
  .rsm-table th {
    text-align: left;
    padding: 10px 16px;
    background: #f0ede8;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #666;
    font-weight: 600;
    border-bottom: 1px solid #e5e0d8;
  }
  .rsm-table td {
    padding: 12px 16px;
    border-bottom: 1px solid #f0ede8;
    color: #333;
  }
  .rsm-table tbody tr:last-child td { border-bottom: none; }
  .rsm-table tbody tr:hover td { background: rgba(16,132,116,0.04); }
  .rsm-table td:first-child { font-weight: 700; color: #111; }

  /* Tips */
  .rsm-tips-heading {
    font-size: 14px;
    font-weight: 700;
    margin: 0 0 12px;
    color: #111;
  }
  .rsm-tips-list {
    padding-left: 18px;
    margin: 0;
    color: #555;
    font-size: 13.5px;
    line-height: 1.75;
  }
  .rsm-tips-list li { margin-bottom: 4px; }

  @media (max-width: 480px) {
    .rsm-scroll { padding: 36px 20px 32px; }
  }
</style>

<script>
(function() {
  var modal   = document.getElementById('ring-size-modal');
  var backdrop = modal.querySelector('.rsm-backdrop');
  var closeBtn = modal.querySelector('.rsm-close');
  var circleBtns = modal.querySelectorAll('.rsm-circle-btn');

  function openModal() {
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }
  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
  }

  backdrop.addEventListener('click', closeModal);
  closeBtn.addEventListener('click', closeModal);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });

  /* Intercept any "Find your size" link/button across the page */
  document.addEventListener('click', function(e) {
    var el = e.target.closest('[data-size-guide], .rsm-trigger, a[href="#size-guide"]');
    if (el) { e.preventDefault(); openModal(); }
  });

  /* Also intercept the accordion trigger labelled "Find your size" */
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.accordion__trigger');
    if (!btn) return;
    var text = btn.textContent.trim().toLowerCase();
    if (text.indexOf('find your size') !== -1 || text.indexOf('size guide') !== -1) {
      e.preventDefault();
      e.stopImmediatePropagation();
      openModal();
    }
  }, true);

  /* Circle button highlight */
  circleBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      circleBtns.forEach(function(b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
    });
  });
})();
</script>

{% schema %}
{
  "name": "Ring Size Guide Modal",
  "tag": "section",
  "class": "section-ring-size-modal",
  "settings": []
}
{% endschema %}
