{% comment %}
  newsletter.liquid
  Mend & Co — full-width dark email capture section.
  Espresso bg, Playfair heading, inline input + amber CTA.
{% endcomment %}

{%- assign form_id   = 'newsletter-' | append: section.id -%}
{%- assign btn_label = section.settings.btn_label | default: 'Subscribe' -%}

<div
  class="nl"
  data-section-id="{{ section.id }}"
  data-section-type="newsletter"
>
  <div class="nl__inner">

    <div class="rule-above nl__rule-above" aria-hidden="true"></div>

    <h2 class="nl__heading" data-reveal data-reveal-delay="0">
      {{ section.settings.heading | default: 'Mending starts with paying attention.' }}
    </h2>

    {%- if section.settings.subtext != blank -%}
      <p class="nl__subtext" data-reveal data-reveal-delay="80">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- form 'customer', id: form_id, class: 'nl__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <p class="nl__success" role="status">
          {{ section.settings.success_message | default: 'You\u2019re in. We\u2019ll be in touch.' }}
        </p>
      {%- else -%}

        {%- if form.errors -%}
          <p class="nl__error" role="alert">
            {%- for message in form.errors.messages -%}
              {{ message[1] }}{% unless forloop.last %}, {% endunless %}
            {%- endfor -%}
          </p>
        {%- endif -%}

        <div class="nl__field-row" data-reveal data-reveal-delay="160">
          <label for="NlEmail-{{ section.id }}" class="visually-hidden">Email address</label>
          <input
            id="NlEmail-{{ section.id }}"
            class="nl__input"
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="your@email.com"
            autocomplete="email"
            autocapitalize="off"
            required
            aria-describedby="nl-privacy-{{ section.id }}"
          >
          <button
            type="submit"
            class="nl__btn"
            aria-label="{{ btn_label }}"
          >
            <span>{{ btn_label }}</span>
            <svg class="nl__btn-arrow" width="16" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true">
              <path d="M1 5h14M10 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <p class="nl__privacy" id="nl-privacy-{{ section.id }}">
          {{ section.settings.privacy_note | default: 'We respect your privacy. Unsubscribe any time.' | escape }} &nbsp;
          <a href="{{ shop.privacy_policy.url }}" class="nl__privacy-link">{{ section.settings.privacy_link_label | default: 'Privacy policy' | escape }}</a>
        </p>

      {%- endif -%}
    {%- endform -%}

  </div>
</div>

<style>
/* ── NEWSLETTER ─────────────────────────────────────────── */

.nl {
  background: var(--cream);
  padding: 80px 2rem;
}

.nl__inner {
  max-width: 560px;
  margin: 0 auto;
  text-align: center;
}

/* Reuse base .rule-above; add centering override */
.nl__rule-above {
  margin-inline: auto;
  margin-bottom: 1.5rem;
  background-color: var(--gold-deep);
}

/* Heading — Cormorant Garamond serif */
.nl__heading {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3rem);  /* up to 48px */
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.02em;
  color: var(--char);
  margin: 0 0 1.125rem;
  text-wrap: balance;
}
.nl__heading em {
  font-style: italic;
  color: var(--gold-deep);
}

/* Subtext — serif italic-friendly */
.nl__subtext {
  font-family: var(--font-serif);
  font-size: 1.1875rem;  /* 19px */
  line-height: 1.55;
  color: var(--char-soft);
  margin: 0 0 2rem;
}

/* ── FORM ──────────────────────────────────────────────── */

.nl__field-row {
  display: flex;
  max-width: 480px;
  margin: 0 auto;
  border: 1px solid var(--line-strong);
  border-radius: 2px;
  overflow: hidden;
  background: var(--paper);
}

.nl__field-row:focus-within {
  outline: 2px solid var(--gold-deep);
  outline-offset: 2px;
  border-color: transparent;
}

/* Input */
.nl__input {
  flex: 1;
  height: 48px;
  padding: 0 1.125rem;
  background: var(--paper);
  border: none;
  font-family: var(--font-body);
  font-size: 0.875rem;
  color: var(--char);
  outline: none;
  min-width: 0;
}

.nl__input::placeholder {
  color: var(--ink-mute);
  font-family: var(--font-mono);
  font-size: 0.8125rem;
  letter-spacing: 0.05em;
}

/* Button — charcoal mono pill */
.nl__btn {
  display: flex;
  align-items: center;
  gap: 14px;
  height: 48px;
  padding: 0 28px;
  background: var(--char);
  border: none;
  cursor: pointer;
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--cream);
  white-space: nowrap;
  transition: background 0.2s ease;
  flex-shrink: 0;
}

.nl__btn:hover {
  background: #0e0d0c;
}

.nl__btn:active {
  transform: scale(0.98);
}

.nl__btn-arrow {
  transition: transform 0.2s ease;
}

.nl__btn:hover .nl__btn-arrow {
  transform: translateX(3px);
}

/* Privacy note — mono uppercase */
.nl__privacy {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-mute);
  margin: 1.25rem 0 0;
  line-height: 1.6;
}

.nl__privacy-link {
  color: var(--gold-deep);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: rgba(138, 102, 59, 0.45);
  transition: text-decoration-color 0.15s ease, color 0.15s ease;
}

.nl__privacy-link:hover {
  color: var(--char);
  text-decoration-color: var(--char);
}

/* ── SUCCESS STATE ─────────────────────────────────────── */

.nl__success {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 400;
  font-style: italic;
  color: var(--gold-deep);
  margin: 0;
  padding: 1.5rem 0;
  animation: nl-fade-in 0.4s ease forwards;
}

/* ── ERROR STATE ───────────────────────────────────────── */

.nl__error {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--rose);
  margin: 0 0 1rem;
  text-align: center;
}

/* ── ANIMATIONS ────────────────────────────────────────── */

@keyframes nl-fade-in {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── MOBILE ────────────────────────────────────────────── */

@media (max-width: 540px) {
  .nl {
    padding: 3rem 1.25rem;
  }

  .nl__inner {
    text-align: left;
  }

  .nl__rule-above {
    margin-inline: 0;
  }

  .nl__field-row {
    flex-direction: column;
    border: none;
    gap: 0.5rem;
    max-width: 100%;
  }

  .nl__field-row:focus-within {
    outline: none;
  }

  .nl__input {
    height: 72px;
    padding: 0 1.5rem;
    border: 1.5px solid rgba(166, 137, 102, 0.35);
    border-radius: var(--radius-sm, 2px);
    outline: none;
    font-size: 1.0625rem;
    width: 100%;
    box-sizing: border-box;
  }

  .nl__input:focus {
    outline: 2px solid var(--color-walnut, #8A6240);
    outline-offset: 2px;
  }

  .nl__btn {
    width: 100%;
    height: 72px;
    justify-content: center;
    border-radius: var(--radius-sm, 2px);
    font-size: 12px;
    gap: 10px;
  }

  .nl__privacy {
    text-align: left;
    font-size: 11px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .nl__success { animation: none; }
  .nl__btn,
  .nl__btn-arrow,
  .nl__privacy-link { transition: none; }
}
</style>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Skin starts in the shower."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Join the list for the science, the rituals, and the offers worth opening."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You\u2019re in. We\u2019ll be in touch."
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "Privacy note",
      "default": "We respect your privacy. Unsubscribe any time."
    },
    {
      "type": "text",
      "id": "privacy_link_label",
      "label": "Privacy link label",
      "default": "Privacy policy"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
