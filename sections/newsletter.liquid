{% comment %}
  newsletter.liquid
  Mend & Co — full-width dark email capture section.
  Espresso bg, Playfair heading, inline input + amber CTA.
{% endcomment %}

{%- assign form_id   = 'newsletter-' | append: section.id -%}
{%- assign btn_label = section.settings.btn_label | default: 'Subscribe' -%}

<div
  class="nl"
  data-section-id="{{ section.id }}"
  data-section-type="newsletter"
>
  <div class="nl__inner">

    <div class="rule-above nl__rule-above" aria-hidden="true"></div>

    <h2 class="nl__heading">
      {{ section.settings.heading | default: 'Skin starts in the shower.' }}
    </h2>

    {%- if section.settings.subtext != blank -%}
      <p class="nl__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- form 'customer', id: form_id, class: 'nl__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <p class="nl__success" role="status">
          {{ section.settings.success_message | default: 'You\u2019re in. We\u2019ll be in touch.' }}
        </p>
      {%- else -%}

        {%- if form.errors -%}
          <p class="nl__error" role="alert">
            {%- for message in form.errors.messages -%}
              {{ message[1] }}{% unless forloop.last %}, {% endunless %}
            {%- endfor -%}
          </p>
        {%- endif -%}

        <div class="nl__field-row">
          <label for="NlEmail-{{ section.id }}" class="visually-hidden">Email address</label>
          <input
            id="NlEmail-{{ section.id }}"
            class="nl__input"
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="your@email.com"
            autocomplete="email"
            autocapitalize="off"
            required
            aria-describedby="nl-privacy-{{ section.id }}"
          >
          <button
            type="submit"
            class="nl__btn"
            aria-label="{{ btn_label }}"
          >
            <span>{{ btn_label }}</span>
            <svg class="nl__btn-arrow" width="16" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true">
              <path d="M1 5h14M10 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <p class="nl__privacy" id="nl-privacy-{{ section.id }}">
          {{ section.settings.privacy_note | default: 'We respect your privacy. Unsubscribe any time.' | escape }} &nbsp;
          <a href="{{ shop.privacy_policy.url }}" class="nl__privacy-link">{{ section.settings.privacy_link_label | default: 'Privacy policy' | escape }}</a>
        </p>

      {%- endif -%}
    {%- endform -%}

  </div>
</div>

<style>
/* ── NEWSLETTER ─────────────────────────────────────────── */

.nl {
  background: var(--color-bone);
  padding: 3.5rem 2rem;
}

.nl__inner {
  max-width: 560px;
  margin: 0 auto;
  text-align: center;
}

/* Reuse base .rule-above; add centering override */
.nl__rule-above {
  margin-inline: auto;
  margin-bottom: 1.5rem;
}

/* Heading — linen on espresso 14.18:1 ✅ */
.nl__heading {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 5vw, 2.75rem);
  font-weight: 400;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--color-black);
  margin: 0 0 1.125rem;
}

/* Subtext — soft gold on espresso 10.51:1 ✅ */
.nl__subtext {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  line-height: 1.65;
  color: var(--color-olive);
  margin: 0 0 1.75rem;
}

/* ── FORM ──────────────────────────────────────────────── */

.nl__field-row {
  display: flex;
  max-width: 480px;
  margin: 0 auto;
  border: 1.5px solid rgba(166, 137, 102, 0.35);
  border-radius: var(--radius-sm, 2px);
  overflow: hidden;
}

.nl__field-row:focus-within {
  outline: 2px solid var(--color-walnut, #8A6240);
  outline-offset: 2px;
  border-color: transparent;
}

/* Input — linen bg, espresso text */
.nl__input {
  flex: 1;
  height: 48px;
  padding: 0 1.125rem;
  background: #FFFFFF;
  border: none;
  font-family: var(--font-label);
  font-size: 0.875rem;
  color: var(--color-black);
  outline: none;
  min-width: 0;
}

.nl__input::placeholder {
  /* Warm mahogany-tinted on linen → #8A6240, 3.30:1 ✅ */
  color: #8A6240;
}

/* Button — teal bg, white text — 6.2:1 ✅ */
.nl__btn {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  height: 48px;
  padding: 0 1.375rem;
  background: var(--color-cta, #2D2D2D);
  border: none;
  cursor: pointer;
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--color-bone, #F2EDE4);
  white-space: nowrap;
  transition: background 0.2s ease;
  flex-shrink: 0;
}

.nl__btn:hover {
  background: var(--color-cta-hover, #1A1A1A);
}

.nl__btn:active {
  transform: scale(0.98);
}

.nl__btn-arrow {
  transition: transform 0.2s ease;
}

.nl__btn:hover .nl__btn-arrow {
  transform: translateX(3px);
}

/* Privacy note — #D9C5B2, 6.62:1 on espresso ✅ */
.nl__privacy {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  color: var(--color-olive);
  margin: 1.125rem 0 0;
  line-height: 1.6;
}

.nl__privacy-link {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
  text-decoration-color: rgba(166, 137, 102, 0.45);
  transition: text-decoration-color 0.15s ease, color 0.15s ease;
}

.nl__privacy-link:hover {
  color: #F2EDE4;
  text-decoration-color: rgba(215, 196, 163, 0.5);
}

/* ── SUCCESS STATE ─────────────────────────────────────── */

.nl__success {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 400;
  font-style: italic;
  /* Soft gold on espresso 10.51:1 ✅ */
  color: #F2EDE4;
  margin: 0;
  padding: 1.5rem 0;
  animation: nl-fade-in 0.4s ease forwards;
}

/* ── ERROR STATE ───────────────────────────────────────── */

.nl__error {
  font-family: var(--font-label);
  font-size: 0.8125rem;
  /* #D9C5B2 on espresso 8.19:1 ✅ */
  color: #D9C5B2;
  margin: 0 0 1rem;
  text-align: center;
}

/* ── ANIMATIONS ────────────────────────────────────────── */

@keyframes nl-fade-in {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── MOBILE ────────────────────────────────────────────── */

@media (max-width: 540px) {
  .nl {
    padding: 3rem 1.5rem;
  }

  .nl__field-row {
    flex-direction: column;
    border: none;
    gap: 0.625rem;
  }

  .nl__field-row:focus-within {
    outline: none;
  }

  .nl__input {
    border: 1.5px solid rgba(166, 137, 102, 0.35);
    border-radius: var(--radius-sm, 2px);
    outline: none;
  }

  .nl__input:focus {
    outline: 2px solid var(--color-walnut, #8A6240);
    outline-offset: 2px;
  }

  .nl__btn {
    width: 100%;
    justify-content: center;
    border-radius: var(--radius-sm, 2px);
  }
}

@media (prefers-reduced-motion: reduce) {
  .nl__success { animation: none; }
  .nl__btn,
  .nl__btn-arrow,
  .nl__privacy-link { transition: none; }
}
</style>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Skin starts in the shower."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Join the list for the science, the rituals, and the offers worth opening."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You\u2019re in. We\u2019ll be in touch."
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "Privacy note",
      "default": "We respect your privacy. Unsubscribe any time."
    },
    {
      "type": "text",
      "id": "privacy_link_label",
      "label": "Privacy link label",
      "default": "Privacy policy"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
