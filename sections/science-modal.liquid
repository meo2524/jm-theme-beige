{% comment %} Science & Evidence Modal — same shell as ring-size-modal {% endcomment %}

<div id="science-modal" class="rsm-overlay" role="dialog" aria-modal="true" aria-label="The Science" hidden>
  <div class="rsm-backdrop"></div>
  <div class="rsm-panel scm-panel">

    <button class="rsm-close" aria-label="Close science panel">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="rsm-scroll">

      <!-- Header -->
      <div class="rsm-header">
        <p class="rsm-eyebrow">N°01 Smart Ring</p>
        <h2 class="rsm-title">The science</h2>
        <p class="rsm-intro">Clinical-grade sensors. Peer-reviewed methods. Here's what powers the ring.</p>
      </div>

      <!-- Stat grid -->
      <div class="scm-grid">

        <div class="scm-stat">
          <p class="scm-number">PPG</p>
          <p class="scm-label">Photoplethysmography</p>
          <p class="scm-desc">Optical heart-rate sensor measures blood volume pulse at 100+ Hz — the same principle used in hospital pulse oximeters.</p>
        </div>

        <div class="scm-stat">
          <p class="scm-number">SpO₂</p>
          <p class="scm-label">Blood oxygen saturation</p>
          <p class="scm-desc">Red and infrared LEDs detect haemoglobin absorption to estimate blood-oxygen levels during sleep.</p>
        </div>

        <div class="scm-stat">
          <p class="scm-number">6-axis</p>
          <p class="scm-label">Motion & activity</p>
          <p class="scm-desc">Accelerometer + gyroscope track movement patterns to separate restless sleep from true wakefulness.</p>
        </div>

        <div class="scm-stat">
          <p class="scm-number">0.1 °C</p>
          <p class="scm-label">Skin temperature</p>
          <p class="scm-desc">Precision NTC sensor detects nightly temperature variation — an early biomarker for recovery and illness onset.</p>
        </div>

      </div>

      <!-- Harvard quote -->
      <div class="scm-quote">
        <svg class="scm-quote-mark" viewBox="0 0 40 32" fill="none" aria-hidden="true">
          <path d="M0 32V19.2C0 8.533 5.867 2.133 17.6 0l1.6 3.2C13.067 4.8 10.133 8 9.6 12.8H16V32H0zm22.4 0V19.2C22.4 8.533 28.267 2.133 40 0l1.6 3.2C35.467 4.8 32.533 8 32 12.8H38.4V32H22.4z" fill="#9a7e57" opacity="0.18"/>
        </svg>
        <p class="scm-quote-text">Smart rings may be more accurate for sleep tracking than smartwatches — and their finger-based sensors offer better signal quality than wrist-worn devices.</p>
        <p class="scm-quote-attr">Harvard Health Publishing · Harvard Medical School</p>
      </div>

      <!-- Sources -->
      <div class="scm-sources">
        <p class="scm-sources-label">Endorsed by</p>
        <div class="scm-sources-row">
          <div class="scm-badge">
            <p class="scm-badge-name">Harvard Health Publishing</p>
            <p class="scm-badge-sub">Harvard Medical School</p>
          </div>
          <div class="scm-badge">
            <p class="scm-badge-name">Sleep Foundation</p>
            <p class="scm-badge-sub">Evidence-based sleep research</p>
          </div>
          <div class="scm-badge">
            <p class="scm-badge-name">JMIR mHealth</p>
            <p class="scm-badge-sub">Peer-reviewed wearable studies</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  /* Panel tint — dark for science content */
  .scm-panel {
    background: #1f1d1a !important;
  }
  .scm-panel .rsm-close {
    background: rgba(239,232,220,0.08) !important;
    color: #efe8dc !important;
  }
  .scm-panel .rsm-close:hover { background: rgba(239,232,220,0.14) !important; }
  .scm-panel .rsm-eyebrow { color: #9a7e57 !important; }
  .scm-panel .rsm-title   { color: #efe8dc !important; }
  .scm-panel .rsm-intro   { color: #8a7d6e !important; }

  /* Stat grid */
  .scm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(239,232,220,0.08);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 32px;
  }

  .scm-stat {
    background: rgba(239,232,220,0.03);
    padding: 24px 20px;
    transition: background 0.25s;
  }
  .scm-stat:hover { background: rgba(154,126,87,0.08); }

  .scm-number {
    font-size: clamp(22px, 4vw, 30px);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 4px;
    background: linear-gradient(135deg, #efe8dc 0%, #9a7e57 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .scm-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9a7e57;
    margin: 0 0 8px;
  }

  .scm-desc {
    font-size: 12.5px;
    line-height: 1.6;
    color: #b8aa92;
    margin: 0;
  }

  /* Quote */
  .scm-quote {
    position: relative;
    padding: 28px 24px 24px;
    background: rgba(239,232,220,0.03);
    border-radius: 12px;
    border: 1px solid rgba(239,232,220,0.08);
    border-left: 3px solid #9a7e57;
    margin-bottom: 32px;
  }

  .scm-quote-mark {
    position: absolute;
    top: 16px; right: 20px;
    width: 28px; height: 22px;
  }

  .scm-quote-text {
    font-size: 14.5px;
    line-height: 1.75;
    color: #c4b89e;
    font-style: italic;
    margin: 0 0 14px;
  }

  .scm-quote-attr {
    font-size: 10px;
    color: #9a7e57;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0;
  }

  /* Sources */
  .scm-sources-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9a7e57;
    margin: 0 0 14px;
    text-align: center;
  }

  .scm-sources-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .scm-badge {
    background: rgba(239,232,220,0.04);
    border: 1px solid rgba(239,232,220,0.1);
    border-radius: 10px;
    padding: 14px 18px;
    text-align: center;
  }

  .scm-badge-name {
    font-size: 14px;
    font-weight: 500;
    color: #e8dec5;
    margin: 0 0 3px;
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    letter-spacing: 0.01em;
  }

  .scm-badge-sub {
    font-size: 11px;
    color: #8a7d6e;
    margin: 0;
    letter-spacing: 0.02em;
  }

  @media (min-width: 480px) {
    .scm-sources-row { flex-direction: row; flex-wrap: wrap; justify-content: center; }
    .scm-badge { flex: 1; min-width: 160px; }
  }

  @media (max-width: 380px) {
    .scm-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
(function() {
  var modal    = document.getElementById('science-modal');
  var backdrop = modal.querySelector('.rsm-backdrop');
  var closeBtn = modal.querySelector('.rsm-close');

  function openModal() {
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }
  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
  }

  backdrop.addEventListener('click', closeModal);
  closeBtn.addEventListener('click', closeModal);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });

  /* Intercept "See the science" accordion trigger */
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.accordion__trigger');
    if (!btn) return;
    var text = btn.textContent.trim().toLowerCase();
    if (text.indexOf('see the science') !== -1 || text.indexOf('the science') !== -1) {
      e.preventDefault();
      e.stopImmediatePropagation();
      openModal();
    }
  }, true);
})();
</script>

{% schema %}
{
  "name": "Science Modal",
  "tag": "section",
  "class": "section-science-modal",
  "settings": []
}
{% endschema %}
