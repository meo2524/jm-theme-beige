<style>
.at-wrap {
  background: var(--color-bone, #0A0812);
  padding: 5rem 0 6rem;
}
.at-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding-inline: clamp(1rem, 4vw, 2rem);
}

/* Header */
.at-head { margin-bottom: 2.5rem; }
.at-head__rule {
  width: 40px; height: 1.5px;
  background: var(--color-walnut, #4A2980);
  opacity: 0.6; margin-bottom: 1.25rem;
}
.at-head__eyebrow {
  font-family: var(--font-body);
  font-size: 0.6875rem; font-weight: 600;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--color-walnut, #4A2980);
  margin: 0 0 0.75rem; max-width: none;
}
.at-head__heading {
  font-family: var(--font-body);
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  font-weight: 400; color: var(--color-black, #F3E8FF);
  line-height: 1.15; margin: 0;
}

/* Tabs */
.at-tabs {
  display: flex; gap: 0.5rem; margin-bottom: 2rem;
  overflow-x: auto; -webkit-overflow-scrolling: touch;
  scrollbar-width: none; padding-bottom: 2px;
}
.at-tabs::-webkit-scrollbar { display: none; }
.at-tab {
  flex-shrink: 0; padding: 0.45rem 1.125rem;
  border-radius: 100px; border: 1.5px solid rgba(138,98,64,0.25);
  background: transparent;
  font-family: var(--font-body);
  font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.04em;
  color: var(--color-olive, #5a4a3a); cursor: pointer;
  transition: background 0.18s, border-color 0.18s, color 0.18s;
  white-space: nowrap;
}
.at-tab:hover { border-color: var(--color-walnut, #4A2980); background: rgba(138,98,64,0.06); }
.at-tab.is-active { background: var(--color-walnut, #4A2980); border-color: var(--color-walnut, #4A2980); color: #f5efe6; }

/* Panels */
.at-panel[hidden] { display: none; }
.at-panel { animation: atFadeIn 0.28s ease; }
@keyframes atFadeIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: none; }
}

/* Carousel */
.at-carousel { position: relative; overflow: hidden; }

.at-track {
  display: flex;
  transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}

/* Cards */
.at-card {
  min-width: 100%; width: 100%;
  display: flex; flex-direction: column; gap: 1rem;
  padding: 2.25rem 2.5rem;
  background: rgba(43,43,43,0.05);
  border: 1px solid rgba(43,43,43,0.1);
  border-radius: 6px; margin: 0; quotes: none;
  box-sizing: border-box;
}

.at-stars {
  color: var(--color-walnut, #4A2980);
  font-size: 13px; letter-spacing: 2px; line-height: 1;
}
.at-card__title {
  font-family: var(--font-body);
  font-size: 1rem; font-weight: 700;
  color: var(--color-black, #F3E8FF); margin: 0; line-height: 1.3;
}
.at-card__body {
  font-family: var(--font-body);
  font-size: 1.125rem; font-style: italic; font-weight: 400;
  line-height: 1.7; color: var(--color-black, #F3E8FF); flex: 1; margin: 0;
}
.at-card__footer {
  display: flex; align-items: center; justify-content: space-between;
  gap: 0.5rem; padding-top: 1rem;
  border-top: 1px solid rgba(43,43,43,0.1); flex-wrap: wrap;
}
.at-card__name {
  font-family: var(--font-body);
  font-size: 0.8125rem; font-weight: 700; color: var(--color-black, #F3E8FF);
}
.at-card__detail {
  font-family: var(--font-body);
  font-size: 0.75rem; color: var(--color-olive, #5a4a3a); opacity: 0.75;
}

/* Nav */
.at-nav {
  display: flex; align-items: center; justify-content: center;
  gap: 1.25rem; margin-top: 1.5rem;
}
.at-nav__btn {
  width: 38px; height: 38px; border-radius: 50%;
  border: 1.5px solid rgba(138,98,64,0.3);
  background: transparent; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  color: var(--color-walnut, #4A2980);
  transition: background 0.18s, border-color 0.18s;
}
.at-nav__btn:hover { background: rgba(138,98,64,0.1); border-color: var(--color-walnut, #4A2980); }
.at-nav__btn:disabled { opacity: 0.25; cursor: default; pointer-events: none; }

/* Dots */
.at-dots { display: flex; gap: 6px; align-items: center; }
.at-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: rgba(138,98,64,0.25);
  transition: background 0.2s, transform 0.2s;
  cursor: pointer; border: none; padding: 0;
}
.at-dot.is-active { background: var(--color-walnut, #4A2980); transform: scale(1.3); }

@media (max-width: 599px) {
  .at-wrap { padding: 3rem 0 4rem; }
  .at-card { padding: 1.75rem 1.25rem; }
}
@media (prefers-reduced-motion: reduce) {
  .at-track { transition: none; }
  .at-panel { animation: none; }
}

/* Desktop: show 3 testimonials side-by-side, drop the carousel UI */
@media (min-width: 1024px) {
  .at-carousel { overflow: visible; }
  .at-track {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    transform: none !important;
    transition: none;
  }
  .at-card { min-width: 0; width: auto; }
  .at-nav, .at-dots { display: none; }
}
</style>

<script>
(function() {
  var section = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;

  var tabs   = section.querySelectorAll('.at-tab');
  var panels = section.querySelectorAll('.at-panel');

  /* ── Carousel init for one panel ── */
  function initCarousel(panel) {
    if (panel._atInit) return;
    panel._atInit = true;

    var track    = panel.querySelector('.at-track');
    var dotsWrap = panel.querySelector('.at-dots');
    var btnPrev  = panel.querySelector('.at-nav__btn--prev');
    var btnNext  = panel.querySelector('.at-nav__btn--next');
    var cards    = panel.querySelectorAll('.at-card');
    var total    = cards.length;
    var current  = 0;

    /* Build dots */
    for (var i = 0; i < total; i++) {
      var dot = document.createElement('button');
      dot.className = 'at-dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('aria-label', 'Review ' + (i + 1));
      dot.dataset.idx = i;
      dotsWrap.appendChild(dot);
    }

    function goTo(idx) {
      current = Math.max(0, Math.min(idx, total - 1));
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dotsWrap.querySelectorAll('.at-dot').forEach(function(d, i) {
        d.classList.toggle('is-active', i === current);
      });
      btnPrev.disabled = current === 0;
      btnNext.disabled = current === total - 1;
    }

    btnPrev.addEventListener('click', function() { goTo(current - 1); });
    btnNext.addEventListener('click', function() { goTo(current + 1); });
    dotsWrap.addEventListener('click', function(e) {
      var dot = e.target.closest('.at-dot');
      if (dot) goTo(parseInt(dot.dataset.idx));
    });

    goTo(0);
  }

  /* Init the default active panel */
  var activePanel = section.querySelector('.at-panel.is-active');
  if (activePanel) initCarousel(activePanel);

  /* ── Tab switching ── */
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = tab.dataset.tab;
      tabs.forEach(function(t) { t.classList.remove('is-active'); t.setAttribute('aria-selected','false'); });
      panels.forEach(function(p) { p.hidden = true; p.classList.remove('is-active'); });
      tab.classList.add('is-active');
      tab.setAttribute('aria-selected','true');
      var panel = section.querySelector('[data-panel="' + target + '"]');
      if (panel) {
        panel.hidden = false;
        panel.classList.add('is-active');
        initCarousel(panel);
      }
    });
  });
})();
</script>

