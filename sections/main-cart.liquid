{% comment %}
  main-cart.liquid
  Mend & Co — Cart page
  2-col layout: item list (left) + order summary (right).
  Supports AJAX qty/remove via component-cart-drawer.js.
  Falls back gracefully to standard form submit with no JS.
{% endcomment %}

<section
  class="cart-page"
  data-section-id="{{ section.id }}"
  data-section-type="main-cart"
>
  <div class="cart-page__inner">

    {%- comment -%} ── HEADER ── {%- endcomment -%}
    <div class="cart-page__header">
      <p class="cart-page__eyebrow">Your Order</p>
      <h1 class="cart-page__title">
        {%- if cart.item_count > 0 -%}
          Shopping Cart
        {%- else -%}
          Your Cart
        {%- endif -%}
      </h1>
      {%- if cart.item_count > 0 -%}
        <p class="cart-page__item-count" aria-live="polite">
          {{ cart.item_count }}&nbsp;item{%- if cart.item_count != 1 -%}s{%- endif -%}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} ── CART WITH ITEMS ── {%- endcomment -%}
    {%- if cart.item_count > 0 -%}

      <div class="cart-layout">

        {%- comment -%} ── ITEMS COLUMN ── {%- endcomment -%}
        <div class="cart-items-col">

          {%- form 'cart', cart,
                id: 'CartPageForm',
                data-cart-form: '' -%}

            <div
              class="cart-items-list"
              id="CartItemsList"
              data-cart-items
            >
              {%- for item in cart.items -%}
                {%- render 'cart-item', item: item, context: 'page' -%}
              {%- endfor -%}
            </div>

          {%- endform -%}
        </div>

        {%- comment -%} ── SUMMARY COLUMN ── {%- endcomment -%}
        <aside class="cart-summary" aria-label="Order summary">
          <div class="cart-summary__inner">

            <p class="cart-summary__heading">Order Summary</p>

            <div class="cart-summary__rows">
              <div class="cart-summary__row">
                <span class="cart-summary__row-label">Subtotal</span>
                <span
                  class="cart-summary__row-value"
                  data-cart-total
                >{{ cart.total_price | money }}</span>
              </div>
              {%- if cart.total_discounts > 0 -%}
                <div class="cart-summary__row cart-summary__row--discount">
                  <span class="cart-summary__row-label">Discounts</span>
                  <span class="cart-summary__row-value">−{{ cart.total_discounts | money }}</span>
                </div>
              {%- endif -%}
            </div>

            <p class="cart-summary__shipping-note">
              Shipping and taxes calculated at checkout
            </p>

            <div class="cart-summary__rule"></div>

            <div class="cart-summary__total-row">
              <span class="cart-summary__total-label">Estimated Total</span>
              <span
                class="cart-summary__total-value"
                data-cart-total
              >{{ cart.total_price | money }}</span>
            </div>

            {%- form 'cart', cart -%}
              <button
                type="submit"
                name="checkout"
                class="cart-checkout-btn"
                id="CartCheckoutBtn"
              >
                Proceed to Checkout
              </button>
            {%- endform -%}

            <a
              href="{{ routes.all_products_collection_url }}"
              class="cart-continue-link"
            >← Continue shopping</a>

          </div>
        </aside>

      </div>

    {%- comment -%} ── EMPTY STATE ── {%- endcomment -%}
    {%- else -%}

      <div class="cart-empty">
        <div class="cart-empty__rule"></div>
        <p class="cart-empty__heading">Nothing here yet</p>
        <p class="cart-empty__body">
          Add the Mend shower filter to your cart and start your routine before your routine.
        </p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-empty__cta">
          Shop now
        </a>
      </div>

    {%- endif -%}

  </div>
</section>


<style>
/* ════════════════════════════════════════════════════════════
   CART PAGE — Mend & Co
   ════════════════════════════════════════════════════════════ */

.cart-page {
  background: var(--color-linen, #F2E8D5);
  min-height: 70vh;
  padding-bottom: 8rem;
}

.cart-page__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 4rem;
}

/* Header */
.cart-page__header {
  padding: 4rem 0 2.5rem;
  border-bottom: 1px solid rgba(43, 43, 43, 0.08);
  margin-bottom: 3rem;
}

.cart-page__eyebrow {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--color-mahogany);
  margin: 0 0 0.75rem;
}

.cart-page__title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 400;
  color: var(--color-espresso);
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin: 0 0 0.5rem;
}

.cart-page__item-count {
  font-family: var(--font-label);
  font-size: 0.8125rem;
  color: var(--color-mahogany);
  margin: 0;
}

/* 2-col layout */
.cart-layout {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 5rem;
  align-items: start;
}

/* Items column */
.cart-items-col {
  /* nothing extra needed */
}

.cart-items-list {
  display: flex;
  flex-direction: column;
}

/* Cart item — page context */
.cart-item--page {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 1.5rem;
  padding: 1.75rem 0;
  border-bottom: 1px solid rgba(43, 43, 43, 0.08);
}

.cart-item__img-link {
  display: block;
  text-decoration: none;
}

.cart-item__img-wrap {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #F2E8D5;
  border-radius: var(--radius-base, 4px);
}

.cart-item__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.cart-item__img-link:hover .cart-item__img {
  transform: scale(1.04);
}

.cart-item__img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-mahogany);
  opacity: 0.15;
}

.cart-item__body {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  min-width: 0;
}

.cart-item__meta {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.cart-item__title-link {
  text-decoration: none;
  color: inherit;
}

.cart-item__title-link:focus-visible {
  outline: 1.5px solid var(--color-amber, #A68966);
  outline-offset: 2px;
  border-radius: var(--radius-sm, 2px);
}

.cart-item__title {
  font-family: var(--font-heading);
  font-size: 1.0625rem;
  font-weight: 400;
  color: var(--color-espresso);
  line-height: 1.3;
  transition: color 0.15s ease;
}

.cart-item__title-link:hover .cart-item__title {
  color: var(--color-mahogany);
}

.cart-item__variant {
  font-family: var(--font-label);
  font-size: 0.8125rem;
  /* Blended mahogany 65% on linen → #9F7C63, 4.79:1 ✅ */
  color: #9F7C63;
  margin: 0;
}

.cart-item__sub {
  font-family: var(--font-label);
  font-size: 0.75rem;
  color: var(--color-sage, #4A7B72);
  margin: 0;
}

.cart-item__controls {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}

/* Quantity stepper (reuses base.css classes, scoped overrides below) */
.cart-item__qty.qty-stepper {
  display: inline-flex;
  align-items: center;
  border: 1.5px solid rgba(43, 43, 43, 0.16);
  border-radius: var(--radius-sm, 2px);
  overflow: hidden;
}

.cart-item__qty .qty-btn {
  width: 36px;
  height: 36px;
  background: transparent;
  border: none;
  font-size: 1rem;
  color: var(--color-espresso);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s ease;
  flex-shrink: 0;
  line-height: 1;
}

.cart-item__qty .qty-btn:hover {
  background: rgba(43, 43, 43, 0.05);
}

.cart-item__qty .qty-input {
  width: 44px;
  height: 36px;
  border: none;
  border-left: 1px solid rgba(43, 43, 43, 0.1);
  border-right: 1px solid rgba(43, 43, 43, 0.1);
  background: transparent;
  font-family: var(--font-label);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-espresso);
  text-align: center;
  -moz-appearance: textfield;
}

.cart-item__qty .qty-input::-webkit-outer-spin-button,
.cart-item__qty .qty-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
}

.cart-item__price-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.125rem;
  margin-left: auto;
}

.cart-item__price {
  font-family: var(--font-heading);
  font-size: 1.125rem;
  font-weight: 400;
  color: var(--color-espresso);
  letter-spacing: -0.01em;
}

.cart-item__price-compare {
  font-family: var(--font-label);
  font-size: 0.8125rem;
  color: var(--color-mahogany);
  text-decoration: line-through;
  /* Blended mahogany 55% on linen → #A98977, 3.54:1 ✅ supplementary */
  color: #A98977;
}

.cart-item__remove {
  background: transparent;
  border: none;
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  /* Blended mahogany 55% on linen → #A98977, 3.54:1 ✅ */
  color: #A98977;
  cursor: pointer;
  padding: 0;
  text-decoration: underline;
  text-underline-offset: 2px;
  text-decoration-color: transparent;
  transition: color 0.15s ease, text-decoration-color 0.15s ease;
  align-self: flex-start;
}

.cart-item__remove:hover {
  color: var(--color-espresso);
  text-decoration-color: var(--color-espresso);
}

/* Order summary */
.cart-summary {
  position: sticky;
  top: 2rem;
}

.cart-summary__inner {
  background: rgba(43, 43, 43, 0.03);
  border: 1px solid rgba(43, 43, 43, 0.08);
  border-top: 1.5px solid var(--color-amber, #A68966);
  padding: 2rem;
}

.cart-summary__heading {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--color-espresso);
  margin: 0 0 1.5rem;
}

.cart-summary__rows {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-bottom: 0.875rem;
}

.cart-summary__row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
}

.cart-summary__row-label {
  font-family: var(--font-label);
  font-size: 0.875rem;
  color: var(--color-mahogany);
}

.cart-summary__row-value {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-espresso);
}

.cart-summary__row--discount .cart-summary__row-value {
  color: var(--color-sage, #4A7B72);
}

.cart-summary__shipping-note {
  font-family: var(--font-label);
  font-size: 0.75rem;
  /* Blended mahogany 60% on tinted bg → approx 4.5:1 ✅ */
  color: #9A7255;
  margin: 0 0 1.25rem;
}

.cart-summary__rule {
  height: 1px;
  background: rgba(43, 43, 43, 0.1);
  margin-bottom: 1.25rem;
}

.cart-summary__total-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.cart-summary__total-label {
  font-family: var(--font-label);
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-espresso);
  letter-spacing: 0.01em;
}

.cart-summary__total-value {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--color-espresso);
  letter-spacing: -0.02em;
}

/* Checkout button */
.cart-checkout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 52px;
  background: var(--color-amber, #A68966);
  color: var(--color-espresso);
  border: none;
  border-radius: var(--radius-sm, 2px);
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.12s ease;
  margin-bottom: 0.75rem;
}

.cart-checkout-btn:hover {
  background: #B87840;
}

.cart-checkout-btn:active {
  transform: scale(0.997);
}

.cart-continue-link {
  display: block;
  text-align: center;
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-mahogany);
  text-decoration: underline;
  text-underline-offset: 2px;
  text-decoration-color: rgba(166, 137, 102, 0.35);
  transition: text-decoration-color 0.15s ease;
}

.cart-continue-link:hover {
  text-decoration-color: var(--color-mahogany);
}

/* Empty state */
.cart-empty {
  padding: 6rem 2rem;
  text-align: center;
  max-width: 420px;
  margin: 0 auto;
}

.cart-empty__rule {
  width: 3rem;
  height: 1.5px;
  background: var(--color-amber, #A68966);
  margin: 0 auto 2rem;
}

.cart-empty__heading {
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 400;
  color: var(--color-espresso);
  letter-spacing: -0.01em;
  margin: 0 0 0.875rem;
}

.cart-empty__body {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  line-height: 1.7;
  color: var(--color-mahogany);
  margin: 0 0 2rem;
}

.cart-empty__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  padding: 0 2rem;
  background: var(--color-amber, #A68966);
  color: var(--color-espresso);
  border-radius: var(--radius-sm, 2px);
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  text-decoration: none;
  transition: background 0.2s ease;
}

.cart-empty__cta:hover {
  background: #B87840;
}

/* ════════════════════════════════════════════════════════════
   RESPONSIVE
   ════════════════════════════════════════════════════════════ */

@media (max-width: 1024px) {
  .cart-page__inner {
    padding: 0 2.5rem;
  }

  .cart-layout {
    grid-template-columns: 1fr 300px;
    gap: 3rem;
  }
}

@media (max-width: 768px) {
  .cart-page__inner {
    padding: 0 1.25rem;
  }

  .cart-page__header {
    padding-top: 2.5rem;
  }

  .cart-layout {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .cart-summary {
    position: static;
  }

  .cart-item--page {
    grid-template-columns: 88px 1fr;
    gap: 1rem;
    padding: 1.25rem 0;
  }

  .cart-item__controls {
    gap: 0.875rem;
  }
}

@media (max-width: 480px) {
  .cart-item__controls {
    flex-direction: column;
    align-items: flex-start;
  }

  .cart-item__price-col {
    margin-left: 0;
    align-items: flex-start;
  }
}
</style>


{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section-main-cart",
  "settings": [],
  "presets": [
    {
      "name": "Cart"
    }
  ]
}
{% endschema %}
