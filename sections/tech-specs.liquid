{%- comment -%}
  tech-specs.liquid
  Mend & Co — full-width Tech Specifications section.
  Dark Mend-black bg, bone text. Oura-style structure:
    [included image] | What's Included
    Tech Specifications heading
    spec groups (icon + heading + body) stacked.
  Content edited via theme editor blocks.
{%- endcomment -%}

<section class="mc-tech-specs" data-section-id="{{ section.id }}">
  <div class="mc-tech-specs__inner">

    {%- comment -%} Top row: charger image + What's Included list {%- endcomment -%}
    {%- if section.settings.included_image != blank or section.settings.included_items != blank -%}
      <div class="mc-tech-specs__included">
        {%- if section.settings.included_image != blank -%}
          <div class="mc-tech-specs__included-media">
            <img
              src="{{ section.settings.included_image | image_url: width: 600 }}"
              srcset="{{ section.settings.included_image | image_url: width: 320 }} 320w, {{ section.settings.included_image | image_url: width: 600 }} 600w, {{ section.settings.included_image | image_url: width: 900 }} 900w"
              sizes="(max-width: 749px) 90vw, 40vw"
              alt="{{ section.settings.included_image.alt | default: 'What is included' | escape }}"
              loading="lazy"
              width="{{ section.settings.included_image.width }}"
              height="{{ section.settings.included_image.height }}">
          </div>
        {%- endif -%}

        <div class="mc-tech-specs__included-copy" data-reveal data-reveal-delay="0">
          <div class="mc-tech-specs__included-head">
            <svg class="mc-tech-specs__included-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
            <h3 class="mc-tech-specs__included-title">{{ section.settings.included_heading | default: "What's Included" | escape }}</h3>
          </div>
          {%- if section.settings.included_items != blank -%}
            <ul class="mc-tech-specs__included-list" role="list">
              {%- assign included_lines = section.settings.included_items | newline_to_br | split: '<br />' -%}
              {%- for line in included_lines -%}
                {%- assign trimmed = line | strip -%}
                {%- if trimmed != blank -%}
                  <li>{{ trimmed }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Tech Spec heading {%- endcomment -%}
    <h2 class="mc-tech-specs__heading" data-reveal data-reveal-delay="80">
      {{ section.settings.specs_heading | default: 'Tech Specifications' | escape }}
    </h2>

    {%- comment -%} Spec groups (blocks) {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="mc-tech-specs__groups">
        {%- for block in section.blocks -%}
          {%- if block.type == 'spec_group' -%}
            <div class="mc-tech-specs__group" data-reveal data-reveal-delay="{{ forloop.index0 | times: 60 }}" {{ block.shopify_attributes }}>
              <div class="mc-tech-specs__group-head">
                <span class="mc-tech-specs__group-icon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'heart' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    {%- when 'check' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11.5 14.5 16 9.5"/></svg>
                    {%- when 'weight' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                    {%- when 'battery' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="18" height="10" rx="2"/><line x1="22" y1="11" x2="22" y2="13"/></svg>
                    {%- when 'ring' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="8"/></svg>
                    {%- when 'shield' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.5C17.25 22.15 21 17.25 21 12V7L12 2z"/></svg>
                    {%- when 'bluetooth' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6.5 6.5 17.5 17.5 12 23 12 1 17.5 6.5 6.5 17.5"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="8"/></svg>
                  {%- endcase -%}
                </span>
                <h3 class="mc-tech-specs__group-title">{{ block.settings.heading | escape }}</h3>
              </div>
              <div class="mc-tech-specs__group-body">
                {{ block.settings.body }}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .mc-tech-specs {
    background: var(--color-black, #F3E8FF);
    color: var(--color-bone, #0A0812);
    padding: 3rem 1.25rem 3rem;
    margin: 0;
  }

  .mc-tech-specs__inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* Included row */
  .mc-tech-specs__included {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 3.25rem;
    align-items: center;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(245, 239, 230, 0.12);
  }

  .mc-tech-specs__included-media img {
    display: block;
    width: 100%;
    max-width: 380px;
    height: auto;
    margin: 0 auto;
  }

  .mc-tech-specs__included-head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0 0 0.75rem;
  }

  .mc-tech-specs__included-icon {
    width: 22px;
    height: 22px;
    color: var(--color-walnut, #c89976);
    flex-shrink: 0;
  }

  .mc-tech-specs__included-title {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0;
    color: var(--color-bone, #0A0812);
    letter-spacing: -0.01em;
  }

  .mc-tech-specs__included-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .mc-tech-specs__included-list li {
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(245, 239, 230, 0.92);
  }

  /* Tech Specifications heading */
  .mc-tech-specs__heading {
    font-family: var(--font-body);
    font-size: clamp(1.85rem, 4.5vw, 2.6rem);
    font-weight: 500;
    margin: 0 0 2rem;
    color: var(--color-bone, #0A0812);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  /* Spec groups */
  .mc-tech-specs__groups {
    display: flex;
    flex-direction: column;
    gap: 2.1rem;
  }

  .mc-tech-specs__group-head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0 0 0.7rem;
  }

  .mc-tech-specs__group-icon svg {
    width: 22px;
    height: 22px;
    display: block;
    color: var(--color-walnut, #c89976);
  }

  .mc-tech-specs__group-title {
    font-family: var(--font-body);
    font-size: 1.35rem;
    font-weight: 500;
    margin: 0;
    color: var(--color-bone, #0A0812);
    letter-spacing: -0.01em;
  }

  .mc-tech-specs__group-body {
    color: rgba(245, 239, 230, 0.92);
    font-size: 0.95rem;
    line-height: 1.65;
    padding-left: calc(22px + 0.7rem);
  }

  .mc-tech-specs__group-body p {
    margin: 0 0 0.5rem;
  }
  .mc-tech-specs__group-body p:last-child {
    margin-bottom: 0;
  }
  .mc-tech-specs__group-body strong {
    color: var(--color-bone, #0A0812);
    font-weight: 600;
  }
  .mc-tech-specs__group-body ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .mc-tech-specs__group-body ul li {
    padding-left: 0;
  }

  /* Desktop: included row goes 2-col */
  @media (min-width: 750px) {
    .mc-tech-specs {
      padding: 5.5rem 2rem 5.5rem;
    }
    .mc-tech-specs__included {
      grid-template-columns: 0.9fr 1.1fr;
      gap: 3rem;
      margin-bottom: 4rem;
      padding-bottom: 3.5rem;
    }
    .mc-tech-specs__included-media img {
      max-width: 100%;
    }
    .mc-tech-specs__included-title {
      font-size: 1.85rem;
    }
    .mc-tech-specs__included-list li {
      font-size: 1rem;
    }
    .mc-tech-specs__group-title {
      font-size: 1.55rem;
    }
    .mc-tech-specs__group-body {
      font-size: 1rem;
      max-width: 720px;
    }
  }
</style>

{% schema %}
{
  "name": "Tech specs",
  "tag": "section",
  "class": "section-tech-specs",
  "settings": [
    {
      "type": "header",
      "content": "Top row: What's Included"
    },
    {
      "type": "image_picker",
      "id": "included_image",
      "label": "Charger / kit image"
    },
    {
      "type": "text",
      "id": "included_heading",
      "label": "Heading",
      "default": "What's Included"
    },
    {
      "type": "textarea",
      "id": "included_items",
      "label": "Items (one per line)",
      "default": "Mend N°01 Smart Ring\nSize-specific charger\nUSB-C cable\nQuick start guide"
    },
    {
      "type": "header",
      "content": "Tech specifications heading"
    },
    {
      "type": "text",
      "id": "specs_heading",
      "label": "Heading",
      "default": "Tech Specifications"
    }
  ],
  "blocks": [
    {
      "type": "spec_group",
      "name": "Spec group",
      "limit": 12,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "heart", "label": "Heart (sensors)" },
            { "value": "check", "label": "Check (compatibility)" },
            { "value": "weight", "label": "Box (weight & dimensions)" },
            { "value": "battery", "label": "Battery (battery life)" },
            { "value": "ring", "label": "Ring (materials)" },
            { "value": "shield", "label": "Shield (warranty)" },
            { "value": "bluetooth", "label": "Bluetooth (connectivity)" }
          ],
          "default": "heart"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Sensors"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<ul><li>Sensor 1</li><li>Sensor 2</li></ul>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tech specs",
      "blocks": [
        { "type": "spec_group", "settings": { "icon": "heart", "heading": "Sensors" } },
        { "type": "spec_group", "settings": { "icon": "check", "heading": "Compatibility" } },
        { "type": "spec_group", "settings": { "icon": "weight", "heading": "Weight & dimensions" } },
        { "type": "spec_group", "settings": { "icon": "battery", "heading": "Battery life" } },
        { "type": "spec_group", "settings": { "icon": "ring", "heading": "Quality materials" } }
      ]
    }
  ]
}
{% endschema %}
