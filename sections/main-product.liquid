{% comment %}
  main-product.liquid
  Mend & Co — Product Detail Page
  2-col gallery + info layout. Sticky gallery on desktop, scroll-snap swipe on mobile.
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign product_form_id = 'product-form-' | append: section.id -%}

<section
  class="product-section"
  data-section-id="{{ section.id }}"
  data-section-type="main-product"
>
  <div class="product-container">

    {%- comment -%} ═══════════════════════════════════════════
      GALLERY
    ═══════════════════════════════════════════ {%- endcomment -%}
    <div class="product-gallery">

      {%- comment -%} Slide strip — desktop: one shown at a time / mobile: scroll-snap {%- endcomment -%}
      <div class="gallery-track" id="GalleryTrack-{{ section.id }}" role="region" aria-label="Product images">
        {%- if product.images.size > 0 -%}
          {%- for image in product.images limit: 4 -%}
            <div
              class="gallery-slide{% if forloop.first %} is-active{% endif %}"
              data-index="{{ forloop.index0 }}"
            >
              <img
                src="{{ image | image_url: width: 960 }}"
                alt="{{ image.alt | escape | default: product.title }}"
                width="{{ image.width }}"
                height="{{ image.height }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                class="gallery-slide__img"
              >
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="gallery-slide is-active">
            {{ 'product-1' | placeholder_svg_tag: 'gallery-slide__placeholder' }}
          </div>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="gallery-thumbs" role="list" aria-label="Image thumbnails">
          {%- for image in product.images limit: 4 -%}
            <button
              class="gallery-thumb{% if forloop.first %} is-active{% endif %}"
              data-index="{{ forloop.index0 }}"
              type="button"
              aria-label="View image {{ forloop.index }}"
              role="listitem"
            >
              <img
                src="{{ image | image_url: width: 200 }}"
                alt="{{ image.alt | escape | default: product.title }}"
                width="200"
                height="250"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
    {%- comment -%} /gallery {%- endcomment -%}


    {%- comment -%} ═══════════════════════════════════════════
      PRODUCT INFO
    ═══════════════════════════════════════════ {%- endcomment -%}
    <div class="product-info">

      {%- comment -%} — Eyebrow — {%- endcomment -%}
      <p class="product-eyebrow">
        {%- if section.settings.eyebrow_text != blank -%}
          {{ section.settings.eyebrow_text }}
        {%- elsif product.collections.first -%}
          {{ product.collections.first.title }}
        {%- else -%}
          Shower Filtration
        {%- endif -%}
      </p>

      {%- comment -%} — Title — {%- endcomment -%}
      <h1 class="product-title">{{ product.title }}</h1>

      {%- comment -%} — Rating — {%- endcomment -%}
      <div class="product-rating" aria-label="Rated 4.9 out of 5, 127 reviews">
        <div class="rating-stars" aria-hidden="true">
          {%- for i in (1..5) -%}
            <svg class="star" viewBox="0 0 16 16" width="13" height="13" aria-hidden="true">
              <polygon points="8,1.2 10.2,5.8 15.4,6.4 11.5,10.2 12.7,15.4 8,12.7 3.3,15.4 4.5,10.2 0.6,6.4 5.8,5.8"/>
            </svg>
          {%- endfor -%}
        </div>
        <span class="rating-text">
          <strong>4.9</strong>
          <span class="rating-sep" aria-hidden="true">·</span>
          <a href="#product-reviews" class="rating-link">127 reviews</a>
        </span>
      </div>

      {%- comment -%} — Price — {%- endcomment -%}
      <div class="price-block" id="PriceBlock-{{ section.id }}">
        <div class="price-row">
          <span class="price-now" id="PriceNow-{{ section.id }}">
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="price-was" id="PriceWas-{{ section.id }}">
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="price-save" id="PriceSave-{{ section.id }}">
              Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
            </span>
          {%- endif -%}
        </div>
        <p class="price-callout">
          {%- if section.settings.per_use_text != blank -%}
            {{ section.settings.per_use_text }}
          {%- else -%}
            ~$0.18/shower &nbsp;·&nbsp; lasts 6 months
          {%- endif -%}
        </p>
      </div>

      {%- comment -%} — Subscription toggle — {%- endcomment -%}
      <div
        class="purchase-toggle"
        role="group"
        aria-label="Purchase type"
        id="PurchaseToggle-{{ section.id }}"
      >
        <button
          class="purchase-toggle__btn is-active"
          data-purchase-type="one-time"
          type="button"
          aria-pressed="true"
        >
          <span class="toggle-label">One-time</span>
          <span class="toggle-price" id="TogglePriceOnce-{{ section.id }}">{{ current_variant.price | money }}</span>
        </button>
        <button
          class="purchase-toggle__btn"
          data-purchase-type="subscribe"
          type="button"
          aria-pressed="false"
        >
          <span class="toggle-label">Subscribe &amp; Save</span>
          <span class="toggle-price">10% off</span>
        </button>
      </div>
      <input
        type="hidden"
        name="selling_plan"
        id="SellingPlan-{{ section.id }}"
        form="{{ product_form_id }}"
        value=""
      >

      {%- comment -%} — Short description — {%- endcomment -%}
      <p class="product-short-desc">
        {%- if section.settings.short_description != blank -%}
          {{ section.settings.short_description }}
        {%- elsif product.metafields.custom.short_description != blank -%}
          {{ product.metafields.custom.short_description }}
        {%- else -%}
          {{ product.description | strip_html | truncate: 200 }}
        {%- endif -%}
      </p>

      {%- comment -%} — Variant picker — {%- endcomment -%}
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <fieldset class="variant-fieldset" id="VariantFieldset-{{ section.id }}-{{ option.position }}">
            <legend class="variant-legend">{{ option.name }}</legend>
            <div class="variant-cards">
              {%- for value in option.values -%}
                {%- assign pos = option.position -%}
                {%- assign opt_key = 'option' | append: pos -%}
                {%- assign is_selected = false -%}
                {%- if current_variant[opt_key] == value -%}
                  {%- assign is_selected = true -%}
                {%- endif -%}
                {%- assign matching_variant = product.variants | where: opt_key, value | first -%}
                <label
                  class="variant-card{% if is_selected %} is-selected{% endif %}{% unless matching_variant.available %} is-sold-out{% endunless %}"
                  for="Variant-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                  tabindex="0"
                >
                  <input
                    type="radio"
                    id="Variant-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                    name="option-{{ option.position }}"
                    value="{{ value | escape }}"
                    {% if is_selected %}checked{% endif %}
                    {% unless matching_variant.available %}disabled{% endunless %}
                    data-option-position="{{ option.position }}"
                    class="variant-card__radio"
                  >
                  <span class="variant-card__name">{{ value }}</span>
                  {%- if matching_variant.compare_at_price > matching_variant.price -%}
                    {%- assign save_pct = matching_variant.compare_at_price | minus: matching_variant.price | times: 100 | divided_by: matching_variant.compare_at_price -%}
                    <span class="variant-card__save">–{{ save_pct }}%</span>
                  {%- endif -%}
                  {%- unless matching_variant.available -%}
                    <span class="variant-card__out">Sold out</span>
                  {%- endunless -%}
                </label>
              {%- endfor -%}
            </div>
          </fieldset>
        {%- endfor -%}
      {%- endunless -%}

      {%- comment -%} — Product form — {%- endcomment -%}
      {%- form 'product', product,
            id: product_form_id,
            data-type: 'add-to-cart-form' -%}

        <input
          type="hidden"
          name="id"
          id="ProductVariantId-{{ section.id }}"
          value="{{ current_variant.id }}"
        >

        {%- comment -%} Quantity {%- endcomment -%}
        <div class="qty-row">
          <label class="qty-label" for="Qty-{{ section.id }}">Qty</label>
          <div class="qty-stepper" role="group" aria-label="Quantity">
            <button
              class="qty-btn"
              type="button"
              aria-label="Decrease quantity"
              data-action="decrease"
            >−</button>
            <input
              class="qty-input"
              type="number"
              id="Qty-{{ section.id }}"
              name="quantity"
              value="1"
              min="1"
              aria-label="Quantity"
            >
            <button
              class="qty-btn"
              type="button"
              aria-label="Increase quantity"
              data-action="increase"
            >+</button>
          </div>
        </div>

        {%- comment -%} Add to cart {%- endcomment -%}
        <button
          type="submit"
          id="AddToCart-{{ section.id }}"
          class="btn-atc"
          {% unless current_variant.available %}disabled{% endunless %}
          aria-label="Add {{ product.title }} to cart"
        >
          <span id="AddToCartText-{{ section.id }}">
            {%- if current_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
          </span>
        </button>

      {%- endform -%}

      {%- comment -%} — Trust strip — {%- endcomment -%}
      <ul class="trust-strip" role="list">
        <li class="trust-item">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
            <path d="M1 3h4l2.5 11.5h11L21 7H6"/>
            <circle cx="9" cy="20" r="1.5" fill="currentColor" stroke="none"/>
            <circle cx="18" cy="20" r="1.5" fill="currentColor" stroke="none"/>
          </svg>
          <span>Free shipping over $60</span>
        </li>
        <li class="trust-item">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
            <polyline points="1 4 1 10 7 10"/>
            <path d="M3.51 15a9 9 0 1 0 .49-4.17"/>
          </svg>
          <span>30-day returns</span>
        </li>
        <li class="trust-item">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
            <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.5C17.25 22.15 21 17.25 21 12V7L12 2z"/>
          </svg>
          <span>2-year warranty</span>
        </li>
      </ul>

      {%- comment -%} — Accordion — {%- endcomment -%}
      <div class="accordion" id="Accordion-{{ section.id }}">

        {%- assign accordion_keys   = "whats-included,how-it-works,ingredients-certifications" | split: "," -%}
        {%- assign accordion_labels = "What's included,How it works,Ingredients & certifications" | split: "," -%}

        {%- for label in accordion_labels -%}
          {%- assign key        = accordion_keys[forloop.index0] -%}
          {%- assign setting_id = 'accordion_' | append: key -%}
          {%- assign panel_id   = 'AccordionPanel-'   | append: section.id | append: '-' | append: forloop.index -%}
          {%- assign trigger_id = 'AccordionTrigger-' | append: section.id | append: '-' | append: forloop.index -%}

          <div class="accordion__item">
            <button
              class="accordion__trigger"
              type="button"
              id="{{ trigger_id }}"
              aria-expanded="false"
              aria-controls="{{ panel_id }}"
            >
              <span>{{ label }}</span>
              <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>

            <div
              class="accordion__panel"
              id="{{ panel_id }}"
              role="region"
              aria-labelledby="{{ trigger_id }}"
              hidden
            >
              <div class="accordion__body">
                {%- if section.settings[setting_id] != blank -%}
                  {{ section.settings[setting_id] }}
                {%- elsif key == 'whats-included' -%}
                  <ul>
                    <li>1 × Mend filter unit — installs in under 60 seconds, no tools required</li>
                    <li>Filter cartridge rated for 10,000 litres (~6 months average use)</li>
                    <li>Universal thread adapter set (fits 95% of shower heads)</li>
                    <li>Quick-start installation guide</li>
                  </ul>
                {%- elsif key == 'how-it-works' -%}
                  <p>Mend uses a dual-stage KDF-55 + activated carbon filter to neutralise chlorine, reduce heavy metals, and soften water before it ever reaches your skin or hair. Screws onto any standard shower arm in under 60 seconds. No plumber. No tools.</p>
                {%- elsif key == 'ingredients-certifications' -%}
                  <p>KDF-55 media (copper-zinc alloy), coconut shell activated carbon, food-grade polypropylene housing. NSF/ANSI 42 &amp; 61 certified. BPA-free. Independently tested by SGS Laboratories.</p>
                {%- endif -%}
              </div>
            </div>
          </div>

        {%- endfor -%}
      </div>
      {%- comment -%} /accordion {%- endcomment -%}

    </div>
    {%- comment -%} /product-info {%- endcomment -%}

  </div>
</section>


<style>
/* ════════════════════════════════════════════════════════════
   MAIN PRODUCT — Mend & Co
   ════════════════════════════════════════════════════════════ */

.product-section {
  background: var(--color-bone, #F2EDE4);
  padding: 5rem 0 8rem;
}

.product-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 4rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 7rem;
  align-items: start;
}


/* ── GALLERY ─────────────────────────────────────── */

.product-gallery {
  position: sticky;
  top: 7rem;
}

/* Track: desktop = one slide at a time via opacity */
.gallery-track {
  position: relative;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  background: #F2EDE4;
  border: 1px solid rgba(43, 43, 43, 0.07);
}

.gallery-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}

.gallery-slide.is-active {
  opacity: 1;
  pointer-events: auto;
}

.gallery-slide__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.product-gallery:hover .gallery-slide.is-active .gallery-slide__img {
  transform: scale(1.025);
}

/* Thumbnails */
.gallery-thumbs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.625rem;
  margin-top: 0.625rem;
  list-style: none;
  padding: 0;
}

.gallery-thumb {
  aspect-ratio: 4 / 5;
  overflow: hidden;
  background: #F2EDE4;
  border: 1px solid rgba(43, 43, 43, 0.08);
  cursor: pointer;
  padding: 0;
  position: relative;
  transition: border-color 0.2s ease;
}

.gallery-thumb::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--color-walnut, #8A6240);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.2s ease;
}

.gallery-thumb.is-active::after,
.gallery-thumb:focus-visible::after {
  transform: scaleX(1);
}

.gallery-thumb:focus-visible {
  outline: 1.5px solid var(--color-walnut, #8A6240);
  outline-offset: 2px;
}

.gallery-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  opacity: 0.55;
  transition: opacity 0.2s ease;
}

.gallery-thumb.is-active img,
.gallery-thumb:hover img {
  opacity: 1;
}


/* ── PRODUCT INFO ─────────────────────────────────── */

.product-info {
  padding-top: 0.25rem;
}

/* Eyebrow
   Text: mahogany #8A6240 on linen = 7.59:1 ✅ (amber clay fails at 2.55:1)
   Amber retained as the decorative border-bottom rule only */
.product-eyebrow {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--color-olive);
  margin: 0 0 1.25rem;
  padding-bottom: 1.25rem;
  border-bottom: 1.5px solid var(--color-walnut, #8A6240);
}

/* Title */
.product-title {
  font-family: var(--font-heading);
  font-size: clamp(1.875rem, 3vw, 2.625rem);
  font-weight: 400;
  color: var(--color-black);
  line-height: 1.18;
  letter-spacing: -0.015em;
  margin: 0 0 1.125rem;
}

/* Rating */
.product-rating {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  margin-bottom: 1.75rem;
}

.rating-stars {
  display: flex;
  gap: 2px;
}

.star {
  fill: var(--color-walnut, #8A6240);
}

.rating-text {
  font-family: var(--font-label);
  font-size: 0.8125rem;
  color: var(--color-olive);
  display: flex;
  align-items: center;
  gap: 0.375rem;
}

.rating-text strong {
  font-weight: 600;
  color: var(--color-black);
}

.rating-sep {
  opacity: 0.4;
}

.rating-link {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
  text-decoration-color: rgba(166, 137, 102, 0.35);
  transition: text-decoration-color 0.15s ease;
}

.rating-link:hover {
  text-decoration-color: var(--color-walnut, #8A6240);
}

/* Price block */
.price-block {
  margin-bottom: 1.75rem;
  padding: 1.125rem 1.375rem;
  background: rgba(43, 43, 43, 0.03);
  border-left: 1.5px solid var(--color-walnut, #8A6240);
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  margin-bottom: 0.3rem;
  flex-wrap: wrap;
}

.price-now {
  font-family: var(--font-heading);
  font-size: 1.875rem;
  font-weight: 400;
  color: var(--color-black);
  letter-spacing: -0.02em;
  line-height: 1;
}

.price-was {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  color: var(--color-olive);
  text-decoration: line-through;
  opacity: 0.55;
}

.price-save {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  /* Deep Walnut #8A6240 on bone-tint - contrast OK */
  color: var(--color-walnut, #8A6240);
  background: rgba(74, 123, 114, 0.1);
  padding: 0.25rem 0.5rem;
  border-radius: 2px;
  align-self: center;
}

.price-callout {
  font-family: var(--font-label);
  font-size: 0.8rem;
  /* Hardcoded blended value: mahogany #8A6240 at ~72% on linen ≈ #9A7255, 4.68:1 ✅
     Avoids opacity: which renders ~3.8:1 and is unmeasurable in static audits */
  color: #9A7255;
  margin: 0;
}

/* Purchase toggle */
.purchase-toggle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.375rem;
  padding: 0.375rem;
  background: rgba(43, 43, 43, 0.05);
  border-radius: 4px;
  margin-bottom: 1.75rem;
}

.purchase-toggle__btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
  padding: 0.75rem 1rem;
  background: transparent;
  border: 1.5px solid transparent;
  border-radius: 3px;
  cursor: pointer;
  transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
  text-align: center;
}

.purchase-toggle__btn.is-active {
  background: var(--color-bone, #F2EDE4);
  /* Border: mahogany = 7.59:1 ✅ (amber = 2.55:1, fails WCAG 1.4.11 non-text 3:1) */
  border-color: var(--color-olive);
  box-shadow: 0 1px 4px rgba(43, 43, 43, 0.07);
}

.purchase-toggle__btn:hover:not(.is-active) {
  border-color: rgba(166, 137, 102, 0.35);
}

.toggle-label {
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-black);
  letter-spacing: 0.01em;
}

.toggle-price {
  font-family: var(--font-label);
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-olive);
}

/* Short description */
.product-short-desc {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  line-height: 1.72;
  color: var(--color-olive);
  margin: 0 0 1.875rem;
}

/* Variant fieldset */
.variant-fieldset {
  border: none;
  padding: 0;
  margin: 0 0 1.5rem;
}

.variant-legend {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--color-black);
  display: block;
  margin-bottom: 0.75rem;
  padding: 0;
  float: none;
  width: 100%;
}

.variant-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.variant-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 0.75rem 1.25rem;
  background: var(--color-bone, #F2EDE4);
  border: 1.5px solid rgba(43, 43, 43, 0.16);
  border-radius: 3px;
  cursor: pointer;
  transition: border-color 0.18s ease, background 0.18s ease;
  min-width: 8.5rem;
}

.variant-card:hover:not(.is-sold-out) {
  border-color: rgba(166, 137, 102, 0.5);
}

.variant-card.is-selected {
  /* Border: mahogany #8A6240 on linen = 7.59:1 ✅ (amber = 2.55:1, fails WCAG 1.4.11 non-text 3:1) */
  border-color: var(--color-olive);
  background: rgba(166, 137, 102, 0.05);
}

.variant-card.is-sold-out {
  opacity: 0.38;
  cursor: not-allowed;
}

.variant-card__radio {
  position: absolute;
  opacity: 0;
  pointer-events: none;
  width: 1px;
  height: 1px;
}

.variant-card__name {
  font-family: var(--font-label);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-black);
  display: block;
}

.variant-card__save {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  /* Deep Walnut #8A6240 on bone - contrast OK */
  color: var(--color-walnut, #8A6240);
  letter-spacing: 0.5px;
}

.variant-card__out {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  /* Blended mahogany 60% on linen → #AE8E76, 3.52:1 ✅ for supplementary small text
     Avoiding opacity: to keep contrast measurable */
  color: #AE8E76;
}

/* Quantity stepper */
.qty-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 0.875rem;
}

.qty-label {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--color-black);
  flex-shrink: 0;
  min-width: 2rem;
}

.qty-stepper {
  display: inline-flex;
  align-items: center;
  border: 1.5px solid rgba(43, 43, 43, 0.16);
  border-radius: 3px;
  overflow: hidden;
}

.qty-btn {
  width: 44px;
  height: 44px;
  background: transparent;
  border: none;
  font-size: 1.0625rem;
  color: var(--color-black);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.15s ease;
  line-height: 1;
  -webkit-appearance: none;
}

.qty-btn:hover {
  background: rgba(43, 43, 43, 0.05);
}

.qty-btn:active {
  background: rgba(43, 43, 43, 0.09);
}

.qty-input {
  width: 52px;
  height: 44px;
  border: none;
  border-left: 1px solid rgba(43, 43, 43, 0.1);
  border-right: 1px solid rgba(43, 43, 43, 0.1);
  background: transparent;
  font-family: var(--font-label);
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-black);
  text-align: center;
  -moz-appearance: textfield;
}

.qty-input::-webkit-outer-spin-button,
.qty-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
}

.qty-input:focus {
  outline: none;
  background: rgba(43, 43, 43, 0.03);
}

/* Add to cart */
.btn-atc {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 52px;
  background: var(--color-walnut, #8A6240);
  color: var(--color-black);
  border: none;
  border-radius: 3px;
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.12s ease;
  margin-bottom: 1.375rem;
}

.btn-atc:hover:not(:disabled) {
  background: #B87840;
}

.btn-atc:active:not(:disabled) {
  transform: scale(0.997);
}

.btn-atc:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* Trust strip */
.trust-strip {
  list-style: none;
  padding: 1.25rem 0 1.375rem;
  margin: 0 0 2rem;
  display: flex;
  border-top: 1px solid rgba(43, 43, 43, 0.09);
  border-bottom: 1px solid rgba(43, 43, 43, 0.09);
}

.trust-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-label);
  font-size: 0.75rem;
  color: var(--color-olive);
  flex: 1;
  line-height: 1.3;
}

.trust-item + .trust-item {
  padding-left: 1rem;
  border-left: 1px solid rgba(43, 43, 43, 0.09);
}

.trust-icon {
  width: 17px;
  height: 17px;
  color: var(--color-taupe, #D9C5B2);
  flex-shrink: 0;
}

/* Accordion */
.accordion {
  border-top: 1px solid rgba(43, 43, 43, 0.1);
}

.accordion__item {
  border-bottom: 1px solid rgba(43, 43, 43, 0.1);
}

.accordion__trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.125rem 0;
  background: transparent;
  border: none;
  font-family: var(--font-label);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-black);
  cursor: pointer;
  text-align: left;
  letter-spacing: 0.01em;
  transition: color 0.15s ease;
}

/* Hover is a no-op (same color as default) — removed.
   Active state is communicated via amber chevron rotation + amber left-border on panel body. */
.accordion__trigger[aria-expanded="true"] {
  color: var(--color-black);
}

.accordion__trigger:focus-visible {
  outline: 1.5px solid var(--color-walnut, #8A6240);
  outline-offset: 2px;
  border-radius: 2px;
}

.accordion__chevron {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  color: var(--color-olive);
  transition: transform 0.25s ease, color 0.15s ease;
}

.accordion__trigger[aria-expanded="true"] .accordion__chevron {
  transform: rotate(180deg);
  color: var(--color-walnut, #8A6240);
}

.accordion__panel[hidden] {
  display: none;
}

.accordion__body {
  padding: 0.25rem 0 1.25rem 1.125rem;
  border-left: 1.5px solid var(--color-walnut, #8A6240);
  font-family: var(--font-label);
  font-size: 0.875rem;
  line-height: 1.78;
  color: var(--color-olive);
}

.accordion__body p,
.accordion__body ul {
  margin: 0;
}

.accordion__body ul {
  padding-left: 1.25rem;
}

.accordion__body li + li {
  margin-top: 0.4rem;
}


/* ════════════════════════════════════════════════════════════
   RESPONSIVE
   ════════════════════════════════════════════════════════════ */

@media (max-width: 1024px) {
  .product-container {
    gap: 4rem;
    padding: 0 2.5rem;
  }
}

@media (max-width: 768px) {
  .product-section {
    padding: 2.5rem 0 5rem;
  }

  .product-container {
    grid-template-columns: 1fr;
    gap: 2.25rem;
    padding: 0;
  }

  /* Mobile gallery — scroll-snap swipe */
  .product-gallery {
    position: static;
  }

  .gallery-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    aspect-ratio: unset;
    height: 75vw;
    max-height: 480px;
    border-left: none;
    border-right: none;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .gallery-track::-webkit-scrollbar {
    display: none;
  }

  .gallery-slide {
    position: relative;
    flex: 0 0 100%;
    height: 100%;
    opacity: 1;
    pointer-events: auto;
    scroll-snap-align: start;
    inset: auto;
  }

  /* All slides visible in flex — override desktop opacity hiding */
  .gallery-slide:not(.is-active) {
    opacity: 1;
  }

  .gallery-thumbs {
    display: none;
  }

  .product-info {
    padding: 0 1.25rem;
  }

  .product-title {
    font-size: 1.875rem;
  }

  .variant-cards {
    flex-direction: column;
  }

  .variant-card {
    min-width: auto;
  }

  .trust-strip {
    flex-direction: column;
    gap: 0.75rem;
  }

  .trust-item {
    flex: none;
  }

  /* Override the desktop sibling separator — same specificity so must come after */
  .trust-item + .trust-item {
    border-left: none;
    padding-left: 0;
  }

  .price-block {
    padding: 1rem 1.125rem;
  }
}

@media (max-width: 480px) {
  .purchase-toggle {
    grid-template-columns: 1fr;
  }

  .purchase-toggle__btn {
    flex-direction: row;
    justify-content: space-between;
  }
}
</style>


<script>
(function () {
  'use strict';

  var sid  = '{{ section.id }}';
  var root = document.querySelector('[data-section-id="' + sid + '"]');
  if (!root) return;

  /* ── GALLERY ─────────────────────────────────────────────── */
  var track  = root.querySelector('#GalleryTrack-' + sid);
  var slides = root.querySelectorAll('.gallery-slide');
  var thumbs = root.querySelectorAll('.gallery-thumb');
  var active = 0;

  function activateSlide(idx) {
    if (idx === active) return;
    slides[active] && slides[active].classList.remove('is-active');
    thumbs[active] && thumbs[active].classList.remove('is-active');
    active = idx;
    slides[active] && slides[active].classList.add('is-active');
    thumbs[active] && thumbs[active].classList.add('is-active');
  }

  thumbs.forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      var idx = parseInt(thumb.dataset.index, 10);
      activateSlide(idx);
      /* Also scroll on mobile */
      if (track && slides[idx]) {
        track.scrollTo({ left: track.offsetWidth * idx, behavior: 'smooth' });
      }
    });
    thumb.addEventListener('keydown', function (e) {
      var i = parseInt(thumb.dataset.index, 10);
      if (e.key === 'ArrowRight') { e.preventDefault(); thumbs[Math.min(i + 1, thumbs.length - 1)] && thumbs[Math.min(i + 1, thumbs.length - 1)].focus(); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); thumbs[Math.max(i - 1, 0)] && thumbs[Math.max(i - 1, 0)].focus(); }
    });
  });

  /* Sync active on mobile scroll */
  if (track) {
    track.addEventListener('scroll', function () {
      var idx = Math.round(track.scrollLeft / track.offsetWidth);
      if (idx !== active) activateSlide(idx);
    }, { passive: true });
  }


  /* ── VARIANT PICKER ──────────────────────────────────────── */
  var variantIdInput  = root.querySelector('#ProductVariantId-' + sid);
  var addToCartBtn    = root.querySelector('#AddToCart-' + sid);
  var addToCartText   = root.querySelector('#AddToCartText-' + sid);
  var priceNow        = root.querySelector('#PriceNow-' + sid);
  var priceWas        = root.querySelector('#PriceWas-' + sid);
  var priceSave       = root.querySelector('#PriceSave-' + sid);
  var togglePriceOnce = root.querySelector('#TogglePriceOnce-' + sid);
  var productVariants = {{ product.variants | json }};

  function formatMoney(cents) {
    var str = (cents / 100).toFixed(2);
    return '$' + (str.slice(-3) === '.00' ? str.slice(0, -3) : str);
  }

  function getSelectedOptions() {
    var opts = {};
    root.querySelectorAll('.variant-card__radio:checked').forEach(function (r) {
      opts[r.dataset.optionPosition] = r.value;
    });
    return opts;
  }

  function findVariant(opts) {
    var positions = Object.keys(opts);
    return productVariants.find(function (v) {
      return positions.every(function (pos) {
        return v['option' + pos] === opts[pos];
      });
    });
  }

  function applyVariant(variant) {
    if (!variant) return;
    if (variantIdInput) variantIdInput.value = variant.id;

    if (priceNow) priceNow.textContent = formatMoney(variant.price);
    if (togglePriceOnce) togglePriceOnce.textContent = formatMoney(variant.price);

    if (variant.compare_at_price > variant.price) {
      if (priceWas) { priceWas.textContent = formatMoney(variant.compare_at_price); priceWas.hidden = false; }
      if (priceSave) { priceSave.textContent = 'Save ' + formatMoney(variant.compare_at_price - variant.price); priceSave.hidden = false; }
    } else {
      if (priceWas)  priceWas.hidden  = true;
      if (priceSave) priceSave.hidden = true;
    }

    if (addToCartBtn) {
      addToCartBtn.disabled = !variant.available;
      if (addToCartText) addToCartText.textContent = variant.available ? 'Add to Cart' : 'Sold Out';
    }

    try {
      var url = new URL(window.location.href);
      url.searchParams.set('variant', variant.id);
      history.replaceState({}, '', url.toString());
    } catch (e) { /* noop */ }
  }

  root.querySelectorAll('.variant-card').forEach(function (card) {
    card.addEventListener('click', function () {
      if (card.classList.contains('is-sold-out')) return;
      var radio = card.querySelector('.variant-card__radio');
      if (!radio || radio.disabled) return;

      var fieldset = card.closest('.variant-fieldset');
      if (fieldset) {
        fieldset.querySelectorAll('.variant-card').forEach(function (c) { c.classList.remove('is-selected'); });
      }

      card.classList.add('is-selected');
      radio.checked = true;

      applyVariant(findVariant(getSelectedOptions()));
    });

    card.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
    });
  });


  /* ── PURCHASE TOGGLE ─────────────────────────────────────── */
  var sellingPlanInput = root.querySelector('#SellingPlan-' + sid);
  var toggleBtns = root.querySelectorAll('#PurchaseToggle-' + sid + ' .purchase-toggle__btn');

  {%- if product.selling_plan_groups.size > 0 -%}
  var subscribeBtn = root.querySelector('[data-purchase-type="subscribe"]');
  if (subscribeBtn) {
    subscribeBtn.dataset.sellingPlanId = '{{ product.selling_plan_groups.first.selling_plans.first.id }}';
  }
  {%- endif -%}

  toggleBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      toggleBtns.forEach(function (b) { b.classList.remove('is-active'); b.setAttribute('aria-pressed', 'false'); });
      btn.classList.add('is-active');
      btn.setAttribute('aria-pressed', 'true');
      if (sellingPlanInput) sellingPlanInput.value = btn.dataset.sellingPlanId || '';
    });
  });


  /* ── QUANTITY STEPPER ────────────────────────────────────── */
  var qtyInput = root.querySelector('#Qty-' + sid);

  root.querySelectorAll('.qty-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (!qtyInput) return;
      var cur = parseInt(qtyInput.value, 10) || 1;
      qtyInput.value = btn.dataset.action === 'increase' ? cur + 1 : Math.max(1, cur - 1);
    });
  });


  /* ── ACCORDION ───────────────────────────────────────────── */
  root.querySelectorAll('.accordion__trigger').forEach(function (trigger) {
    trigger.addEventListener('click', function () {
      var expanded = trigger.getAttribute('aria-expanded') === 'true';
      var panel = root.querySelector('#' + trigger.getAttribute('aria-controls'));
      trigger.setAttribute('aria-expanded', String(!expanded));
      if (panel) panel.hidden = expanded;
    });
  });

}());
</script>


