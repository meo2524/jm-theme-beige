{% comment %}
  main-product.liquid
  Mend & Co -- Product Detail Page
  2-col gallery + info layout. Sticky gallery on desktop, scroll-snap swipe on mobile.
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign product_form_id = 'product-form-' | append: section.id -%}

<section
  class="product-section"
  data-section-id="{{ section.id }}"
  data-section-type="main-product"
>
  <div class="product-container">

    {%- comment -%} ===========================================
      GALLERY — sticky left column
      carousel lives inside gallery-main so they move as one unit
    =========================================== {%- endcomment -%}
    <div class="product-gallery">

      {%- comment -%} Left: vertical thumbnail strip (desktop only) {%- endcomment -%}
      {%- if product.images.size > 1 -%}
        <div class="gallery-thumbs" id="GalleryThumbs-{{ section.id }}" role="list" aria-label="Image thumbnails">
          {%- for image in product.images limit: 8 -%}
            <button
              class="gallery-thumb{% if forloop.first %} is-active{% endif %}"
              data-index="{{ forloop.index0 }}"
              type="button"
              aria-label="View image {{ forloop.index }}"
              role="listitem"
            >
              <img
                src="{{ image | image_url: width: 160 }}"
                alt="{{ image.alt | escape | default: product.title }}"
                width="160"
                height="200"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Right: photo box + carousel stacked inside the same bordered box {%- endcomment -%}
      <div class="gallery-main">

        <div class="gallery-track" id="GalleryTrack-{{ section.id }}" role="region" aria-label="Product images">
          {%- if product.images.size > 0 -%}
            {%- for image in product.images limit: 8 -%}
              <div
                class="gallery-slide{% if forloop.first %} is-active{% endif %}"
                data-index="{{ forloop.index0 }}"
              >
                <img
                  src="{{ image | image_url: width: 960 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  width="960"
                  height="{{ image.height | times: 960 | divided_by: image.width }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  class="gallery-slide__img"
                >
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="gallery-slide is-active">
              {{ 'product-1' | placeholder_svg_tag: 'gallery-slide__placeholder' }}
            </div>
          {%- endif -%}

        </div>

        {%- if product.images.size > 1 -%}
          <button class="gallery-arrow gallery-arrow--prev" type="button" aria-label="Previous image" data-gallery-prev>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="gallery-arrow gallery-arrow--next" type="button" aria-label="Next image" data-gallery-next>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        {%- endif -%}

        {%- if product.images.size > 1 -%}
          <div class="gallery-dots" aria-hidden="true">
            {%- for image in product.images limit: 8 -%}
              <span class="gallery-dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}"></span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} Mini review carousel — inside the photo box, moves with it on scroll {%- endcomment -%}
        {%- assign mini_reviews = section.blocks | where: 'type', 'mini_testimonial' -%}
        {%- if mini_reviews.size > 0 -%}
          <div class="pdp-review-carousel" id="PdpReviewCarousel-{{ section.id }}" aria-label="Customer reviews">
            <div class="prc-track">
              {%- for block in mini_reviews -%}
                <div class="prc-slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
                  <div class="prc-stars" aria-label="{{ block.settings.stars | default: 5 }} out of 5 stars">
                    {%- assign stars = block.settings.stars | default: 5 -%}
                    {%- for i in (1..5) -%}
                      <span class="prc-star{% if i > stars %} prc-star--empty{% endif %}" aria-hidden="true">★</span>
                    {%- endfor -%}
                  </div>
                  <p class="prc-quote">{{ block.settings.quote | escape }}</p>
                  <div class="prc-footer">
                    <div class="prc-author-wrap">
                      <span class="prc-name">{{ block.settings.author | escape }}</span>
                      {%- if block.settings.verified -%}
                        <span class="prc-badge">Verified</span>
                      {%- endif -%}
                    </div>
                    {%- if block.settings.author_detail != blank -%}
                      <span class="prc-detail">{{ block.settings.author_detail | escape }}</span>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
            <div class="prc-controls">
              <button class="prc-arrow prc-arrow--prev" type="button" aria-label="Previous review">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <div class="prc-dots" aria-hidden="true">
                {%- for block in mini_reviews -%}
                  <button class="prc-dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" type="button" aria-label="Review {{ forloop.index }}"></button>
                {%- endfor -%}
              </div>
              <button class="prc-arrow prc-arrow--next" type="button" aria-label="Next review">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>
        {%- endif -%}

      </div>
      {%- comment -%} /gallery-main {%- endcomment -%}

    </div>
    {%- comment -%} /product-gallery {%- endcomment -%}

    {%- comment -%} ===========================================
      PRODUCT INFO
    =========================================== {%- endcomment -%}
    <div class="product-info">

      {%- comment -%} -- Rating (above title) -- {%- endcomment -%}
      {%- if section.settings.rating_show -%}
        <a class="product-rating" href="#product-reviews" aria-label="Rated 4.9 out of 5, 100+ reviews — scroll to reviews" onclick="event.preventDefault();var r=document.getElementById('judgeme_product_reviews');if(r)r.scrollIntoView({behavior:'smooth'});">
          <span class="rating-left">
            <div class="rating-stars" aria-hidden="true">
              {%- for i in (1..5) -%}
                <svg class="star" viewBox="0 0 16 16" width="20" height="20" aria-hidden="true" style="display:block;">
                  <polygon points="8,1.2 10.2,5.8 15.4,6.4 11.5,10.2 12.7,15.4 8,12.7 3.3,15.4 4.5,10.2 0.6,6.4 5.8,5.8"/>
                </svg>
              {%- endfor -%}
            </div>
            <span class="rating-label">Excellent</span>
            <span class="rating-value-num">4.9</span>
          </span>
          <span class="rating-divider" aria-hidden="true"></span>
          <span class="rating-count">{{ section.settings.rating_count_text | default: '100+ Happy Menders' }}</span>
        </a>
      {%- endif -%}

      {%- comment -%} -- Eyebrow (renders only when explicitly set) -- {%- endcomment -%}
      {%- if section.settings.eyebrow_text != blank -%}
        <p class="product-eyebrow">{{ section.settings.eyebrow_text }}</p>
      {%- endif -%}

      {%- comment -%} -- Title -- {%- endcomment -%}
      <h1 class="product-title">{{ product.title }}{%- if section.settings.model_badge != blank %} <span class="product-title__model">{{ section.settings.model_badge }}</span>{%- endif -%}</h1>

      {%- comment -%} -- Simple benefits list (arrow bullets) -- {%- endcomment -%}
      {%- assign benefits_raw = section.settings.benefits_list | default: '' -%}
      {%- if benefits_raw != blank -%}
        {%- assign benefits_items = benefits_raw | newline_to_br | split: '<br />' -%}
        <ul class="pdp-simple-benefits">
          {%- for item in benefits_items -%}
            {%- assign item_clean = item | strip -%}
            {%- if item_clean != blank -%}
              <li>{{ item_clean }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

{%- comment -%} -- Product badges -- {%- endcomment -%}
      {%- assign pdp_is_hot = false -%}
      {%- if product.tags contains 'Hot' -%}{%- assign pdp_is_hot = true -%}{%- endif -%}
      {%- assign pdp_on_sale = false -%}
      {%- if current_variant.compare_at_price > current_variant.price -%}{%- assign pdp_on_sale = true -%}{%- endif -%}
      {%- if pdp_on_sale or pdp_is_hot -%}
        <div class="pdp-badges" data-reveal data-reveal-delay="0">
          {%- if pdp_on_sale -%}
            <span class="badge badge--amber">Sale Ends Tonight</span>
          {%- endif -%}
          {%- if pdp_is_hot -%}
            <span class="badge badge--hot">Hot</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} -- Price -- {%- endcomment -%}
      <div class="price-block" id="PriceBlock-{{ section.id }}" data-reveal data-reveal-delay="0">
        <div class="price-row">
          <span class="price-now{% if current_variant.compare_at_price > current_variant.price %} price-now--on-sale{% endif %}" id="PriceNow-{{ section.id }}">
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="price-was" id="PriceWas-{{ section.id }}">
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="price-save" id="PriceSave-{{ section.id }}">
              Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
            </span>
          {%- endif -%}
        </div>
        <p class="price-callout">
          {%- if product.metafields.custom.per_use_callout != blank -%}
            {{ product.metafields.custom.per_use_callout }}
          {%- elsif section.settings.per_use_text != blank -%}
            {{ section.settings.per_use_text }}
          {%- endif -%}
        </p>
      </div>

      {%- comment -%} -- Subscription toggle (only when selling plans are configured) -- {%- endcomment -%}
      {%- if product.selling_plan_groups.size > 0 -%}
        {%- liquid
          assign sp_group = product.selling_plan_groups.first
          assign sp       = sp_group.selling_plans.first
          assign sp_adj   = sp.price_adjustments.first

          assign subscribe_label = sp_group.name | default: section.settings.toggle_subscribe_label | default: 'Subscribe & Save'

          if sp_adj.value_type == 'percentage'
            assign subscribe_badge = sp_adj.value | append: '% off'
          elsif sp_adj.value_type == 'fixed_amount'
            assign subscribe_badge = sp_adj.value | money | append: ' off'
          else
            assign subscribe_badge = section.settings.toggle_subscribe_savings | default: '10% off'
          endif
        -%}
        <div
          class="purchase-toggle"
          role="group"
          aria-label="Purchase type"
          id="PurchaseToggle-{{ section.id }}"
        >
          <button
            class="purchase-toggle__btn is-active"
            data-purchase-type="one-time"
            type="button"
            aria-pressed="true"
          >
            <span class="toggle-label">{{ section.settings.toggle_onetime_label | default: 'One-time' }}</span>
            <span class="toggle-price" id="TogglePriceOnce-{{ section.id }}">{{ current_variant.price | money }}</span>
          </button>
          <button
            class="purchase-toggle__btn"
            data-purchase-type="subscribe"
            type="button"
            aria-pressed="false"
          >
            <span class="toggle-label">{{ subscribe_label | escape }}</span>
            <span class="toggle-price">{{ subscribe_badge | escape }}</span>
          </button>
        </div>
      {%- endif -%}
      <input
        type="hidden"
        name="selling_plan"
        id="SellingPlan-{{ section.id }}"
        form="{{ product_form_id }}"
        value=""
      >

      {%- comment -%} -- Short description / product description -- {%- endcomment -%}
      {%- assign blurb_heading    = product.metafields.custom.blurb_heading    | default: section.settings.blurb_heading -%}
      {%- assign blurb_subheading = product.metafields.custom.blurb_subheading | default: section.settings.blurb_subheading -%}
      {%- assign blurb_body = product.metafields.custom.short_description | default: section.settings.short_description -%}
      {%- if blurb_heading != blank or blurb_subheading != blank or blurb_body != blank -%}
        <div class="product-blurb">
          {%- if blurb_heading != blank -%}
            <p class="product-blurb__heading">{{ blurb_heading }}</p>
          {%- endif -%}
          {%- if blurb_subheading != blank -%}
            <p class="product-blurb__subhead">{{ blurb_subheading }}</p>
          {%- endif -%}
          <div class="product-blurb__body">{{ blurb_body }}</div>
        </div>
      {%- endif -%}
      {%- if product.description != blank -%}
        <div class="product-description rte">{{ product.description }}</div>
      {%- endif -%}


{%- comment -%} -- Bundle selector (renders in-form when block added via theme editor) -- {%- endcomment -%}
<div style="display:none" aria-hidden="true">
{%- for block in section.blocks -%}
  {%- if block.type == 'bundle_selector' -%}
    {%- render 'bundle-selector', block: block, product: product, section: section -%}
  {%- endif -%}
{%- endfor -%}
</div>

{%- comment -%} -- Variant picker -- {%- endcomment -%}
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <fieldset class="variant-fieldset" id="VariantFieldset-{{ section.id }}-{{ option.position }}">
            <legend class="variant-legend">{{ option.name }}</legend>
            <div class="variant-cards">
              {%- for value in option.values -%}
                {%- assign pos = option.position -%}
                {%- assign opt_key = 'option' | append: pos -%}
                {%- assign is_selected = false -%}
                {%- if current_variant[opt_key] == value -%}
                  {%- assign is_selected = true -%}
                {%- endif -%}
                {%- assign matching_variant = product.variants | where: opt_key, value | first -%}
                <label
                  class="variant-card{% if is_selected %} is-selected{% endif %}{% unless matching_variant.available %} is-sold-out{% endunless %}"
                  for="Variant-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                  tabindex="0"
                >
                  <input
                    type="radio"
                    id="Variant-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                    name="option-{{ option.position }}"
                    value="{{ value | escape }}"
                    {% if is_selected %}checked{% endif %}
                    {% unless matching_variant.available %}disabled{% endunless %}
                    data-option-position="{{ option.position }}"
                    class="variant-card__radio"
                  >
                  <span class="variant-card__name">{{ value }}</span>
                  {%- unless matching_variant.available -%}
                    <span class="variant-card__out">{{ section.settings.variant_sold_out_label | default: 'Sold out' | escape }}</span>
                  {%- endunless -%}
                </label>
              {%- endfor -%}
            </div>
          </fieldset>
        {%- endfor -%}
      {%- endunless -%}

      {%- comment -%} -- Product form -- {%- endcomment -%}
      {%- form 'product', product,
            id: product_form_id,
            data-type: 'add-to-cart-form' -%}

        <input
          type="hidden"
          name="id"
          id="ProductVariantId-{{ section.id }}"
          value="{{ current_variant.id }}"
        >

        {%- comment -%} Quantity {%- endcomment -%}
        <div class="qty-row">
          <label class="qty-label" for="Qty-{{ section.id }}">{{ section.settings.qty_label | default: 'Qty' | escape }}</label>
          <div class="qty-stepper" role="group" aria-label="Quantity">
            <button
              class="qty-btn"
              type="button"
              aria-label="Decrease quantity"
              data-action="decrease"
            >-</button>
            <input
              class="qty-input"
              type="number"
              id="Qty-{{ section.id }}"
              name="quantity"
              value="1"
              min="1"
              aria-label="Quantity"
            >
            <button
              class="qty-btn"
              type="button"
              aria-label="Increase quantity"
              data-action="increase"
            >+</button>
          </div>
        </div>

        {%- comment -%} Find your size CTA — primary-styled, opens ring-size modal {%- endcomment -%}
        {%- if section.settings.show_size_guide != false -%}
        <button type="button" class="pdp-find-size-cta" data-size-guide data-open-size-modal aria-label="Open ring size guide">
          <span class="pdp-find-size-cta__inner">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M3 8l4-4 14 14-4 4z"/>
              <path d="M7 12l2 2M11 8l2 2M15 4l2 2"/>
            </svg>
            <span>Find your size</span>
          </span>
          <svg class="pdp-find-size-cta__chev" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="9 6 15 12 9 18"/>
          </svg>
        </button>
        {%- endif -%}

        {%- comment -%} Add to cart {%- endcomment -%}
        <button
          type="submit"
          id="AddToCart-{{ section.id }}"
          class="btn-atc{% if settings.motion_enabled %} mc-shine{% endif %}"
          {% unless current_variant.available %}disabled{% endunless %}
          aria-label="Add {{ product.title }} to cart"
        >
          <span id="AddToCartText-{{ section.id }}">
            {%- if current_variant.available -%}
              {{ section.settings.atc_label | default: 'Add to Cart' | escape }}
            {%- else -%}
              {{ section.settings.atc_sold_out_label | default: 'Sold Out' | escape }}
            {%- endif -%}
          </span>
        </button>

        <div class="pdp-payment-btns" data-pdp-payment-btns>
          {{ form | payment_button }}
        </div>

      {%- endform -%}

      {%- comment -%} -- Guarantee + payment methods strip -- {%- endcomment -%}
      {%- comment -%} -- Free shipping urgency strip -- {%- endcomment -%}
      <div class="pdp-shipping" data-reveal data-reveal-delay="300">
        <svg class="pdp-shipping__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <rect x="1" y="6" width="14" height="11" rx="1"/>
          <path d="M15 9h4l3 3v5h-7"/>
          <circle cx="6" cy="19" r="2"/>
          <circle cx="18" cy="19" r="2"/>
        </svg>
        <span class="pdp-shipping__text">
          {%- assign shipping_label = section.settings.shipping_label | default: 'Free shipping.' -%}
          {%- assign shipping_sub   = section.settings.shipping_subtext | default: 'Ships within 24 hours — start mending ASAP.' -%}
          <strong>{{ shipping_label }}</strong>
          {{ shipping_sub }}
        </span>
      </div>

      <div class="pdp-guarantee" data-reveal data-reveal-delay="320">
        <svg class="pdp-guarantee__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="10"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <span class="pdp-guarantee__text">
          {%- assign guarantee_label = section.settings.guarantee_label | default: '30-day money-back guarantee.' -%}
          {%- assign guarantee_sub   = section.settings.guarantee_subtext | default: "Wear it for 30 nights. If it’s not for you, send it back for a full refund — no questions." -%}
          <strong>{{ guarantee_label }}</strong>
          {{ guarantee_sub }}
        </span>
      </div>

      {%- if section.settings.show_secure_checkout != false -%}
      <div class="pdp-payments" aria-label="Accepted payment methods">
        <span class="pdp-payments__label">Secure checkout</span>
        <ul class="pdp-payments__icons" role="list">
          {%- comment -%}
            shop.enabled_payment_types reflects exactly what's enabled in
            Shopify Admin → Settings → Payments. No Apple Pay if you're not
            on a payment provider that supports it, etc.
          {%- endcomment -%}
          {%- for method in shop.enabled_payment_types -%}
            <li class="pdp-payments__icon">{{ method | payment_type_svg_tag }}</li>
          {%- endfor -%}
        </ul>
      </div>
      {%- endif -%}

      {%- comment -%} -- Trust strip -- {%- endcomment -%}
      {%- assign t1 = section.settings.trust_1_text | default: '' -%}
      {%- assign t2 = section.settings.trust_2_text | default: '' -%}
      {%- assign t3 = section.settings.trust_3_text | default: '' -%}
      {%- if t1 != blank or t2 != blank or t3 != blank -%}
      <ul class="trust-strip" aria-label="Trust signals">
        {%- if t1 != blank -%}
        <li class="trust-item">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="6" width="14" height="11" rx="1"/><path d="M15 9h4l3 3v5h-7"/><circle cx="6" cy="19" r="2"/><circle cx="18" cy="19" r="2"/></svg>
          {{ t1 }}
        </li>
        {%- endif -%}
        {%- if t2 != blank -%}
        <li class="trust-item">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg>
          {{ t2 }}
        </li>
        {%- endif -%}
        {%- if t3 != blank -%}
        <li class="trust-item">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {{ t3 }}
        </li>
        {%- endif -%}
      </ul>
      {%- endif -%}

      {%- comment -%} -- Accordion -- {%- endcomment -%}
      <div class="accordion" id="Accordion-{{ section.id }}">

        {%- assign accordion_keys = "whats-included,how-it-works,ingredients-certifications" | split: "," -%}
        {%- comment -%}
          Use a sentinel for blank labels so the loop can detect "skip this entry"
          after the split. Templates set a setting to "" to remove that accordion
          item entirely (label-based skip — see filter below).
        {%- endcomment -%}
        {%- assign label_1 = section.settings.accordion_label_1 -%}
        {%- if label_1 == blank -%}{%- assign label_1 = "What's included" -%}{%- endif -%}
        {%- assign label_2 = section.settings.accordion_label_2 -%}
        {%- if label_2 == blank -%}{%- assign label_2 = "__SKIP__" -%}{%- endif -%}
        {%- assign label_3 = section.settings.accordion_label_3 -%}
        {%- if label_3 == blank -%}{%- assign label_3 = "Ingredients & certifications" -%}{%- endif -%}
        {%- assign accordion_labels = label_1 | append: "|||" | append: label_2 | append: "|||" | append: label_3 | split: "|||" -%}

        {%- for label in accordion_labels -%}
          {%- assign key        = accordion_keys[forloop.index0] -%}
          {%- assign setting_id = 'accordion_' | append: key -%}
          {%- assign panel_id   = 'AccordionPanel-'   | append: section.id | append: '-' | append: forloop.index -%}
          {%- assign trigger_id = 'AccordionTrigger-' | append: section.id | append: '-' | append: forloop.index -%}
          {%- comment -%} Per-product metafield overrides section setting {%- endcomment -%}
          {%- assign mf_panel = '' -%}
          {%- if forloop.index0 == 0 -%}
            {%- assign mf_panel = product.metafields.custom.whats_included -%}
          {%- elsif forloop.index0 == 1 -%}
            {%- assign mf_panel = product.metafields.custom.how_it_works -%}
          {%- elsif forloop.index0 == 2 -%}
            {%- assign mf_panel = product.metafields.custom.ingredients_certifications -%}
          {%- endif -%}

          {%- comment -%}
            Decide if this accordion item should render.
            - If body content (metafield OR section setting) is blank AND
              the label doesn't reference a size guide, skip the item
              entirely. This lets templates (e.g. smart-band) opt out
              of items by leaving their content blank.
            - Items whose label contains "size" or "size guide" still
              render even with blank content because the size-modal JS
              intercepts the click and opens the modal instead.
          {%- endcomment -%}
          {%- comment -%} Sentinel from blank setting → skip this accordion entry entirely. {%- endcomment -%}
          {%- if label == "__SKIP__" -%}{%- continue -%}{%- endif -%}
          {%- assign label_lower = label | downcase -%}
          {%- assign is_size_trigger = false -%}
          {%- if label_lower contains 'size' -%}{%- assign is_size_trigger = true -%}{%- endif -%}
          {%- assign has_content = false -%}
          {%- if mf_panel != blank or section.settings[setting_id] != blank -%}{%- assign has_content = true -%}{%- endif -%}
          {%- unless has_content or is_size_trigger -%}{%- continue -%}{%- endunless -%}

          <div class="accordion__item{% if is_size_trigger %} accordion__item--size{% endif %}">
            <button
              class="accordion__trigger"
              type="button"
              id="{{ trigger_id }}"
              aria-expanded="false"
              aria-controls="{{ panel_id }}"
            >
              <span>{{ label }}</span>
              <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>

            <div
              class="accordion__panel"
              id="{{ panel_id }}"
              role="region"
              aria-labelledby="{{ trigger_id }}"
              hidden
            >
              <div class="accordion__body">
                {%- if mf_panel != blank -%}
                  {{ mf_panel }}
                {%- elsif section.settings[setting_id] != blank -%}
                  {{ section.settings[setting_id] }}
                {%- elsif key == 'whats-included' -%}
                  <ul>
                    <li>1 × N°01 Smart Ring (your selected size and finish)</li>
                    <li>Wireless charging cradle and USB-C cable</li>
                    <li>Quick-start guide and sizing reference</li>
                  </ul>
                {%- elsif key == 'how-it-works' -%}
                  <p>The Smart Ring reads your physiology overnight — heart rate, HRV, blood oxygen, skin temperature, and movement — then translates it into a single morning readiness score. Wear it to sleep, every night, and you'll know whether to push or rest before the day starts.</p>
                {%- elsif key == 'ingredients-certifications' -%}
                  <p>Aerospace-grade titanium core with a hypoallergenic ceramic outer shell. 5ATM water resistance. Sensors validated against medical-grade ECG and gold-standard HRV references in peer-reviewed studies.</p>
                {%- endif -%}
              </div>
            </div>
          </div>

        {%- endfor -%}

        {%- comment -%}
          'Install the app' accordion removed 2026-05-05.
          The dedicated app-showcase section below the FAQ supersedes this
          inline mini-CTA. Keeping the accordion duplicated download UI in
          the same column as the ATC was repetitive — users now hit the app
          install path once, on the section dedicated to it.
        {%- endcomment -%}


      </div>
      {%- comment -%} /accordion {%- endcomment -%}

    </div>
    {%- comment -%} /product-info {%- endcomment -%}

  </div>
  {%- content_for 'blocks' -%}
</section>

{%- comment -%} Sticky mobile add-to-cart bar — slides in when main ATC leaves viewport {%- endcomment -%}
{%- comment -%} Sticky mobile add-to-cart removed per request {%- endcomment -%}

{%- comment -%} Lightbox: click any gallery image to open at full resolution {%- endcomment -%}
{%- if product.images.size > 0 -%}
  <div class="gallery-lightbox" id="GalleryLightbox-{{ section.id }}" aria-hidden="true" role="dialog" aria-label="Product image viewer">
    <button class="gallery-lightbox__close" type="button" aria-label="Close" data-lightbox-close>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button class="gallery-lightbox__nav gallery-lightbox__nav--prev" type="button" aria-label="Previous image" data-lightbox-prev>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="gallery-lightbox__nav gallery-lightbox__nav--next" type="button" aria-label="Next image" data-lightbox-next>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div class="gallery-lightbox__stage" data-lightbox-stage>
      {%- for image in product.images limit: 8 -%}
        <img
          class="gallery-lightbox__img"
          data-index="{{ forloop.index0 }}"
          src="{{ image | image_url: width: 1800 }}"
          alt="{{ image.alt | escape | default: product.title }}"
          loading="lazy"
        >
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}


<style>
/* ============================================================
   MAIN PRODUCT -- Mend & Co
   ============================================================ */

/* Find your size CTA — primary-styled, sits between qty and ATC, opens ring-size modal */
.pdp-find-size-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  width: 100%;
  padding: 16px 20px;
  margin: 16px 0;
  background: var(--gold-deep);
  color: var(--color-bone, var(--cream-3));
  border: none;
  border-radius: 10px;
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.15s ease;
  box-shadow: 0 2px 8px rgba(107, 63, 160, 0.15);
}
.pdp-find-size-cta:hover { background: var(--gold-light); }
.pdp-find-size-cta:active { transform: translateY(1px); }
.pdp-find-size-cta:focus-visible {
  outline: 1.5px solid var(--gold-deep);
  outline-offset: 2px;
}
.pdp-find-size-cta__inner {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.pdp-find-size-cta__chev {
  flex-shrink: 0;
  opacity: 0.85;
}

/* Top 3 key benefits — first card inside product-info, all viewports.
   Sits flush with sibling cards (rating / variant / starter). */
.pdp-mobile-benefits {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  list-style: none;
  margin: 1rem 0 0.5rem;
  padding: 1rem 1.25rem;
  background: var(--color-bone, var(--cream-3));
  border-radius: 10px;
  border: 1px solid rgba(107, 63, 160, 0.15);
  box-sizing: border-box;
}
.pdp-mobile-benefits__item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  font-size: 0.8125rem;
  line-height: 1.5;
  color: var(--color-black, #F3E8FF);
}
.pdp-mobile-benefits__icon {
  flex-shrink: 0;
  color: var(--gold-deep);
  display: inline-flex;
  margin-top: 2px;
}
.pdp-mobile-benefits__item strong { font-weight: 600; }

.product-section {
  background: var(--color-bone, var(--cream-3));
  padding: 5rem 0 8rem;
}

.product-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 4rem;
  display: grid;
  grid-template-columns: 0.85fr 1.2fr;
  gap: 4rem;
  align-items: start;
}


/* -- GALLERY --------------------------------------- */

/* Sticky gallery — the photo follows scroll through the hero section
   so it stays visible while the longer right column scrolls past. */
.product-gallery {
  position: sticky;
  top: 6rem;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
  align-items: stretch;
}
.product-gallery .gallery-main { order: 1; }
.product-gallery .gallery-thumbs { order: 2; }

/* Thumbnails sit below main photo so the photo can use full column width */
.gallery-thumbs {
  display: flex;
  flex-direction: row;
  gap: 0.5rem;
  width: 100%;
  flex-shrink: 0;
  overflow-x: auto;
  scrollbar-width: none;
}
.gallery-thumbs::-webkit-scrollbar { display: none; }

.gallery-thumb {
  width: 76px;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: var(--cream-3);
  border: 1.5px solid rgba(107, 63, 160, 0.20);
  border-radius: 4px;
  cursor: pointer;
  padding: 0;
  position: relative;
  transition: border-color 0.2s ease;
  flex-shrink: 0;
}

.gallery-thumb.is-active {
  border-color: var(--gold-deep);
}

.gallery-thumb:focus-visible {
  outline: 1.5px solid var(--gold-deep);
  outline-offset: 2px;
}

.gallery-thumb img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  opacity: 0.6;
  transition: opacity 0.2s ease;
  padding: 4px;
}

.gallery-thumb.is-active img,
.gallery-thumb:hover img {
  opacity: 1;
}

/* Right: photo track + carousel stacked */
.gallery-main {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid rgba(107, 63, 160, 0.20);
  border-radius: 8px;
  box-shadow: 0 6px 32px rgba(107, 63, 160, 0.20), 0 1px 4px rgba(107, 63, 160, 0.10);
  overflow: hidden;
}

/* Track: desktop = one slide at a time via opacity */
.gallery-track {
  position: relative;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: var(--cream-3);
}

.gallery-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}

.gallery-slide.is-active {
  opacity: 1;
  pointer-events: auto;
}

.gallery-slide__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  cursor: zoom-in;
}


/* -- LIGHTBOX --------------------------------------- */
.gallery-lightbox {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: rgba(20, 18, 16, 0.92);
  display: none;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}
.gallery-lightbox.is-open {
  display: flex;
}
.gallery-lightbox__stage {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.gallery-lightbox__img {
  display: none;
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  cursor: zoom-out;
  user-select: none;
}
.gallery-lightbox__img.is-active {
  display: block;
}
.gallery-lightbox__close,
.gallery-lightbox__nav {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  color: #fff;
  cursor: pointer;
  transition: background 0.2s ease;
  z-index: 2;
}
.gallery-lightbox__close:hover,
.gallery-lightbox__nav:hover {
  background: rgba(255, 255, 255, 0.22);
}
.gallery-lightbox__close {
  top: 1.25rem;
  right: 1.25rem;
}
.gallery-lightbox__nav--prev { left: 1.25rem; top: 50%; transform: translateY(-50%); }
.gallery-lightbox__nav--next { right: 1.25rem; top: 50%; transform: translateY(-50%); }
@media (max-width: 599px) {
  .gallery-lightbox { padding: 1rem; }
  .gallery-lightbox__close { top: 0.75rem; right: 0.75rem; width: 38px; height: 38px; }
  .gallery-lightbox__nav { width: 38px; height: 38px; }
  .gallery-lightbox__nav--prev { left: 0.5rem; }
  .gallery-lightbox__nav--next { right: 0.5rem; }
}
body.lightbox-open { overflow: hidden; }


/* Prev / next arrows — inside .gallery-track so z-index is unambiguous */
.gallery-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: rgba(255, 255, 255, 0.92);
  border: none;
  border-radius: 50%;
  color: var(--char);
  cursor: pointer;
  pointer-events: auto;
  box-shadow: 0 2px 8px rgba(0,0,0,0.14);
  opacity: 0;
  transition: opacity 0.2s ease, background 0.15s;
  backdrop-filter: blur(4px);
}

.gallery-arrow--prev { left: 10px; }
.gallery-arrow--next { right: 10px; }

.gallery-main:hover .gallery-arrow {
  opacity: 1;
}

.gallery-arrow:hover {
  background: var(--cream-2);
}

/* Dots — mobile only */
.gallery-dots {
  display: none;
}


/* -- PRODUCT INFO ----------------------------------- */

.product-info {
  padding-top: 0.25rem;
}

/* Eyebrow
   Text: mahogany #8A6240 on linen = 7.59:1  (amber clay fails at 2.55:1)
   Amber retained as the decorative border-bottom rule only */
.product-eyebrow {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold-deep);
  margin: 0 0 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1.5px solid var(--gold-deep);
}

/* Title */
.product-title {
  font-family: var(--font-body);
  font-size: clamp(2.25rem, 4vw, 3.25rem);
  font-weight: 900;
  line-height: 1.2;
  letter-spacing: -0.02em;
  margin: 0 0 1.75rem;
  padding-bottom: 0.15em;
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  flex-wrap: wrap;
  color: #3d2c1a !important;
}

.product-title__model {
  font-family: var(--font-body);
  font-size: 0.6em;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gold);
  background: rgba(107, 63, 160, 0.1);
  border: 1px solid rgba(107, 63, 160, 0.25);
  border-radius: 3px;
  padding: 3px 8px;
  vertical-align: middle;
  line-height: 1;
  white-space: nowrap;
  position: relative;
  top: -0.1em;
}

/* Rating */
.product-rating {
  display: flex;
  align-items: center;
  gap: clamp(0.3rem, 1.6vw, 0.6rem);
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 1.75rem;
  background: rgba(154, 126, 87, 0.08);
  border: 1px solid rgba(154, 126, 87, 0.25);
  border-radius: 12px;
  padding: clamp(0.5rem, 2vw, 0.75rem) clamp(0.65rem, 3vw, 1.25rem);
  text-decoration: none;
  cursor: pointer;
}

.rating-stars {
  display: flex;
  align-items: center;
  gap: 2px;
  flex-shrink: 0;
  line-height: 0;
}

.star {
  fill: var(--gold-deep);
  display: block;
  width: clamp(13px, 3.6vw, 20px);
  height: auto;
}

.rating-label {
  font-family: var(--font-body);
  font-size: clamp(0.72rem, 2.7vw, 1.0625rem);
  font-weight: 700;
  color: var(--color-black);
  line-height: 1;
  white-space: nowrap;
}

.rating-value-num {
  font-family: var(--font-body);
  font-size: clamp(0.72rem, 2.7vw, 1.0625rem);
  font-weight: 700;
  color: var(--gold-deep);
  line-height: 1;
}

.rating-left {
  display: flex;
  align-items: center;
  gap: clamp(0.3rem, 1.6vw, 0.6rem);
  min-width: 0;
}

.rating-divider {
  width: 1px;
  height: 1rem;
  background: rgba(154, 126, 87, 0.35);
  flex-shrink: 0;
  margin: 0 0.1rem;
}

.rating-count {
  font-family: var(--font-body);
  font-size: clamp(0.72rem, 2.7vw, 1.0625rem);
  font-weight: 700;
  color: var(--color-black);
  line-height: 1;
  white-space: nowrap;
  text-decoration: underline;
  text-underline-offset: 2px;
  text-decoration-color: rgba(154, 126, 87, 0.4);
}

.product-rating:hover {
  background: rgba(154, 126, 87, 0.14);
  border-color: rgba(154, 126, 87, 0.4);
}

.product-rating:hover .rating-count {
  text-decoration-color: var(--gold-deep);
}

/* Product badges */
.pdp-badges {
  display: flex;
  flex-direction: row;
  gap: 6px;
  margin-bottom: 1rem;
}

.pdp-badges .badge {
  min-width: 42px;
  justify-content: center;
}

/* Price block */
.price-block {
  margin-bottom: 1.75rem;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  margin-bottom: 0.3rem;
  flex-wrap: wrap;
}

.price-now {
  font-family: var(--font-body);
  font-size: 1.875rem;
  font-weight: 400;
  color: var(--color-black);
  letter-spacing: -0.02em;
  line-height: 1;
}

.price-was {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  color: var(--color-olive);
  text-decoration: line-through;
  opacity: 0.55;
}

.price-now--on-sale {
  color: var(--gold-deep);
}

.price-save {
  font-family: var(--font-body);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #C0392B;
  background: rgba(192, 57, 43, 0.1);
  padding: 0.25rem 0.5rem;
  border-radius: 2px;
  align-self: center;
}

.price-callout {
  font-family: var(--font-body);
  font-size: 0.8rem;
  /* Hardcoded blended value: mahogany #8A6240 at ~72% on linen ~ #9A7255, 4.68:1 
     Avoids opacity: which renders ~3.8:1 and is unmeasurable in static audits */
  color: var(--char-soft);
  margin: 0;
}

/* Purchase toggle */
.purchase-toggle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.375rem;
  padding: 0.375rem;
  background: rgba(107, 63, 160, 0.10);
  border-radius: 4px;
  margin-bottom: 1.75rem;
}

.purchase-toggle__btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
  padding: 0.75rem 1rem;
  background: transparent;
  border: 1.5px solid transparent;
  border-radius: 3px;
  cursor: pointer;
  transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
  text-align: center;
}

.purchase-toggle__btn.is-active {
  background: var(--color-bone, var(--cream-3));
  /* Border: mahogany = 7.59:1  (amber = 2.55:1, fails WCAG 1.4.11 non-text 3:1) */
  border-color: var(--color-olive);
  box-shadow: 0 1px 4px rgba(107, 63, 160, 0.15);
}

.purchase-toggle__btn:hover:not(.is-active) {
  border-color: rgba(166, 137, 102, 0.35);
}

.toggle-label {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-black);
  letter-spacing: 0.01em;
}

.toggle-price {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-olive);
}

/* Blurb */
.product-blurb {
  margin: 0 0 1.875rem;
  padding-top: 1.375rem;
  border-top: 1.5px solid var(--gold-deep);
}

.product-blurb__heading {
  font-family: var(--font-body);
  font-size: clamp(1.75rem, 3.5vw, 2.375rem);
  font-weight: 300;
  color: var(--color-black);
  line-height: 1.08;
  letter-spacing: -0.025em;
  margin: 0 0 0.625rem;
}

.product-blurb__subhead {
  font-family: var(--font-body);
  font-size: clamp(1.1rem, 2.2vw, 1.375rem);
  font-style: italic;
  font-weight: 400;
  color: var(--gold-deep);
  line-height: 1.45;
  letter-spacing: 0.008em;
  margin: 0 0 0.875rem;
  opacity: 0.9;
}

.product-blurb__body {
  font-size: 0.9375rem;
  color: var(--color-olive, #5a5040);
  line-height: 1.65;
}

.product-description {
  margin: 0 0 1.5rem;
  font-size: 0.9375rem;
  color: var(--color-black, #1f1d1a);
  line-height: 1.65;
}

/* Spec pills */
.spec-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin: 0 0 1.75rem;
}

.spec-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.35rem 0.75rem;
  background: rgba(107, 63, 160, 0.07);
  border: 1px solid rgba(107, 63, 160, 0.18);
  border-radius: 100px;
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-olive);
  letter-spacing: 0.01em;
  white-space: nowrap;
}

.spec-pill svg {
  color: var(--gold-deep);
  flex-shrink: 0;
}

/* Variant fieldset */
.variant-fieldset {
  border: none;
  padding: 0;
  margin: 0 0 1.5rem;
}

.variant-legend {
  font-family: var(--font-body);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--color-black);
  display: block;
  margin-bottom: 0.75rem;
  padding: 0;
  float: none;
  width: 100%;
}

.variant-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.variant-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 0.75rem 1.25rem;
  background: var(--color-bone, var(--cream-3));
  border: 1.5px solid rgba(107, 63, 160, 0.30);
  border-radius: 3px;
  cursor: pointer;
  transition: border-color 0.18s ease, background 0.18s ease;
  min-width: 8.5rem;
}

.variant-card:hover:not(.is-sold-out) {
  border-color: rgba(166, 137, 102, 0.5);
}

.variant-card.is-selected {
  /* Border: mahogany #8A6240 on linen = 7.59:1  (amber = 2.55:1, fails WCAG 1.4.11 non-text 3:1) */
  border-color: var(--color-olive);
  background: rgba(166, 137, 102, 0.05);
}

.variant-card.is-sold-out {
  opacity: 0.38;
  cursor: not-allowed;
}

.variant-card__radio {
  position: absolute;
  opacity: 0;
  pointer-events: none;
  width: 1px;
  height: 1px;
}

.variant-card__name {
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-black);
  display: block;
}

.variant-card__save {
  font-family: var(--font-body);
  font-size: 0.6875rem;
  font-weight: 500;
  /* Deep Walnut #8A6240 on bone - contrast OK */
  color: var(--gold-deep);
  letter-spacing: 0.5px;
}

.variant-card__out {
  font-family: var(--font-body);
  font-size: 0.6875rem;
  /* Blended mahogany 60% on linen -> #AE8E76, 3.52:1  for supplementary small text
     Avoiding opacity: to keep contrast measurable */
  color: var(--char-soft);
}

/* Quantity stepper */
.qty-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 0.875rem;
}

.qty-label {
  font-family: var(--font-body);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--color-black);
  flex-shrink: 0;
  min-width: 2rem;
}

.qty-stepper {
  display: inline-flex;
  align-items: center;
  border: 1.5px solid rgba(107, 63, 160, 0.30);
  border-radius: 3px;
  overflow: hidden;
}

.qty-btn {
  width: 44px;
  height: 44px;
  background: transparent;
  border: none;
  font-size: 1.0625rem;
  color: var(--color-black);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.15s ease;
  line-height: 1;
  -webkit-appearance: none;
}

.qty-btn:hover {
  background: rgba(107, 63, 160, 0.10);
}

.qty-btn:active {
  background: rgba(107, 63, 160, 0.20);
}

.qty-input {
  width: 52px;
  height: 44px;
  border: none;
  border-left: 1px solid rgba(107, 63, 160, 0.22);
  border-right: 1px solid rgba(107, 63, 160, 0.22);
  background: transparent;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-black);
  text-align: center;
  -moz-appearance: textfield;
}

.qty-input::-webkit-outer-spin-button,
.qty-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
}

.qty-input:focus {
  outline: none;
  background: rgba(107, 63, 160, 0.06);
}

/* No-subscription badge — sits directly above ATC */
.mc-no-sub-badge {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  margin: 0.875rem 0 0.625rem;
  padding: 0.625rem 0.875rem;
  border: 1px solid rgba(138, 102, 64, 0.22);
  border-radius: 6px;
  background: rgba(245, 239, 230, 0.6);
  font-size: 0.8125rem;
  line-height: 1.4;
  color: var(--color-olive, #4a4640);
}
.mc-no-sub-badge__icon {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36px;
  height: 36px;
  padding: 0 8px;
  background: var(--gold-deep);
  color: var(--color-bone, #f5efe6);
  font-family: var(--font-body);
  font-style: italic;
  font-size: 1.125rem;
  font-weight: 500;
  border-radius: 4px;
  letter-spacing: -0.01em;
}
.mc-no-sub-badge__text {
  flex: 1;
}
.mc-no-sub-badge__text strong {
  color: var(--color-ink, #1a1814);
  font-weight: 600;
}
@media (max-width: 480px) {
  .mc-no-sub-badge {
    font-size: 0.75rem;
    padding: 0.5rem 0.625rem;
  }
  .mc-no-sub-badge__icon {
    min-width: 32px;
    height: 32px;
    font-size: 1rem;
  }
}

/* Add to cart */
.btn-atc {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 56px;
  background: var(--color-cta, #5B21B6);
  color: var(--color-bone, var(--cream-3));
  border: none;
  border-radius: 4px;
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.12s ease, box-shadow 0.2s ease;
  margin-bottom: 0.75rem;
  box-shadow: 0 2px 12px rgba(107, 63, 160, 0.35);
  position: relative;
  overflow: hidden;
  animation: breathe 2.4s ease-in-out infinite;
}


/* -- Sale countdown -- */
.pdp-summer-sale {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.6rem 0;
  background: transparent;
  border: none;
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-black, #1a1a1a);
  width: 100%;
  justify-content: center;
  box-sizing: border-box;
}
.pdp-summer-sale__hurry {
  color: var(--gold-deep);
  font-weight: 800;
  font-style: italic;
}
.pdp-summer-sale__label { color: var(--color-black, #1a1a1a); }
.pdp-summer-sale__clock {
  font-variant-numeric: tabular-nums;
  font-weight: 800;
  color: var(--gold-deep);
  letter-spacing: 0.02em;
}
.pdp-summer-sale { margin: 0.875rem 0 0; }

/* -- Simple benefits list (between title and countdown) -- */
.pdp-simple-benefits {
  list-style: none;
  padding: 0;
  margin: 0 0 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.pdp-simple-benefits li {
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 500;
  line-height: 1.4;
  color: var(--color-black, #1a1a1a);
  display: flex;
  align-items: center;
  gap: 0.625rem;
}
.pdp-simple-benefits li::before {
  content: '→';
  flex-shrink: 0;
  color: var(--gold-deep);
  font-weight: 800;
  font-size: 1.15rem;
  line-height: 1;
}

/* -- Money-back guarantee strip -- */

.pdp-shipping,
.pdp-guarantee {
  display: flex;
  align-items: flex-start;
  gap: 0.625rem;
  margin: 0.75rem 0 0.5rem;
  padding: 0.75rem 0.875rem;
  background: rgba(122, 92, 58, 0.06);
  border: 1px solid rgba(122, 92, 58, 0.18);
  border-radius: 8px;
  font-size: 0.8125rem;
  line-height: 1.45;
  color: var(--color-olive, #5a5040);
}
.pdp-shipping { margin-top: 1rem; }
.pdp-shipping__icon {
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  color: var(--gold-deep);
  margin-top: 1px;
}
.pdp-shipping__text strong {
  color: var(--color-black, #F3E8FF);
  font-weight: 600;
  margin-right: 0.25rem;
}
.pdp-guarantee__icon {
  flex-shrink: 0;
  width: 18px;
  height: 18px;
  color: var(--gold-deep);
  margin-top: 1px;
}
.pdp-guarantee__text strong {
  color: var(--color-black, #F3E8FF);
  font-weight: 600;
  margin-right: 0.25rem;
}

/* -- Payment-method icons strip -- */
.pdp-payments {
  margin: 0.625rem 0 0.875rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
}
.pdp-payments__label {
  font-family: var(--font-body);
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-deep);
  opacity: 0.78;
}
.pdp-payments__icons {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.4rem;
  list-style: none;
  margin: 0;
  padding: 0;
}
.pdp-payments__icon {
  display: inline-flex;
}
.pdp-payments__icon svg {
  width: 32px;
  height: 20px;
  border-radius: 3px;
  display: block;
}

/* Low-stock urgency indicator — sits between ATC and Shop Pay */
.pdp-stock-urgency {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  margin: 0.75rem 0 0.875rem;
  padding: 0.55rem 0.875rem;
  background: rgba(185, 28, 28, 0.06);
  border: 1px solid rgba(185, 28, 28, 0.2);
  border-radius: 8px;
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 600;
  color: #7f1d1d;
  letter-spacing: 0.01em;
}
.pdp-stock-urgency strong {
  font-weight: 800;
  color: #b91c1c;
}
.pdp-stock-urgency__pulse {
  width: 8px; height: 8px;
  flex-shrink: 0;
  border-radius: 50%;
  background: #b91c1c;
  box-shadow: 0 0 0 0 rgba(185, 28, 28, 0.65);
  animation: pdp-stock-pulse 1.6s ease-out infinite;
}
@keyframes pdp-stock-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(185, 28, 28, 0.65); }
  70%  { box-shadow: 0 0 0 8px rgba(185, 28, 28, 0); }
  100% { box-shadow: 0 0 0 0 rgba(185, 28, 28, 0); }
}
@media (prefers-reduced-motion: reduce) {
  .pdp-stock-urgency__pulse { animation: none; }
}

.pdp-payment-btns .shopify-payment-button__button {
  border-radius: 4px;
  font-size: 0.875rem;
}

.pdp-payment-btns .shopify-payment-button__button--unbranded {
  background-color: var(--color-cta, #5B21B6) !important;
}

@media (max-width: 767px) {
  .btn-atc {
    animation: breathe-opacity 2.4s ease-in-out infinite;
  }
}

.btn-atc.is-loading {
  background: var(--gold-deep);
  color: #fff;
  pointer-events: none;
  transition: background 0.2s ease, color 0.2s ease;
}

.btn-atc::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  height: 2px;
  width: 0%;
  background: rgba(255,255,255,0.6);
  transition: width 0s;
}

.btn-atc.is-loading::after {
  width: 100%;
  transition: width 0.6s ease;
}

.btn-atc:hover:not(:disabled) {
  background: var(--color-cta-hover, #7C3AED);
  box-shadow: 0 4px 20px rgba(107, 63, 160, 0.50);
}

.btn-atc:active:not(:disabled) {
  transform: scale(0.997);
}

.btn-atc:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* -- MINI REVIEW CAROUSEL (below gallery) --------- */

.pdp-review-carousel {
  border-top: 1px solid rgba(107, 63, 160, 0.20);
  padding: 1.125rem 1.375rem 1rem;
  background: rgba(107, 63, 160, 0.05);
}

.prc-track {
  position: relative;
  /* Fixed height so controls never move: stars + quote (3 lines) + footer */
  height: 8.5rem;
  overflow: hidden;
}

.prc-slide {
  display: none;
  flex-direction: column;
  gap: 0.5rem;
  position: absolute;
  inset: 0;
}

.prc-slide.is-active {
  display: flex;
  animation: prc-fade 0.25s ease;
}

@keyframes prc-fade {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}

.prc-stars {
  display: flex;
  gap: 2px;
}

.prc-star {
  font-size: 11px;
  color: var(--gold-deep);
  line-height: 1;
}

.prc-star--empty { opacity: 0.2; }

.prc-quote {
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-style: italic;
  font-weight: 400;
  line-height: 1.55;
  color: var(--char-soft);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.prc-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  padding-top: 0.625rem;
  border-top: 1px solid rgba(107, 63, 160, 0.20);
}

.prc-author-wrap {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.prc-name {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-black, #F3E8FF);
}

.prc-badge {
  font-family: var(--font-body);
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--char);
  background: rgba(74,123,114,0.85);
  padding: 2px 5px;
  border-radius: 2px;
}

.prc-detail {
  font-family: var(--font-body);
  font-size: 0.6875rem;
  color: var(--char-soft);
  opacity: 0.7;
}

.prc-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 0.875rem;
}

.prc-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  background: transparent;
  border: 1px solid rgba(107, 63, 160, 0.30);
  border-radius: 50%;
  cursor: pointer;
  color: var(--color-black, #F3E8FF);
  transition: border-color 0.15s, background 0.15s;
  flex-shrink: 0;
}

.prc-arrow:hover {
  border-color: rgba(107, 63, 160, 0.50);
  background: rgba(107, 63, 160, 0.10);
}

.prc-dots {
  display: flex;
  gap: 5px;
  align-items: center;
}

.prc-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  border: none;
  background: rgba(107, 63, 160, 0.40);
  cursor: pointer;
  padding: 0;
  transition: background 0.2s, transform 0.2s;
}

.prc-dot.is-active {
  background: var(--gold-deep);
  transform: scale(1.4);
}

/* Trust strip */
.trust-strip {
  list-style: none;
  padding: 0.875rem 0;
  margin: 0 0 1.375rem;
  display: flex;
  border-top: 1px solid rgba(107, 63, 160, 0.20);
  border-bottom: 1px solid rgba(107, 63, 160, 0.20);
}

.trust-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-size: 0.75rem;
  color: var(--color-olive);
  flex: 1;
  line-height: 1.3;
  text-align: center;
}

.trust-item + .trust-item {
  padding-left: 0.75rem;
  border-left: 1px solid rgba(107, 63, 160, 0.20);
}

.trust-icon {
  width: 17px;
  height: 17px;
  color: var(--gold-deep);
  flex-shrink: 0;
}

.trust-item .trust-icon,
.trust-item svg,
.trust-item__icon {
  color: var(--gold-deep);
}

/* Accordion */
.accordion {
  border-top: 1px solid rgba(107, 63, 160, 0.22);
}

.accordion__item {
  border-bottom: 1px solid rgba(107, 63, 160, 0.22);
}

.accordion__trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.125rem 0;
  background: transparent;
  border: none;
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-black);
  cursor: pointer;
  text-align: left;
  letter-spacing: 0.01em;
  transition: color 0.15s ease;
}

/* Hover is a no-op (same color as default) -- removed.
   Active state is communicated via amber chevron rotation + amber left-border on panel body. */
.accordion__trigger[aria-expanded="true"] {
  color: var(--color-black);
}

.accordion__trigger:focus-visible {
  outline: 1.5px solid var(--gold-deep);
  outline-offset: 2px;
  border-radius: 2px;
}

.accordion__chevron {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  color: var(--color-olive);
  transition: transform 0.25s ease, color 0.15s ease;
}

.accordion__trigger[aria-expanded="true"] .accordion__chevron {
  transform: rotate(180deg);
  color: var(--gold-deep);
}

.accordion__panel[hidden] {
  display: none;
}

.accordion__body {
  padding: 0.25rem 0 1.25rem 1.125rem;
  border-left: 1.5px solid var(--gold-deep);
  font-family: var(--font-body);
  font-size: 0.875rem;
  line-height: 1.78;
  color: var(--color-olive);
}

.accordion__body p,
.accordion__body ul {
  margin: 0;
}

.accordion__body ul {
  padding-left: 1.25rem;
}

.accordion__body li + li {
  margin-top: 0.4rem;
}

.science-quote {
  margin: 0;
  padding: 0;
  border: none;
}
.science-quote p {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-style: italic;
  line-height: 1.6;
  color: var(--color-black);
  margin: 0 0 0.625rem;
}
.science-quote footer {
  font-family: var(--font-body);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold-deep);
}


/* ============================================================
   RESPONSIVE
   ============================================================ */

@media (max-width: 1024px) {
  .product-container {
    gap: 4rem;
    padding: 0 2.5rem;
  }
}

@media (max-width: 768px) {
  .product-section {
    padding: 2.5rem 0 5rem;
  }

  /* When the mobile video hero is mounted, drop the top padding so
     the hero butts up against the header with no gap. Bottom padding
     stays for breathing room into the next section. */
  .product-section:has(.mc-mobile-hero) {
    padding-top: 0;
  }

  .product-container {
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 0;
  }

  /* Mobile: unstick gallery, stack vertically. Hard-constrain to viewport
     so the swipe carousel can't push the section past its container. */
  .product-gallery {
    position: static;
    flex-direction: column;
    gap: 0;
    align-items: stretch;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .pdp-summer-sale {
    margin: 0.5rem 0 0;
  }

  .gallery-thumbs {
    max-height: none;
    width: 100%;
    max-width: 100%;
    flex-direction: row;
    overflow-x: auto;
    overflow-y: visible;
    padding: 0.75rem 1rem;
    box-sizing: border-box;
  }

  .gallery-thumb {
    width: 56px;
    height: 56px;
    aspect-ratio: 1 / 1;
    flex-shrink: 0;
  }

  .gallery-main {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
    border-left: none;
    border-right: none;
    border-radius: 0;
    box-shadow: none;
  }

  .gallery-track {
    display: flex;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    aspect-ratio: 1 / 1;
    height: auto;
    max-height: 100vw;
    border-left: none;
    border-right: none;
    border-radius: 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .gallery-track::-webkit-scrollbar {
    display: none;
  }

  .gallery-slide {
    position: relative;
    flex: 0 0 100%;
    height: 100%;
    opacity: 1;
    pointer-events: auto;
    scroll-snap-align: start;
    inset: auto;
  }

  /* All slides visible in flex -- override desktop opacity hiding */
  .gallery-slide:not(.is-active) {
    opacity: 1;
  }

  /* Arrows always visible on mobile, vertically centered over the track.
     Track is aspect 1/1, capped at 520px, so center = min(50vw, 260px). */
  .gallery-main .gallery-arrow {
    opacity: 1;
    top: min(50vw, 260px);
    transform: translateY(-50%);
  }

  /* Dot indicators */
  .gallery-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 10px;
    margin-bottom: 28px;
  }

  .gallery-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(107, 63, 160, 0.40);
    transition: background 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .gallery-dot.is-active {
    background: var(--gold-deep);
    transform: scale(1.4);
  }

  .product-info {
    padding: 0 1rem;
    max-width: 100%;
    box-sizing: border-box;
  }

  /* ── Mobile density pass — strip dead air from product info ── */
  .product-eyebrow {
    margin: 0 0 1.25rem;
    padding-bottom: 0.875rem;
  }
  .product-title {
    margin: 0 0 1.5rem;
  }
  .product-rating {
    margin-bottom: 0.5rem;
    padding: 0.5rem 0.875rem;
    gap: 0.5rem;
    font-size: 0.8125rem;
    /* two equal cells flanking a centred divider — minmax(0,1fr) forces
       the columns equal regardless of content width (1fr alone won't
       shrink below content, which pushed the divider off-centre) */
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
  }
  .product-rating .rating-left { justify-content: center; }
  .product-rating .rating-count { justify-self: center; text-align: center; }
  .product-info-above-gallery .product-rating {
    margin-bottom: 0;
  }
  /* font sizes + star size now scale fluidly via clamp() in the base rules */
  .pdp-badges {
    margin-bottom: 0.625rem;
  }
  .price-block {
    margin-bottom: 1rem;
  }
  .spec-pills {
    margin: 0 0 1rem;
  }
  .product-blurb {
    margin: 0 0 1rem;
  }
  .variant-fieldset {
    margin: 0 0 0.875rem;
  }
  .purchase-toggle {
    margin-bottom: 1rem;
    padding: 0.25rem;
  }
  .purchase-toggle__btn {
    padding: 0.55rem 0.75rem;
  }
  .gallery-dots {
    margin-top: 8px;
    margin-bottom: 16px;
  }

  /* All direct children of product-info must stay within the padded column */
  .product-info > * {
    max-width: 100%;
    box-sizing: border-box;
  }

  .product-title {
    font-size: 1.875rem;
  }

  .variant-cards {
    gap: 0.4rem;
  }

  .variant-card {
    min-width: 0;
    flex: 1 1 calc(33.333% - 0.4rem);
    padding: 0.6rem 0.75rem;
  }

  .trust-strip {
    display: none;
  }

  .trust-item {
    flex: 1;
    justify-content: center;
    font-size: 0.6875rem;
    gap: 0.3rem;
  }

  .trust-icon {
    width: 14px;
    height: 14px;
  }

  /* Override the desktop sibling separator */
  .trust-item + .trust-item {
    border-left: 1px solid rgba(107, 63, 160, 0.20);
    padding-left: 0;
  }

}

@media (max-width: 480px) {
  .purchase-toggle {
    grid-template-columns: 1fr;
  }

  .purchase-toggle__btn {
    flex-direction: row;
    justify-content: space-between;
  }
}

@media (prefers-reduced-motion: reduce) {
  .btn-atc {
    animation: none !important;
  }
}
