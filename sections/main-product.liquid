  }

  /* Mobile: unstick gallery, stack vertically */
  .product-gallery {
    position: static;
    flex-direction: column;
    gap: 0;
    align-items: stretch;
  }

  .gallery-thumbs {
    max-height: none;
    width: 100%;
    flex-direction: row;
    overflow-x: auto;
    overflow-y: visible;
