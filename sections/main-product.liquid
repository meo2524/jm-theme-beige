</style>


<script>
(function () {
  'use strict';

  var sid  = '{{ section.id }}';
  var root = document.querySelector('[data-section-id="' + sid + '"]');
  if (!root) return;

  /* -- GALLERY ----------------------------------------------- */
  var track   = root.querySelector('#GalleryTrack-' + sid);
  var slides  = root.querySelectorAll('.gallery-slide');
  var thumbs  = root.querySelectorAll('.gallery-thumb');
  var dots    = root.querySelectorAll('.gallery-dot');
  var btnPrev = root.querySelector('[data-gallery-prev]');
  var btnNext = root.querySelector('[data-gallery-next]');
  var active  = 0;
  var total   = slides.length;

  function activateSlide(idx) {
    slides[active] && slides[active].classList.remove('is-active');
    thumbs[active] && thumbs[active].classList.remove('is-active');
    dots[active]   && dots[active].classList.remove('is-active');
    active = idx;
    slides[active] && slides[active].classList.add('is-active');
    thumbs[active] && thumbs[active].classList.add('is-active');
    dots[active]   && dots[active].classList.add('is-active');
  }

  var programmaticScroll = false;

  function goTo(idx) {
    idx = (idx + total) % total;
    activateSlide(idx);
    /* Only scroll on mobile where the track is a real scroll container */
    if (track && track.scrollWidth > track.clientWidth && slides[idx]) {
      programmaticScroll = true;
      track.scrollTo({ left: track.offsetWidth * idx, behavior: 'smooth' });
      setTimeout(function () { programmaticScroll = false; }, 700);
    }
  }

  thumbs.forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      goTo(parseInt(thumb.dataset.index, 10));
    });
    thumb.addEventListener('keydown', function (e) {
      var i = parseInt(thumb.dataset.index, 10);
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') { e.preventDefault(); var t = thumbs[Math.min(i + 1, thumbs.length - 1)]; t && t.focus(); }
      if (e.key === 'ArrowUp'   || e.key === 'ArrowLeft')  { e.preventDefault(); var t = thumbs[Math.max(i - 1, 0)]; t && t.focus(); }
    });
  });

  if (btnPrev) btnPrev.addEventListener('click', function () { goTo(active - 1); });
  if (btnNext) btnNext.addEventListener('click', function () { goTo(active + 1); });

  /* Sync active state on manual swipe (ignore programmatic scrollTo calls) */
  if (track) {
    track.addEventListener('scroll', function () {
      if (programmaticScroll) return;
      var idx = Math.round(track.scrollLeft / track.offsetWidth);
      if (idx !== active) activateSlide(idx);
    }, { passive: true });
  }


  /* -- VARIANT PICKER ---------------------------------------- */
  var variantIdInput  = root.querySelector('#ProductVariantId-' + sid);
  var addToCartBtn    = root.querySelector('#AddToCart-' + sid);
  var addToCartText   = root.querySelector('#AddToCartText-' + sid);
  var priceNow        = root.querySelector('#PriceNow-' + sid);
  var priceWas        = root.querySelector('#PriceWas-' + sid);
  var priceSave       = root.querySelector('#PriceSave-' + sid);
  var togglePriceOnce = root.querySelector('#TogglePriceOnce-' + sid);
  var productVariants = {{ product.variants | json }};

  var _moneyFmt = new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: (window.Shopify && Shopify.currency && Shopify.currency.active) || 'USD',
    minimumFractionDigits: 2,
  });
  function formatMoney(cents) { return _moneyFmt.format(cents / 100); }

  function getSelectedOptions() {
    var opts = {};
    root.querySelectorAll('.variant-card__radio:checked').forEach(function (r) {
      opts[r.dataset.optionPosition] = r.value;
    });
    return opts;
  }

  function findVariant(opts) {
    var positions = Object.keys(opts);
    return productVariants.find(function (v) {
      return positions.every(function (pos) {
        return v['option' + pos] === opts[pos];
      });
    });
  }

  function applyVariant(variant) {
    if (!variant) return;
    if (variantIdInput) variantIdInput.value = variant.id;

    if (variant.featured_image && variant.featured_image.position) {
      goTo(variant.featured_image.position - 1);
    }

    if (priceNow) priceNow.textContent = formatMoney(variant.price);
    if (togglePriceOnce) togglePriceOnce.textContent = formatMoney(variant.price);

    if (variant.compare_at_price > variant.price) {
      if (priceWas) { priceWas.textContent = formatMoney(variant.compare_at_price); priceWas.hidden = false; }
      if (priceSave) { priceSave.textContent = 'Save ' + formatMoney(variant.compare_at_price - variant.price); priceSave.hidden = false; }
    } else {
      if (priceWas)  priceWas.hidden  = true;
      if (priceSave) priceSave.hidden = true;
    }

    if (addToCartBtn) {
      addToCartBtn.disabled = !variant.available;
      if (addToCartText) addToCartText.textContent = variant.available ? 'Add to Cart' : 'Sold Out';
    }

    try {
      var url = new URL(window.location.href);
      url.searchParams.set('variant', variant.id);
      history.replaceState({}, '', url.toString());
    } catch (e) { /* noop */ }
  }

  root.querySelectorAll('.variant-card').forEach(function (card) {
    card.addEventListener('click', function () {
      if (card.classList.contains('is-sold-out')) return;
      var radio = card.querySelector('.variant-card__radio');
      if (!radio || radio.disabled) return;

      var fieldset = card.closest('.variant-fieldset');
      if (fieldset) {
        fieldset.querySelectorAll('.variant-card').forEach(function (c) { c.classList.remove('is-selected'); });
      }

      card.classList.add('is-selected');
      radio.checked = true;

      applyVariant(findVariant(getSelectedOptions()));
    });

    card.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
    });
  });


  /* -- PURCHASE TOGGLE --------------------------------------- */
  var sellingPlanInput = root.querySelector('#SellingPlan-' + sid);
  var toggleBtns = root.querySelectorAll('#PurchaseToggle-' + sid + ' .purchase-toggle__btn');

  {%- if product.selling_plan_groups.size > 0 -%}
  var subscribeBtn = root.querySelector('[data-purchase-type="subscribe"]');
  if (subscribeBtn) {
    subscribeBtn.dataset.sellingPlanId = '{{ product.selling_plan_groups.first.selling_plans.first.id }}';
  }
  {%- endif -%}

  toggleBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      toggleBtns.forEach(function (b) { b.classList.remove('is-active'); b.setAttribute('aria-pressed', 'false'); });
      btn.classList.add('is-active');
      btn.setAttribute('aria-pressed', 'true');
      if (sellingPlanInput) sellingPlanInput.value = btn.dataset.sellingPlanId || '';
    });
  });


  /* -- QUANTITY STEPPER -------------------------------------- */
  var qtyInput = root.querySelector('#Qty-' + sid);

  root.querySelectorAll('.qty-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (!qtyInput) return;
      var cur = parseInt(qtyInput.value, 10) || 1;
      qtyInput.value = btn.dataset.action === 'increase' ? cur + 1 : Math.max(1, cur - 1);
    });
  });


  /* -- ACCORDION --------------------------------------------- */
  root.querySelectorAll('.accordion__trigger').forEach(function (trigger) {
    trigger.addEventListener('click', function () {
      var expanded = trigger.getAttribute('aria-expanded') === 'true';
      var panel = root.querySelector('#' + trigger.getAttribute('aria-controls'));
      trigger.setAttribute('aria-expanded', String(!expanded));
      if (panel) panel.hidden = expanded;
    });
  });


  /* -- ATC LOADING STATE ------------------------------------- */
  var atcOriginalText = addToCartText ? addToCartText.textContent.trim() : 'Add to Cart';

  function atcSetLoading() {
    if (!addToCartBtn) return;
    addToCartBtn.classList.add('is-loading');
    if (addToCartText) addToCartText.textContent = 'Adding\u2026';
  }

  function atcClearLoading() {
    if (!addToCartBtn) return;
    addToCartBtn.classList.remove('is-loading');
    if (addToCartText) addToCartText.textContent = atcOriginalText;
  }

  if (addToCartBtn) {
    var atcForm = addToCartBtn.closest('form');
    if (atcForm) {
      atcForm.addEventListener('submit', function (e) {
        if (addToCartBtn.disabled) return;
        atcSetLoading();
      });
    }
  }

  /* Restore when item added (success or error) or cart externally refreshed */
  document.addEventListener('cart:item-added', atcClearLoading);
  document.addEventListener('cart:refresh', atcClearLoading);

}());
</script>


