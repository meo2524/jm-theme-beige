    flex-shrink: 0;
  }

  .gallery-thumbs {
    display: none;
  }

  .gallery-main {
    width: 100%;
  }

  .gallery-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    /* Use proper aspect ratio instead of fixed height so ring photos
       aren't squashed — 1:1 works for square/portrait product shots */
    aspect-ratio: 1 / 1;
    height: auto;
    max-height: 520px;
    border-left: none;
    border-right: none;
    border-radius: 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .gallery-track::-webkit-scrollbar {
    display: none;
  }

  .gallery-slide {
    position: relative;
    flex: 0 0 100%;
    height: 100%;
    opacity: 1;
    pointer-events: auto;
    scroll-snap-align: start;
    inset: auto;
  }

  /* All slides visible in flex -- override desktop opacity hiding */
  .gallery-slide:not(.is-active) {
    opacity: 1;
  }

  /* Arrows always visible on mobile */
  .gallery-track .gallery-arrow {
    opacity: 1;
  }

  /* Dot indicators */
  .gallery-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 10px;
    margin-bottom: 28px;
  }

  .gallery-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(43, 43, 43, 0.2);
    transition: background 0.2s, transform 0.2s;
    flex-shrink: 0;
