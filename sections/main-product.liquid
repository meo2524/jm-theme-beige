  opacity: 0;
  pointer-events: none;
  width: 1px;
  height: 1px;
}

.variant-card__name {
  font-family: var(--font-label);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-black);
  display: block;
}

.variant-card__save {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  /* Deep Walnut #8A6240 on bone - contrast OK */
  color: var(--color-walnut, #8A6240);
  letter-spacing: 0.5px;
}

.variant-card__out {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  /* Blended mahogany 60% on linen -> #AE8E76, 3.52:1  for supplementary small text
     Avoiding opacity: to keep contrast measurable */
  color: #AE8E76;
}

/* Quantity stepper */
.qty-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 0.875rem;
}

.qty-label {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--color-black);
