  .gallery-dot.is-active {
    background: var(--color-walnut, #8A6240);
    transform: scale(1.4);
  }

  .product-info {
    padding: 0 1.25rem;
  }

  .product-title {
    font-size: 1.875rem;
  }

  .variant-cards {
