{% comment %}
  main-product.liquid
  Mend & Co -- Product Detail Page
  2-col gallery + info layout. Sticky gallery on desktop, scroll-snap swipe on mobile.
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign product_form_id = 'product-form-' | append: section.id -%}

<section
  class="product-section"
  data-section-id="{{ section.id }}"
  data-section-type="main-product"
>
  <div class="product-container">

    {%- comment -%} ===========================================
      GALLERY
    =========================================== {%- endcomment -%}
    <div class="product-gallery">

      {%- comment -%} Left: vertical thumbnail strip (desktop only) {%- endcomment -%}
      {%- if product.images.size > 1 -%}
        <div class="gallery-thumbs" id="GalleryThumbs-{{ section.id }}" role="list" aria-label="Image thumbnails">
          {%- for image in product.images limit: 8 -%}
            <button
              class="gallery-thumb{% if forloop.first %} is-active{% endif %}"
              data-index="{{ forloop.index0 }}"
              type="button"
              aria-label="View image {{ forloop.index }}"
              role="listitem"
            >
              <img
                src="{{ image | image_url: width: 160 }}"
                alt="{{ image.alt | escape | default: product.title }}"
                width="160"
                height="200"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Right: main image + arrows + dots {%- endcomment -%}
      <div class="gallery-main">

        <div class="gallery-track" id="GalleryTrack-{{ section.id }}" role="region" aria-label="Product images">
          {%- if product.images.size > 0 -%}
            {%- for image in product.images limit: 8 -%}
              <div
                class="gallery-slide{% if forloop.first %} is-active{% endif %}"
                data-index="{{ forloop.index0 }}"
              >
                <img
                  src="{{ image | image_url: width: 960 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  class="gallery-slide__img"
                >
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="gallery-slide is-active">
              {{ 'product-1' | placeholder_svg_tag: 'gallery-slide__placeholder' }}
            </div>
          {%- endif -%}

          {%- comment -%} Arrows inside the track so z-index is unambiguous {%- endcomment -%}
          {%- if product.images.size > 1 -%}
            <button class="gallery-arrow gallery-arrow--prev" type="button" aria-label="Previous image" data-gallery-prev>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="gallery-arrow gallery-arrow--next" type="button" aria-label="Next image" data-gallery-next>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="gallery-dots" aria-hidden="true">
            {%- for image in product.images limit: 8 -%}
              <span class="gallery-dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}"></span>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>

    </div>
    {%- comment -%} /gallery {%- endcomment -%}


    {%- comment -%} ===========================================
      PRODUCT INFO
    =========================================== {%- endcomment -%}
    <div class="product-info">

      {%- comment -%} -- Eyebrow -- {%- endcomment -%}
      <p class="product-eyebrow">
        {%- if section.settings.eyebrow_text != blank -%}
          {{ section.settings.eyebrow_text }}
        {%- elsif product.collections.first -%}
          {{ product.collections.first.title }}
        {%- else -%}
          Shower Filtration
        {%- endif -%}
      </p>

      {%- comment -%} -- Title -- {%- endcomment -%}
      <h1 class="product-title">{{ product.title }}</h1>

      {%- comment -%} -- Rating -- {%- endcomment -%}
      {%- liquid
        comment
          Priority:
          1. product.metafields.reviews.rating / reviews.rating_count (Judge.me, Okendo, etc.)
          2. product.metafields.custom.rating_value / custom.rating_count
          3. Section setting overrides (manual fallback)
        endcomment

        assign rating_value = ''
        assign rating_count = ''

        if product.metafields.reviews.rating != blank
          assign rating_value = product.metafields.reviews.rating.value
          assign rating_count = product.metafields.reviews.rating_count.value
        elsif product.metafields.custom.rating_value != blank
          assign rating_value = product.metafields.custom.rating_value
          assign rating_count = product.metafields.custom.rating_count
        endif

        if section.settings.rating_value != blank
          assign rating_value = section.settings.rating_value
        endif
        if section.settings.rating_count_text != blank
          assign rating_count = section.settings.rating_count_text
        endif

        assign rating_href = section.settings.rating_link | default: '#product-reviews'
      -%}
      {%- if rating_value != blank and section.settings.rating_show -%}
        <div class="product-rating" aria-label="Rated {{ rating_value }} out of 5, {{ rating_count }}">
          <div class="rating-stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              <svg class="star" viewBox="0 0 16 16" width="13" height="13" aria-hidden="true">
                <polygon points="8,1.2 10.2,5.8 15.4,6.4 11.5,10.2 12.7,15.4 8,12.7 3.3,15.4 4.5,10.2 0.6,6.4 5.8,5.8"/>
              </svg>
            {%- endfor -%}
          </div>
          <span class="rating-text">
            <strong>{{ rating_value }}</strong>
            <span class="rating-sep" aria-hidden="true">&middot;</span>
            <a href="{{ rating_href }}" class="rating-link">{{ rating_count }}</a>
          </span>
        </div>
      {%- endif -%}

      {%- comment -%} -- Product badges -- {%- endcomment -%}
      {%- assign pdp_is_hot = false -%}
      {%- if product.tags contains 'Hot' -%}{%- assign pdp_is_hot = true -%}{%- endif -%}
      {%- assign pdp_on_sale = false -%}
      {%- if current_variant.compare_at_price > current_variant.price -%}{%- assign pdp_on_sale = true -%}{%- endif -%}
      {%- if pdp_on_sale or pdp_is_hot -%}
        <div class="pdp-badges" data-reveal data-reveal-delay="0">
          {%- if pdp_on_sale -%}
            <span class="badge badge--amber">Sale</span>
          {%- endif -%}
          {%- if pdp_is_hot -%}
            <span class="badge badge--hot">Hot</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} -- Price -- {%- endcomment -%}
      <div class="price-block" id="PriceBlock-{{ section.id }}" data-reveal data-reveal-delay="0">
        <div class="price-row">
          <span class="price-now{% if current_variant.compare_at_price > current_variant.price %} price-now--on-sale{% endif %}" id="PriceNow-{{ section.id }}">
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="price-was" id="PriceWas-{{ section.id }}">
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="price-save" id="PriceSave-{{ section.id }}">
              Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
            </span>
          {%- endif -%}
        </div>
        <p class="price-callout">
          {%- if product.metafields.custom.per_use_callout != blank -%}
            {{ product.metafields.custom.per_use_callout }}
          {%- elsif section.settings.per_use_text != blank -%}
            {{ section.settings.per_use_text }}
          {%- endif -%}
        </p>
      </div>

      {%- comment -%} -- Subscription toggle (only when selling plans are configured) -- {%- endcomment -%}
      {%- if product.selling_plan_groups.size > 0 -%}
        {%- liquid
          assign sp_group = product.selling_plan_groups.first
          assign sp       = sp_group.selling_plans.first
          assign sp_adj   = sp.price_adjustments.first

          assign subscribe_label = sp_group.name | default: section.settings.toggle_subscribe_label | default: 'Subscribe & Save'

          if sp_adj.value_type == 'percentage'
            assign subscribe_badge = sp_adj.value | append: '% off'
          elsif sp_adj.value_type == 'fixed_amount'
            assign subscribe_badge = sp_adj.value | money | append: ' off'
          else
            assign subscribe_badge = section.settings.toggle_subscribe_savings | default: '10% off'
          endif
        -%}
        <div
          class="purchase-toggle"
          role="group"
          aria-label="Purchase type"
          id="PurchaseToggle-{{ section.id }}"
        >
          <button
            class="purchase-toggle__btn is-active"
            data-purchase-type="one-time"
            type="button"
            aria-pressed="true"
          >
            <span class="toggle-label">{{ section.settings.toggle_onetime_label | default: 'One-time' }}</span>
            <span class="toggle-price" id="TogglePriceOnce-{{ section.id }}">{{ current_variant.price | money }}</span>
          </button>
          <button
            class="purchase-toggle__btn"
            data-purchase-type="subscribe"
            type="button"
            aria-pressed="false"
          >
            <span class="toggle-label">{{ subscribe_label | escape }}</span>
            <span class="toggle-price">{{ subscribe_badge | escape }}</span>
          </button>
        </div>
      {%- endif -%}
      <input
        type="hidden"
        name="selling_plan"
        id="SellingPlan-{{ section.id }}"
        form="{{ product_form_id }}"
        value=""
      >

      {%- comment -%} -- Short description -- {%- endcomment -%}
      <p class="product-short-desc">
        {%- if product.metafields.custom.short_description != blank -%}
          {{ product.metafields.custom.short_description }}
        {%- elsif section.settings.short_description != blank -%}
          {{ section.settings.short_description }}
        {%- else -%}
          {{ product.description | strip_html | truncate: 200 }}
        {%- endif -%}
      </p>

      {%- comment -%} -- Variant picker -- {%- endcomment -%}
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <fieldset class="variant-fieldset" id="VariantFieldset-{{ section.id }}-{{ option.position }}">
            <legend class="variant-legend">{{ option.name }}</legend>
            <div class="variant-cards">
              {%- for value in option.values -%}
                {%- assign pos = option.position -%}
                {%- assign opt_key = 'option' | append: pos -%}
                {%- assign is_selected = false -%}
                {%- if current_variant[opt_key] == value -%}
                  {%- assign is_selected = true -%}
                {%- endif -%}
                {%- assign matching_variant = product.variants | where: opt_key, value | first -%}
                <label
                  class="variant-card{% if is_selected %} is-selected{% endif %}{% unless matching_variant.available %} is-sold-out{% endunless %}"
                  for="Variant-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                  tabindex="0"
                >
                  <input
                    type="radio"
                    id="Variant-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                    name="option-{{ option.position }}"
                    value="{{ value | escape }}"
                    {% if is_selected %}checked{% endif %}
                    {% unless matching_variant.available %}disabled{% endunless %}
                    data-option-position="{{ option.position }}"
                    class="variant-card__radio"
                  >
                  <span class="variant-card__name">{{ value }}</span>
                  {%- unless matching_variant.available -%}
                    <span class="variant-card__out">{{ section.settings.variant_sold_out_label | default: 'Sold out' | escape }}</span>
                  {%- endunless -%}
                </label>
              {%- endfor -%}
            </div>
          </fieldset>
        {%- endfor -%}
      {%- endunless -%}

      {%- comment -%} -- Product form -- {%- endcomment -%}
      {%- form 'product', product,
            id: product_form_id,
            data-type: 'add-to-cart-form' -%}

        <input
          type="hidden"
          name="id"
          id="ProductVariantId-{{ section.id }}"
          value="{{ current_variant.id }}"
        >

        {%- comment -%} Quantity {%- endcomment -%}
        <div class="qty-row">
          <label class="qty-label" for="Qty-{{ section.id }}">{{ section.settings.qty_label | default: 'Qty' | escape }}</label>
          <div class="qty-stepper" role="group" aria-label="Quantity">
            <button
              class="qty-btn"
              type="button"
              aria-label="Decrease quantity"
              data-action="decrease"
            >-</button>
            <input
              class="qty-input"
              type="number"
              id="Qty-{{ section.id }}"
              name="quantity"
              value="1"
              min="1"
              aria-label="Quantity"
            >
            <button
              class="qty-btn"
              type="button"
              aria-label="Increase quantity"
              data-action="increase"
            >+</button>
          </div>
        </div>

        {%- comment -%} Add to cart {%- endcomment -%}
        <button
          type="submit"
          id="AddToCart-{{ section.id }}"
          class="btn-atc"
          {% unless current_variant.available %}disabled{% endunless %}
          aria-label="Add {{ product.title }} to cart"
        >
          <span id="AddToCartText-{{ section.id }}">
            {%- if current_variant.available -%}
              {{ section.settings.atc_label | default: 'Add to Cart' | escape }}
            {%- else -%}
              {{ section.settings.atc_sold_out_label | default: 'Sold Out' | escape }}
            {%- endif -%}
          </span>
        </button>

        {%- comment -%} Accelerated checkout (Shop Pay, Apple Pay, etc.) {%- endcomment -%}
        <div class="pdp-payment-btns">
          {{ form | payment_button }}
        </div>

      {%- endform -%}

      {%- comment -%} -- Trust strip -- {%- endcomment -%}
      <ul class="trust-strip" role="list">
        <li class="trust-item" data-reveal data-reveal-delay="0">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
            <path d="M1 3h4l2.5 11.5h11L21 7H6"/>
            <circle cx="9" cy="20" r="1.5" fill="currentColor" stroke="none"/>
            <circle cx="18" cy="20" r="1.5" fill="currentColor" stroke="none"/>
          </svg>
          <span>{{ section.settings.trust_1_text | default: 'Free shipping over $60' | escape }}</span>
        </li>
        <li class="trust-item" data-reveal data-reveal-delay="80">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
            <polyline points="1 4 1 10 7 10"/>
            <path d="M3.51 15a9 9 0 1 0 .49-4.17"/>
          </svg>
          <span>{{ section.settings.trust_2_text | default: '30-day returns' | escape }}</span>
        </li>
        <li class="trust-item" data-reveal data-reveal-delay="160">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
            <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.5C17.25 22.15 21 17.25 21 12V7L12 2z"/>
          </svg>
          <span>{{ section.settings.trust_3_text | default: '2-year warranty' | escape }}</span>
        </li>
      </ul>

      {%- comment -%} -- Accordion -- {%- endcomment -%}
      <div class="accordion" id="Accordion-{{ section.id }}">

        {%- assign accordion_keys = "whats-included,how-it-works,ingredients-certifications" | split: "," -%}
        {%- assign label_1 = section.settings.accordion_label_1 | default: "What's included" -%}
        {%- assign label_2 = section.settings.accordion_label_2 | default: "How it works" -%}
        {%- assign label_3 = section.settings.accordion_label_3 | default: "Ingredients & certifications" -%}
        {%- assign accordion_labels = label_1 | append: "|||" | append: label_2 | append: "|||" | append: label_3 | split: "|||" -%}

        {%- for label in accordion_labels -%}
          {%- assign key        = accordion_keys[forloop.index0] -%}
          {%- assign setting_id = 'accordion_' | append: key -%}
          {%- assign panel_id   = 'AccordionPanel-'   | append: section.id | append: '-' | append: forloop.index -%}
          {%- assign trigger_id = 'AccordionTrigger-' | append: section.id | append: '-' | append: forloop.index -%}
          {%- comment -%} Per-product metafield overrides section setting {%- endcomment -%}
          {%- if forloop.index0 == 0 -%}
            {%- assign mf_panel = product.metafields.custom.whats_included -%}
          {%- elsif forloop.index0 == 1 -%}
            {%- assign mf_panel = product.metafields.custom.how_it_works -%}
          {%- elsif forloop.index0 == 2 -%}
            {%- assign mf_panel = product.metafields.custom.ingredients_certifications -%}
          {%- endif -%}

          <div class="accordion__item">
            <button
              class="accordion__trigger"
              type="button"
              id="{{ trigger_id }}"
              aria-expanded="false"
              aria-controls="{{ panel_id }}"
            >
              <span>{{ label }}</span>
              <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>

            <div
              class="accordion__panel"
              id="{{ panel_id }}"
              role="region"
              aria-labelledby="{{ trigger_id }}"
              hidden
            >
              <div class="accordion__body">
                {%- if mf_panel != blank -%}
                  {{ mf_panel }}
                {%- elsif section.settings[setting_id] != blank -%}
                  {{ section.settings[setting_id] }}
                {%- elsif key == 'whats-included' -%}
                  <ul>
                    <li>1 x Mend filter unit -- installs in under 60 seconds, no tools required</li>
                    <li>Filter cartridge rated for 10,000 litres (~6 months average use)</li>
                    <li>Universal thread adapter set (fits 95% of shower heads)</li>
                    <li>Quick-start installation guide</li>
                  </ul>
                {%- elsif key == 'how-it-works' -%}
                  <p>Mend uses a dual-stage KDF-55 + activated carbon filter to neutralise chlorine, reduce heavy metals, and soften water before it ever reaches your skin or hair. Screws onto any standard shower arm in under 60 seconds. No plumber. No tools.</p>
                {%- elsif key == 'ingredients-certifications' -%}
                  <p>KDF-55 media (copper-zinc alloy), coconut shell activated carbon, food-grade polypropylene housing. NSF/ANSI 42 &amp; 61 certified. BPA-free. Independently tested by SGS Laboratories.</p>
                {%- endif -%}
              </div>
            </div>
          </div>

        {%- endfor -%}
      </div>
      {%- comment -%} /accordion {%- endcomment -%}

    </div>
    {%- comment -%} /product-info {%- endcomment -%}

  </div>
  {%- content_for 'blocks' -%}
</section>


<style>
/* ============================================================
   MAIN PRODUCT -- Mend & Co
   ============================================================ */

.product-section {
  background: var(--color-bone, #F2EDE4);
  padding: 5rem 0 8rem;
}

.product-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 4rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 7rem;
  align-items: start;
}


/* -- GALLERY --------------------------------------- */

.product-gallery {
  position: sticky;
  top: 7rem;
  display: flex;
  flex-direction: row;
  gap: 0.75rem;
  align-items: flex-start;
}

/* Left: vertical thumbnail strip */
.gallery-thumbs {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  width: 76px;
  flex-shrink: 0;
}

.gallery-thumb {
  width: 76px;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  background: #F2EDE4;
  border: 1.5px solid rgba(43, 43, 43, 0.08);
  border-radius: 4px;
  cursor: pointer;
  padding: 0;
  position: relative;
  transition: border-color 0.2s ease;
  flex-shrink: 0;
}

.gallery-thumb.is-active {
  border-color: var(--color-walnut, #8A6240);
}

.gallery-thumb:focus-visible {
  outline: 1.5px solid var(--color-walnut, #8A6240);
  outline-offset: 2px;
}

.gallery-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  opacity: 0.6;
  transition: opacity 0.2s ease;
}

.gallery-thumb.is-active img,
.gallery-thumb:hover img {
  opacity: 1;
}

/* Right: main image wrapper */
.gallery-main {
  flex: 1;
  position: relative;
}

/* Track: desktop = one slide at a time via opacity */
.gallery-track {
  position: relative;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  background: #F2EDE4;
  border: 1px solid rgba(43, 43, 43, 0.08);
  border-radius: 8px;
  box-shadow: 0 6px 32px rgba(43, 43, 43, 0.08), 0 1px 4px rgba(43, 43, 43, 0.05);
}

.gallery-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}

.gallery-slide.is-active {
  opacity: 1;
  pointer-events: auto;
}

.gallery-slide__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}


/* Prev / next arrows — inside .gallery-track so z-index is unambiguous */
.gallery-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: rgba(255, 255, 255, 0.92);
  border: none;
  border-radius: 50%;
  color: #2D2D2D;
  cursor: pointer;
  pointer-events: auto;
  box-shadow: 0 2px 8px rgba(0,0,0,0.14);
  opacity: 0;
  transition: opacity 0.2s ease, background 0.15s;
  backdrop-filter: blur(4px);
}

.gallery-arrow--prev { left: 10px; }
.gallery-arrow--next { right: 10px; }

.gallery-track:hover .gallery-arrow {
  opacity: 1;
}

.gallery-arrow:hover {
  background: #fff;
}

/* Dots — mobile only */
.gallery-dots {
  display: none;
}


/* -- PRODUCT INFO ----------------------------------- */

.product-info {
  padding-top: 0.25rem;
}

/* Eyebrow
   Text: mahogany #8A6240 on linen = 7.59:1  (amber clay fails at 2.55:1)
   Amber retained as the decorative border-bottom rule only */
.product-eyebrow {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--color-olive);
  margin: 0 0 1.25rem;
  padding-bottom: 1.25rem;
  border-bottom: 1.5px solid var(--color-walnut, #8A6240);
}

/* Title */
.product-title {
  font-family: var(--font-heading);
  font-size: clamp(1.875rem, 3vw, 2.625rem);
  font-weight: 400;
  color: var(--color-black);
  line-height: 1.18;
  letter-spacing: -0.015em;
  margin: 0 0 1.125rem;
}

/* Rating */
.product-rating {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  margin-bottom: 1.75rem;
}

.rating-stars {
  display: flex;
  gap: 2px;
}

.star {
  fill: var(--color-walnut, #8A6240);
}

.rating-text {
  font-family: var(--font-label);
  font-size: 0.8125rem;
  color: var(--color-olive);
  display: flex;
  align-items: center;
  gap: 0.375rem;
}

.rating-text strong {
  font-weight: 600;
  color: var(--color-black);
}

.rating-sep {
  opacity: 0.4;
}

.rating-link {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
  text-decoration-color: rgba(166, 137, 102, 0.35);
  transition: text-decoration-color 0.15s ease;
}

.rating-link:hover {
  text-decoration-color: var(--color-walnut, #8A6240);
}

/* Product badges */
.pdp-badges {
  display: flex;
  flex-direction: row;
  gap: 6px;
  margin-bottom: 1rem;
}

.pdp-badges .badge {
  min-width: 42px;
  justify-content: center;
}

/* Price block */
.price-block {
  margin-bottom: 1.75rem;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  margin-bottom: 0.3rem;
  flex-wrap: wrap;
}

.price-now {
  font-family: var(--font-heading);
  font-size: 1.875rem;
  font-weight: 400;
  color: var(--color-black);
  letter-spacing: -0.02em;
  line-height: 1;
}

.price-was {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  color: var(--color-olive);
  text-decoration: line-through;
  opacity: 0.55;
}

.price-now--on-sale {
  color: var(--color-walnut, #8A6240);
}

.price-save {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #C0392B;
  background: rgba(192, 57, 43, 0.1);
  padding: 0.25rem 0.5rem;
  border-radius: 2px;
  align-self: center;
}

.price-callout {
  font-family: var(--font-label);
  font-size: 0.8rem;
  /* Hardcoded blended value: mahogany #8A6240 at ~72% on linen ~ #9A7255, 4.68:1 
     Avoids opacity: which renders ~3.8:1 and is unmeasurable in static audits */
  color: #9A7255;
  margin: 0;
}

/* Purchase toggle */
.purchase-toggle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.375rem;
  padding: 0.375rem;
  background: rgba(43, 43, 43, 0.05);
  border-radius: 4px;
  margin-bottom: 1.75rem;
}

.purchase-toggle__btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
  padding: 0.75rem 1rem;
  background: transparent;
  border: 1.5px solid transparent;
  border-radius: 3px;
  cursor: pointer;
  transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
  text-align: center;
}

.purchase-toggle__btn.is-active {
  background: var(--color-bone, #F2EDE4);
  /* Border: mahogany = 7.59:1  (amber = 2.55:1, fails WCAG 1.4.11 non-text 3:1) */
  border-color: var(--color-olive);
  box-shadow: 0 1px 4px rgba(43, 43, 43, 0.07);
}

.purchase-toggle__btn:hover:not(.is-active) {
  border-color: rgba(166, 137, 102, 0.35);
}

.toggle-label {
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-black);
  letter-spacing: 0.01em;
}

.toggle-price {
  font-family: var(--font-label);
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-olive);
}

/* Short description */
.product-short-desc {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  line-height: 1.72;
  color: var(--color-olive);
  margin: 0 0 1.875rem;
}

/* Variant fieldset */
.variant-fieldset {
  border: none;
  padding: 0;
  margin: 0 0 1.5rem;
}

.variant-legend {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--color-black);
  display: block;
  margin-bottom: 0.75rem;
  padding: 0;
  float: none;
  width: 100%;
}

.variant-cards {
  display: flex;
