  }

  .variant-card {
    min-width: 0;
    flex: 1 1 calc(33.333% - 0.4rem);
    padding: 0.6rem 0.75rem;
  }

  .trust-strip {
    flex-direction: column;
    gap: 0.75rem;
  }

  .trust-item {
