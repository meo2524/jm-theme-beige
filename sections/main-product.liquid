{% comment %}
  main-product.liquid
  Mend & Co -- Product Detail Page
  2-col gallery + info layout. Sticky gallery on desktop, scroll-snap swipe on mobile.
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign product_form_id = 'product-form-' | append: section.id -%}

<section
  class="product-section"
  data-section-id="{{ section.id }}"
  data-section-type="main-product"
>
  <div class="product-container">

    {%- comment -%} ===========================================
      GALLERY — sticky left column
      carousel lives inside gallery-main so they move as one unit
    =========================================== {%- endcomment -%}
    <div class="product-gallery">

      {%- comment -%} Left: vertical thumbnail strip (desktop only) {%- endcomment -%}
      {%- if product.images.size > 1 -%}
        <div class="gallery-thumbs" id="GalleryThumbs-{{ section.id }}" role="list" aria-label="Image thumbnails">
          {%- for image in product.images limit: 8 -%}
            <button
              class="gallery-thumb{% if forloop.first %} is-active{% endif %}"
              data-index="{{ forloop.index0 }}"
              type="button"
              aria-label="View image {{ forloop.index }}"
              role="listitem"
            >
              <img
                src="{{ image | image_url: width: 160 }}"
                alt="{{ image.alt | escape | default: product.title }}"
                width="160"
                height="200"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Right: photo box + carousel stacked inside the same bordered box {%- endcomment -%}
      <div class="gallery-main">

        <div class="gallery-track" id="GalleryTrack-{{ section.id }}" role="region" aria-label="Product images">
          {%- if product.images.size > 0 -%}
            {%- for image in product.images limit: 8 -%}
              <div
                class="gallery-slide{% if forloop.first %} is-active{% endif %}"
                data-index="{{ forloop.index0 }}"
              >
                <img
                  src="{{ image | image_url: width: 960 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  class="gallery-slide__img"
                >
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="gallery-slide is-active">
              {{ 'product-1' | placeholder_svg_tag: 'gallery-slide__placeholder' }}
            </div>
          {%- endif -%}

          {%- if product.images.size > 1 -%}
            <button class="gallery-arrow gallery-arrow--prev" type="button" aria-label="Previous image" data-gallery-prev>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="gallery-arrow gallery-arrow--next" type="button" aria-label="Next image" data-gallery-next>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="gallery-dots" aria-hidden="true">
            {%- for image in product.images limit: 8 -%}
              <span class="gallery-dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}"></span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} Mini review carousel — inside the photo box, moves with it on scroll {%- endcomment -%}
        {%- assign mini_reviews = section.blocks | where: 'type', 'mini_testimonial' -%}
        {%- if mini_reviews.size > 0 -%}
          <div class="pdp-review-carousel" id="PdpReviewCarousel-{{ section.id }}" aria-label="Customer reviews">
            <div class="prc-track">
              {%- for block in mini_reviews -%}
                <div class="prc-slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
                  <div class="prc-stars" aria-label="{{ block.settings.stars | default: 5 }} out of 5 stars">
                    {%- assign stars = block.settings.stars | default: 5 -%}
                    {%- for i in (1..5) -%}
                      <span class="prc-star{% if i > stars %} prc-star--empty{% endif %}" aria-hidden="true">★</span>
                    {%- endfor -%}
                  </div>
                  <p class="prc-quote">{{ block.settings.quote | escape }}</p>
                  <div class="prc-footer">
                    <div class="prc-author-wrap">
                      <span class="prc-name">{{ block.settings.author | escape }}</span>
                      {%- if block.settings.verified -%}
                        <span class="prc-badge">Verified</span>
                      {%- endif -%}
                    </div>
                    {%- if block.settings.author_detail != blank -%}
                      <span class="prc-detail">{{ block.settings.author_detail | escape }}</span>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
            <div class="prc-controls">
              <button class="prc-arrow prc-arrow--prev" type="button" aria-label="Previous review">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <div class="prc-dots" aria-hidden="true">
                {%- for block in mini_reviews -%}
                  <button class="prc-dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" type="button" aria-label="Review {{ forloop.index }}"></button>
                {%- endfor -%}
              </div>
              <button class="prc-arrow prc-arrow--next" type="button" aria-label="Next review">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>
        {%- endif -%}

      </div>
      {%- comment -%} /gallery-main {%- endcomment -%}

    </div>
    {%- comment -%} /product-gallery {%- endcomment -%}


    {%- comment -%} ===========================================
      PRODUCT INFO
    =========================================== {%- endcomment -%}
    <div class="product-info">

      {%- comment -%} ============================================================
        MOTHER'S DAY BANNER — gated by settings.motion_enabled.
        Live countdown to Sunday 11 May 2026 23:59 NZT.
      ============================================================ {%- endcomment -%}
      {%- if settings.motion_enabled -%}
        <div class="mc-mday-banner" data-mday-deadline="2026-05-11T23:59:00+12:00" data-reveal data-reveal-delay="0">
          <span class="mc-mday-banner__shine" aria-hidden="true"></span>
          <div class="mc-mday-banner__inner">
            <span class="mc-mday-banner__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M12 21s-7.5-4.7-9.6-9.4C1.1 8.3 3.4 5 6.7 5c1.9 0 3.7 1.1 4.6 2.7C12.2 6.1 14 5 16 5c3.3 0 5.6 3.3 4.3 6.6C19.5 16.3 12 21 12 21z"/></svg>
            </span>
            <span class="mc-mday-banner__title">Mother's Day Sale</span>
            <span class="mc-mday-banner__sep" aria-hidden="true">·</span>
            <span class="mc-mday-banner__count" aria-live="polite">Ends Sunday</span>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} -- Eyebrow -- {%- endcomment -%}
      <p class="product-eyebrow">
        {%- if section.settings.eyebrow_text != blank -%}
          {{ section.settings.eyebrow_text }}
        {%- elsif product.collections.first -%}
          {{ product.collections.first.title }}
        {%- else -%}
          Shower Filtration
        {%- endif -%}
      </p>

      {%- comment -%} -- Title -- {%- endcomment -%}
      <h1 class="product-title" data-word-reveal>{{ product.title }}{%- if section.settings.model_badge != blank %} <span class="product-title__model">{{ section.settings.model_badge }}</span>{%- endif -%}</h1>

      {%- comment -%} -- Rating -- {%- endcomment -%}
      {%- liquid
        comment
          Priority:
          1. product.metafields.reviews.rating / reviews.rating_count (Judge.me, Okendo, etc.)
          2. product.metafields.custom.rating_value / custom.rating_count
          3. Section setting overrides (manual fallback)
        endcomment

        assign rating_value = ''
        assign rating_count = ''

        if product.metafields.reviews.rating != blank
          assign rating_value = product.metafields.reviews.rating.value
          assign rating_count = product.metafields.reviews.rating_count.value
        elsif product.metafields.custom.rating_value != blank
          assign rating_value = product.metafields.custom.rating_value
          assign rating_count = product.metafields.custom.rating_count
        endif

        if section.settings.rating_value != blank
          assign rating_value = section.settings.rating_value
        endif
        if section.settings.rating_count_text != blank
          assign rating_count = section.settings.rating_count_text
        endif

        assign rating_href = section.settings.rating_link | default: '#product-reviews'
      -%}
      {%- if rating_value != blank and section.settings.rating_show -%}
        <div class="product-rating" aria-label="Rated {{ rating_value }} out of 5, {{ rating_count }}">
          <div class="rating-stars-wrap">
            <div class="rating-stars" aria-hidden="true">
              {%- for i in (1..5) -%}
                <svg class="star" viewBox="0 0 16 16" width="20" height="20" aria-hidden="true">
                  <polygon points="8,1.2 10.2,5.8 15.4,6.4 11.5,10.2 12.7,15.4 8,12.7 3.3,15.4 4.5,10.2 0.6,6.4 5.8,5.8"/>
                </svg>
              {%- endfor -%}
            </div>
            <span class="rating-value-num">{{ rating_value }}</span>
          </div>
          <div class="rating-copy">
            <span class="rating-count">{{ rating_count }}</span>
            {%- if section.settings.rating_subtext != blank -%}
              <span class="rating-subtext">{{ section.settings.rating_subtext }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} -- Product badges -- {%- endcomment -%}
      {%- assign pdp_is_hot = false -%}
      {%- if product.tags contains 'Hot' -%}{%- assign pdp_is_hot = true -%}{%- endif -%}
      {%- assign pdp_on_sale = false -%}
      {%- if current_variant.compare_at_price > current_variant.price -%}{%- assign pdp_on_sale = true -%}{%- endif -%}
      {%- if pdp_on_sale or pdp_is_hot -%}
        <div class="pdp-badges" data-reveal data-reveal-delay="0">
          {%- if pdp_on_sale -%}
            <span class="badge badge--amber">{% if settings.motion_enabled %}Mother's Day Deal{% else %}Sale{% endif %}</span>
          {%- endif -%}
          {%- if pdp_is_hot -%}
            <span class="badge badge--hot">Hot</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} -- Price -- {%- endcomment -%}
      <div class="price-block" id="PriceBlock-{{ section.id }}" data-reveal data-reveal-delay="0">
        <div class="price-row">
          <span class="price-now{% if current_variant.compare_at_price > current_variant.price %} price-now--on-sale{% endif %}" id="PriceNow-{{ section.id }}">
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="price-was" id="PriceWas-{{ section.id }}">
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="price-save" id="PriceSave-{{ section.id }}">
              Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
            </span>
          {%- endif -%}
        </div>
        <p class="price-callout">
          {%- if product.metafields.custom.per_use_callout != blank -%}
            {{ product.metafields.custom.per_use_callout }}
          {%- elsif section.settings.per_use_text != blank -%}
            {{ section.settings.per_use_text }}
          {%- endif -%}
        </p>
      </div>

      {%- comment -%} -- Subscription toggle (only when selling plans are configured) -- {%- endcomment -%}
      {%- if product.selling_plan_groups.size > 0 -%}
        {%- liquid
          assign sp_group = product.selling_plan_groups.first
          assign sp       = sp_group.selling_plans.first
          assign sp_adj   = sp.price_adjustments.first

          assign subscribe_label = sp_group.name | default: section.settings.toggle_subscribe_label | default: 'Subscribe & Save'

          if sp_adj.value_type == 'percentage'
            assign subscribe_badge = sp_adj.value | append: '% off'
          elsif sp_adj.value_type == 'fixed_amount'
            assign subscribe_badge = sp_adj.value | money | append: ' off'
          else
            assign subscribe_badge = section.settings.toggle_subscribe_savings | default: '10% off'
          endif
        -%}
        <div
          class="purchase-toggle"
          role="group"
          aria-label="Purchase type"
          id="PurchaseToggle-{{ section.id }}"
        >
          <button
            class="purchase-toggle__btn is-active"
            data-purchase-type="one-time"
            type="button"
            aria-pressed="true"
          >
            <span class="toggle-label">{{ section.settings.toggle_onetime_label | default: 'One-time' }}</span>
            <span class="toggle-price" id="TogglePriceOnce-{{ section.id }}">{{ current_variant.price | money }}</span>
          </button>
          <button
            class="purchase-toggle__btn"
            data-purchase-type="subscribe"
            type="button"
            aria-pressed="false"
          >
            <span class="toggle-label">{{ subscribe_label | escape }}</span>
            <span class="toggle-price">{{ subscribe_badge | escape }}</span>
          </button>
        </div>
      {%- endif -%}
      <input
        type="hidden"
        name="selling_plan"
        id="SellingPlan-{{ section.id }}"
        form="{{ product_form_id }}"
        value=""
      >

      {%- comment -%} -- Short description -- {%- endcomment -%}
      {%- assign blurb_heading    = product.metafields.custom.blurb_heading    | default: section.settings.blurb_heading -%}
      {%- assign blurb_subheading = product.metafields.custom.blurb_subheading | default: section.settings.blurb_subheading -%}
      <div class="product-blurb">
        {%- if blurb_heading != blank -%}
          <p class="product-blurb__heading">{{ blurb_heading }}</p>
        {%- endif -%}
        {%- if blurb_subheading != blank -%}
          <p class="product-blurb__subhead">{{ blurb_subheading }}</p>
        {%- endif -%}
        <p class="product-blurb__body">
          {%- if product.metafields.custom.short_description != blank -%}
            {{ product.metafields.custom.short_description }}
          {%- elsif section.settings.short_description != blank -%}
            {{ section.settings.short_description }}
          {%- else -%}
            {{ product.description | strip_html | truncate: 200 }}
          {%- endif -%}
        </p>
      </div>

      {%- comment -%} -- Spec pills -- {%- endcomment -%}
      <div class="spec-pills" role="list">
        <span class="spec-pill mc-spec-pill" role="listitem" data-reveal data-reveal-delay="0" data-spec-tip="One charge. Most of the week. Forget the cable.">
          <svg class="mc-spec-icon mc-spec-icon--battery" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12" aria-hidden="true"><circle cx="8" cy="8" r="6"/><path d="M8 5v3l2 1"/></svg>
          <span class="mc-spec-num">5–7</span> day battery
        </span>
        <span class="spec-pill mc-spec-pill" role="listitem" data-reveal data-reveal-delay="80" data-spec-tip="Swim, shower, sauna — all good.">
          <svg class="mc-spec-icon mc-spec-icon--water" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12" aria-hidden="true"><path d="M8 2c-2.5 0-5 2-5 5s2.5 6 5 6 5-3 5-6-2.5-5-5-5z"/><path d="M8 8v-3"/></svg>
          5ATM waterproof
        </span>
        <span class="spec-pill mc-spec-pill" role="listitem" data-reveal data-reveal-delay="160" data-spec-tip="Zirconia ceramic — scratch-resistant, hypoallergenic.">
          <svg class="mc-spec-icon mc-spec-icon--ceramic" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12" aria-hidden="true"><rect x="2" y="5" width="12" height="8" rx="1.5"/><path d="M5 5V4a3 3 0 016 0v1"/></svg>
          Ceramic build
        </span>
        <span class="spec-pill mc-spec-pill mc-spec-pill--hero" role="listitem" data-reveal data-reveal-delay="240" data-spec-tip="Own your data. No subscription, ever.">
          <svg class="mc-spec-icon mc-spec-icon--zero" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12" aria-hidden="true"><path d="M8 2v12M5 5h4.5a2.5 2.5 0 010 5H5"/><path d="M5 10h5"/></svg>
          <span class="mc-spec-num">$0</span> / month
        </span>
      </div>

      {%- comment -%} -- Variant picker -- {%- endcomment -%}
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <fieldset class="variant-fieldset" id="VariantFieldset-{{ section.id }}-{{ option.position }}">
            <legend class="variant-legend">{{ option.name }}</legend>
            <div class="variant-cards">
              {%- for value in option.values -%}
                {%- assign pos = option.position -%}
                {%- assign opt_key = 'option' | append: pos -%}
                {%- assign is_selected = false -%}
                {%- if current_variant[opt_key] == value -%}
                  {%- assign is_selected = true -%}
                {%- endif -%}
                {%- assign matching_variant = product.variants | where: opt_key, value | first -%}
                <label
                  class="variant-card{% if is_selected %} is-selected{% endif %}{% unless matching_variant.available %} is-sold-out{% endunless %}"
                  for="Variant-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                  tabindex="0"
                >
                  <input
                    type="radio"
                    id="Variant-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                    name="option-{{ option.position }}"
                    value="{{ value | escape }}"
                    {% if is_selected %}checked{% endif %}
                    {% unless matching_variant.available %}disabled{% endunless %}
                    data-option-position="{{ option.position }}"
                    class="variant-card__radio"
                  >
                  <span class="variant-card__name">{{ value }}</span>
                  {%- unless matching_variant.available -%}
                    <span class="variant-card__out">{{ section.settings.variant_sold_out_label | default: 'Sold out' | escape }}</span>
                  {%- endunless -%}
                </label>
              {%- endfor -%}
            </div>
          </fieldset>
        {%- endfor -%}
      {%- endunless -%}

      {%- comment -%} -- Product form -- {%- endcomment -%}
      {%- form 'product', product,
            id: product_form_id,
            data-type: 'add-to-cart-form' -%}

        <input
          type="hidden"
          name="id"
          id="ProductVariantId-{{ section.id }}"
          value="{{ current_variant.id }}"
        >

        {%- comment -%} Quantity {%- endcomment -%}
        <div class="qty-row">
          <label class="qty-label" for="Qty-{{ section.id }}">{{ section.settings.qty_label | default: 'Qty' | escape }}</label>
          <div class="qty-stepper" role="group" aria-label="Quantity">
            <button
              class="qty-btn"
              type="button"
              aria-label="Decrease quantity"
              data-action="decrease"
            >-</button>
            <input
              class="qty-input"
              type="number"
              id="Qty-{{ section.id }}"
              name="quantity"
              value="1"
              min="1"
              aria-label="Quantity"
            >
            <button
              class="qty-btn"
              type="button"
              aria-label="Increase quantity"
              data-action="increase"
            >+</button>
          </div>
        </div>

        {%- comment -%} Add to cart {%- endcomment -%}
        <button
          type="submit"
          id="AddToCart-{{ section.id }}"
          class="btn-atc{% if settings.motion_enabled %} mc-shine{% endif %}"
          {% unless current_variant.available %}disabled{% endunless %}
          aria-label="Add {{ product.title }} to cart"
        >
          <span id="AddToCartText-{{ section.id }}">
            {%- if current_variant.available -%}
              {{ section.settings.atc_label | default: 'Add to Cart' | escape }}
            {%- else -%}
              {{ section.settings.atc_sold_out_label | default: 'Sold Out' | escape }}
            {%- endif -%}
          </span>
        </button>

        {%- comment -%} Accelerated checkout (Shop Pay, Apple Pay, etc.) {%- endcomment -%}
        <div class="pdp-payment-btns">
          {{ form | payment_button }}
        </div>

      {%- endform -%}

      {%- comment -%} -- Live status pulse (mc-pulse-dot) -- {%- endcomment -%}
      <p class="mc-pulse-dot mc-pulse-dot--urgent mc-trust-pulse" data-reveal data-reveal-delay="0" aria-live="polite">
        Only 47 left for Mother's Day
      </p>

      {%- comment -%} -- Trust strip -- {%- endcomment -%}
      <ul class="trust-strip" role="list">
        <li class="trust-item mc-trust-item" data-reveal data-reveal-delay="80">
          <svg class="trust-icon mc-trust-icon mc-trust-icon--ship" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
            <path class="mc-draw" d="M1 3h4l2.5 11.5h11L21 7H6"/>
            <circle cx="9" cy="20" r="1.5" fill="currentColor" stroke="none"/>
            <circle cx="18" cy="20" r="1.5" fill="currentColor" stroke="none"/>
          </svg>
          <span>{{ section.settings.trust_1_text | default: 'Free shipping over $60' | escape }}</span>
        </li>
        <li class="trust-item mc-trust-item" data-reveal data-reveal-delay="160">
          <svg class="trust-icon mc-trust-icon mc-trust-icon--return" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
            <polyline class="mc-draw" points="1 4 1 10 7 10"/>
            <path class="mc-draw" d="M3.51 15a9 9 0 1 0 .49-4.17"/>
          </svg>
          <span>{{ section.settings.trust_2_text | default: '30-day returns' | escape }}</span>
        </li>
        <li class="trust-item mc-trust-item mc-trust-item--hero" data-reveal data-reveal-delay="240">
          <svg class="trust-icon mc-trust-icon mc-trust-icon--shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
            <path class="mc-draw" d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.5C17.25 22.15 21 17.25 21 12V7L12 2z"/>
          </svg>
          <span>{{ section.settings.trust_3_text | default: '2-year warranty' | escape }}</span>
        </li>
      </ul>

      {%- comment -%} -- Accordion -- {%- endcomment -%}
      <div class="accordion" id="Accordion-{{ section.id }}">

        {%- assign accordion_keys = "whats-included,how-it-works,ingredients-certifications" | split: "," -%}
        {%- assign label_1 = section.settings.accordion_label_1 | default: "What's included" -%}
        {%- assign label_2 = section.settings.accordion_label_2 | default: "How it works" -%}
        {%- assign label_3 = section.settings.accordion_label_3 | default: "Ingredients & certifications" -%}
        {%- assign accordion_labels = label_1 | append: "|||" | append: label_2 | append: "|||" | append: label_3 | split: "|||" -%}

        {%- for label in accordion_labels -%}
          {%- assign key        = accordion_keys[forloop.index0] -%}
          {%- assign setting_id = 'accordion_' | append: key -%}
          {%- assign panel_id   = 'AccordionPanel-'   | append: section.id | append: '-' | append: forloop.index -%}
          {%- assign trigger_id = 'AccordionTrigger-' | append: section.id | append: '-' | append: forloop.index -%}
          {%- comment -%} Per-product metafield overrides section setting {%- endcomment -%}
          {%- if forloop.index0 == 0 -%}
            {%- assign mf_panel = product.metafields.custom.whats_included -%}
          {%- elsif forloop.index0 == 1 -%}
            {%- assign mf_panel = product.metafields.custom.how_it_works -%}
          {%- elsif forloop.index0 == 2 -%}
            {%- assign mf_panel = product.metafields.custom.ingredients_certifications -%}
          {%- endif -%}

          <div class="accordion__item">
            <button
              class="accordion__trigger"
              type="button"
              id="{{ trigger_id }}"
              aria-expanded="false"
              aria-controls="{{ panel_id }}"
            >
              <span>{{ label }}</span>
              <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>

            <div
              class="accordion__panel"
              id="{{ panel_id }}"
              role="region"
              aria-labelledby="{{ trigger_id }}"
              hidden
            >
              <div class="accordion__body">
                {%- if mf_panel != blank -%}
                  {{ mf_panel }}
                {%- elsif section.settings[setting_id] != blank -%}
                  {{ section.settings[setting_id] }}
                {%- elsif key == 'whats-included' -%}
                  <ul>
                    <li>1 x Mend filter unit -- installs in under 60 seconds, no tools required</li>
                    <li>Filter cartridge rated for 10,000 litres (~6 months average use)</li>
                    <li>Universal thread adapter set (fits 95% of shower heads)</li>
                    <li>Quick-start installation guide</li>
                  </ul>
                {%- elsif key == 'how-it-works' -%}
                  <p>Mend uses a dual-stage KDF-55 + activated carbon filter to neutralise chlorine, reduce heavy metals, and soften water before it ever reaches your skin or hair. Screws onto any standard shower arm in under 60 seconds. No plumber. No tools.</p>
                {%- elsif key == 'ingredients-certifications' -%}
                  <p>KDF-55 media (copper-zinc alloy), coconut shell activated carbon, food-grade polypropylene housing. NSF/ANSI 42 &amp; 61 certified. BPA-free. Independently tested by SGS Laboratories.</p>
                {%- endif -%}
              </div>
            </div>
          </div>

        {%- endfor -%}
      </div>
      {%- comment -%} /accordion {%- endcomment -%}

    </div>
    {%- comment -%} /product-info {%- endcomment -%}

  </div>
  {%- content_for 'blocks' -%}
</section>


{%- comment -%} ============================================================
   STICKY ATC — mobile-only, glass-blur, shows after main ATC scrolls out.
   Gated by settings.motion_enabled (kill switch). Component lives in
   assets/component-sticky-atc.js (custom element <mc-sticky-atc>).
============================================================ {%- endcomment -%}
{%- if settings.motion_enabled -%}
  <mc-sticky-atc data-show-on="mobile-only" aria-label="Sticky add to cart">
    <div class="sticky-atc__bar">
      <div class="page-width">
        <div class="sticky-atc__inner">
          <div class="sticky-atc__left">
            {%- if product.featured_image -%}
              <img
                class="sticky-atc__img"
                src="{{ product.featured_image | image_url: width: 120 }}"
                alt="{{ product.title | escape }}"
                width="52" height="52" loading="lazy">
            {%- endif -%}
            <div class="sticky-atc__info">
              <p class="sticky-atc__title">{{ product.title | escape }}</p>
              <p class="sticky-atc__price">
                {%- if current_variant.compare_at_price > current_variant.price -%}
                  <s>{{ current_variant.compare_at_price | money }}</s>
                {%- endif -%}
                {{ current_variant.price | money }}
              </p>
            </div>
          </div>
          <div class="sticky-atc__right">
            <form action="/cart/add" method="post" enctype="multipart/form-data" data-type="sticky-atc-form">
              {%- if product.has_only_default_variant -%}
                <input type="hidden" name="id" value="{{ current_variant.id }}">
              {%- else -%}
                <div class="sticky-atc__select-wrap">
                  <select name="id" class="sticky-atc__select" aria-label="Choose variant">
                    {%- for v in product.variants -%}
                      <option value="{{ v.id }}"{% if v.id == current_variant.id %} selected{% endif %}{% unless v.available %} disabled{% endunless %}>
                        {{ v.title }}{% unless v.available %} — sold out{% endunless %}
                      </option>
                    {%- endfor -%}
                  </select>
                  <svg class="sticky-atc__caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              {%- endif -%}
              <button type="submit" class="sticky-atc__btn mc-shine"{% unless current_variant.available %} disabled{% endunless %}>
                <span class="sticky-atc__btn-text">
                  {%- if current_variant.available -%}{{ section.settings.atc_label | default: 'Add to Cart' | escape }}{%- else -%}{{ section.settings.atc_sold_out_label | default: 'Sold Out' | escape }}{%- endif -%}
                </span>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </mc-sticky-atc>
{%- endif -%}


<style>
/* ============================================================
   MAIN PRODUCT -- Mend & Co
   ============================================================ */

.product-section {
  background: var(--color-bone, #F2EDE4);
  padding: 5rem 0 8rem;
}

.product-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 4rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 7rem;
  align-items: start;
}


/* -- GALLERY --------------------------------------- */

.product-gallery {
  position: sticky;
  top: 7rem;
  display: flex;
  flex-direction: row;
  gap: 0.75rem;
  align-items: flex-start;
}

/* Left: vertical thumbnail strip */
.gallery-thumbs {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  width: 76px;
  flex-shrink: 0;
  /* Clamp to photo-track height only (4:5 ratio, track-width = col - 76px - 0.75rem gap) */
  max-height: calc((((min(100vw, 1280px) - 15rem) / 2) - 76px - 0.75rem) * 1.25);
  overflow-y: auto;
  scrollbar-width: none;
}
.gallery-thumbs::-webkit-scrollbar { display: none; }

.gallery-thumb {
  width: 76px;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  background: #F2EDE4;
  border: 1.5px solid rgba(43, 43, 43, 0.08);
  border-radius: 4px;
  cursor: pointer;
  padding: 0;
  position: relative;
  transition: border-color 0.2s ease;
  flex-shrink: 0;
}

.gallery-thumb.is-active {
  border-color: var(--color-walnut, #8A6240);
}

.gallery-thumb:focus-visible {
  outline: 1.5px solid var(--color-walnut, #8A6240);
  outline-offset: 2px;
}

.gallery-thumb img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  opacity: 0.6;
  transition: opacity 0.2s ease;
  padding: 4px;
}

.gallery-thumb.is-active img,
.gallery-thumb:hover img {
  opacity: 1;
}

/* Right: photo track + carousel stacked */
.gallery-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid rgba(43, 43, 43, 0.08);
  border-radius: 8px;
  box-shadow: 0 6px 32px rgba(43, 43, 43, 0.08), 0 1px 4px rgba(43, 43, 43, 0.05);
  overflow: hidden;
}

/* Track: desktop = one slide at a time via opacity */
.gallery-track {
  position: relative;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  background: #F2EDE4;
}

.gallery-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}

.gallery-slide.is-active {
  opacity: 1;
  pointer-events: auto;
}

.gallery-slide__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  padding: 1rem;
}


/* Prev / next arrows — inside .gallery-track so z-index is unambiguous */
.gallery-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: rgba(255, 255, 255, 0.92);
  border: none;
  border-radius: 50%;
  color: #2D2D2D;
  cursor: pointer;
  pointer-events: auto;
  box-shadow: 0 2px 8px rgba(0,0,0,0.14);
  opacity: 0;
  transition: opacity 0.2s ease, background 0.15s;
  backdrop-filter: blur(4px);
}

.gallery-arrow--prev { left: 10px; }
.gallery-arrow--next { right: 10px; }

.gallery-track:hover .gallery-arrow {
  opacity: 1;
}

.gallery-arrow:hover {
  background: #fff;
}

/* Dots — mobile only */
.gallery-dots {
  display: none;
}


/* -- PRODUCT INFO ----------------------------------- */

.product-info {
  padding-top: 0.25rem;
}

/* Eyebrow
   Text: mahogany #8A6240 on linen = 7.59:1  (amber clay fails at 2.55:1)
   Amber retained as the decorative border-bottom rule only */
.product-eyebrow {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--color-walnut, #8A6240);
  margin: 0 0 1.25rem;
  padding-bottom: 1.25rem;
  border-bottom: 1.5px solid var(--color-walnut, #8A6240);
}

/* Title */
.product-title {
  font-family: var(--font-heading);
  font-size: clamp(1.875rem, 3vw, 2.625rem);
  font-weight: 400;
  color: var(--color-black);
  line-height: 1.18;
  letter-spacing: -0.015em;
  margin: 0 0 1.125rem;
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.product-title__model {
  font-family: var(--font-mono, monospace);
  font-size: 0.6em;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-walnut, #8A6240);
  background: rgba(138, 98, 64, 0.1);
  border: 1px solid rgba(138, 98, 64, 0.25);
  border-radius: 3px;
  padding: 3px 8px;
  vertical-align: middle;
  line-height: 1;
  white-space: nowrap;
  position: relative;
  top: -0.1em;
}

/* Rating */
.product-rating {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.75rem;
  background: rgba(138, 98, 64, 0.06);
  border: 1px solid rgba(138, 98, 64, 0.15);
  border-radius: 10px;
  padding: 0.875rem 1.125rem;
}

.rating-stars-wrap {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}

.rating-stars {
  display: flex;
  gap: 2px;
}

.star {
  fill: var(--color-walnut, #8A6240);
}

.rating-value-num {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--color-black);
  line-height: 1;
}

.rating-copy {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.rating-count {
  font-family: var(--font-label);
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-black);
  line-height: 1.3;
}

.rating-subtext {
  font-family: var(--font-label);
  font-size: 0.75rem;
  color: var(--color-olive);
  line-height: 1.3;
}

/* Product badges */
.pdp-badges {
  display: flex;
  flex-direction: row;
  gap: 6px;
  margin-bottom: 1rem;
}

.pdp-badges .badge {
  min-width: 42px;
  justify-content: center;
}

/* Price block */
.price-block {
  margin-bottom: 1.75rem;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  margin-bottom: 0.3rem;
  flex-wrap: wrap;
}

.price-now {
  font-family: var(--font-heading);
  font-size: 1.875rem;
  font-weight: 400;
  color: var(--color-black);
  letter-spacing: -0.02em;
  line-height: 1;
}

.price-was {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  color: var(--color-olive);
  text-decoration: line-through;
  opacity: 0.55;
}

.price-now--on-sale {
  color: var(--color-walnut, #8A6240);
}

.price-save {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #C0392B;
  background: rgba(192, 57, 43, 0.1);
  padding: 0.25rem 0.5rem;
  border-radius: 2px;
  align-self: center;
}

.price-callout {
  font-family: var(--font-label);
  font-size: 0.8rem;
  /* Hardcoded blended value: mahogany #8A6240 at ~72% on linen ~ #9A7255, 4.68:1 
     Avoids opacity: which renders ~3.8:1 and is unmeasurable in static audits */
  color: #9A7255;
  margin: 0;
}

/* Purchase toggle */
.purchase-toggle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.375rem;
  padding: 0.375rem;
  background: rgba(43, 43, 43, 0.05);
  border-radius: 4px;
  margin-bottom: 1.75rem;
}

.purchase-toggle__btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
  padding: 0.75rem 1rem;
  background: transparent;
  border: 1.5px solid transparent;
  border-radius: 3px;
  cursor: pointer;
  transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
  text-align: center;
}

.purchase-toggle__btn.is-active {
  background: var(--color-bone, #F2EDE4);
  /* Border: mahogany = 7.59:1  (amber = 2.55:1, fails WCAG 1.4.11 non-text 3:1) */
  border-color: var(--color-olive);
  box-shadow: 0 1px 4px rgba(43, 43, 43, 0.07);
}

.purchase-toggle__btn:hover:not(.is-active) {
  border-color: rgba(166, 137, 102, 0.35);
}

.toggle-label {
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-black);
  letter-spacing: 0.01em;
}

.toggle-price {
  font-family: var(--font-label);
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-olive);
}

/* Blurb */
.product-blurb {
  margin: 0 0 1.875rem;
}

.product-blurb__heading {
  font-family: var(--font-heading);
  font-size: clamp(1.375rem, 3vw, 1.75rem);
  font-weight: 400;
  color: var(--color-black);
  line-height: 1.15;
  margin: 0 0 0.15rem;
}

.product-blurb__subhead {
  font-family: var(--font-heading);
  font-size: clamp(1.125rem, 2.5vw, 1.375rem);
  font-style: italic;
  font-weight: 400;
  color: var(--color-walnut, #8A6240);
  line-height: 1.2;
  margin: 0 0 0.875rem;
}

.product-blurb__body {
  font-family: var(--font-label);
  font-size: 0.9375rem;
  line-height: 1.72;
  color: var(--color-olive);
  margin: 0;
  background: rgba(138, 98, 64, 0.05);
  border-left: 2px solid rgba(138, 98, 64, 0.3);
  padding: 0.75rem 1rem;
  border-radius: 0 6px 6px 0;
}

/* Spec pills */
.spec-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin: 0 0 1.75rem;
}

.spec-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.35rem 0.75rem;
  background: rgba(138, 98, 64, 0.07);
  border: 1px solid rgba(138, 98, 64, 0.18);
  border-radius: 100px;
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-olive);
  letter-spacing: 0.01em;
  white-space: nowrap;
}

.spec-pill svg {
  color: var(--color-walnut, #8A6240);
  flex-shrink: 0;
}

/* Variant fieldset */
.variant-fieldset {
  border: none;
  padding: 0;
  margin: 0 0 1.5rem;
}

.variant-legend {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--color-black);
  display: block;
  margin-bottom: 0.75rem;
  padding: 0;
  float: none;
  width: 100%;
}

.variant-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.variant-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 0.75rem 1.25rem;
  background: var(--color-bone, #F2EDE4);
  border: 1.5px solid rgba(43, 43, 43, 0.16);
  border-radius: 3px;
  cursor: pointer;
  transition: border-color 0.18s ease, background 0.18s ease;
  min-width: 8.5rem;
}

.variant-card:hover:not(.is-sold-out) {
  border-color: rgba(166, 137, 102, 0.5);
}

.variant-card.is-selected {
  /* Border: mahogany #8A6240 on linen = 7.59:1  (amber = 2.55:1, fails WCAG 1.4.11 non-text 3:1) */
  border-color: var(--color-olive);
  background: rgba(166, 137, 102, 0.05);
}

.variant-card.is-sold-out {
  opacity: 0.38;
  cursor: not-allowed;
}

.variant-card__radio {
  position: absolute;
  opacity: 0;
  pointer-events: none;
  width: 1px;
  height: 1px;
}

.variant-card__name {
  font-family: var(--font-label);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-black);
  display: block;
}

.variant-card__save {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  /* Deep Walnut #8A6240 on bone - contrast OK */
  color: var(--color-walnut, #8A6240);
  letter-spacing: 0.5px;
}

.variant-card__out {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  /* Blended mahogany 60% on linen -> #AE8E76, 3.52:1  for supplementary small text
     Avoiding opacity: to keep contrast measurable */
  color: #AE8E76;
}

/* Quantity stepper */
.qty-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 0.875rem;
}

.qty-label {
  font-family: var(--font-label);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--color-black);
  flex-shrink: 0;
  min-width: 2rem;
}

.qty-stepper {
  display: inline-flex;
  align-items: center;
  border: 1.5px solid rgba(43, 43, 43, 0.16);
  border-radius: 3px;
  overflow: hidden;
}

.qty-btn {
  width: 44px;
  height: 44px;
  background: transparent;
  border: none;
  font-size: 1.0625rem;
  color: var(--color-black);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.15s ease;
  line-height: 1;
  -webkit-appearance: none;
}

.qty-btn:hover {
  background: rgba(43, 43, 43, 0.05);
}

.qty-btn:active {
  background: rgba(43, 43, 43, 0.09);
}

.qty-input {
  width: 52px;
  height: 44px;
  border: none;
  border-left: 1px solid rgba(43, 43, 43, 0.1);
  border-right: 1px solid rgba(43, 43, 43, 0.1);
  background: transparent;
  font-family: var(--font-label);
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-black);
  text-align: center;
  -moz-appearance: textfield;
}

.qty-input::-webkit-outer-spin-button,
.qty-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
}

.qty-input:focus {
  outline: none;
  background: rgba(43, 43, 43, 0.03);
}

/* Add to cart */
.btn-atc {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 56px;
  background: var(--color-cta, #2D2D2D);
  color: var(--color-bone, #F2EDE4);
  border: none;
  border-radius: 4px;
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.12s ease, box-shadow 0.2s ease;
  margin-bottom: 0.75rem;
  box-shadow: 0 2px 12px rgba(43, 43, 43, 0.18);
  position: relative;
  overflow: hidden;
  animation: breathe 2.4s ease-in-out infinite;
}

.pdp-payment-btns {
  margin-bottom: 0.875rem;
}

.pdp-payment-btns .shopify-payment-button__button {
  border-radius: 4px;
  font-size: 0.875rem;
}

.pdp-payment-btns .shopify-payment-button__button--unbranded {
  background-color: var(--color-cta, #2D2D2D) !important;
}

@media (max-width: 767px) {
  .btn-atc {
    animation: breathe-opacity 2.4s ease-in-out infinite;
  }
}

.btn-atc.is-loading {
  background: var(--color-walnut, #8A6240);
  color: #fff;
  pointer-events: none;
  transition: background 0.2s ease, color 0.2s ease;
}

.btn-atc::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  height: 2px;
  width: 0%;
  background: rgba(255,255,255,0.6);
  transition: width 0s;
}

.btn-atc.is-loading::after {
  width: 100%;
  transition: width 0.6s ease;
}

.btn-atc:hover:not(:disabled) {
  background: var(--color-cta-hover, #1A1A1A);
  box-shadow: 0 4px 20px rgba(43, 43, 43, 0.26);
}

.btn-atc:active:not(:disabled) {
  transform: scale(0.997);
}

.btn-atc:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* -- MINI REVIEW CAROUSEL (below gallery) --------- */

.pdp-review-carousel {
  border-top: 1px solid rgba(43,43,43,0.09);
  padding: 1.125rem 1.375rem 1rem;
  background: rgba(43,43,43,0.02);
}

.prc-track {
  position: relative;
  /* Fixed height so controls never move: stars + quote (3 lines) + footer */
  height: 8.5rem;
  overflow: hidden;
}

.prc-slide {
  display: none;
  flex-direction: column;
  gap: 0.5rem;
  position: absolute;
  inset: 0;
}

.prc-slide.is-active {
  display: flex;
  animation: prc-fade 0.25s ease;
}

@keyframes prc-fade {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}

.prc-stars {
  display: flex;
  gap: 2px;
}

.prc-star {
  font-size: 11px;
  color: var(--color-walnut, #8A6240);
  line-height: 1;
}

.prc-star--empty { opacity: 0.2; }

.prc-quote {
  font-family: var(--font-heading, serif);
  font-size: 0.875rem;
  font-style: italic;
  font-weight: 400;
  line-height: 1.55;
  color: var(--color-olive, #8A6240);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.prc-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  padding-top: 0.625rem;
  border-top: 1px solid rgba(43,43,43,0.08);
}

.prc-author-wrap {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.prc-name {
  font-family: var(--font-label, sans-serif);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-black, #1f1d1a);
}

.prc-badge {
  font-family: var(--font-label, sans-serif);
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: #C8F0EC;
  background: rgba(74,123,114,0.85);
  padding: 2px 5px;
  border-radius: 2px;
}

.prc-detail {
  font-family: var(--font-label, sans-serif);
  font-size: 0.6875rem;
  color: var(--color-olive, #8A6240);
  opacity: 0.7;
}

.prc-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 0.875rem;
}

.prc-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  background: transparent;
  border: 1px solid rgba(43,43,43,0.15);
  border-radius: 50%;
  cursor: pointer;
  color: var(--color-black, #1f1d1a);
  transition: border-color 0.15s, background 0.15s;
  flex-shrink: 0;
}

.prc-arrow:hover {
  border-color: rgba(43,43,43,0.35);
  background: rgba(43,43,43,0.04);
}

.prc-dots {
  display: flex;
  gap: 5px;
  align-items: center;
}

.prc-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  border: none;
  background: rgba(43,43,43,0.2);
  cursor: pointer;
  padding: 0;
  transition: background 0.2s, transform 0.2s;
}

.prc-dot.is-active {
  background: var(--color-walnut, #8A6240);
  transform: scale(1.4);
}

/* Trust strip */
.trust-strip {
  list-style: none;
  padding: 0.875rem 0;
  margin: 0 0 1.375rem;
  display: flex;
  border-top: 1px solid rgba(43, 43, 43, 0.09);
  border-bottom: 1px solid rgba(43, 43, 43, 0.09);
}

.trust-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-label);
  font-size: 0.75rem;
  color: var(--color-olive);
  flex: 1;
  line-height: 1.3;
}

.trust-item + .trust-item {
  padding-left: 1rem;
  border-left: 1px solid rgba(43, 43, 43, 0.09);
}

.trust-icon {
  width: 17px;
  height: 17px;
  color: var(--color-walnut, #8A6240);
  flex-shrink: 0;
}

.trust-item .trust-icon,
.trust-item svg,
.trust-item__icon {
  color: var(--color-walnut, #8A6240);
}

/* Accordion */
.accordion {
  border-top: 1px solid rgba(43, 43, 43, 0.1);
}

.accordion__item {
  border-bottom: 1px solid rgba(43, 43, 43, 0.1);
}

.accordion__trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.125rem 0;
  background: transparent;
  border: none;
  font-family: var(--font-label);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-black);
  cursor: pointer;
  text-align: left;
  letter-spacing: 0.01em;
  transition: color 0.15s ease;
}

/* Hover is a no-op (same color as default) -- removed.
   Active state is communicated via amber chevron rotation + amber left-border on panel body. */
.accordion__trigger[aria-expanded="true"] {
  color: var(--color-black);
}

.accordion__trigger:focus-visible {
  outline: 1.5px solid var(--color-walnut, #8A6240);
  outline-offset: 2px;
  border-radius: 2px;
}

.accordion__chevron {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  color: var(--color-olive);
  transition: transform 0.25s ease, color 0.15s ease;
}

.accordion__trigger[aria-expanded="true"] .accordion__chevron {
  transform: rotate(180deg);
  color: var(--color-walnut, #8A6240);
}

.accordion__panel[hidden] {
  display: none;
}

.accordion__body {
  padding: 0.25rem 0 1.25rem 1.125rem;
  border-left: 1.5px solid var(--color-walnut, #8A6240);
  font-family: var(--font-label);
  font-size: 0.875rem;
  line-height: 1.78;
  color: var(--color-olive);
}

.accordion__body p,
.accordion__body ul {
  margin: 0;
}

.accordion__body ul {
  padding-left: 1.25rem;
}

.accordion__body li + li {
  margin-top: 0.4rem;
}


/* ============================================================
   RESPONSIVE
   ============================================================ */

@media (max-width: 1024px) {
  .product-container {
    gap: 4rem;
