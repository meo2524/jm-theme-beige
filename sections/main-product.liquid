}

.qty-input {
  width: 52px;
  height: 44px;
  border: none;
  border-left: 1px solid rgba(43, 43, 43, 0.1);
  border-right: 1px solid rgba(43, 43, 43, 0.1);
  background: transparent;
  font-family: var(--font-label);
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-black);
  text-align: center;
  -moz-appearance: textfield;
}

.qty-input::-webkit-outer-spin-button,
.qty-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
}

.qty-input:focus {
  outline: none;
  background: rgba(43, 43, 43, 0.03);
}

/* Add to cart */
.btn-atc {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 56px;
  background: var(--color-cta, #2D2D2D);
  color: var(--color-bone, #F2EDE4);
  border: none;
  border-radius: 4px;
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.12s ease, box-shadow 0.2s ease;
  margin-bottom: 0.75rem;
  box-shadow: 0 2px 12px rgba(43, 43, 43, 0.18);
  position: relative;
  overflow: hidden;
  animation: breathe 2.4s ease-in-out infinite;
}

.pdp-payment-btns {
  margin-bottom: 1.375rem;
}

.pdp-payment-btns .shopify-payment-button__button {
  border-radius: 4px;
  font-size: 0.875rem;
}

@media (max-width: 767px) {
  .btn-atc {
    animation: breathe-opacity 2.4s ease-in-out infinite;
  }
}

.btn-atc.is-loading {
  background: var(--color-walnut, #8A6240);
  color: #fff;
  pointer-events: none;
  transition: background 0.2s ease, color 0.2s ease;
}

.btn-atc::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  height: 2px;
  width: 0%;
  background: rgba(255,255,255,0.6);
  transition: width 0s;
}

.btn-atc.is-loading::after {
  width: 100%;
  transition: width 0.6s ease;
}

.btn-atc:hover:not(:disabled) {
  background: var(--color-cta-hover, #1A1A1A);
  box-shadow: 0 4px 20px rgba(43, 43, 43, 0.26);
}

.btn-atc:active:not(:disabled) {
  transform: scale(0.997);
}

.btn-atc:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* Trust strip */
.trust-strip {
  list-style: none;
  padding: 1.25rem 0 1.375rem;
  margin: 0 0 2rem;
  display: flex;
  border-top: 1px solid rgba(43, 43, 43, 0.09);
  border-bottom: 1px solid rgba(43, 43, 43, 0.09);
}

.trust-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-label);
  font-size: 0.75rem;
  color: var(--color-olive);
  flex: 1;
  line-height: 1.3;
}

.trust-item + .trust-item {
  padding-left: 1rem;
  border-left: 1px solid rgba(43, 43, 43, 0.09);
}

.trust-icon {
  width: 17px;
  height: 17px;
  color: var(--color-walnut, #8A6240);
  flex-shrink: 0;
}

.trust-item .trust-icon,
.trust-item svg,
.trust-item__icon {
  color: var(--color-walnut, #8A6240);
}

/* Accordion */
.accordion {
  border-top: 1px solid rgba(43, 43, 43, 0.1);
}

.accordion__item {
  border-bottom: 1px solid rgba(43, 43, 43, 0.1);
}

.accordion__trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.125rem 0;
  background: transparent;
  border: none;
  font-family: var(--font-label);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-black);
  cursor: pointer;
  text-align: left;
  letter-spacing: 0.01em;
  transition: color 0.15s ease;
}

/* Hover is a no-op (same color as default) -- removed.
   Active state is communicated via amber chevron rotation + amber left-border on panel body. */
.accordion__trigger[aria-expanded="true"] {
  color: var(--color-black);
}

.accordion__trigger:focus-visible {
  outline: 1.5px solid var(--color-walnut, #8A6240);
  outline-offset: 2px;
  border-radius: 2px;
}

.accordion__chevron {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  color: var(--color-olive);
  transition: transform 0.25s ease, color 0.15s ease;
}

.accordion__trigger[aria-expanded="true"] .accordion__chevron {
  transform: rotate(180deg);
  color: var(--color-walnut, #8A6240);
}

.accordion__panel[hidden] {
  display: none;
}

.accordion__body {
  padding: 0.25rem 0 1.25rem 1.125rem;
  border-left: 1.5px solid var(--color-walnut, #8A6240);
  font-family: var(--font-label);
  font-size: 0.875rem;
  line-height: 1.78;
  color: var(--color-olive);
}

.accordion__body p,
.accordion__body ul {
  margin: 0;
}

.accordion__body ul {
  padding-left: 1.25rem;
}

.accordion__body li + li {
  margin-top: 0.4rem;
}


/* ============================================================
   RESPONSIVE
   ============================================================ */

@media (max-width: 1024px) {
  .product-container {
    gap: 4rem;
    padding: 0 2.5rem;
  }
}

@media (max-width: 768px) {
  .product-section {
    padding: 2.5rem 0 5rem;
  }

  .product-container {
    grid-template-columns: 1fr;
    gap: 2.25rem;
    padding: 0;
  }

  /* Mobile gallery -- scroll-snap swipe */
  .product-gallery {
    position: static;
    flex-direction: column;
    gap: 0;
  }

  .gallery-thumbs {
    display: none;
  }

  .gallery-main {
    width: 100%;
  }

  .gallery-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    aspect-ratio: unset;
    height: 75vw;
    max-height: 480px;
    border-left: none;
    border-right: none;
    border-radius: 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .gallery-track::-webkit-scrollbar {
    display: none;
  }

  .gallery-slide {
    position: relative;
    flex: 0 0 100%;
    height: 100%;
    opacity: 1;
    pointer-events: auto;
    scroll-snap-align: start;
