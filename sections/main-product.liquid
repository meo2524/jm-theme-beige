}

.qty-stepper {
  display: inline-flex;
  align-items: center;
  border: 1.5px solid rgba(43, 43, 43, 0.16);
  border-radius: 3px;
  overflow: hidden;
}

.qty-btn {
  width: 44px;
  height: 44px;
  background: transparent;
  border: none;
  font-size: 1.0625rem;
  color: var(--color-black);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.15s ease;
  line-height: 1;
  -webkit-appearance: none;
}

.qty-btn:hover {
  background: rgba(43, 43, 43, 0.05);
}

.qty-btn:active {
