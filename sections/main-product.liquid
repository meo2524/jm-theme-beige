{
  "name": "Product",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow label",
      "default": "Shower Filtration",
      "info": "Shown above the product title. Falls back to collection name if blank."
    },
    {
      "type": "text",
      "id": "short_description",
      "label": "Short description",
      "info": "2–3 sentence teaser above the variant picker. Falls back to product description if blank."
    },
    {
      "type": "text",
      "id": "per_use_text",
      "label": "Per-use cost callout",
      "default": "~$0.18/shower · lasts 6 months",
      "info": "Small line below the price — keep under 50 characters."
    },
    {
      "type": "header",
      "content": "Accordion content"
    },
    {
      "type": "richtext",
      "id": "accordion_whats-included",
      "label": "What's included",
      "info": "Leave blank to use default copy."
    },
    {
      "type": "richtext",
      "id": "accordion_how-it-works",
      "label": "How it works",
      "info": "Leave blank to use default copy."
    },
    {
      "type": "richtext",
      "id": "accordion_ingredients-certifications",
      "label": "Ingredients & certifications",
      "info": "Leave blank to use default copy."
    }
  ],
  "presets": [
    {
      "name": "Product"
    }
  ]
}
