{%- comment -%} Social proof strip — rating + review count {% endcomment -%}

<div class="sp-strip" aria-label="Customer rating">
  <div class="sp-strip__inner">

    <div class="sp-strip__rating">
      <span class="sp-strip__score">4.9</span>
      <span class="sp-strip__stars" aria-hidden="true">★★★★★</span>
    </div>

    <div class="sp-strip__divider" aria-hidden="true"></div>

    <div class="sp-strip__copy">
      <span class="sp-strip__count">3,500+ reviews</span>
      <span class="sp-strip__sub">from verified customers</span>
    </div>

  </div>
</div>

<style>
  .sp-strip {
    background: var(--color-walnut, #8a6240);
    color: var(--color-bone, #f5efe6);
    padding: 0.6rem 1.5rem;
    text-align: center;
  }

  .sp-strip__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    max-width: 960px;
    margin: 0 auto;
  }

  .sp-strip__rating {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .sp-strip__score {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 1.625rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-bone, #f5efe6);
  }

  .sp-strip__stars {
    font-size: 0.8rem;
    letter-spacing: 2px;
    color: rgba(245, 239, 230, 0.9);
    line-height: 1;
  }

  .sp-strip__divider {
    width: 1px;
    height: 1.5rem;
    background: rgba(245, 239, 230, 0.25);
    flex-shrink: 0;
  }

  .sp-strip__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
  }

  .sp-strip__count {
    font-family: var(--font-label, 'Inter', sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.2;
    color: var(--color-bone, #f5efe6);
  }

  .sp-strip__sub {
    font-family: var(--font-label, 'Inter', sans-serif);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.6;
    line-height: 1;
  }

  @media (max-width: 480px) {
    .sp-strip {
      padding: 0.55rem 1rem;
    }
    .sp-strip__divider {
      height: 1.25rem;
    }
  }
</style>

{% schema %}
{
  "name": "Social proof strip",
  "settings": [],
  "presets": [
    {
      "name": "Social proof strip"
    }
  ]
}
{% endschema %}
