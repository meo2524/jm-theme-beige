{%- layout none -%}
{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign option_count = product.options.size
-%}

<div class="mc-qv-content">

  <!-- Left: image carousel -->
  <div class="mc-qv-media">
    <div class="mc-qv-carousel" data-carousel>
      <div class="mc-qv-carousel__track" data-track>
        {%- for media in product.images limit: 8 -%}
          <div class="mc-qv-carousel__slide{% if forloop.first %} is-active{% endif %}">
            {{
              media
              | image_url: width: 900
              | image_tag:
                class: 'mc-qv-img',
                loading: 'eager',
                widths: '450, 700, 900',
                sizes: '(max-width: 640px) 100vw, 45vw',
                alt: media.alt | default: product.title | escape
            }}
          </div>
        {%- endfor -%}
      </div>

      {%- if product.images.size > 1 -%}
        <button class="mc-qv-carousel__arrow mc-qv-carousel__arrow--prev" data-carousel-prev aria-label="Previous image">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
            <polyline points="13 4 7 10 13 16"/>
          </svg>
        </button>
        <button class="mc-qv-carousel__arrow mc-qv-carousel__arrow--next" data-carousel-next aria-label="Next image">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
            <polyline points="7 4 13 10 7 16"/>
          </svg>
        </button>
        <div class="mc-qv-carousel__dots" data-dots>
          {%- for media in product.images limit: 8 -%}
            <button class="mc-qv-carousel__dot{% if forloop.first %} is-active{% endif %}"
              data-dot="{{ forloop.index0 }}" aria-label="Go to image {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- Right: info -->
  <div class="mc-qv-info">

    <p class="mc-qv-vendor">{{ product.vendor }}</p>
    <h2 class="mc-qv-title">{{ product.title }}</h2>

    <div class="mc-qv-price-row">
      <span class="mc-qv-price" id="mc-qv-price-{{ product.id }}">
        {{- current_variant.price | money -}}
      </span>
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <span class="mc-qv-compare-price" id="mc-qv-compare-{{ product.id }}">{{ current_variant.compare_at_price | money }}</span>
      {%- endif -%}
    </div>

    {%- form 'product', product, class: 'mc-qv-form', novalidate: 'novalidate' -%}
      <input type="hidden" name="id" class="mc-qv-variant-id" value="{{ current_variant.id }}">

      {%- comment -%} Variant data for JS {%- endcomment -%}
      <script class="mc-qv-variants-json" type="application/json">
        [
          {%- for v in product.variants -%}
          {
            "id":         {{ v.id }},
            "title":      {{ v.title | json }},
            "price":      {{ v.price | money | json }},
            "compare":    {% if v.compare_at_price > v.price %}{{ v.compare_at_price | money | json }}{% else %}null{% endif %},
            "available":  {{ v.available }},
            "option1":    {{ v.option1 | json }},
            "option2":    {{ v.option2 | json }},
            "option3":    {{ v.option3 | json }},
            "image_index": {% if v.featured_image %}{{ v.featured_image.position | minus: 1 }}{% else %}0{% endif %}
          }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
      </script>

      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="mc-qv-opt-group">
            <span class="mc-qv-label">{{ option.name }}</span>
            <div class="mc-qv-opt-btns">
              {%- for value in option.values -%}
                <button
                  type="button"
                  class="mc-qv-opt-btn{% if option.selected_value == value %} is-active{% endif %}"
                  data-opt-pos="{{ option.position }}"
                  data-opt-val="{{ value | escape }}"
                >
                  {{- value -}}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      <!-- Qty + ATC -->
      <div class="mc-qv-atc-row">
        <div class="mc-qv-qty">
          <button type="button" class="mc-qv-qty__btn" data-qty-dec aria-label="Decrease">−</button>
          <input class="mc-qv-qty__input" type="number" name="quantity" value="1" min="1" aria-label="Quantity">
          <button type="button" class="mc-qv-qty__btn" data-qty-inc aria-label="Increase">+</button>
        </div>

        <button
          type="submit"
          class="mc-qv-atc"
          {%- unless current_variant.available %} disabled{%- endunless -%}
        >
          <span class="mc-qv-atc-text">
            {%- if current_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
          </span>
        </button>
      </div>

      <div class="mc-qv-payment-btn">
        {{ form | payment_button }}
      </div>

    {%- endform -%}

    <a href="{{ product.url }}" class="mc-qv-full-link">View full details →</a>

  </div>
</div>
