    "product_faq_nzQWrk": {
      "type": "product-faq",
      "blocks": {
        "faq_item_t4QVVd": {
          "type": "faq_item",
          "settings": {
            "question": "What does the mist actually do?",
            "answer": "<p>The Wand has a small refillable tank. As you comb, it releases a fine botanical mist — fill it with plain water to refresh and de-static, or add your favourite lightweight serum or hair oil to carry it evenly from root to tip.</p>"
          }
        },
        "faq_item_7jnciW": {
          "type": "faq_item",
          "settings": {
            "question": "What's the red light for?",
            "answer": "<p>The warm 650nm glow is part of the at-home scalp ritual — a soothing, spa-like warmth as the bristles massage your scalp. We keep our claims honest: it's there for comfort and relaxation, not as a medical hair-loss treatment.</p>"
          }
        },
        "faq_item_iW4FAr": {
          "type": "faq_item",
          "settings": {
            "question": "Can I use it on wet or dry hair?",
            "answer": "<p>Both. Mist-and-comb damp hair to smooth and style, or run it through dry hair through the day to refresh, de-static and tame flyaways.</p>"
          }
        },
        "faq_item_box20": {
          "type": "faq_item",
          "settings": {
            "question": "How do I clean it?",
            "answer": "<p>One click. The self-cleaning bristles retract to release trapped hair instantly — no picking strands out by hand. Wipe the bristles and tank and you're done.</p>"
          }
        },
        "faq_item_safe": {
          "type": "faq_item",
          "settings": {
            "question": "How long does the battery last?",
            "answer": "<p>Around 5 to 7 days of regular use on a full charge. It's cordless and USB-rechargeable, with no pods, refills or subscription to buy.</p>"
          }
        },
        "faq_item_ingr": {
          "type": "faq_item",
          "settings": {
            "question": "Is it gentle on my scalp and all hair types?",
            "answer": "<p>Yes. The ball-tipped, anti-static bristles are shaped to glide and massage without scratching, and the mist suits straight, wavy, curly and coily hair alike.</p>"
          }
        },
        "faq_item_results": {
          "type": "faq_item",
          "settings": {
            "question": "Which colour should I choose?",
            "answer": "<p>Whichever you love — Blush Pink, Lavender Purple or Ivory Creme. They're identical inside; the colour is the only difference.</p>"
          }
        },
        "faq_item_ship": {
          "type": "faq_item",
          "settings": {
            "question": "What about shipping, returns and warranty?",
            "answer": "<p>Shipping is free and every order leaves us within 24 hours. You're covered by a 30-day money-back guarantee and a 2-year warranty — if it's not for you, we'll make it right.</p>"
          }
        }
      },
