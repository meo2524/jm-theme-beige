<ul class="scrolling_banner_inner">
  {% content_for 'blocks' %}
</ul>

{% schema %}
{
  "name": "t:blocks.name",
  "tag": null,
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_description"
    },
    {
      "type": "_dbtfy-scrolling-banner_text"
    },
    {
      "type": "_dbtfy-scrolling-banner_button"
    },
    {
      "type": "_dbtfy-scrolling-banner_icon"
    },
    {
      "type": "_dbtfy-scrolling-banner_image"
    },
    {
      "type": "_dbtfy-scrolling-banner-image-with-text"
    }
  ],
  "presets": [
    {
      "name": "t:blocks.name"
    }
  ]
