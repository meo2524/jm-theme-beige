{% render 'block-padding', block: block %}

<style>
  {% if block.settings.vertical_alignment == 'none' %}
    {% assign vertical_alignment = "inherit" %}
  {% else %}
    {% assign vertical_alignment = block.settings.vertical_alignment %}
  {% endif %}

  #block-{{ block.id }}{
      --dbtfy-row-vertical: {{ vertical_alignment }};
      --dbtfy-column-vertical: {{ vertical_alignment }};
    }

    {% if block.settings.gap == 'custom' %}
      .block-{{ block.id }}-padding {
        gap: {{ block.settings.row_gap }}px {{ block.settings.column_gap }}px;
      }
    {% endif %}
</style>
<div
  class="
    d-grid dbtfy-row {{ block.settings.text_alignment }}
    section-custom-column show-on--{{ block.settings.show_on }}
    dbtfy-row-vertical block-{{ block.id }}-padding
  "

  {{ block.shopify_attributes }}
  id="block-{{ block.id }}"
>
  {% content_for 'blocks' %}
</div>

{% schema %}
{
  "name": "Row",
  "tag": null,
  "blocks": [
    {
      "type": "_custom-column"
    },
    {
      "type": "_title"
    },
    {
      "type": "_caption"
    },
    {
      "type": "_description"
    },
    {
      "type": "_icon"
    },
    {
      "type": "_image"
    },
    {
      "type": "_subtitle"
    },
    {
      "type": "_double_button"
    },
    {
      "type": "_single_button"
    },
    {
      "type": "_cc-icon_with_text"
    },
    {
      "type": "_cc-icon_with_image"
    },
    {
      "type": "_cc-faq"
    },
    {
      "type": "_cc-video"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "show_on",
      "label": "t:sections.all.show_on.label",
      "default": "both",
      "options": [
        {
          "value": "desktop-only",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile-only",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "text-left",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "start",
          "label": "Start"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "end",
          "label": "End"
        }
      ]
    },
    {
      "type": "select",
      "id": "gap",
      "label": "Gap",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Inherit"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ]
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 0,
      "max": 40,
      "step": 5,
      "label": "Column Gap",
      "unit": "px",
      "default": 10,
      "visible_if": "{{ block.settings.gap == 'custom' }}"
    },
    {
      "type": "range",
      "id": "row_gap",
      "min": 0,
      "max": 40,
      "step": 5,
      "label": "Row gap",
      "default": 10,
      "visible_if": "{{ block.settings.gap == 'custom' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding_section.block_padding"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.top",
      "default": "none",
      "options": [
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_top",
      "default": 36
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.bottom",
      "default": "none",
      "options": [
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Row"
    }
  ]
}
{% endschema %}
