{% if block.settings.product != blank %}
  {% assign selected_product = block.settings.product %}
{% endif %}

<dbtfy-product-tab-horizontal>
  <div class="dbtfy-product-tabs dbtfy-product-tab--horizontal hidden" data-product="{{ selected_product.id }}"></div>
</dbtfy-product-tab-horizontal>

{% schema %}
{
  "name": "t:blocks.dbtfy-product-tabs.name",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.main-product.settings.product.label"
    }
  ],
  "presets": [
    {
      "name": "t:blocks.dbtfy-product-tabs.name",
      "settings": {
        "product": "{{ closest.product }}"
      }
    }
  ]
}
{% endschema %}
