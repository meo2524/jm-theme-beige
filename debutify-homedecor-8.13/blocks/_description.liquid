{%- render 'block-padding', block: block, label: 'description' -%}
{%- if block.settings.text_animation != 'none' -%}
  {%- render 'dbtfy_description_text_animation', block: block -%}
{%- endif -%}

{% style %}
  .icon-text {
    gap: 6px;
    display: flex;
    flex-direction: row;
    align-items: center;
  } 
  .icon-text {
    h1,h2,h3,h4,h5,h6 {
      margin: 0
    }
  }
{% endstyle %}  

{%- if block.settings.description != blank -%}
  {%- assign has_html_tags = false -%}
  {%- if block.settings.description contains '<p>' or block.settings.description contains '<p' -%}
    {%- assign has_html_tags = true -%}
  {%- endif -%}
  <div
    id="block-{{ block.id }}"
    class="
      rte description-block description-background__fillable {% if block.settings.alignment == "inherit" %}{{ settings.description_alignment }} {% else %} {{ block.settings.alignment }} {% endif %} {{ block.settings.alignment_mobile }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} block-{{ block.id }}-padding"
    data-animation="{{ block.settings.text_animation }}"
    {{ block.shopify_attributes }}
  >
     {%- if block.settings.text_animation == 'typing' and block.settings.custom_bullet_icon == blank and has_html_tags == true -%}
      <text-animation
        class="
          block-{{ block.id }}
          text-animation-block
          {% if block.settings.text_animation == 'typing' %}typing-text{% endif %}
        "
        data-animation="{{ block.settings.text_animation }}"
        data-typing-speed="{{ block.settings.typing_speed }}"
        data-typing-initial-delay="{{ block.settings.typing_initial_delay }}"
        data-typing-pause="{{ block.settings.typing_pause_duration }}"
        data-typing-deleting-speed="{{ block.settings.typing_deleting_speed }}"
        data-typing-show-cursor="{{ block.settings.typing_show_cursor }}"
        data-typing-hide-cursor="{{ block.settings.typing_hide_cursor_while_typing }}"
        data-typing-cursor="{{ block.settings.typing_cursor_character }}"
        {{ block.shopify_attributes }}
      >

      {% elsif block.settings.text_animation == 'glacier' %}
        <div class="rte block-{{ block.id }} dbtfy-text-glacier-active dbtfy-text-glacier-visible">
       {% else %}
        <div class="rte">
      {% endif %}

      {%- if block.settings.custom_bullet_icon != blank -%}
        {%- capture content_replace -%}
          <li class="icon-text"><span> {% render 'material-icon', icon: block.settings.custom_bullet_icon %} </span>
        {%- endcapture -%}
        {% assign content = block.settings.description | replace: '<ul>', '<ul class="custom_bullet_icon">' %}
        {{ content }}

        <script>
          var contentReplace = {{ content_replace | json }};
          this.customBulletUls = document.querySelectorAll("#block-{{ block.id }} ul.custom_bullet_icon");
          this.customBulletUls.forEach((ul) => {
            ul.innerHTML = ul.innerHTML.replace(/<li>/g, contentReplace);
          });
        </script>
      {%- else -%}
        {{ block.settings.description }}
      {%- endif -%}
      {%- if block.settings.text_animation == 'typing' and block.settings.custom_bullet_icon == blank and has_html_tags == true -%}
    </text-animation>
      {%- else -%}
        </div>
      {%- endif -%}
  </div>
{%- endif -%}

{%- schema -%}
{
  "name": "t:general.settings.description",
  "class": "w-full description-block",
  "settings": [
    {
      "type": "richtext",
      "id": "description",
      "label": "t:general.settings.text",
      "default": "t:blocks.description.default"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:general.settings.alignment.label",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        { "value": "text-left", "label": "t:general.settings.alignment.option__4" },
        { "value": "text-center", "label": "t:general.settings.alignment.option__5" },
        { "value": "text-right", "label": "t:general.settings.alignment.option__6" },
        { "value": "text-justify", "label": "t:general.settings.alignment.option__7" }
      ]
    },
    {
      "type": "select",
      "id": "alignment_mobile",
      "label": "t:general.settings.alignment.label_mobile",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "t:general.settings.alignment.option__12"
        },
        { "value": "mobile-text-left", "label": "t:general.settings.alignment.option__4" },
        { "value": "mobile-text-center", "label": "t:general.settings.alignment.option__5" },
        { "value": "mobile-text-right", "label": "t:general.settings.alignment.option__6" },
        { "value": "mobile-text-justify", "label": "t:general.settings.alignment.option__7" }
      ]
    },
    {
      "type": "text",
      "id": "custom_bullet_icon",
      "label": "t:general.settings.custom_bullet_icon.label",
      "info": "t:sections.all.icon.info"
    },
    {
      "type": "paragraph",
      "content": "t:general.settings.custom_bullet_icon.info"
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.element-animation.settings.header"
    },
    {
      "type": "select",
      "id": "text_animation",
      "label": "t:settings_schema.global.settings.element-animation.settings.dbtfy_element_animation_type.label",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "glacier",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__2"
        },
        {
          "value": "typing",
          "label": "t:general.settings.aniamtion.typing"
        }
      ],
      "default": "none",
      "info": "t:general.settings.aniamtion.info"
    },

    {
      "type": "range",
      "id": "glacier_speed",
      "label": "t:general.settings.aniamtion.speed",
      "min": 1,
      "max": 20,
      "step": 1,
      "unit": "s",
      "default": 5,
      "info": "t:general.settings.aniamtion.speed_info",
      "visible_if": "{{ block.settings.text_animation == 'glacier' }}"
    },
    {
      "type": "range",
      "id": "typing_speed",
      "label": "t:general.settings.aniamtion.typing_speed",
      "min": 10,
      "max": 200,
      "step": 10,
      "unit": "ms",
      "default": 50,
      "info": "t:general.settings.aniamtion.typing_speed_info",
      "visible_if": "{{ block.settings.text_animation == 'typing' }}"
    },
    {
      "type": "range",
      "id": "typing_initial_delay",
      "label": "t:general.settings.aniamtion.delay",
      "min": 0,
      "max": 5000,
      "step": 100,
      "unit": "ms",
      "default": 0,
      "info": "t:general.settings.aniamtion.delay_info",
      "visible_if": "{{ block.settings.text_animation == 'typing' }}"
    },
    {
      "type": "range",
      "id": "typing_pause_duration",
      "label": "t:general.settings.aniamtion.pause",
      "min": 0,
      "max": 5000,
      "step": 100,
      "unit": "ms",
      "default": 2000,
      "info": "t:general.settings.aniamtion.pause_info",
      "visible_if": "{{ block.settings.text_animation == 'typing' }}"
    },
    {
      "type": "range",
      "id": "typing_deleting_speed",
      "label": "t:general.settings.aniamtion.deleting_speed",
      "min": 10,
      "max": 200,
      "step": 10,
      "unit": "ms",
      "default": 30,
      "info": "t:general.settings.aniamtion.deleting_speed_info",
      "visible_if": "{{ block.settings.text_animation == 'typing' }}"
    },
    {
      "type": "checkbox",
      "id": "typing_show_cursor",
      "label": "t:general.settings.aniamtion.cursor",
      "default": true,
      "info": "t:general.settings.aniamtion.cursor_info",
      "visible_if": "{{ block.settings.text_animation == 'typing' }}"
    },
    {
      "type": "text",
      "id": "typing_cursor_character",
      "label": "t:general.settings.aniamtion.cursor_character",
      "default": "|",
      "info": "t:general.settings.aniamtion.cursor_character_info",
      "visible_if": "{{ block.settings.text_animation == 'typing' and block.settings.typing_show_cursor }}"
    },
    {
      "type": "range",
      "id": "typing_cursor_blink_duration",
      "label": "t:general.settings.aniamtion.cursor_blink_speed",
      "min": 100,
      "max": 1000,
      "step": 50,
      "unit": "ms",
      "default": 500,
      "info": "t:general.settings.aniamtion.cursor_blink_speed_info",
      "visible_if": "{{ block.settings.text_animation == 'typing' and block.settings.typing_show_cursor }}"
    },
    {
      "type": "checkbox",
      "id": "typing_hide_cursor_while_typing",
      "label": "t:general.settings.aniamtion.hide_cursor_while_typing",
      "default": false,
      "info": "t:general.settings.aniamtion.hide_cursor_while_typing_info",
      "visible_if": "{{ block.settings.text_animation == 'typing' and block.settings.typing_show_cursor }}"
    },

    {
      "type": "header",
      "content": "t:sections.all.padding_section.block_padding"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.top",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_top",
      "default": 36
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.bottom",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_bottom",
      "default": 36
    }
  ],
  "presets": [{ "name": "t:general.settings.description" }]
}
{%- endschema -%}