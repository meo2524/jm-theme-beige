{% render 'block-padding', block: block %}
{% if block.settings.as_column %}
  {% style %}
    @media (min-width: 750px) {
      .block-{{ block.id }}-padding.horizontal-heading{
        display: grid;
        grid-template-columns: repeat({{ block.settings.columns }}, 1fr);
        column-gap: {{ block.settings.column_gap }}px;
        row-gap: {{ block.settings.row_gap }}px;
      }
    }

    @media (max-width: 749px) {
      .block-{{ block.id }}-padding.horizontal-heading{
        display: grid;
        grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
        column-gap: {{ block.settings.column_gap_mobile }}px;
        row-gap: {{ block.settings.row_gap_mobile }}px;
      }
    }
  {% endstyle %}
{% endif %}
<div
  class="block-{{ block.id }}-padding {%if block.settings.as_column %}horizontal-heading{% endif %}"
  {{ block.shopify_attributes }}
>
  {% content_for 'blocks' %}
</div>
{% schema %}
{
  "name": "Heading",
  "settings": [
    {
      "type": "checkbox",
      "id": "as_column",
      "label": "t:general.settings.display_as_columns",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.dbtfy-breadcrumbs.settings.show_icons_on.options__1.label"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "t:general.settings.column",
      "default": 1
    },
    {
      "type": "range",
      "id": "row_gap",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "t:general.settings.gap.row",
      "default": 20
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "t:general.settings.gap.column",
      "default": 20
    },
    {
      "type": "header",
      "content": "t:sections.dbtfy-breadcrumbs.settings.show_icons_on.options__2.label"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "t:general.settings.column",
      "default": 1
    },
    {
      "type": "range",
      "id": "row_gap_mobile",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "t:general.settings.gap.row",
      "default": 20
    },
    {
      "type": "range",
      "id": "column_gap_mobile",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "t:general.settings.gap.column",
      "default": 20
    },
    {
      "type": "header",
      "content": "t:sections.all.padding_section.block_padding"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.top",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_top",
      "default": 36
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.bottom",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_icon"
    },
    {
      "type": "_caption"
    },
    {
      "type": "_title"
    },
    {
      "type": "_subtitle"
    },
    {
      "type": "_description"
    },
    {
      "type": "_single_button"
    },
    {
      "type": "_double_button"
    },
    {
      "type": "_image"
    },
    {
      "type": "_cc-icon_with_text"
    },
    {
      "type": "_advance_double_button"
    }
  ],
  "presets": [
    {
      "name": "Heading",
      "blocks": [
        {
          "type": "_caption",
          "settings": {
            "caption": "This is caption"
          }
        },
        { "type": "_title", "settings": {} },
        { "type": "_subtitle", "settings": {} },
        { "type": "_description", "settings": {} }
      ]
    }
  ]
}
{% endschema %}
