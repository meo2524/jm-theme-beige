{%- render 'block-padding', block: block -%}

<dbtfy-trustpilot-review class="w-full h-full">
  <link rel="stylesheet" href="{{ 'trustpilot-review-style.css' | asset_url }}">

  {% if block.settings.custom_color %}
    {% style %}
      #section-{{ section.id }} .trustpilot-review {
        background-color: {{ block.settings.background_color }}
      }
    {% endstyle %}
  {% endif %}
  <div
    id="section-{{ section.id }}"
    {{ block.shopify_attributes }}
    class="w-full show-on--{{ block.settings.show_on }} color-{{ block.settings.custom_color_scheme }} dbtfy-color-{{ block.settings.color_scheme }}  gradient section-{{ section.id }}-padding section-trustpilot-reviews {% if block.settings.height %}flex flex-column justify-content-center{% endif %} block-{{ block.id }}-padding"
  >
    <div class="page-full trustpilot-reviews trustpilot-reviews--desktop-content-above">
      {% content_for 'block', type: '_heading', id: 'heading' %}

      {% render 'trustpilot', setting: block.settings %}

      {% capture inner_content %}
          {% content_for 'block', type: '_trustpilot-review', id: 'trustpilot-review' %}
      {% endcapture %}

      {% render 'splide-slider-component',
        inner_content: inner_content,
        setting: block.settings,
        spacing_grid_horizontal_desktop: block.settings.spacing_grid_horizontal,
        class: 'trustpilot-reviews__slider',
        custom_icon: settings.custom_arrow_icon,
        icon: settings.arrow_icon
      %}
    </div>
  </div>
</dbtfy-trustpilot-review>
{% schema %}
{
  "name": "Blocks",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.dbtfy-trustpilot.help.info"
    },
    {
      "type": "header",
      "content": "t:blocks.help.header"
    },
    {
      "type": "paragraph",
      "content": "t:sections.dbtfy-trustpilot.help.link"
    },
    {
      "type": "paragraph",
      "content": "t:help.enterprise_info"
    },
    {
      "type": "header",
      "content": "t:general.settings.settigns"
    },
    {
      "type": "select",
      "id": "show_on",
      "label": "t:sections.all.show_on.label",
      "default": "both",
      "options": [
        {
          "value": "desktop-only",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile-only",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:general.settings.col.desktop",
      "visible_if": "{{ block.settings.show_on != 'mobile-only' }}"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:general.settings.col.mobile.options__1"
        },
        {
          "value": "2",
          "label": "t:general.settings.col.mobile.options__2"
        }
      ],
      "default": "1",
      "label": "t:general.settings.col.mobile.label",
      "visible_if": "{{ block.settings.show_on != 'desktop-only' }}"
    },
    {
      "type": "checkbox",
      "id": "custom_color",
      "label": "Custom background color",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "checkbox",
      "id": "height",
      "default": false,
      "label": "t:general.settings.center_title"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:general.settings.subheading",
      "default": "t:sections.dbtfy-trustpilot.subheading_default"
    },
    {
      "type": "range",
      "id": "rating",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "label": "t:blocks.star_rating.rating_label",
      "default": 4.5
    },
    {
      "type": "header",
      "content": "t:general.settings.slider.slider_settings"
    },
    {
      "type": "select",
      "id": "slider_on",
      "default": "both",
      "label": "t:general.settings.slider.Enable_slider",
      "options": [
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        },
        {
          "value": "desktop",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "default": false,
      "label": "t:general.settings.slider.enable_autoplay",
      "visible_if": "{{ block.settings.slider_on != 'none' }}"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:general.settings.slider.autoplay_speed",
      "default": 5,
      "min": 3,
      "max": 8,
      "step": 1,
      "unit": "s",
      "visible_if": "{{ block.settings.enable_autoplay and block.settings.slider_on != 'none' }}"
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "default": true,
      "label": "Loop",
      "info": "Continue from the last slide to the first slide",
      "visible_if": "{{ block.settings.slider_on != 'none' }}"
    },
    {
      "type": "checkbox",
      "id": "enable_dots",
      "default": true,
      "label": "t:general.settings.slider.show_dots",
      "visible_if": "{{ block.settings.slider_on != 'none' }}"
    },
    {
      "type": "checkbox",
      "id": "enable_arrows",
      "default": true,
      "label": "t:general.settings.slider.show_arrows",
      "visible_if": "{{ block.settings.slider_on != 'none' }}"
    },
    {
      "type": "select",
      "id": "arrow_position",
      "default": "bottom",
      "label": "t:sections.dbtfy-before-and-after.settings.arrow_position.label",
      "options": [
        {
          "value": "middle",
          "label": "t:general.settings.alignment.option__2"
        },
        {
          "value": "bottom",
          "label": "t:general.settings.alignment.option__3"
        }
      ],
      "visible_if": "{{ block.settings.enable_arrows and block.settings.slider_on != 'none' }}"
    },
    {
      "type": "select",
      "id": "arrow_color",
      "default": "inherit",
      "label": "t:general.settings.slider.arrow_color",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ],
      "visible_if": "{{ block.settings.enable_arrows and block.settings.slider_on != 'none' }}"
    },
    {
      "type": "color",
      "id": "custom_arrow_color",
      "label": "t:general.settings.slider.custom-arrow-color",
      "default": "#ffffff",
      "visible_if": "{{ block.settings.enable_arrows and block.settings.slider_on != 'none'}}"
    },
    {
      "type": "color",
      "id": "custom_arrow_background_color",
      "label": "t:general.settings.slider.custom-arrow-bg-color",
      "default": "#7559ff",
      "visible_if": "{{ block.settings.enable_arrows and block.settings.slider_on != 'none' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding_section.block_padding"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.top",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_top",
      "default": 36
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.bottom",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.dbtfy-trustpilot.name",
      "blocks": [
        {
          "type": "_heading",
          "static": true,
          "id": "heading",
          "blocks": [{ "type": "_title", "settings": { "title": "Trustpilot reviews" } }]
        },
        {
          "type": "_trustpilot-review",
          "static": true,
          "id": "trustpilot-review",
          "blocks": [
            { "type": "_trustpilot-review-block" },
            { "type": "_trustpilot-review-block" },
            { "type": "_trustpilot-review-block" },
            { "type": "_trustpilot-review-block" }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
