      "type": "select",
      "id": "add_to_cart_style",
      "default": "button button--secondary",
      "label": "t:settings_schema.global_settings.settings.button_style.add-to-cart-style.label",
      "options": [
        { "value": "button button--tertiary", "label": "t:general.settings.style.default" },
