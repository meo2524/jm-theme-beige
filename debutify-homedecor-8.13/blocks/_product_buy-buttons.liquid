      "type": "color",
      "id": "add_to_cart__custom_background_color",
      "label": "Primary Color",
      "visible_if": "{{ block.settings.custom_add_to_cart_buttons == 'custom' and block.settings.add_to_cart_color == 'custom_color' }}"
    },
    {
      "type": "color",
      "id": "add_to_cart__custom_text_color",
      "label": "Secondary color",
      "visible_if": "{{ block.settings.custom_add_to_cart_buttons == 'custom' and block.settings.add_to_cart_color == 'custom_color' }}"
