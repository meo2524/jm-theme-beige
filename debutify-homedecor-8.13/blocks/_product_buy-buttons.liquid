{%- liquid
  unless section.settings.product == blank
    assign product = section.settings.product
  endunless

  if product != null
    assign product_form_id = 'product-form-' | append: section.id

    if settings.dbtfy_back_in_stock
      render 'dbtfy-back-in-stock', product: product
    endif

    render 'buy-buttons', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true
  endif
-%}

{% schema %}
{
  "name": "t:sections.main-product.blocks.buy_buttons.name",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-product.blocks.buy_buttons.settings.show_dynamic_checkout_notice"
    },
    {
      "type": "select",
      "id": "custom_add_to_cart_buttons",
      "label": "t:settings_schema.global_settings.settings.button_settings.label",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:settings_schema.global_settings.settings.button_settings.inherit_message",
