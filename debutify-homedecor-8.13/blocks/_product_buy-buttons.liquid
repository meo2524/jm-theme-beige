        },
        {
          "value": "light_color",
          "label": "t:settings_schema.global_settings.settings.button_style.add_to_cart_color.light"
        },
        {
          "value": "dark_color",
          "label": "t:settings_schema.global_settings.settings.button_style.add_to_cart_color.dark"
