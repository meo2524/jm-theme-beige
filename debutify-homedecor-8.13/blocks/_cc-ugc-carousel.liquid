{% render 'widget-blocker',
  enabled: settings.dbtfy_ugc_carousel,
  section: section,
  name: 'UGC Carousel',
  type: '⚡ Paid Sections'
%}

{% if request.design_mode or settings.dbtfy_ugc_carousel %}
  {{ 'dbtfy-ugc-carousel.css' | asset_url | stylesheet_tag }}

  {% liquid
    assign block_id = 'ugc-' | append: block.id
    render 'custom-arrow-style', as_a: 'block', id: block_id
  %}

  <style>
    {% if block.settings.enable_dots == true %}
      product-info dbtfy-ugc-carousel #{{ block.id }} .splide__dots-and-arrows {
        padding-bottom: 5rem;
      }
    {% else %}
      product-info dbtfy-ugc-carousel #{{ block.id }} .splide__dots-and-arrows {
        padding-bottom: 0;
      }
    {% endif %}
  </style>

  {%- render 'block-padding', block: block -%}
  {% liquid
    render 'custom-arrow-style'
  -%}
  <dbtfy-ugc-carousel
    data-loop="{{ block.settings.enable_loop }}"
    data-autoplay="{{ block.settings.enable_autoplay }}"
    data-autoplay-speed="{{ block.settings.autoplay_speed }}"
    data-dots="{{ block.settings.enable_dots }}"
    data-arrows="{{ block.settings.enable_arrows }}"
    data-slider-enabled="{{ block.settings.slider_on }}"
    data-slider-desktop-col="{{ block.settings.columns_desktop }}"
    data-slider-mobile-col="{{ block.settings.columns_mobile }}"
    data-center-mode="false"
    data-play-all-video="{{ block.settings.enable_play_video }}"
    class="h-full {% if block.settings.vertical_center %}flex flex-column justify-content-center{% endif %}"
    id="{{ block_id }}"
  >
    <div
      id="{{ block.id }}"
      class="show-on--{{ block.settings.show_on }} block-{{ block.id }}-padding dbtfy-ugc-carousel__mobile--{{ block.settings.columns_mobile }}"
    >
      <div class="{{ block.settings.container_size }}">
        {% content_for 'block', type: '_heading', id: 'heading' %}
        {% content_for 'block',
          type: '_ugc_carousel',
          id: 'ugc_carousel',
          arrows: block.settings.enable_arrows,
          dots: block.settings.enable_dots,
          loop: block.settings.enable_loop,
          columns_desktop: block.settings.columns_desktop
        %}
      </div>
    </div>
  </dbtfy-ugc-carousel>

  <script src="{{ 'dbtfy-ugc-carousel.js' | asset_url }}"></script>
{% endif %}
{% schema %}
{
  "name": "t:sections.ugc-carousel.name",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.ugc-carousel.help.info"
    },
    {
      "type": "header",
      "content": "t:blocks.help.header"
    },
    {
      "type": "paragraph",
      "content": "t:sections.ugc-carousel.help.youtube_link"
    },
    {
      "type": "paragraph",
      "content": "t:help.enterprise_info"
    },
    {
      "type": "header",
      "content": "t:general.settings.settigns"
    },
    {
      "type": "select",
      "id": "show_on",
      "label": "t:sections.all.show_on.label",
      "default": "both",
      "options": [
        {
          "value": "desktop-only",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile-only",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "vertical_center",
      "default": false,
      "label": "t:general.settings.center_title"
    },
    {
      "type": "select",
      "id": "container_size",
      "label": "t:sections.all.container_size.label",
      "default": "page-width",
      "options": [
        {
          "value": "page-width",
          "label": "t:general.settings.style.default"
        },
        {
          "value": "page-full",
          "label": "t:sections.all.container_size.options__2.label"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "t:general.settings.col.desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:general.settings.col.mobile.label",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "t:sections.guarantee.settings.columns_per_row_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.guarantee.settings.columns_per_row_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "t:sections.video.settings.enable_video_looping.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_play_video",
      "label": "Play all video",
      "default": false
    },
    {
      "type": "header",
      "content": "t:general.settings.slider.slider_settings"
    },
    {
      "type": "select",
      "id": "slider_on",
      "default": "both",
      "label": "t:general.settings.slider.Enable_slider",
      "options": [
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        },
        {
          "value": "desktop",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "default": false,
      "label": "t:general.settings.slider.enable_autoplay"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:general.settings.slider.autoplay_speed",
      "default": 5,
      "min": 3,
      "max": 8,
      "step": 1,
      "unit": "s"
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "default": true,
      "label": "Loop",
      "info": "Continue from the last slide to the first slide"
    },
    {
      "type": "checkbox",
      "id": "enable_dots",
      "default": true,
      "label": "t:general.settings.slider.show_dots"
    },
    {
      "type": "checkbox",
      "id": "enable_arrows",
      "default": true,
      "label": "t:general.settings.slider.show_arrows"
    },
    {
      "type": "select",
      "id": "arrow_color",
      "default": "inherit",
      "label": "t:general.settings.slider.arrow_color",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "color",
      "id": "custom_arrow_color",
      "label": "t:general.settings.slider.custom-arrow-color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_arrow_background_color",
      "label": "t:general.settings.slider.custom-arrow-bg-color",
      "default": "#7559ff"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.top",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_top",
      "default": 36
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.bottom",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.ugc-carousel.name",
      "blocks": [
        {
          "type": "_heading",
          "static": true,
          "id": "heading",
          "blocks": [
            {
              "type": "_title",
              "settings": {
                "title": "Step Inside Our Shop",
                "alignment": "text-center"
              }
            }
          ]
        },
        {
          "type": "_ugc_carousel",
          "static": true,
          "id": "ugc_carousel",
          "blocks": [
            {
              "type": "_ugc_carousel-block"
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
