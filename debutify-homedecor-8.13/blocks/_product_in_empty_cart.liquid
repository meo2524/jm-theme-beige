{%- render 'widget-blocker-warning',
  enabled: settings.dbtfy_product_in_empty_cart,
  type: 'widget',
  as: 'block',
  name: 'Product in Empty Cart',
  id: block
-%}

{%- if settings.dbtfy_product_in_empty_cart or request.design_mode -%}
  {% assign collection = collections[block.settings.cart_collection] %}
  {% assign collection_enabled = false %}
  {% if collection and collection.products.size > 0 %}
    {% assign collection_enabled = true %}
  {% endif %}

  {% assign product_list_enbled = false %}
  {% assign product_list = block.settings.cart_product_list %}
  {% if product_list != blank %}
    {% assign product_list_enbled = true %}
  {% endif %}

  {% if collection_enabled %}
    {% assign products = collection.products %}
  {% elsif product_list_enbled %}
    {% assign products = block.settings.cart_product_list %}
  {% endif %}
  {% liquid
    assign slider_on = 'slider slider--everywhere'
    capture slider_parameters
      echo ' data-autoplay="' | append: block.settings.enable_autoplay | append: '"'
      echo ' data-speed="' | append: block.settings.autoplay_speed | append: '"'
      echo ' data-loop="' | append: block.settings.enable_loop | append: '"'
      echo ' data-arrows="' | append: block.settings.enable_arrows | append: '"'
      echo ' data-dots="' | append: block.settings.enable_dots | append: '"'
    endcapture

    assign arrow_class = ''
    if block.settings.arrow_position == 'middle'
      assign arrow_class = 'slideshow__controls slideshow__controls--top'
    endif
  %}

  {% style %}
    #block-{{ block.id }} .slider-buttons {
      {% if block.settings.arrow_color == 'custom' %}
        --arrow-color: {{ block.settings.custom_arrow_color }};
        --color-button-text: {{ block.settings.custom_arrow_color }};
        --arrow-background-color: {{ block.settings.custom_arrow_background_color }};
      {% endif %}
        {% if arrow_class == blank or block.settings.enable_dots == true %}
          margin-bottom: 10px;
        {% endif %}
      }
  {% endstyle %}
  <dbtfy-product-in-empty-cart>
    {%- if collection_enabled or product_list_enbled -%}
      <div class="cart-empty__content {{ block.shopify_attributes }}" id="block-{{ block.id }}">
        <div class="card-product-vertical">
          <dbtfy-slider-component {{ slider_parameters }}>
            <ul
              id="Slider-{{ block.id }}"
              class="contains-card contains-card--product {{ slider_on }} {% if block.settings.direction == "vertical" %} card-vertical grid--3-col-desktop grid--1-col{% else %} card-horizontal grid--1-col{% endif %} grid"
              role="list"
            >
              {%- for product in products limit: 3 -%}
                <li id="Slide-{{ section.id }}" class="grid__item">
                  {%- render 'card-product',
                    card_product: product,
                    media_aspect_ratio: 'inherit',
                    show_secondary_image: 'inherit',
                    quick_add: 'standard',
                    show_rating: block.settings.show_star_ratings,
                    show_sale_badge: false,
                    show_sold_out_badge: true,
                    badges: false
                  -%}
                </li>
              {%- endfor -%}
            </ul>
            {%- render 'dbtfy-arrow', class: arrow_class -%}
          </dbtfy-slider-component>
        </div>
      </div>
    {%- endif -%}
  </dbtfy-product-in-empty-cart>
{%- endif -%}
{%- schema -%}
{
  "name": "t:blocks.dbtfy-product-cart-empty.settings.empty_cart.name",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:blocks.dbtfy-product-cart-empty.help.info"
    },
    {
      "type": "header",
      "content": "t:blocks.help.header"
    },
    {
      "type": "paragraph",
      "content": "t:blocks.dbtfy-product-cart-empty.help.youtube_link"
    },
    {
      "type": "paragraph",
      "content": "t:help.professional_info"
    },
    {
      "type": "header",
      "content": "t:general.settings.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:general.settings.block-name.label",
      "info": "t:general.settings.block-name.info",
      "default": "t:blocks.dbtfy-product-cart-empty.settings.title"
    },
    {
      "type": "header",
      "content": "t:blocks.dbtfy-product-cart-empty.settings.empty_cart.info"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:sections.cart-upsell.upsell_direction",
      "default": "vertical",
      "options": [
        {
          "value": "horizontal",
          "label": "t:general.settings.alignment.option__10"
        },
        {
          "value": "vertical",
          "label": "t:general.settings.alignment.option__11"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:blocks.dbtfy-product-cart-empty.settings.info"
    },
    {
      "type": "collection",
      "id": "cart_collection",
      "label": "t:general.settings.visibility.collection.label",
      "info": "t:blocks.dbtfy-product-cart-empty.settings.collection_info"
    },
    {
      "type": "paragraph",
      "content": "t:general.settings.or"
    },
    {
      "type": "product_list",
      "id": "cart_product_list",
      "label": "t:blocks.dbtfy-product-cart-empty.settings.product_list",
      "limit": 3
    },
    {
      "type": "checkbox",
      "id": "show_star_ratings",
      "label": "t:sections.dbtfy-shipping-checkpoints.review",
      "default": true
    },
    {
      "type": "header",
      "content": "t:general.settings.slider.slider_settings"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "default": false,
      "label": "t:general.settings.slider.enable_autoplay"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:general.settings.slider.autoplay_speed",
      "default": 5,
      "min": 3,
      "max": 8,
      "step": 1,
      "unit": "s",
      "visible_if": "{{ block.settings.enable_autoplay }}"
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "default": true,
      "label": "t:sections.dbtfy-footer.blocks.newsletter.settings.media_setting.loop.label",
      "info": "t:sections.dbtfy-footer.blocks.newsletter.settings.media_setting.loop.info"
    },
    {
      "type": "checkbox",
      "id": "enable_arrows",
      "default": true,
      "label": "t:general.settings.slider.show_arrows"
    },
    {
      "type": "checkbox",
      "id": "enable_dots",
      "default": true,
      "label": "t:general.settings.slider.show_dots"
    },
    {
      "type": "select",
      "id": "arrow_color",
      "default": "inherit",
      "label": "t:general.settings.slider.arrow_color",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ],
      "visible_if": "{{ block.settings.enable_arrows }}"
    },
    {
      "type": "color",
      "id": "custom_arrow_color",
      "label": "t:general.settings.slider.custom-arrow-color",
      "default": "#ffffff",
      "visible_if": "{{ block.settings.arrow_color == 'custom' }}"
    },
    {
      "type": "color",
      "id": "custom_arrow_background_color",
      "label": "t:general.settings.slider.custom-arrow-bg-color",
      "default": "#7559ff",
      "visible_if": "{{ block.settings.arrow_color == 'custom' }}"
    },
    {
      "type": "select",
      "id": "arrow_position",
      "default": "middle",
      "label": "t:sections.dbtfy-before-and-after.settings.arrow_position.label",
      "options": [
        {
          "value": "middle",
          "label": "t:general.settings.alignment.option__2"
        },
        {
          "value": "bottom",
          "label": "t:general.settings.alignment.option__3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:blocks.dbtfy-product-cart-empty.settings.empty_cart.name"
    }
  ]
}
{%- endschema -%}
