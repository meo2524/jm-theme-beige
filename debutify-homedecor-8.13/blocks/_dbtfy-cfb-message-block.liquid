<div
  class="{% if block.settings.width_message == 'full-width' %}grid--12-col{% else %}grid--6-col{% endif %}"
  {{ block.shopify_attributes }}
>
  <div class="field">
    <textarea
      rows="10"
      id="ContactForm-body"
      class="text-area field__input"
      name="contact[{{ 'templates.contact.form.comment' | t }}]"
      placeholder="{{ 'templates.contact.form.comment' | t }}"
      style="min-height: {{ block.settings.min_height }}rem;"
      {% if block.settings.required %}
        required
      {% endif %}
    >
      {{- form.body -}}
    </textarea>
    <label class="form__label field__label" for="ContactForm-body">
      {% if block.settings.label != blank %}
        {{- block.settings.label -}}
      {% else %}
        {{- 'templates.contact.form.comment' | t -}}
      {% endif %}
      {% if block.settings.required %}
        <span aria-hidden="true">*</span>
      {% endif %}
    </label>
  </div>
  {% if block.settings.required %}
    <small class="error-message w-100 hidden">
      <span class="svg-wrapper">
        {{- 'icon-error.svg' | inline_asset_content -}}
      </span>
      <span class="error-message-text"> {{ block.settings.error_message }} </span>
    </small>
  {% endif %}
</div>
{% schema %}
{
  "name": "Message",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:general.settings.block-name.label",
      "info": "t:general.settings.block-name.info"
    },
    {
      "type": "text",
      "id": "label",
      "label": "t:general.settings.label",
      "default": "t:blocks.minimum_order.settings.dbtfy_minimum_order_message.label"
    },
    {
      "type": "checkbox",
      "id": "required",
      "label": "t:general.settings.require",
      "default": false,
      "info": "t:sections.dbtfy-contact-form-builder.blocks.input.settings.required.info"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "t:sections.dbtfy-contact-form-builder.blocks.message.settings.min_height.label",
      "default": 20,
      "min": 10,
      "max": 40,
      "unit": "rem"
    },
    {
      "type": "select",
      "id": "width_message",
      "label": "t:sections.dbtfy-contact-form-builder.blocks.message.settings.width_message.label",
      "default": "full-width",
      "options": [
        {
          "value": "full-width",
          "label": "t:sections.dbtfy-content-tabs.settings.full_width"
        },
        {
          "value": "half-width",
          "label": "t:sections.dbtfy-contact-form-builder.blocks.message.settings.width_message.options__2.label"
        }
      ]
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "t:sections.dbtfy-contact-form-builder.blocks.error_label",
      "default": "t:sections.dbtfy-contact-form-builder.blocks.message.settings.message_error"
    }
  ],
  "presets": [
    {
      "name": "Message"
    }
  ]
}
{% endschema %}
