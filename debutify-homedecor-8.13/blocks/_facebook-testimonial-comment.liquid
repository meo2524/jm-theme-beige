<div class="facebook-post__comment flex" {{ block.shopify_attributes }}>
  <div class="facebook-post__comment__avatar media media--transparent circle ">
    {%- if block.settings.author_profile_image != blank -%}
      {{ block.settings.author_profile_image | image_url: width: 200 | image_tag: loading: 'lazy', width: 100 }}
    {%- else -%}
      <svg width="50" height="50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 41.67 41.67" fill="none">
        <path class="cls-1" d="M21,41.84A20.83,20.83,0,1,0,.16,21,20.82,20.82,0,0,0,21,41.84Z" transform="translate(-0.16 -0.18)" fill="#C9CCD1"/>
        <path class="cls-2" d="M21,10.45a7.8,7.8,0,0,0-.1,15.6h.37A7.8,7.8,0,0,0,21,10.45Z" transform="translate(-0.16 -0.18)" fill="#FDFDFE"/>
        <path class="cls-2" d="M35.12,36.32a20.83,20.83,0,0,1-28.25,0,8.94,8.94,0,0,1,3.83-5c5.69-3.79,14.94-3.79,20.58,0A8.87,8.87,0,0,1,35.12,36.32Z" transform="translate(-0.16 -0.18)" fill="#FDFDFE"/>
      </svg>
    {%- endif -%}
  </div>
  <div class="facebook-post__comment__right">
    <div class="facebook-post__comment__box">
      {%- if block.settings.author_name != blank -%}
        <p class="facebook-post__comment__author text--bold flex flex-align-center">
          {{- block.settings.author_name -}}
          {%- if block.settings.author_verified -%}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              class="verified-icon"
              viewBox="0 0 122.88 116.87"
            >
              <polygon fill="#0866FF" fill-rule="evenodd" points="61.37 8.24 80.43 0 90.88 17.79 111.15 22.32 109.15 42.85 122.88 58.43 109.2 73.87 111.15 94.55 91 99 80.43 116.87 61.51 108.62 42.45 116.87 32 99.08 11.73 94.55 13.73 74.01 0 58.43 13.68 42.99 11.73 22.32 31.88 17.87 42.45 0 61.37 8.24 61.37 8.24"></polygon>
              <path fill="#fff" d="M37.92,65c-6.07-6.53,3.25-16.26,10-10.1,2.38,2.17,5.84,5.34,8.24,7.49L74.66,39.66C81.1,33,91.27,42.78,84.91,49.48L61.67,77.2a7.13,7.13,0,0,1-9.9.44C47.83,73.89,42.05,68.5,37.92,65Z"></path>
            </svg>
          {%- endif -%}
        </p>
      {%- endif -%}
      {%- if block.settings.author_comment != blank -%}
        <div class="facebook-post__comment__text">
          <p>{{ block.settings.author_comment }}</p>
        </div>
      {%- endif -%}
    </div>
    <p class="facebook-post__comment__ctas">
      {%- if block.settings.time_posted != blank -%}
        <span class="facebook-post__comment__ctas__time">{{ block.settings.time_posted }}</span>
      {%- endif -%}
      <span class="facebook-post__comment__ctas__cta">{{ 'sections.facebook-testimonials.like' | t }}</span>
      <span class="facebook-post__comment__ctas__cta">{{ 'sections.facebook-testimonials.replay' | t }}</span>
    </p>
  </div>
</div>
{% schema %}
{
  "name": "Comment",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "author_name",
      "label": "t:sections.facebook_tesimonial.settings.author.name",
      "default": "t:sections.facebook_tesimonial.settings.comment.name_default"
    },
    {
      "type": "image_picker",
      "id": "author_profile_image",
      "label": "t:sections.facebook_tesimonial.settings.comment.profile_image"
    },
    {
      "type": "checkbox",
      "id": "author_verified",
      "label": "t:sections.facebook_tesimonial.settings.author.verified"
    },
    {
      "type": "text",
      "id": "time_posted",
      "label": "t:sections.facebook_tesimonial.settings.post.time_posted",
      "default": "t:sections.facebook_tesimonial.settings.comment.time_posted_default"
    },
    {
      "type": "text",
      "id": "author_comment",
      "label": "t:sections.facebook_tesimonial.settings.comment.author_comment",
      "default": "t:sections.facebook_tesimonial.settings.comment.author_comment_default"
    }
  ],

  "presets": [
    {
      "name": "Comment"
    }
  ]
}
{% endschema %}
