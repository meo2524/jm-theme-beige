      "info": "t:sections.main-product.blocks.social_discount.info"
    },
    {
      "type": "text",
      "id": "button_icon",
      "label": "t:blocks.news-letter.settings.modal.button_icon.label",
      "default": "share",
      "info": "t:sections.all.icon.info"
    },
    {
      "type": "header",
      "content": "t:sections.main-product.blocks.social_discount.settings.modal_sharing.header"
