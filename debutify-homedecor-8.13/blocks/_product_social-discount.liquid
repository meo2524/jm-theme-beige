{%- liquid
  unless section.settings.product == blank
    assign product = section.settings.product
  endunless
  render 'dbtfy-social-discount', block: block, product: product
-%}

{% schema %}
{
  "name": "t:sections.main-product.blocks.social_discount.name",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-product.blocks.social_discount.help.info"
    },
    {
      "type": "header",
      "content": "t:blocks.help.header"
    },
    {
      "type": "paragraph",
      "content": "t:sections.main-product.blocks.social_discount.help.link"
    },
    {
      "type": "paragraph",
      "content": "t:help.professional_info"
    },
    {
      "type": "header",
      "content": "t:general.settings.settigns"
    },
    {
      "type": "select",
      "id": "button_style",
      "default": "link underlined-link button--link",
      "label": "t:general.settings.style.lable",
      "options": [
        {
          "value": "link underlined-link button--link",
          "label": "t:sections.all.button.option_1_label"
        },
        { "value": "button button--tertiary", "label": "t:general.settings.style.default" },
        { "value": "button button--primary", "label": "t:sections.all.button.options__3.label" },
        { "value": "button button--secondary", "label": "t:sections.all.button.options__4.label" }
      ]
    },
    {
