      "info": "t:sections.main-product.blocks.social_discount.info"
    },
    {
      "type": "inline_richtext",
      "id": "modal_content",
      "label": "t:sections.main-product.blocks.social_discount.settings.modal_sharing.modal_sharing_content.label",
      "default": "t:sections.main-product.blocks.social_discount.settings.modal_sharing.modal_sharing_content.default",
      "info": "t:sections.main-product.blocks.social_discount.info"
    },
    {
      "type": "header",
      "content": "t:sections.main-product.blocks.social_discount.settings.modal_thank_you.header"
    },
    {
      "type": "inline_richtext",
      "id": "modal_thank_you_title",
      "label": "t:sections.main-product.blocks.social_discount.settings.modal_thank_you.modal_thank_you_title.label",
      "default": "t:sections.main-product.blocks.social_discount.settings.modal_thank_you.modal_thank_you_title.default",
      "info": "t:sections.main-product.blocks.social_discount.info"
    },
    {
      "type": "inline_richtext",
      "id": "modal_thank_you_content",
      "label": "t:sections.main-product.blocks.social_discount.settings.modal_thank_you.modal_thank_you_content.label",
      "default": "t:sections.main-product.blocks.social_discount.settings.modal_thank_you.modal_thank_you_content.default"
    },
    {
      "type": "inline_richtext",
      "id": "modal_discount_label",
      "label": "t:sections.main-product.blocks.social_discount.settings.discount_button.label",
      "default": "t:blocks.news-letter.settings.thank_you_modal.button_text.default"
    },
    {
      "type": "header",
      "content": "t:general.settings.discount.header.content",
      "info": "t:general.settings.discount.header.info_1"
    },
    {
      "type": "text",
      "id": "discount_name",
      "label": "t:general.settings.discount.name.label",
      "default": "t:general.settings.discount.name.label"
    },
    {
      "type": "select",
      "id": "discount_type",
      "label": "t:general.settings.discount.type.label",
      "default": "%",
      "options": [
        {
          "value": "%",
          "label": "t:general.settings.discount.type.options__1.label"
        },
        {
          "value": "$",
          "label": "t:general.settings.discount.type.options__2.label"
        }
      ]
    },
    {
      "type": "text",
      "id": "discount_amount",
      "label": "t:general.settings.discount.amount.label",
      "info": "t:general.settings.discount.type.info",
      "default": "30"
    },
    {
      "type": "header",
      "content": "t:settings_schema.social-media.settings.header_2"
    },
    {
      "type": "text",
      "id": "social_share_title",
      "label": "t:general.settings.title",
      "default": "t:settings_schema.social-media.settings.header_3"
    },
    {
      "type": "checkbox",
      "id": "enable_facebook",
      "label": "t:settings_schema.social-media.settings.social_facebook_link.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_twitter",
      "label": "t:settings_schema.social-media.settings.social_twitter_link.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_pinterest",
      "label": "t:settings_schema.social-media.settings.social_pinterest_link.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_linkedin",
      "label": "t:settings_schema.social-media.settings.social_linkedin_link.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_whatsapp",
      "label": "t:settings_schema.social-media.settings.social_whatsapp_link.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_email",
      "label": "t:settings_schema.social-media.settings.social_email_link.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.main-product.blocks.social_discount.name"
    }
  ]
