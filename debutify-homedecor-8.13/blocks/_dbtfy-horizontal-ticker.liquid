{% liquid
  if section.settings.border_radius == 'global'
    assign border_radius = 'content-container'
  endif
%}

<li
  {{ block.shopify_attributes }}
>
  <div class="dbtfy-horizontal-ticker {{ border_radius }} color-{{ block.settings.custom_color_scheme }} dbtfy-color-{{ block.settings.color_scheme }} gradient">
    <div class="dbtfy-horizontal-ticker-image">
      {% if block.settings.author_image != blank %}
        <img
          src="{{ block.settings.author_image | image_url: width: 100, height: 100}}"
          alt="{{ block.settings.author_image.alt }}"
          loading="lazy"
          width="100"
          height="100"
        >
      {% endif %}
    </div>
    <div class="dbtfy-horizontal-ticker-content">
      <p>{{ block.settings.text }}</p>
      <div class="dbtfy-horizontal-ticker-footer">
        <span>{{ block.settings.author }}</span>
        <div class="dbtfy-horizontal-ticker-rating-stars__container svg">
          {%- for i in (1..5) -%}
            {%- if i <= block.settings.star_rating -%}
              {%- render 'icon-star' -%}
            {%- else -%}
              {%- render 'icon-empty-star' -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</li>

{% schema %}
{
  "name": "t:sections.horizontal_ticker.name_1",
  "tag": null,
  "settings": [
    {
      "type": "range",
      "id": "star_rating",
      "label": "t:blocks.star_rating.name",
      "default": 5,
      "min": 1,
      "max": 5,
      "step": 1
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "t:general.settings.text",
      "default": "t:sections.dbtfy-image-video-testimonial.blocks.text"
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "t:sections.dbtfy_testimonials.blocks.testimonial.settings.author_image.label"
    },
    {
      "type": "richtext",
      "id": "author",
      "label": "t:sections.dbtfy_testimonials.blocks.testimonial.settings.author.label",
      "default": "<p><strong>Author's name</strong></p>"
    },
    {
      "type": "header",
      "content": "t:sections.all.color_schemes.header.heading.label",
      "info": "t:sections.all.color_schemes.header.info.content"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.all.color_schemes.default.label",
      "options": [
        {
          "value": "scheme-1",
          "label": "t:sections.all.color_schemes.default.options__1.label"
        },
        {
          "value": "scheme-2",
          "label": "t:sections.all.color_schemes.default.options__2.label"
        },
        {
          "value": "scheme-3",
          "label": "t:sections.dbtfy_text_col_with_img.settings.background_style.label"
        },
        {
          "value": "scheme-4",
          "label": "t:sections.all.color_schemes.default.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ],
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "custom_color_scheme",
      "label": "t:sections.all.color_schemes.custom.label",
      "default": "scheme-1"
    }
  ],

  "presets": [
    {
      "name": "t:sections.horizontal_ticker.name_1"
    }
  ]
}
{% endschema %}
