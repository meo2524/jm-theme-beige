{% render 'block-padding', block: block %}
{% style %}
  .block-{{ block.id }}-padding figure{
    {%- if block.settings.full_width -%}
      max-width:100%;
      width:100%;
    {%- else -%}
      max-width:{{ block.settings.width }}px;
    {%- endif -%}
  }

  .block-{{ block.id }}-padding figure.global-media-settings:after {
    z-index: 1;
  }
{% endstyle %}
<div
  class="w-full image-block block-{{ block.id }}-padding {{ block.settings.alignment }} {{ block.settings.alignment_mobile }}"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.image != blank -%}
    <figure class="dbtfy-image--block global-media-settings">
      {{
        block.settings.image
        | image_url: width: 1206
        | image_tag: widths: '246, 493, 600, 713, 823, 990, 1100, 1206'
      }}
    </figure>
  {%- else -%}
    <figure class="dbtfy-image--block {{ block.settings.alignment }} {{ block.settings.alignment_mobile }} global-media-settings">
      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
    </figure>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:general.settings.image",
  "class": "w-full",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:general.settings.image"
    },
    {
      "type": "range",
      "id": "width",
      "label": "t:general.settings.width",
      "default": 100,
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full Width",
      "default": false,
      "info": "This settings will override the width settings."
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:general.settings.alignment.label",
      "default": "text-center",
      "options": [
        {
          "value": "",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "text-left",
          "label": "t:general.settings.alignment.option__4"
        },
        {
          "value": "text-center",
          "label": "t:general.settings.alignment.option__5"
        },
        {
          "value": "text-right",
          "label": "t:general.settings.alignment.option__6"
        }
      ],
      "info": "t:general.settings.image_info"
    },
    {
      "type": "select",
      "id": "alignment_mobile",
      "label": "t:general.settings.alignment.label_mobile",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "t:general.settings.alignment.option__12"
        },
        { "value": "mobile-text-left", "label": "t:general.settings.alignment.option__4" },
        { "value": "mobile-text-center", "label": "t:general.settings.alignment.option__5" },
        { "value": "mobile-text-right", "label": "t:general.settings.alignment.option__6" },
        { "value": "mobile-text-justify", "label": "t:general.settings.alignment.option__7" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.padding_section.block_padding"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.top",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_top",
      "default": 36
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.bottom",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "extra_small",
          "label": "t:general.settings.size.option__4"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "extra_large",
          "label": "t:general.settings.size.option__7"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_bottom",
      "default": 36
    }
  ],
  "presets": [{ "name": "t:general.settings.image" }]
}
{% endschema %}
