<div
  class="{% if block.settings.width_checkbox == 'full-width' %}grid--12-col{% else %}grid--6-col{% endif %}"
  {{ block.shopify_attributes }}
>
  {% assign options = block.settings.options | split: ',' %}
  <p class="" style="margin: 0 0 .25rem;">
    {{ block.settings.label }}
    {% if block.settings.required %}
      <span aria-hidden="true">*</span>
    {% endif %}
  </p>
  <div class="checkbox_field {% if block.settings.required %}required{% endif %}">
    {% for option in options %}
      <div class="">
        <input
          id="input-{{ block.id }}-{{ forloop.index }}"
          class="checkbox__input"
          type="checkbox"
          value="{{ option }}"
          name="contact[{{ block.settings.label | handleize }}]"
        >
        <label for="input-{{ block.id }}-{{ forloop.index }}" class="">
          {{ option }}
        </label>
      </div>
    {% endfor %}
  </div>
  {% if block.settings.required %}
    <small class="error-message w-100 hidden">
      <span class="svg-wrapper">
        {{- 'icon-error.svg' | inline_asset_content -}}
      </span>
      <span class="error-message-text"> {{ block.settings.error_message }} </span>
    </small>
  {% endif %}
</div>
{% schema %}
{
  "name": "Checkbox",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:general.settings.block-name.label",
      "info": "t:general.settings.block-name.info"
    },
    {
      "type": "text",
      "id": "label",
      "label": "t:general.settings.label",
      "default": "Country"
    },
    {
      "type": "checkbox",
      "id": "required",
      "label": "t:general.settings.require",
      "default": false,
      "info": "t:sections.dbtfy-contact-form-builder.blocks.input.settings.required.info"
    },
    {
      "type": "html",
      "id": "options",
      "label": "t:blocks.customizable_products.blocks.group.settings.options.label",
      "default": "t:sections.dbtfy-contact-form-builder.blocks.checkbox.settings.options.default",
      "info": "t:sections.dbtfy-contact-form-builder.blocks.checkbox.settings.options.info"
    },
    {
      "type": "select",
      "id": "width_checkbox",
      "label": "t:sections.dbtfy-contact-form-builder.blocks.checkbox.settings.width_checkbox.label",
      "default": "half-width",
      "options": [
        {
          "value": "full-width",
          "label": "t:sections.dbtfy-content-tabs.settings.full_width"
        },
        {
          "value": "half-width",
          "label": "t:sections.dbtfy-contact-form-builder.blocks.checkbox.settings.width_checkbox.options__2.label"
        }
      ]
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "t:sections.dbtfy-contact-form-builder.blocks.error_label",
      "default": "t:sections.dbtfy-contact-form-builder.blocks.select.settings.select_error"
    }
  ],
  "presets": [
    {
      "name": "Checkbox"
    }
  ]
}
{% endschema %}
