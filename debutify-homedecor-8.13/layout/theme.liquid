    {%- render 'integrations-gtm' -%}

    <!-- Klaviyo app -->
    {%- render 'integrations-klaviyo' -%}

    <script>
      {% render 'license.js' %}
    </script>

    {%- if request.design_mode -%}
      {% render 'dbtfy-plan-modal' %}
    {%- endif -%}
