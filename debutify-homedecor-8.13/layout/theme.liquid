    {%- if settings.button_animation -%}
      {%- render 'button-animation-css' -%}
    {%- endif -%}
    <link rel="stylesheet" href="{{ 'dbtfy-video.css' | asset_url }}" media="print" onload="this.media='all'">
    <script src="{{ 'dbtfy-video.js' | asset_url }}" defer></script>

    <style>
      .hidden {
        display: none;
