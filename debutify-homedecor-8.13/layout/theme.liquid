    </style>

    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ 'dbtfy-drawer.css' | asset_url | stylesheet_tag }}
    <link rel="stylesheet" href="{{ 'dbtfy-toast.css' | asset_url }}" media="print" onload="this.media='all'">
    <script src="{{ 'dbtfy-toast.js' | asset_url }}" defer></script>

    {%- if settings.dbtfy_wish_list -%}
      <link rel="stylesheet" href="{{ 'dbtfy-wishlist.css' | asset_url }}" media="print" onload="this.media='all'">
      <script src="{{ 'dbtfy-wishlist.js' | asset_url }}" defer></script>
    {%- endif -%}

    {%- if settings.dbtfy_quick_view -%}
      <link rel="stylesheet" href="{{ 'dbtfy-quickview.css' | asset_url }}" media="print" onload="this.media='all'">
    {%- endif -%}

    {%- if settings.dbtfy_recently_viewed -%}
      <script src="{{ 'dbtfy-recently-viewed.js' | asset_url }}" defer></script>
    {%- endif -%}

    {%- if settings.dbtfy_quick_compare -%}
      <link rel="stylesheet" href="{{ 'dbtfy-compare.css' | asset_url }}" media="print" onload="this.media='all'">
      <script src="{{ 'dbtfy-compare.js' | asset_url }}" defer></script>
    {%- endif -%}

    <link
      rel="stylesheet"
      href="{{ 'dbtfy-element-animation.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
