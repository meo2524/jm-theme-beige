    },
    {
      "type": "richtext",
      "id": "banner_subheading",
      "label": "t:sections.dbtfy-faq.settings.banner_subheading.label",
      "default": "t:sections.dbtfy-faq.settings.banner_subheading.default"
    },
    {
      "type": "text",
