  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "_dbtfy-faq-group"
    }
  ],
  "presets": [
    {
      "name": "t:sections.dbtfy-faq.name",
      "blocks": [
        {
          "type": "_heading",
          "static": true,
