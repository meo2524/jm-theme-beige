{%- render 'widget-blocker',
  enabled: settings.dbtfy_facebook_testimonials,
  section: section,
  name: 'Facebook Testimonial',
  type: '⚡ Paid Sections'
-%}

{% if request.design_mode or settings.dbtfy_facebook_testimonials %}
  <link rel="stylesheet" href="{{ 'facebook-testimonial.css' | asset_url }}" media="print" onload="this.media='all'">
  <link
    rel="stylesheet"
    href="{{ 'component-deferred-media.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  {% render 'section-padding', section: section %}

  {%- if section.settings.pattern_bg != 'none' -%}
    {%- render 'dbtfy-background-pattern', setting: section.settings -%}
  {%- endif -%}

  <div id="section-{{ section.id }}" class="facebook-testimonial-section">
    <div class="color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} show-on--{{ section.settings.show_on }} gradient dbtfy-background-pattern-{{ section.id }}">
      <div class="section-{{ section.id }}-padding {{ section.settings.container_size }}">
        {% content_for 'block', type: '_heading', id: 'heading' %}

        {% capture inner_content %}
          {% content_for 'block', type: '_facebook-testimonial-group', id: 'facebook-testimonial-group' %}
        {% endcapture %}

        {% render 'splide-slider-component',
          inner_content: inner_content,
          setting: section.settings,
          custom_icon: settings.custom_arrow_icon,
          icon: settings.arrow_icon
        %}
      </div>
    </div>
  </div>
{% endif %}
