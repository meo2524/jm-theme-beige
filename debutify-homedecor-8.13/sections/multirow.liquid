{%- render 'widget-blocker',
  enabled: settings.dbtfy_multirow,
  section: section,
  name: 'Multirow',
  type: '⚡ Paid Sections'
-%}
{%- if request.design_mode or settings.dbtfy_multirow -%}
  <link
    rel="stylesheet"
    href="{{ 'component-image-with-text.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  {%- render 'section-padding', section: section -%}
  {% if section.settings.pattern_bg != 'none' %}
    {% render 'dbtfy-background-pattern', setting: section.settings %}
  {% endif %}

  <dbtfy-multirow>
    <div class="multirow section-{{ section.id }}-padding gradient color-{{ section.settings.custom_section_color_scheme }} dbtfy-color-{{ section.settings.section_color_scheme }} dbtfy-background-pattern-{{ section.id }}">
      {% content_for 'block', type: '_heading', id: 'heading' %}
      <div class="multirow__inner page-width {{ section.settings.image_layout }}">
        {% content_for 'block', type: '_multirow', id: 'multirow' %}
      </div>
    </div>
  </dbtfy-multirow>
{% endif %}

{% schema %}
