{%- render 'widget-blocker',
  enabled: settings.dbtfy_guarantee,
  section: section,
  name: 'Guarantee',
  type: '⚡ Paid Sections'
-%}
{%- if request.design_mode or settings.dbtfy_guarantee -%}
  <link rel="stylesheet" href="{{ 'dbtfy-guarantee.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
  {%- render 'section-padding', section: section -%}

  {%- if section.settings.pattern_bg != 'none' -%}
    {%- render 'dbtfy-background-pattern', setting: section.settings -%}
  {%- endif -%}

  <dbtfy-guarantee>
    <div class="dbtfy-guarantee__section color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} gradient show-on--{{ section.settings.show_on }}  section-{{ section.id }}-padding dbtfy-background-pattern-{{ section.id }}">
      <div
        class="{{ section.settings.container_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {% content_for 'block', type: '_heading', id: 'heading' %}

        <div class="grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_per_row_mobile }}-col">
          {% content_for 'block', type: '_dbtfy-guarantee', id: 'dbtfy-guarantee' %}
        </div>
      </div>
    </div>
  </dbtfy-guarantee>
{% endif %}
{% schema %}
{
  "name": "t:sections.guarantee.name",
  "disabled_on": { "groups": ["aside"] },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.guarantee.settings.help.info"
    },
    {
      "type": "header",
      "content": "t:blocks.help.header"
    },
    {
      "type": "paragraph",
      "content": "t:sections.guarantee.settings.help.link"
    },
    {
      "type": "paragraph",
      "content": "t:help.growth_info"
    },
    {
      "type": "header",
      "content": "t:general.settings.settigns"
    },
    {
      "type": "select",
      "id": "show_on",
      "label": "t:sections.all.show_on.label",
      "default": "both",
      "options": [
        {
          "value": "desktop-only",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile-only",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "container_size",
      "label": "t:sections.all.container_size.label",
      "default": "page-width",
      "options": [
        {
          "value": "page-width",
          "label": "t:general.settings.style.default"
        },
        {
          "value": "",
          "label": "t:sections.all.container_size.options__2.label"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:general.settings.col.desktop"
    },
    {
      "type": "select",
      "id": "columns_per_row_mobile",
      "label": "t:general.settings.col.mobile.label",
      "default": "2",
      "options": [
        {
          "value": "1",
          "label": "t:sections.guarantee.settings.columns_per_row_mobile.options__1.label"
