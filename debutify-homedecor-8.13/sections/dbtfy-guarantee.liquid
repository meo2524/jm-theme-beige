                  }
                }
              ]
            },
            {
              "type": "_dbtfy-guarantee-block",
              "blocks": [
                {
                  "type": "_icon",
                  "settings": {
                    "icon": "lock",
                    "size": "medium",
                    "alignment": "text-center"
                  }
                },
                {
                  "type": "_title",
                  "settings": {
                    "title": "Our guarantee",
                    "size": "h5",
                    "alignment": "text-center"
                  }
                },
                {
                  "type": "_description",
                  "settings": {
                    "description": "<p>Share your guarantees with your customers.</p>",
                    "alignment": "text-center"
                  }
                }
              ]
            },
            {
              "type": "_dbtfy-guarantee-block",
              "blocks": [
                {
                  "type": "_icon",
                  "settings": {
                    "icon": "lock",
                    "size": "medium",
                    "alignment": "text-center"
                  }
                },
                {
                  "type": "_title",
                  "settings": {
                    "title": "Our guarantee",
                    "size": "h5",
                    "alignment": "text-center"
                  }
                },
                {
                  "type": "_description",
                  "settings": {
                    "description": "<p>Share your guarantees with your customers.</p>",
