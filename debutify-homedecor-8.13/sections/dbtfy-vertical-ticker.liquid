{%- render 'widget-blocker',
  enabled: settings.dbtfy_vertical_ticker,
  section: section,
  name: 'Vertical Ticker',
  type: '⚡ Paid Sections'
-%}
{% if settings.dbtfy_vertical_ticker or request.design_mode %}
  {%- render 'section-padding', section: section -%}
  {%- if section.settings.pattern_bg != 'none' -%}
    {%- render 'dbtfy-background-pattern', setting: section.settings -%}
  {%- endif -%}
  {{ 'dbtfy-vertical-ticker.css' | asset_url | stylesheet_tag }}

  {% liquid
    assign grid = 'grid grid--1-col grid--2-col-tablet grid-2-col-desktop'
    assign content = section.settings.show_content
    if content == 'mobile-only' or content == 'hidden'
      assign grid = 'grid grid--1-col'
    endif

    assign show_on = 'show-on--' | append: content

    if content == 'hidden'
      assign show_on = 'hidden'
    endif

    assign text_size = section.settings.text_size
    assign tickers_display = section.settings.number_of_tickers_display
  %}

  <div class="dbtfy-vertical-ticker dbtfy-vertical-ticker-{{ section.id }} section-{{ section.id }}-padding color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} gradient show-on--{{ section.settings.show_on }} dbtfy-background-pattern-{{ section.id }}">
    <div class="{{ section.settings.container_size }}">
      <div class="{{ grid }} dbtfy-vertical-ticker-and-content dbtfy-ticker-desktop_{{ section.settings.ticker_placement_desktop }} dbtfy-ticker-mobile_{{ section.settings.ticker_placement_mobile }}">
        <div class="dbtfy-vertical-ticker_cta_block grid__item {{ show_on }} color-{{ section.settings.content_default_custom_color_scheme }} dbtfy-color-{{ section.settings.content_default_color_scheme }} gradient">
          {% content_for 'block', type: '_cta_block', id: 'cta-block' %}
        </div>
        <div class="grid__item dbtfy-vertical-ticker_content color-{{ section.settings.custom_color }} dbtfy-color-{{ section.settings.default_color_scheme }} gradient">
          <div class="dbtfy-vertical-ticker__inner">
            <div class="dbtfy-vertical-ticker__container">
              {% content_for 'block', type: '_dbtfy-vertical-tickers', id: 'dbtfy-vertical-tickers' %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endif %}

{% style %}
  {% if section.settings.background_image != blank %}
    .dbtfy-vertical-ticker-{{ section.id }} .dbtfy-vertical-ticker_cta_block:before{
      content: '';
      background-image: url({{ section.settings.background_image | image_url: width: 2048, height: 2048 }});
      opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    }
    {% endif %}

    {% assign ticker_animation = tickers_display | divided_by: section.settings.ticker_speed | times: 4 %}
    {%- if ticker_animation <= 0 -%}
      {%- assign ticker_animation = section.settings.ticker_speed -%}
    {%- endif -%}

    .dbtfy-vertical-ticker-{{ section.id }} .dbtfy-vertical-ticker__container {
      animation: vertTicker {{ ticker_animation }}s linear infinite forwards;
      gap: {{ section.settings.space_between_tickers }}px;
    }

    {% if section.settings.pause_ticker_on_hover %}
      .dbtfy-vertical-ticker-{{ section.id }} .dbtfy-vertical-ticker__container:hover {
        animation-play-state: paused;
      }
    {% endif %}



    .dbtfy-vertical-ticker-{{ section.id }} .dbtfy-vertical-ticker__item {
      font-size: {{ text_size }}rem;
      line-height: 1.2em;
    }
    .dbtfy-vertical-ticker-{{ section.id }} .dbtfy-vertical-ticker__inner {
      max-height: calc((2 * {{tickers_display}}rem) + ({{ section.settings.space_between_tickers | divided_by: 10 }} * {{tickers_display}}rem) + {{tickers_display}}rem);
    }

    @media screen and (min-width: 500px) {
      .dbtfy-vertical-ticker-{{ section.id }} .dbtfy-vertical-ticker__item {
        font-size: {{ text_size | times: 0.8 | round: 1 }}rem;
      }
    }

    @media screen and (min-width: 750px) {
      .dbtfy-vertical-ticker-{{ section.id }} .dbtfy-vertical-ticker__item {
        font-size: {{ text_size }}rem;
      }
    }
{% endstyle %}

