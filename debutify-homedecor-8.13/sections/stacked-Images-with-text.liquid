{%- render 'widget-blocker',
  enabled: settings.stacked_images_with_text,
  section: section,
  name: 'Stacked Images with Text',
  type: '⚡ Paid Sections'
-%}
{%- render 'section-padding', section: section -%}

{% style %}
  #shopify-section-{{ section.id }} { --image-border-radius: {{ section.settings.image_border_radius }}px; }
  #shopify-section-{{ section.id }} .gradient {
    {% if section.settings.image_desktop != blank %}
      background-image: url('{{ section.settings.image_desktop | image_url: width: 1600 }}');
      background-size: cover;
      background-position: center;
    {% endif %}
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .gradient {
      {% if section.settings.image_mobile  != blank%}
        background-image: url('{{ section.settings.image_mobile | image_url: width: 800 }}');
      {% endif %}
    }
  }
  {% if section.settings.image_desktop != blank %}
    #shopify-section-{{ section.id }} .gradient::before {
      {% if section.settings.overlay_opacity > 0 %}
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});
        pointer-events: none;
        z-index: 0;
        backdrop-filter: blur(5px);
      {% endif %}
    }
  {% endif %}
{% endstyle %}

<link rel="stylesheet" href="{{ 'stacked-images-with-text.css' | asset_url }}">
<dbtfy-stacked-images-with-text>
  <div class="section-{{ section.id }}-padding gradient relative show-on--{{section.settings.show_on}} color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }}">
    <div class="dbtfy-stacked-with-image {{ section.settings.container_size }}">
      <div class="grid grid--1-col grid--2-col-tablet{% if section.settings.desktop == 'right' %} image-with-text__grid--reverse{% endif %} image-with-text__mobile--{{ section.settings.mobile }}">
        <div class="grid__item">
          {%- content_for 'block', type: '_stacked_images', id: 'stacked_images' -%}
        </div>
        <div class="stacked-image-content grid__item">
          {% content_for 'block', type: '_heading', id: 'heading' %}
        </div>
      </div>
    </div>
  </div>
</dbtfy-stacked-images-with-text>

{% schema %}
{
  "name": "t:sections.stacked-images-with-text.name",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.stacked-images-with-text.help.info"
    },
    {
      "type": "header",
      "content": "t:blocks.help.header"
    },
    {
      "type": "paragraph",
      "content": "t:sections.stacked-images-with-text.help.link"
    },
    {
      "type": "paragraph",
      "content": "t:help.enterprise_info"
    },
    {
      "type": "header",
      "content": "t:general.settings.settigns"
    },
    {
      "type": "select",
      "id": "show_on",
      "label": "t:sections.all.show_on.label",
      "default": "both",
      "options": [
        {
          "value": "desktop-only",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile-only",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "container_size",
      "label": "t:sections.all.container_size.label",
      "default": "page-full",
      "options": [
        {
          "value": "page-width",
          "label": "t:general.settings.style.default"
        },
        {
          "value": "page-full",
          "label": "t:sections.all.container_size.options__2.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.stacked-images-with-text.settings.media_position"
    },
    {
      "type": "select",
      "id": "desktop",
      "label": "t:sections.dbtfy-breadcrumbs.settings.show_icons_on.options__1.label",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "t:general.settings.alignment.option__4"
        },
        {
          "value": "right",
          "label": "t:general.settings.alignment.option__6"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile",
      "label": "t:sections.dbtfy-breadcrumbs.settings.show_icons_on.options__2.label",
      "default": "bottom",
      "options": [
        {
          "value": "top",
          "label": "t:general.settings.alignment.option__1"
        },
        {
          "value": "bottom",
          "label": "t:general.settings.alignment.option__3"
        }
      ]
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "t:sections.stacked-images-with-text.settings.image_border_radius",
      "default": 8,
      "min": 0,
      "max": 15,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:sections.stacked-images-with-text.settings.background_media"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "t:sections.image_banner.settings.image_desktop.label"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:sections.image_banner.settings.image_mobile.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.dbtfy-footer.blocks.newsletter.settings.media_setting.overlay_opacity.label",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "t:sections.all.color_schemes.header.heading.label",
      "info": "t:sections.all.color_schemes.header.info.content"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.all.color_schemes.default.label",
      "options": [
        {
          "value": "scheme-1",
          "label": "t:sections.all.color_schemes.default.options__1.label"
        },
        {
          "value": "scheme-2",
          "label": "t:sections.all.color_schemes.default.options__2.label"
        },
        {
          "value": "scheme-3",
          "label": "t:sections.dbtfy_text_col_with_img.settings.background_style.label"
        },
        {
          "value": "scheme-4",
          "label": "t:sections.all.color_schemes.default.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ],
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "custom_color_scheme",
      "label": "t:sections.all.color_schemes.custom.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:settings_schema.layout.settings.spacing.section_desktop.label"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.top",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_top",
      "default": 36
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.bottom",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "_caption"
    },
    {
      "type": "_title"
    },
    {
      "type": "_description"
    },
    {
      "type": "_single_button"
    },
    {
      "type": "_stacked_image"
    }
  ],
  "presets": [
    {
      "name": "t:sections.stacked-images-with-text.name",
      "blocks": [
        {
          "type": "_heading",
          "static": true,
          "id": "heading",
          "blocks": [
            { "type": "_caption" },
            { "type": "_title" },
            { "type": "_description" },
            { "type": "_single_button" }
          ]
        },
        {
          "type": "_stacked_images",
          "static": true,
          "id": "stacked_images",
          "blocks": [
            { "type": "_stacked_image" },
            { "type": "_stacked_image" },
            { "type": "_stacked_image" },
            { "type": "_stacked_image" },
            { "type": "_stacked_image" }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
