{%- render 'widget-blocker',
  enabled: settings.dbtfy_featured_on,
  section: section,
  name: 'Featured on',
  type: '👑 Enterprise Sections'
-%}

{% if request.design_mode or settings.dbtfy_featured_on %}
  {% render 'section-padding', section: section %}

  {%- if section.settings.pattern_bg != 'none' -%}
    {%- render 'dbtfy-background-pattern', setting: section.settings -%}
  {%- endif -%}

  <link rel="stylesheet" href="{{ 'dbtfy-featured-on.css' | asset_url }}">
  {% style %}
    #section-{{ section.id }} {
      img,svg{
        max-height: {{ section.settings.logo_desktop_height }}px;
      }
    }

    @media screen and (min-width: 750px) {
      {% if section.settings.custom_spacing_desktop %}
      #section-{{ section.id }} .dbtfy-featured-on-logos-wrapper .splide__list {
        --grid-desktop-horizontal-spacing: {{ section.settings.logo_spacing_desktop }}px;
        --grid-desktop-vertical-spacing: {{ section.settings.logo_spacing_desktop }}px;
      }
      {% endif %}
    }

    @media screen and (max-width: 749px) {
      #section-{{ section.id }}{
       img,
       svg{
          max-height: {{ section.settings.logo_mobile_height }}px;
        }
      }
    }
  {% endstyle %}
  <dbtfy-featured-on>
    <div
      id="section-{{ section.id }}"
      class="dbtfy-featured-on section-{{ section.id }}-padding color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} gradient show-on--{{section.settings.show_on}} {% if section.settings.slider_on == 'mobile' %}mobile_in_slider{% else %}no_slider{% endif %} dbtfy-background-pattern-{{ section.id }}"
    >
      <div class="{{ section.settings.container_size }}">
        <div class="grid dbtfy-featured-on-wrapper {{  section.settings.desktop_layout }} logo-list">
          <div class="logo-list__heading dbtfy-featured-on-title">
            {% content_for 'block', type: '_title', id: 'title' %}
          </div>
          <div class="dbtfy-featured-on-logos-wrapper grid">
            {%- capture inner_content -%}
            {% content_for 'block', type: '_dbtfy-featured-on', id: 'logos' %}
          {%- endcapture -%}
            {% render 'splide-slider-component',
              inner_content: inner_content,
              setting: section.settings,
              spacing_grid_horizontal_desktop: 30,
              columns_mobile: 2,
              desktop_adaptive_height: false,
              custom_icon: settings.custom_arrow_icon,
              icon: settings.arrow_icon
            %}
          </div>
        </div>
      </div>
    </div>
  </dbtfy-featured-on>
{% endif %}
{% schema %}
{
  "name": "t:sections.featured-on.name",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.featured-on.help.info"
    },
    {
      "type": "header",
      "content": "t:blocks.help.header"
    },
    {
      "type": "paragraph",
      "content": "t:sections.featured-on.help.link"
    },
    {
      "type": "paragraph",
      "content": "t:help.enterprise_info"
    },
    {
      "type": "header",
      "content": "t:general.settings.settigns"
    },
    {
      "type": "select",
      "id": "show_on",
      "label": "t:sections.all.show_on.label",
      "options": [
        {
          "value": "desktop-only",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile-only",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        }
      ],
      "default": "both"
    },
    {
      "type": "select",
      "id": "container_size",
      "label": "t:sections.all.container_size.label",
      "default": "page-width",
      "options": [
        {
          "value": "page-width",
          "label": "t:general.settings.style.default"
        },
        {
          "value": "page--full",
          "label": "t:sections.all.container_size.options__2.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "grey_logos",
      "label": "t:sections.featured-on.settings.grey_logos"
    },
    {
      "type": "checkbox",
      "id": "custom_spacing_desktop",
      "label": "t:sections.featured-on.settings.custom_spacing_desktop",
      "default": false
    },
    {
      "type": "range",
      "id": "logo_spacing_desktop",
      "label": "t:sections.featured-on.settings.logo_spacing_desktop",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.custom_spacing_desktop }}"
    },
    {
      "type": "range",
      "id": "logo_desktop_height",
      "label": "t:sections.featured-on.settings.logo_desktop_height",
      "default": 80,
      "min": 50,
      "max": 150,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "logo_mobile_height",
      "label": "t:sections.featured-on.settings.logo_mobile_height",
      "default": 80,
      "min": 50,
      "max": 150,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.bubble.background_pattern_settings.label"
    },
    {
      "type": "select",
      "id": "pattern_bg",
      "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.pattern",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "curved-grid",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__1"
        },
        {
          "value": "radial-rings",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__2"
        },
        {
          "value": "diamond-grid",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__3"
        },
        {
          "value": "quatrefoils",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__4"
        },
        {
          "value": "hexagons",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__5"
        },
        {
          "value": "intersecting-circles",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__6"
        },
        {
          "value": "brick-wall",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__7"
        },
        {
          "value": "formal-invitation",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__8"
        },
        {
          "value": "jupiter",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__9"
        },
        {
          "value": "yyy",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__10"
        },
        {
          "value": "temple",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__11"
        },
        {
          "value": "lips",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__12"
        }
      ]
    },
    {
      "type": "color",
      "id": "pattern_color",
      "label": "t:settings_schema.widgets.color_swatches.option_name.default",
      "default": "#A52A2A",
      "visible_if": "{{ section.settings.pattern_bg != 'none' }}"
    },
    {
      "type": "range",
      "id": "pattern_size",
      "min": 4,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:general.settings.size.label",
      "default": 20,
      "visible_if": "{{ section.settings.pattern_bg != 'none' and section.settings.pattern_bg != 'formal-invitation' }}"
    },
    {
      "type": "range",
      "id": "pattern_size_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "t:settings_schema.global.settings.dimension.label",
      "default": 1,
      "visible_if": "{{ section.settings.pattern_bg == 'formal-invitation' or section.settings.pattern_bg == 'radial-rings' }}"
    },
    {
      "type": "range",
      "id": "pattern_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:settings_schema.global.settings.bubble.opacity",
      "default": 50,
      "visible_if": "{{ section.settings.pattern_bg != 'none' }}"
    },
    {
      "type": "header",
      "content": "t:sections.dbtfy-breadcrumbs.settings.show_icons_on.options__1.label",
      "visible_if": "{{ section.settings.show_on != 'mobile-only' }}"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "t:sections.collage.settings.desktop_layout.label",
      "default": "horizontal",
      "options": [
        {
          "value": "horizontal",
          "label": "t:general.settings.alignment.option__10"
        },
        {
          "value": "vertical",
          "label": "t:general.settings.alignment.option__11"
        }
      ],
      "visible_if": "{{ section.settings.show_on != 'mobile-only' }}"
    },
    {
      "type": "header",
      "content": "t:general.settings.slider.slider_settings"
    },
    {
      "type": "select",
      "id": "slider_on",
      "default": "mobile",
      "label": "t:general.settings.slider.Enable_slider",
      "options": [
        {
          "value": "mobile",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "default": false,
      "label": "t:general.settings.slider.enable_autoplay",
      "visible_if": "{{ section.settings.slider_on != 'none' }}"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:general.settings.slider.autoplay_speed",
      "default": 5,
      "min": 3,
      "max": 8,
      "step": 1,
      "unit": "s",
      "visible_if": "{{ section.settings.enable_autoplay and section.settings.slider_on != 'none' }}"
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "default": true,
      "label": "Loop",
      "info": "Continue from the last slide to the first slide",
      "visible_if": "{{ section.settings.slider_on != 'none' }}"
    },
    {
      "type": "checkbox",
      "id": "enable_dots",
      "default": true,
      "label": "t:general.settings.slider.show_dots",
      "visible_if": "{{ section.settings.slider_on != 'none' }}"
    },
    {
      "type": "checkbox",
      "id": "enable_arrows",
      "default": true,
      "label": "t:general.settings.slider.show_arrows",
      "visible_if": "{{ section.settings.slider_on != 'none' }}"
    },
    {
      "type": "select",
      "id": "arrow_position",
      "default": "bottom",
      "label": "t:sections.dbtfy-before-and-after.settings.arrow_position.label",
      "options": [
        {
          "value": "middle",
          "label": "t:general.settings.alignment.option__2"
        },
        {
          "value": "bottom",
          "label": "t:general.settings.alignment.option__3"
        }
      ],
      "visible_if": "{{ section.settings.enable_arrows and section.settings.slider_on != 'none' }}"
    },
    {
      "type": "select",
      "id": "arrow_color",
      "default": "inherit",
      "label": "t:general.settings.slider.arrow_color",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ],
      "visible_if": "{{ section.settings.enable_arrows and section.settings.slider_on != 'none' }}"
    },
    {
      "type": "color",
      "id": "custom_arrow_color",
      "label": "t:general.settings.slider.custom-arrow-color",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.enable_arrows and section.settings.slider_on != 'none'}}"
    },
    {
      "type": "color",
      "id": "custom_arrow_background_color",
      "label": "t:general.settings.slider.custom-arrow-bg-color",
      "default": "#7559ff",
      "visible_if": "{{ section.settings.enable_arrows and section.settings.slider_on != 'none' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.color_schemes.header.heading.label",
      "info": "t:sections.all.color_schemes.header.info.content"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.all.color_schemes.default.label",
      "options": [
        {
          "value": "scheme-1",
          "label": "t:sections.all.color_schemes.default.options__1.label"
        },
        {
          "value": "scheme-2",
          "label": "t:sections.all.color_schemes.default.options__2.label"
        },
        {
          "value": "scheme-3",
          "label": "t:sections.dbtfy_text_col_with_img.settings.background_style.label"
        },
        {
          "value": "scheme-4",
          "label": "t:sections.all.color_schemes.default.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ],
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "custom_color_scheme",
      "label": "t:sections.all.color_schemes.custom.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:settings_schema.layout.settings.spacing.section_desktop.label"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.top",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_top",
      "default": 36
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.bottom",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-on.name",
      "blocks": [
        {
          "type": "_title",
          "static": true,
          "id": "title",
          "settings": {
            "title": "Featured On",
            "alignment": "text-center",
            "padding___top": "custom",
            "custom_padding_top": 0,
            "padding___bottom": "custom",
            "custom_padding_bottom": 0
          }
        },
        {
          "type": "_dbtfy-featured-on",
          "static": true,
          "id": "logos",
          "blocks": [
            { "type": "_dbtfy-featured-on-block" },
            { "type": "_dbtfy-featured-on-block" },
            { "type": "_dbtfy-featured-on-block" },
            { "type": "_dbtfy-featured-on-block" },
            { "type": "_dbtfy-featured-on-block" }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
