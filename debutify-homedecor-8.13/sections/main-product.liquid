{% if settings.dbtfy_recently_viewed %}
  <dbtfy-recently-viewed-badge data-product-url="{{product.url }}" />
{% endif %}

{% style %}
  #MainProduct-{{ section.id }} {
    .price--on-sale {
      display: flex;
      align-items: center;
    }

    .dbtfy-sold-out-badge {
      flex-shrink: 0;
    }

    .dbtfy-sale-badge {
      flex-shrink: 0;
    }
   }

  {% if section.settings.arrow_color == 'custom'  %}
    #MainProduct-{{ section.id }} .slider-button svg path {
      --color-button-text: {{ section.settings.custom_arrow_color }};
      fill: var(--color-button-text);
    }

    #MainProduct-{{ section.id }} .slider-button svg {
      --color-button: {{ section.settings.custom_arrow_background_color }};
      background-color: var(--color-button)
    }
  {% endif %}

  {% if section.settings.add_to_cart_position %}
    .addtocart_and_selector_wrapper {
      display: flex;
      gap: 1rem;
      align-items: flex-end;
    }
    .product-form-buy-button .product-form__input{
      flex:unset;
      max-width: unset;
      min-width:unset;
      margin-bottom: 10px;
    }

    @media screen and (max-width: 575px) {
      .quantity {
        width: calc(11rem / var(--font-body-scale) + var(--inputs-border-width) * 2);
      }
    }
  {% endif %}
{% endstyle %}

{%- liquid
  render 'custom-arrow-style'
  capture block_content
    content_for 'blocks'
  endcapture

  render 'main-product', product: product, url_should_update: settings.product_grid_enable_history_state, block_content: block_content
-%}

