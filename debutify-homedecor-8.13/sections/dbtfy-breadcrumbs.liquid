{%- render 'widget-blocker',
  enabled: settings.dbtfy_breadcrumbs,
  section: section,
  name: 'Breadcrumbs',
  type: '⚡ Paid Sections'
-%}
{%- if request.design_mode or settings.dbtfy_breadcrumbs -%}
  {{ 'dbtfy-breadcrumbs.css' | asset_url | stylesheet_tag: preload: true }}

  {%- render 'section-padding', section: section -%}

  {% if section.settings.pattern_bg != 'none' %}
    {% render 'dbtfy-background-pattern', setting: section.settings %}
  {% endif %}

  {%- unless request.page_type == 'index'
    or request.page_type == 'cart'
    or request.page_type == 'list-collections'
    or request.page_type == '404'
  -%}
    <dbtfy-breadcrumbs>
      {%- liquid
        assign social_share_title = section.settings.social_share_title

        if section.settings.share_on_facebook == true
          assign facebook = true
        endif
        if section.settings.share_on_messenger == true
          assign messenger = true
        endif
        if section.settings.tweet_on_twitter == true
          assign twitter = true
        endif
        if section.settings.pin_on_pinterest == true
          assign pinterest = true
        endif
        if section.settings.share_on_linkedin == true
          assign linkedin = true
        endif
        if section.settings.share_on_reddit == true
          assign reddit = true
        endif
        if section.settings.share_on_whatsapp == true
          assign whatsapp = true
        endif
        if section.settings.share_on_email == true
          assign email = true
        endif
      -%}

      {%- assign template_name = request.page_type | split: '.' | first -%}

      {%- capture separator -%}
      <li>
        {% render 'material-icon', icon: 'Chevron Right' %}
      </li>                 
     {%- endcapture -%}
      <div
        class="show-on--{{section.settings.show_on}}"
      >
        <div
          class="color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding dbtfy-background-pattern-{{ section.id }}"
        >
          <div class="page-width">
            <div class="dbtfy-breadcrumbs d-grid">
              <div
                class="
                  dbtfy-breadcrumbs-list dbtfy-breadcrumbs-menu-icons
                  {% if section.settings.show_social_media_icons == "mobile-only" %}
                  grid--12-col
                  {% else %}
                  grid--9-col-desktop
                  grid--7-col-tablet
                  grid--12-col
                  {% endif %}
                "
              >
                <ul>
                  <li>
                    <a href="{{ routes.root_url }} "> {% render 'material-icon', icon: 'home' %} </a>
                  </li>
                  {{- separator -}}
                  {%- case template_name -%}
                    {%- when 'page' -%}
                      <li class="dbtfy-breadcrumbs-title">
                        {{ 'templates.search.page' | t }}
                      </li>
                      {{- separator -}}
                      <li class="dbtfy-breadcrumbs-title">
                        <a href="{{ page.url }}" aria-current="page"> {{ page.title }}</a>
                      </li>

                    {%- when 'product' -%}
                      <li>
                        {%- if collection.url -%}
                          <a href="{{ collection.url }}" aria-current="page">
                            {{ collection.title | capitalize }}
                          </a>
                        {% else %}
                          <a href="{{ routes.all_products_collection_url }}" aria-current="page">
                            {{ template_name | capitalize }}
                          </a>
                        {%- endif -%}
                      </li>
                      {{- separator -}}
                      <li class="dbtfy-breadcrumbs-title">
                        <a href="{{ product.url }}" aria-current="page">{{ product.title | capitalize }}</a>
                      </li>

                    {%- when 'collection' -%}
                      <li>
                        <a href="{{ routes.collections_url }}" aria-current="page">
                          {{ template_name | capitalize }}
                        </a>
                      </li>
                      {{- separator -}}
                      <li class="dbtfy-breadcrumbs-title">
                        <a href="{{ collection.url }}" aria-current="page">{{ collection.title | capitalize }}</a>
                      </li>

                    {%- when 'blog' -%}
                      <li class="dbtfy-breadcrumbs-title">
                        {{ template_name | capitalize }}
                      </li>
                      {{- separator -}}
                      <li class="dbtfy-breadcrumbs-title">
                        <a href="{{ blog.url }}" aria-current="page">{{ blog.title }}</a>
                      </li>

                    {%- when 'article' -%}
                      <li class="dbtfy-breadcrumbs-title">
                        {{ template_name | capitalize }}
                      </li>
                      {{- separator -}}
                      <li class="dbtfy-breadcrumbs-title">
                        <a href="{{ article.url }}" aria-current="page">{{ article.title }}</a>
                      </li>
                  {%- endcase -%}
                </ul>
              </div>
              {% if facebook or messenger or twitter or pinterest or linkedin or whatsapp or email %}
                <div class="dbtfy-breadcrumbs-list dbtfy-breadcrumbs-list-social grid--3-col-desktop grid--5-col-tablet grid--12-col show-on--{{ section.settings.show_social_media_icons }}">
                  <ul class="">
                    <li>{% render 'material-icon', icon: 'Share' %}</li>
                    <li>Share</li>
                    <li>
                      {%- render 'social-sharing',
                        facebook: facebook,
                        messenger: messenger,
                        twitter: twitter,
                        pinterest: pinterest,
                        linkedin: linkedin,
                        whatsapp: whatsapp,
                        reddit: reddit,
                        email: email,
                        title: social_share_title
                      -%}
                    </li>
                  </ul>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </dbtfy-breadcrumbs>
  {%- endunless -%}
{%- endif -%}

{% schema %}
{
  "name": "t:sections.dbtfy-breadcrumbs.name",
  "disabled_on": { "groups": ["aside"] },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.dbtfy-breadcrumbs.settings.enabled.info"
    },
    {
      "type": "header",
      "content": "t:blocks.help.header"
    },
    {
      "type": "paragraph",
      "content": "t:sections.dbtfy-breadcrumbs.settings.enabled.link"
    },
    {
      "type": "paragraph",
      "content": "t:help.free_info"
    },
    {
      "type": "header",
      "content": "t:general.settings.settigns"
    },
    {
      "type": "select",
      "id": "show_on",
      "label": "t:sections.all.show_on.label",
      "options": [
        {
          "value": "desktop-only",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile-only",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "show_social_media_icons",
      "label": "t:sections.dbtfy-breadcrumbs.settings.show_icons_on.label",
      "default": "both",
      "options": [
        {
          "value": "desktop-only",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile-only",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:settings_schema.social-media.settings.header"
    },
    {
      "type": "checkbox",
      "id": "share_on_facebook",
      "label": "t:settings_schema.social-media.settings.social_facebook_link.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "share_on_messenger",
      "label": "t:settings_schema.social-media.settings.social_messenger_link.label",
      "default": false,
      "info": "t:settings_schema.social-media.settings.social_messenger_link.messanger_mobile_only"
    },
    {
      "type": "checkbox",
      "id": "tweet_on_twitter",
      "label": "t:settings_schema.social-media.settings.social_twitter_link.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "pin_on_pinterest",
      "label": "t:settings_schema.social-media.settings.social_pinterest_link.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "share_on_whatsapp",
      "label": "t:settings_schema.social-media.settings.social_whatsapp_link.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "share_on_linkedin",
      "label": "t:settings_schema.social-media.settings.social_linkedin_link.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "share_on_reddit",
      "label": "t:settings_schema.social-media.settings.social_reddit_link.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "share_on_email",
      "label": "t:settings_schema.social-media.settings.social_email_link.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.bubble.background_pattern_settings.label"
    },
    {
      "type": "select",
      "id": "pattern_bg",
      "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.pattern",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "curved-grid",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__1"
        },
        {
          "value": "radial-rings",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__2"
        },
        {
          "value": "diamond-grid",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__3"
        },
        {
          "value": "quatrefoils",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__4"
        },
        {
          "value": "hexagons",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__5"
        },
        {
          "value": "intersecting-circles",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__6"
        },
        {
          "value": "brick-wall",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__7"
        },
        {
          "value": "formal-invitation",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__8"
        },
        {
          "value": "jupiter",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__9"
        },
        {
          "value": "yyy",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__10"
        },
        {
          "value": "temple",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__11"
        },
        {
          "value": "lips",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__12"
        }
      ]
    },
    {
      "type": "color",
      "id": "pattern_color",
      "label": "t:settings_schema.widgets.color_swatches.option_name.default",
      "default": "#A52A2A",
      "visible_if": "{{ section.settings.pattern_bg != 'none' }}"
    },
    {
      "type": "range",
      "id": "pattern_size",
      "min": 4,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:general.settings.size.label",
      "default": 20,
      "visible_if": "{{ section.settings.pattern_bg != 'none' and section.settings.pattern_bg != 'formal-invitation' }}"
    },
    {
      "type": "range",
      "id": "pattern_size_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "t:settings_schema.global.settings.dimension.label",
      "default": 1,
      "visible_if": "{{ section.settings.pattern_bg == 'formal-invitation' or section.settings.pattern_bg == 'radial-rings' }}"
    },
    {
      "type": "range",
      "id": "pattern_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:settings_schema.global.settings.bubble.opacity",
      "default": 50,
      "visible_if": "{{ section.settings.pattern_bg != 'none' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.color_schemes.header.heading.label",
      "info": "t:sections.all.color_schemes.header.info.content"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.all.color_schemes.default.label",
      "options": [
        {
          "value": "scheme-1",
          "label": "t:sections.all.color_schemes.default.options__1.label"
        },
        {
          "value": "scheme-2",
          "label": "t:sections.all.color_schemes.default.options__2.label"
        },
        {
          "value": "scheme-3",
          "label": "t:sections.dbtfy_text_col_with_img.settings.background_style.label"
        },
        {
          "value": "scheme-4",
          "label": "t:sections.all.color_schemes.default.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ],
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "custom_color_scheme",
      "label": "t:sections.all.color_schemes.custom.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:settings_schema.layout.settings.spacing.section_desktop.label"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.top",
      "default": "small",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_top",
      "default": 36
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.bottom",
      "default": "small",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.dbtfy-breadcrumbs.name"
    }
  ]
}
{% endschema %}
