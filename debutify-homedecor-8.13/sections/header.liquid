{%- render 'widget-settings', key: 'header', settings: section.settings -%}

<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}


<style>
  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }
  {% if section.settings.menu_center and section.settings.logo_position == "middle-left" %}
    .header_menu_center nav{
      text-align: center;
    }
    
    .header_menu_center nav ul{
      justify-content: center;
    }

    @media screen and (min-width: 990px) {
      .header_menu_center .header--middle-left {
          grid-template-columns: auto auto auto;
      }
    }
 {% endif %}
  {% if section.settings.sticky_header_type != "none" %}
    .dbtfy-header:not(.shopify-section-header-hidden){
        top: var(--height-header);
    }

    {%- liquid
      assign is_header_transparent = false
      if section.settings.header_transparent and request.page_type == 'index'
        assign is_header_transparent = true
     elsif section.settings.collection_header_transparent and request.page_type == 'collection'
        assign is_header_transparent = true
      endif
    -%}

    .template-index .dbtfy-header.header--transparent:not(.scrolled-past-header) .header-wrapper,
    .template-collection .dbtfy-header.header--transparent:not(.scrolled-past-header) .header-wrapper,
    .dbtfy-header--transparent{
        background: transparent;
    }
  {% endif %}

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
  .list-menu {
    {% if section.settings.menu_text_bold_mobile == true %}
      font-weight: bold;
    {% endif %}
    }

  {% if section.settings.select_menu_text_type_mobile == 'custom' %}  
    header nav ul li {
      .link.font-size-custom {
        font-size: {{ section.settings.menu_text_size_mobile }}px;
      }

      .link.dropdown-font-size {
        font-size: calc({{ section.settings.menu_text_size_mobile }}px - 3px);
      }

      .link.dropdown-font-size-level-2 {
        font-size: calc({{ section.settings.menu_text_size_mobile }}px - 6px);
      }
    }
  {% endif %}
  }

  @media screen and (min-width: 768px) {
  .list-menu {
    {% if section.settings.menu_text_bold == true %}
      font-weight: bold;
    {% endif %}
    }

  {% if section.settings.select_menu_text_type == 'custom' %}
    header nav ul mega-menu-item .mega-menu .header__menu-item {
      font-size: {{ section.settings.menu_text_size }}px;
    }
    header nav ul li {
      .link.font-size-custom {
        font-size: {{ section.settings.menu_text_size }}px;
      }

      .link.dropdown-font-size {
        font-size: calc({{ section.settings.menu_text_size }}px - 5px);
      }

      .link.dropdown-font-size-level-2 {
        font-size: calc({{ section.settings.menu_text_size }}px - 8px);
      }
    }
  {% endif %}
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }
  .dbtfy-quick-compare-count {
    {% liquid 
      if settings.dbtfy_quick_compare_bubble_background_color == "inherit"
        assign dbtfy_cart_bubble_background_color = "rgb(var(--color-foreground))"
      else
        assign dbtfy_cart_bubble_background_color = settings.dbtfy_quick_compare_bubble_background_color_custom
      endif

      if settings.dbtfy_quick_compare_bubble_border_color == "inherit"
        assign dbtfy_cart_bubble_border_color = "rgb(var(--color-background))"
      else
        assign dbtfy_cart_bubble_border_color = settings.dbtfy_quick_compare_bubble_border_color_custom
      endif
    %}
    --dbtfy-quick-compare-bubble-background-color: {{ dbtfy_cart_bubble_background_color }};
    --dbtfy-quick-compare-bubble-border-color: {{ dbtfy_cart_bubble_border_color }};
    opacity: {{ settings.dbtfy_quick_compare_bubble_opacity }}%;
  }

  .cart-count-bubble {
    {% liquid 
      if settings.dbtfy_cart_bubble_background_color == "inherit"
        assign dbtfy_cart_bubble_background_color = "rgb(var(--color-foreground))"
      else
        assign dbtfy_cart_bubble_background_color = settings.dbtfy_cart_bubble_background_color_custom
      endif
      if settings.dbtfy_cart_bubble_border_color == "inherit"
        assign dbtfy_cart_bubble_border_color = "rgb(var(--color-background))"
      else
        assign dbtfy_cart_bubble_border_color = settings.dbtfy_cart_bubble_border_color_custom
      endif
    %}
    --dbtfy-cart-bubble-background-color: {{ dbtfy_cart_bubble_background_color }};
    --dbtfy-cart-bubble-border-color: {{ dbtfy_cart_bubble_border_color }};
    opacity: {{ settings.dbtfy_cart_bubble_opacity }}%;
  }

  .wishlist-count-bubble{
    {% liquid
      if settings.dbtfy_wish_list_bubble_background_color == "inherit"
        assign dbtfy_wish_list_bubble_background_color = "rgb(var(--color-foreground))"
      else
        assign dbtfy_wish_list_bubble_background_color = settings.dbtfy_wish_list_bubble_background_color_custom
      endif

      if settings.dbtfy_wish_list_bubble_border_color == "inherit"
        assign dbtfy_wish_list_bubble_border_color = "rgb(var(--color-background))"
      else
        assign dbtfy_wish_list_bubble_border_color = settings.dbtfy_wish_list_bubble_border_color_custom
      endif

    %}

    --dbtfy-wishlist-bubble-background-color: {{ dbtfy_wish_list_bubble_background_color }};
    --dbtfy-wishlist-bubble-border-color: {{ dbtfy_wish_list_bubble_border_color }};
    opacity:{{ settings.dbtfy_wish_list_bubble_opacity }}%;
  } 
</style>

{% render 'section-padding', section: section, setup_variable: true %}
{% if section.settings.pattern_bg != 'none' and section.settings.header_transparent == false %}
  {% render 'dbtfy-background-pattern', setting: section.settings %}
{% endif %}
{%- style -%}
  .header {
    padding: var(--section-padding-top) 3rem var(--section-padding-bottom) 3rem;
  }

  .section-header {
    position: sticky; /* This is for fixing a Safari z-index issue. PR #2147 */
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  .header--transparent .header-transparent-logo,
  .header--transparent.scrolled-past-header .header__heading-logo-wrapper:not(.header-transparent-none) .header-logo{
    display: block;
  }

  .header-transparent-logo,
  .header--transparent.scrolled-past-header .header-transparent-logo,
  .header--transparent .header__heading-logo-wrapper:not(.header-transparent-none) .header-logo{
    display: none;
  }

  .header-text-width {
    width: fit-content;
    margin-right: 5px;
    margin-left: 5px;
  }

  .header__icon--search,
  .header__icon--account,
  .header__icon--cart,
  .header__icon--localization,
  .header__icon--wishlist,
  .header__icon--compare, {
    width: auto;
  }
  
  .header__icon--search{
    font-size: 14px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }};
    }
  }

  @media screen and (min-width: 990px) {

    .header {
      padding-top: var(--section-padding-top);
      padding-bottom: var(--section-padding-bottom);
    }

    .header-mobile-logo{
      display: none!important;
    }

    .header--transparent .header-transparent-mobile-logo{
      display: none!important;
    }
   
  }

  {% if settings.mobile_logo != blank %}
    @media (max-width:989px){
       .header-desktop-logo{
        display: none!important;
      }
    }
  {% endif %}

  {% if settings.transparent_mobile_logo != blank %}
    @media (max-width:989px){
      .header--transparent .header-transparent-desktop-logo{
        display: none!important;
      }
    }
  {% endif %}

  @media (max-width:575px){
    .header{
      padding-left: 13px;
      padding-right: 13px;
    }
    #menu-drawer.mobile-width-partial{
      width: 90vw;
    }
  }
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{%- liquid
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}
{%- if section.settings.sticky_header_type != 'none' -%}
  {%- render 'widget-blocker',
    enabled: settings.dbtfy_sticky_header,
    section: section,
    name: 'Sticky header',
    type: '💎 Professional Widget / sections'
  -%}
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  {%- render 'widget-blocker',
    enabled: settings.dbtfy_mega_menu,
    section: section,
    name: 'Mega Menu',
    type: '💎 Professional Widget / sections'
  -%}
{%- endif -%}

<script>
  var header_loaded = true;
</script>

{% if is_header_transparent %}
  {% style %}
  body:not(.header-loaded) sticky-header {
    position: absolute;
    width: 100%;
  }

    body #MainContent [id^='shopify-section']:first-child .first-section-mobile-padding {
      padding-top: 15vh;
    }

    @media (min-width:750px){
      body #MainContent [id^='shopify-section']:first-child .first-section-desktop-padding {
        padding-top: 15vh;
      }
    }

  @media (max-width: 749px) {
    body #MainContent [id^='shopify-section']:first-child .first-section-mobile-padding {
      padding-top: 10vh;
    }
  }
  {% endstyle %}
{% endif %}

<{% if section.settings.sticky_header_type != 'none' %}sticky-header data-color-scheme="{{ section.settings.color_scheme }}" data-custom-color-scheme="{{ section.settings.custom_color_scheme }}" data-transparent-header-color-scheme="{{ section.settings.transparent_header_color_scheme }}" data-custom-transparent-header-color-scheme="{{ section.settings.custom_transparent_header_color_scheme }}" data-sticky-type="{{ section.settings.sticky_header_type }}"{% else %}div{% endif %} class="header-wrapper {% unless is_header_transparent  %} color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} {% endunless %} {% if is_header_transparent  %} dbtfy-header--transparent dbtfy-color-{{ section.settings.transparent_header_color_scheme }} {% endif %} {% if is_header_transparent and section.settings.sticky_header_type == "none" %} color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} {% endif %} {% if settings.dbtfy_sticky_header == false and request.page_type == "index" %} color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} {% endif %}gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %} {% if section.settings.menu_center %}header_menu_center{% endif %} dbtfy-background-pattern-{{ section.id }}">
  {%- liquid
    assign social_links = false
    assign localization_forms = false

    if settings.social_twitter_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_tiktok_link != blank or settings.social_tumblr_link != blank or settings.social_snapchat_link != blank
      assign social_links = true
    endif

    if localization.available_countries.size >= 1 and section.settings.enable_country_selector or section.settings.enable_language_selector and localization.available_languages.size >= 1
      assign localization_forms = true
    endif
    if localization.available_countries.size >= 1 and section.settings.enable_country_selector_mobile or section.settings.enable_language_selector_mobile and localization.available_languages.size >= 1
      assign localization_forms = true
    endif
    
    assign mega_menu_blocks = section.blocks | where: 'type', 'mega' | map: 'settings' | sort: 'link_position'

    assign allow_localization = false
    assign desktop_localization_country = "medium-hide large-up-hide"
    assign mobile_localization_country= "small-hide"
    assign desktop_localization_language = "medium-hide large-up-hide"
    assign mobile_localization_language = "small-hide"

    assign desktop_localization = "medium-hide large-up-hide"
    assign mobile_localization = "small-hide"

    if section.settings.enable_country_selector and localization.available_countries.size >= 1
      assign desktop_localization = ""
      assign allow_localization = true
      assign desktop_localization_country = ""
    endif
    if section.settings.enable_language_selector and localization.available_languages.size >= 1
      assign desktop_localization = ""
      assign allow_localization = true
      assign desktop_localization_language = ""
    endif
    if section.settings.enable_country_selector_mobile and localization.available_countries.size >= 1
      assign mobile_localization = ""
      assign allow_localization = true
      assign mobile_localization_country = ""
    endif
    if section.settings.enable_language_selector_mobile and localization.available_languages.size >= 1
      assign mobile_localization = ""
      assign allow_localization = true
      assign mobile_localization_language = ""
    endif


  -%}

  <header class="header header--{{ section.settings.logo_position }} header--mobile-{{ section.settings.mobile_logo_position }} page-width   {% if section.settings.menu_type_desktop == "mega" %} {{ section.settings.menu_type_desktop }} {% endif %} {% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank or mega_menu_blocks.size > 0 %} header--has-menu{% endif %}{% if has_app_block %} header--has-app{% endif %}{% if social_links %} header--has-social{% endif %}{% if shop.customer_accounts_enabled %} header--has-account{% endif %}{% if localization_forms %} header--has-localizations{% endif %}  {% if settings.dbtfy_sticky_header and is_header_transparent and section.settings.sticky_header_type != "none" %} header--transparent {% endif %} {% if section.settings.mobile_search %}mobile_search_right_side{% endif %}">
    <div class="header-drawer">
    {%- liquid
      if section.settings.menu != blank or section.settings.mobile_menu != 'blank'
        render 'header-drawer', desktop_localization_country: desktop_localization_country, mobile_localization_country: mobile_localization_country , desktop_localization_language: desktop_localization_language, mobile_localization_language: mobile_localization_language
      endif

      if section.settings.show_searchbar
        render 'header-search', input_id: 'Search-In-Modal-1'
      endif
      if section.settings.logo_position == 'top-center' or section.settings.menu == blank
      endif
      -%}
    </div>

    {%- if section.settings.logo_position != 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
      {% render "header-logo" %}
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    {%- endif -%}

    {%- liquid
      if section.settings.menu != blank
        if section.settings.menu_type_desktop == 'dropdown'
          render 'header-dropdown-menu'
        elsif section.settings.menu_type_desktop != 'drawer'
          render 'header-mega-menu'
        endif
      else
        render 'header-mega-menu'
      endif
    %}

    {%- if section.settings.logo_position == 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
      {% render "header-logo" %}
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    {%- endif -%}

    <div class="header__icons {% if section.settings.enable_country_selector or section.settings.enable_language_selector or section.settings.enable_country_selector_mobile or section.settings.enable_language_selector_mobile %} header__icons--localization header-localization{% endif %}">

      {%- if allow_localization -%}
        <header-menu data-hover="true">
          <details>
            <summary
              class="header__icon header__icon--localization {{ desktop_localization }} {{ mobile_localization  }} {% if section.settings.show_localization_text_icon == 'text' %} header-text-width {% endif %}"
            >
            {% if section.settings.show_localization_text_icon == 'text' %}
               {{ localization.country.name }}/{{ localization.language.name }}
            {%  elsif section.settings.show_localization_text_icon == 'icon' %}              
              {% render 'material-icon', icon: 'language' %}
            {% endif %}
            </summary>
            <div
              class="header__localization-dropdown header__submenu list-menu list-menu--disclosure caption-large motion-reduce global-settings-popup"
              tabindex="-1"
            >
              <div class="desktop-localization-wrapper">
                {%- if section.settings.enable_country_selector or section.settings.enable_country_selector_mobile -%}
                  <localization-form data-prevent-hide class='{{ desktop_localization_country }} {{ mobile_localization_country }}'>
                    {%- form 'localization', id: 'HeaderCountryForm', class: 'localization-form' -%}
                      <div>
                        <h5 id="HeaderCountryLabel">{{ 'localization.country_label' | t }}</h5>
                        {%- render 'country-localization', localPosition: 'HeaderCountry' -%}
                      </div>
                    {%- endform -%}
                  </localization-form>
                {% endif %}
      
                {%- if section.settings.enable_language_selector or section.settings.enable_language_selector_mobile -%}
                  <localization-form data-prevent-hide class='{{ desktop_localization_language }} {{ mobile_localization_language }}'>
                    {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
                      <div>
                        <h5 id="HeaderLanguageLabel">{{ 'localization.language_label' | t }}</h5>
                        {%- render 'language-localization', localPosition: 'HeaderLanguage' -%}
                      </div>
                    {%- endform -%}
                  </localization-form>
                {%- endif -%}
              </div>
            </div>
          </details>
        </header-menu>
      {%- endif -%}
      {% if section.settings.show_searchbar %}
        {% render 'header-search', input_id: 'Search-In-Modal', section: section %}
      {% endif %}
      {% if settings.dbtfy_wish_list and section.settings.show_wishlist %}
        <a href="/pages/{{settings.dbtfy_wish_list_page}}" class="header__icon header__icon--wishlist link focus-inset relative small-hide {% if section.settings.show_wishlist_text_icon == 'text' %} header-text-width {% endif %}">
          {% render "dbtfy-wishlist" %}
        </a>
      {% endif %}
      {% if settings.dbtfy_quick_compare and section.settings.show_compare %}
        <a href="/pages/{{ settings.dbtfy_quick_compare_page }}" class="header__icon relative header__icon--compare link focus-inset small-hide {% if section.settings.show_compare_text_icon == 'text' %} header-text-width {% endif %}">
          {% render "dbtfy-quick-compare" %}
        </a>
      {% endif %}
      {%- if shop.customer_accounts_enabled -%}
          {%- if section.settings.enable_customer_avatar -%}
            <shopify-account menu="{{ section.settings.customer_account_menu }}">
              {%- if customer and customer.has_avatar? -%}
              {{ customer | avatar }}
              {%- else -%}    
                <a
                  href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
                  class="header__icon header__icon--account link focus-inset{% if section.settings.menu != blank %} small-hide{% endif %} {% if section.settings.show_account_text_icon == 'text' %} header-text-width {% endif %}"
                  rel="nofollow"
                >       
                  <span>
                    {% if section.settings.show_account_text_icon == 'text' %}
                      <span>{{ 'customer.account.title' | t }}</span>
                    {% else %}
                      {% render 'material-icon', icon: 'account_circle' %}
                    {% endif %}
                  </span>
                </a>
              {%- endif -%}
            </shopify-account>
          {%- else -%}
            <a
              href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
              class="header__icon header__icon--account link focus-inset{% if section.settings.menu != blank %} small-hide{% endif %} {% if section.settings.show_account_text_icon == 'text' %} header-text-width {% endif %}"
              rel="nofollow"
            > 
            <span>
              {% if section.settings.show_account_text_icon == 'text' %}
                <span>{{ 'customer.account.title' | t }}</span>
              {% else %}
                {% render 'material-icon', icon: 'account_circle' %}
              {% endif %}
            </span>
          </a>
          {%- endif -%}
          <span class="visually-hidden">
            {%- liquid
              if customer
                echo 'customer.account_fallback' | t
              else
                echo 'customer.log_in' | t
              endif
            -%}
          </span>
      {%- endif -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset {% if section.settings.show_cart_text_icon == 'text' %} header-text-width {% endif %}" id="cart-icon-bubble" data-type="{{ settings.cart_type }}">
        {% if section.settings.show_cart_text_icon == 'text' %}
        <span>
          <span>{{ 'templates.cart.cart' | t }}</span>
        {% elsif section.settings.show_cart_text_icon == 'icon' %}
        <span>
          {% render 'cart-icon-bubble' %}
        {% endif %}
        </span>
      </a>
    </div>
  </header>
</{% if section.settings.sticky_header_type != 'none' %}sticky-header{% else %}div{% endif %}>

{% if section.settings.menu_type_desktop == 'mega' and section.blocks.size > 0  %}
 
{% endif %}

{%- if settings.cart_type == "notification" -%}
  {%- render 'cart-notification', 
    color_scheme: section.settings.color_scheme,
    custom_color_scheme: section.settings.custom_color_scheme,
     desktop_menu_type: section.settings.menu_type_desktop 
     -%}
{%- endif -%}

{% javascript %}
  class StickyHeader extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      if(Debutify.settings.dbtfy_sticky_header == false) return;

      this.defaultColorScheme = "dbtfy-color-"+this.dataset.colorScheme;
      this.defaultCustomColorScheme = "color-"+this.dataset.customColorScheme;
      this.transparentColorScheme = "dbtfy-color-"+this.dataset.transparentHeaderColorScheme;
      this.transparentCustomColorScheme = "color-"+this.dataset.customTransparentHeaderColorScheme;
      
      this.header = document.querySelector('.section-header');
      this.headerIsAlwaysSticky = this.getAttribute('data-sticky-type') === 'always' || this.getAttribute('data-sticky-type') === 'reduce-logo-size';
      this.headerBounds = {};

      this.setHeaderHeight();

      window.matchMedia('(max-width: 990px)').addEventListener('change', this.setHeaderHeight.bind(this));

      if (this.headerIsAlwaysSticky) {
        this.header.classList.add('shopify-section-header-sticky');
      };

      if((Debutify.widgets.header.header_transparent && document.body.classList.contains('template-index')) || (Debutify.widgets.header.collection_header_transparent && document.body.classList.contains('template-collection'))){
        this.classList.add('dbtfy-header--transparent');
        this.classList.add(this.transparentColorScheme);
        this.classList.add(this.transparentCustomColorScheme);
      }

      this.currentScrollTop = 0;
      this.preventReveal = false;
      this.predictiveSearch = this.querySelector('predictive-search');

      this.onScrollHandler = this.onScroll.bind(this);
      this.hideHeaderOnScrollUp = () => this.preventReveal = true;

      this.addEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.addEventListener('scroll', this.onScrollHandler, false);

      this.createObserver();
    }

    setHeaderHeight() {
      document.documentElement.style.setProperty('--header-height', `${this.header.offsetHeight}px`);
    }

    disconnectedCallback() {
      this.removeEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.removeEventListener('scroll', this.onScrollHandler);
    }

    createObserver() {
      let observer = new IntersectionObserver((entries, observer) => {
        this.headerBounds = entries[0].intersectionRect;
        observer.disconnect();
      });

      observer.observe(this.header);
    }

    onScroll() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

      if (this.predictiveSearch && this.predictiveSearch.isOpen) return;

      if (scrollTop > this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (this.preventHide) return;
        requestAnimationFrame(this.hide.bind(this));
        
        if((Debutify.widgets.header.header_transparent && document.body.classList.contains('template-index')) || (Debutify.widgets.header.collection_header_transparent && document.body.classList.contains('template-collection'))){
          this.classList.add(this.defaultColorScheme,this.defaultCustomColorScheme);
          if(this.classList.contains("dbtfy-header--transparent")){
            this.classList.remove('dbtfy-header--transparent');
          }
         if(this.transparentColorScheme && this.transparentColorScheme !== this.defaultColorScheme){
            this.classList.remove(this.transparentColorScheme);
          }
          if (this.transparentCustomColorScheme && this.transparentCustomColorScheme !== this.defaultCustomColorScheme) {
            this.classList.remove(this.transparentCustomColorScheme);
          }
        }
        
      } else if (scrollTop < this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (!this.preventReveal) {
          requestAnimationFrame(this.reveal.bind(this));
        } else {
          window.clearTimeout(this.isScrolling);

          this.isScrolling = setTimeout(() => {
            this.preventReveal = false;
          }, 66);

          requestAnimationFrame(this.hide.bind(this));
        }
      } else if (scrollTop <= this.headerBounds.top) {

        if((Debutify.widgets.header.header_transparent && document.body.classList.contains('template-index')) || (Debutify.widgets.header.collection_header_transparent && document.body.classList.contains('template-collection'))){
          this.classList.add(this.transparentColorScheme,this.transparentCustomColorScheme,'dbtfy-header--transparent');
          if(this.defaultColorScheme && this.defaultColorScheme !== this.transparentColorScheme){
            this.classList.remove(this.defaultColorScheme);
          }
          if (this.defaultCustomColorScheme && this.defaultCustomColorScheme !== this.transparentCustomColorScheme) {
            this.classList.remove(this.defaultCustomColorScheme);
          }
        }

        this.header.classList.remove('scrolled-past-header');
        requestAnimationFrame(this.reset.bind(this));
      }
      this.currentScrollTop = scrollTop;
    }

    hide() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.add('shopify-section-header-hidden', 'shopify-section-header-sticky');
      this.closeMenuDisclosure();
      this.closeSearchModal();
    }

    reveal() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.add('shopify-section-header-sticky', 'animate');
      this.header.classList.remove('shopify-section-header-hidden');
    }

    reset() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.remove('shopify-section-header-hidden', 'shopify-section-header-sticky', 'animate');
    }

    closeMenuDisclosure() {
      this.disclosures = this.disclosures || this.header.querySelectorAll('header-menu');
      this.disclosures.forEach(disclosure => disclosure.close());
    }

    closeSearchModal() {
      this.searchModal = this.searchModal || this.header.querySelector('details-modal');
      this.searchModal.close(false);
    }
  }

  customElements.define('sticky-header', StickyHeader);
{% endjavascript %}

