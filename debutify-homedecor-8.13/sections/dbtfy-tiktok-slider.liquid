{%- if request.design_mode -%}
  {%- render 'widget-blocker',
    enabled: settings.dbtfy_tiktok_slider,
    section: section,
    name: 'TikTok Slider',
    type: '⚡ Paid Sections'
  -%}
{% endif %}

{% if request.design_mode or settings.dbtfy_tiktok_slider %}
  {% liquid
    capture slider_parameters
      echo ' data-autoplay="' | append: section.settings.enable_autoplay | append: '"'
      echo ' data-speed="' | append: section.settings.autoplay_speed | append: '"'
      echo ' data-loop="' | append: section.settings.enable_loop | append: '"'
      echo ' data-dots="' | append: section.settings.enable_dots | append: '"'
      echo ' data-arrows="' | append: section.settings.enable_arrows | append: '"'
    endcapture

    assign slider_on = 'slider slider--everywhere'
    if section.settings.slider_on == 'none'
      assign slider_on = ''
      assign slider_parameters = ''
    elsif section.settings.slider_on != 'both'
      assign slider_on = 'slider slider--' | append: section.settings.slider_on
    endif

    render 'custom-arrow-style'

    render 'section-padding', section: section
  %}

  {%- if section.settings.pattern_bg != 'none' -%}
    {%- render 'dbtfy-background-pattern', setting: section.settings -%}
  {%- endif -%}

  {{ 'dbtfy-tiktok-slider.css' | asset_url | stylesheet_tag }}
  <dbtfy-tiktok-slider>
    <div
      class="dbtfy-tiktok-slider color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} gradient show-on--{{section.settings.show_on}} dbtfy-background-pattern-{{ section.id }}"
      id="section-{{ section.id }}"
    >
      <div class="section-{{ section.id }}-padding {{ section.settings.container_size }}">
        <div>
          {% content_for 'block', type: '_cta_block', id: 'cta_block' %}
        </div>
        <div
          class="videos-wrapper {{ slider_on }}"
          {{ slider_parameters }}
        >
          {% capture inner_content %}
          {% content_for 'block', type: '_dbtfy-tiktok-videos', id: 'dbtfy-tiktok-video' %}
        {% endcapture %}

          {% render 'splide-slider-component',
            inner_content: inner_content,
            setting: section.settings,
            spacing_grid_horizontal_desktop: settings.spacing_grid_horizontal,
            video_slider: true,
            custom_icon: settings.custom_arrow_icon,
            icon: settings.arrow_icon
          %}
        </div>
      </div>
    </div>
  </dbtfy-tiktok-slider>
{% endif %}

{% schema %}
