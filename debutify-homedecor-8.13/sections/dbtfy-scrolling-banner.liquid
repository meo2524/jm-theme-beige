{%- if request.design_mode or settings.dbtfy_scrolling_banner -%}
  {%- render 'widget-blocker',
    enabled: settings.dbtfy_scrolling_banner,
    section: section,
    name: 'Scrolling Banner',
    type: '⚡ Paid Sections'
  -%}
  {%- render 'section-padding', section: section -%}

  {% if section.settings.pattern_bg != 'none' %}
    {% render 'dbtfy-background-pattern', setting: section.settings %}
  {% endif %}

  {%- style -%}
    .section-{{ section.id }}-padding ul.scrolling_banner_inner > li {
      padding-left: {{ section.settings.mobile_gap }}px;
      padding-right: {{ section.settings.mobile_gap }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding ul.scrolling_banner_inner > li {
        padding-left: {{ section.settings.gap }}px;
        padding-right: {{ section.settings.gap }}px;
      }
    }

    {% if section.settings.show_overlay %}
      dbtfy-scrolling-section #section-{{ section.id }} .overlay:after{
          background-color: rgba(var(--color-background), {{ section.settings.image_overlay_opacity | divided_by: 100.0 }});
      }
    {% endif %}
  {%- endstyle -%}

  {{ 'dbtfy-scrolling-banner.css' | asset_url | stylesheet_tag: preload: true }}
  <dbtfy-scrolling-section>
    <div
      class="color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding gradient relative show-on--{{ section.settings.show_on }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} dbtfy-background-pattern-{{ section.id }}"
      id="section-{{ section.id }}"
    >
      <div class="page-width relative">{% content_for 'block', type: '_heading', id: 'heading' %}</div>

      <dbtfy-scrolling-banner
        id="dbtfy-scrolling-banner-{{ section.id }}"
        class="dbtfy-scrolling-banner {% if section.settings.pause_on_hover %} enable_paused{% endif %}"
        data-section-id="{{ section.id }}"
        data-animation-duration="{{ section.settings.animation_duration }}"
        data-marquee-direction="{{ section.settings.marquee_direction }}"
      >
        {% content_for 'block', type: '_dbtfy-scrolling-banner', id: 'dbtfy-scrolling-banner' %}
      </dbtfy-scrolling-banner>

      {%- if section.settings.background_image != blank -%}
        <div class="media-wrapper media-wrapper--cover media-wrapper--center-center {% if section.settings.show_overlay %} overlay{% endif %} h-100 w-100 absolute">
          {{-
            section.settings.background_image
            | image_url: width: section.settings.background_image.width
            | image_tag:
              loading: 'lazy',
              sizes: '100vw',
              widths: '300,400,500,600,700,800,1000,1200,1400,1600,1800,2000,2200,2400,2600',
              class: 'media'
          -}}
        </div>
      {%- endif -%}
    </div>
  </dbtfy-scrolling-section>
  <script src="{{ 'dbtfy-scrolling-banner.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "t:sections.dbtfy-scrolling-banner.name",
  "tag": "section",
  "disabled_on": { "groups": ["aside"] },
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.dbtfy-scrolling-banner.help.info"
    },
    {
      "type": "header",
      "content": "t:blocks.help.header"
    },
    {
      "type": "paragraph",
      "content": "t:sections.dbtfy-scrolling-banner.help.link"
    },
    {
      "type": "paragraph",
      "content": "t:help.enterprise_info"
    },
    {
      "type": "header",
      "content": "t:general.settings.settigns"
    },
    {
      "type": "select",
      "id": "show_on",
      "label": "t:sections.all.show_on.label",
      "default": "both",
      "options": [
        {
          "value": "desktop-only",
          "label": "t:sections.all.show_on.options__1.label"
        },
        {
          "value": "mobile-only",
          "label": "t:sections.all.show_on.options__2.label"
        },
        {
          "value": "both",
          "label": "t:sections.all.show_on.options__3.label"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:blocks.age-check.settings.background_img.label"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "t:sections.image_banner.settings.show_overlay.label"
    },
    {
      "type": "range",
      "id": "image_overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "t:sections.double-image-banner.settings.image_overlay_opacity.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.dbtfy-scrolling-banner.scroll_setting.label"
    },
    {
      "type": "select",
      "id": "marquee_direction",
      "label": "t:sections.dbtfy-scrolling-banner.scroll_setting.direction_label",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "t:sections.dbtfy-scrolling-banner.scroll_setting.speed_label",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 10,
      "unit": "sec"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "t:sections.dbtfy-scrolling-banner.scroll_setting.pause_label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.dbtfy-scrolling-banner.spacing.label"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:sections.dbtfy-scrolling-banner.spacing.desktop_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "t:sections.dbtfy-scrolling-banner.spacing.mobile_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.bubble.background_pattern_settings.label"
    },
    {
      "type": "select",
      "id": "pattern_bg",
      "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.pattern",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "curved-grid",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__1"
        },
        {
          "value": "radial-rings",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__2"
        },
        {
          "value": "diamond-grid",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__3"
        },
        {
          "value": "quatrefoils",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__4"
        },
        {
          "value": "hexagons",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__5"
        },
        {
          "value": "intersecting-circles",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__6"
        },
        {
          "value": "brick-wall",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__7"
        },
        {
          "value": "formal-invitation",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__8"
        },
        {
          "value": "jupiter",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__9"
        },
        {
          "value": "yyy",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__10"
        },
        {
          "value": "temple",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__11"
        },
        {
          "value": "lips",
          "label": "t:settings_schema.global.settings.bubble.background_pattern_settings.option__12"
        }
      ]
    },
    {
      "type": "color",
      "id": "pattern_color",
      "label": "t:settings_schema.widgets.color_swatches.option_name.default",
      "default": "#A52A2A",
      "visible_if": "{{ section.settings.pattern_bg != 'none' }}"
    },
    {
      "type": "range",
      "id": "pattern_size",
      "min": 4,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:general.settings.size.label",
      "default": 20,
      "visible_if": "{{ section.settings.pattern_bg != 'none' and section.settings.pattern_bg != 'formal-invitation' }}"
    },
    {
      "type": "range",
      "id": "pattern_size_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "t:settings_schema.global.settings.dimension.label",
      "default": 1,
      "visible_if": "{{ section.settings.pattern_bg == 'formal-invitation' or section.settings.pattern_bg == 'radial-rings' }}"
    },
    {
      "type": "range",
      "id": "pattern_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:settings_schema.global.settings.bubble.opacity",
      "default": 50,
      "visible_if": "{{ section.settings.pattern_bg != 'none' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.color_schemes.header.heading.label",
      "info": "t:sections.all.color_schemes.header.info.content"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.all.color_schemes.default.label",
      "options": [
        {
          "value": "scheme-1",
          "label": "t:sections.all.color_schemes.default.options__1.label"
        },
        {
          "value": "scheme-2",
          "label": "t:sections.all.color_schemes.default.options__2.label"
        },
        {
          "value": "scheme-3",
          "label": "t:sections.dbtfy_text_col_with_img.settings.background_style.label"
        },
        {
          "value": "scheme-4",
          "label": "t:sections.all.color_schemes.default.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ],
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "custom_color_scheme",
      "label": "t:sections.all.color_schemes.custom.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:settings_schema.layout.settings.spacing.section_desktop.label"
    },
    {
      "type": "select",
      "id": "padding___top",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.top",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_top",
      "default": 36
    },
    {
      "type": "select",
      "id": "padding___bottom",
      "label": "t:settings_schema.layout.settings.spacing.block_padding.bottom",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:general.settings.size.option__1"
        },
        {
          "value": "none",
          "label": "t:settings_schema.global_settings.settings.add-to-cart-animation-effect.options__1"
        },
        {
          "value": "small",
          "label": "t:general.settings.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animation.image_behavior.parallax_speed.medium"
        },
        {
          "value": "large",
          "label": "t:sections.image_banner.settings.section_height_mobile.options__4.label"
        },
        {
          "value": "custom",
          "label": "t:general.settings.size.option__9"
        }
      ]
    },
    {
      "type": "range",
      "id": "custom_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding_section.custom_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.dbtfy-scrolling-banner.name",
      "blocks": [
        {
          "type": "_heading",
          "static": true,
          "id": "heading",
          "settings": {
            "padding___top": "none",
            "padding___bottom": "none"
          }
        },
        {
          "type": "_dbtfy-scrolling-banner",
          "static": true,
          "id": "dbtfy-scrolling-banner",
          "blocks": [{ "type": "_dbtfy-scrolling-banner_text" }, { "type": "_dbtfy-scrolling-banner_icon" }]
        }
      ]
    }
  ]
}
{% endschema %}
