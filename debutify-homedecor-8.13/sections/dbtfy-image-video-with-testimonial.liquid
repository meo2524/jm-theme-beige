{%- render 'widget-blocker',
  enabled: settings.image_video_with_testimonial,
  name: 'Image / Video with Testimonial',
  type: '⚡ Paid Sections'
-%}
{% if settings.image_video_with_testimonial or request.design_mode %}
  {%- liquid
    assign show_on = section.settings.show_on
    render 'section-padding', section: section
  -%}

  {%- if section.settings.pattern_bg != 'none' -%}
    {%- render 'dbtfy-background-pattern', setting: section.settings -%}
  {%- endif -%}

  {{ 'dbtfy-image-video-testimonial.css' | asset_url | stylesheet_tag }}

  <link rel="stylesheet" href="{{ 'video-section.css' | asset_url }}" media="print" onload="this.media='all'">

  <dbtfy-image-video-with-testimonial>
    <div class="section-{{ section.id }}-padding show-on--{{ show_on }} color-{{ section.settings.custom_color_scheme }} dbtfy-color-{{ section.settings.color_scheme }} gradient dbtfy-background-pattern-{{ section.id }}">
      <div class="{{ section.settings.container_size }}">
        <div class="grid grid--1-col grid--2-col-desktop  {% if section.settings.desktop == 'right' %} dbtfy-image-video-testimonials-grid--reverse{% endif %}{% if section.settings.mobile == 'bottom' %} dbtfy-image-video-testimonials-grid--bottom{% endif %}">
          <div class="grid__item">
            <div class="dbtfy-image-video-testimonial-media image-height--{{ section.settings.image_height }}">
              {% if section.settings.video_url != blank or section.settings.video != blank %}
                {% render 'dbtfy-video', settings: section.settings %}
              {% elsif section.settings.image != blank %}
                <div class="dbtfy-image-video-testimonial-image global-media-radius">
                  {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'w-full' }}
                </div>
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
            </div>
          </div>
          <div class="grid__item flex flex-column justify-content-center">
            {% content_for 'block', type: '_cta_block', id: 'cta_block' %}
            {% content_for 'block', type: '_dbtfy_image_video_testimonial', id: 'testimonial' %}
          </div>
        </div>
      </div>
    </div>
  </dbtfy-image-video-with-testimonial>
{% endif %}
{% schema %}
{
