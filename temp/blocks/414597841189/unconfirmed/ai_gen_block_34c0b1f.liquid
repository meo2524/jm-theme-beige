{% doc %}
  @prompt
    A video or image carousel. ALl the text and boxes need to work on mobile view as well hence the scaling needs to be top notch
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-carousel-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-carousel-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 32px;
  }

  .ai-carousel-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
  }

  .ai-carousel-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-carousel-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    gap: {{ block.settings.slide_gap }}px;
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    flex: 0 0 calc(100% / {{ block.settings.slides_per_view_desktop }} - {{ block.settings.slide_gap }}px * ({{ block.settings.slides_per_view_desktop }} - 1) / {{ block.settings.slides_per_view_desktop }});
    position: relative;
    border-radius: {{ block.settings.slide_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.slide_background }};
  }

  .ai-carousel-media-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.media_aspect_ratio }};
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-carousel-media-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-carousel-media-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-carousel-media-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-carousel-media-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-carousel-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-carousel-slide-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.slide_title_size }}px;
    color: {{ block.settings.slide_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-carousel-slide-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.slide_text_size }}px;
    color: {{ block.settings.slide_text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-carousel-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 32px;
  }

  .ai-carousel-button-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid {{ block.settings.button_border_color }};
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_color }};
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-carousel-button-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_color }};
    border-color: {{ block.settings.button_hover_background }};
  }

  .ai-carousel-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-carousel-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
    opacity: 0.3;
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc(100% / {{ block.settings.slides_per_view_tablet }} - {{ block.settings.slide_gap }}px * ({{ block.settings.slides_per_view_tablet }} - 1) / {{ block.settings.slides_per_view_tablet }});
    }

    .ai-carousel-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-carousel-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-carousel-slide-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.slide_title_size }}px * 0.9);
    }

    .ai-carousel-slide-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.slide_text_size }}px * 0.95);
    }

    .ai-carousel-content-{{ ai_gen_id }} {
      padding: calc({{ block.settings.content_padding }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc(100% - {{ block.settings.slide_gap }}px);
    }

    .ai-carousel-container-{{ ai_gen_id }} {
      padding-left: 16px;
      padding-right: 16px;
    }

    .ai-carousel-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.65);
    }

    .ai-carousel-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.85);
    }

    .ai-carousel-slide-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.slide_title_size }}px * 0.85);
    }

    .ai-carousel-slide-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.slide_text_size }}px * 0.9);
    }

    .ai-carousel-content-{{ ai_gen_id }} {
      padding: calc({{ block.settings.content_padding }}px * 0.7);
    }

    .ai-carousel-button-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-carousel-button-{{ ai_gen_id }} svg {
      width: 16px;
      height: 16px;
    }

    .ai-carousel-controls-{{ ai_gen_id }} {
      margin-top: 24px;
    }
  }
{% endstyle %}

<media-carousel-{{ ai_gen_id }} class="ai-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-carousel-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-carousel-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-carousel-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-carousel-track-{{ ai_gen_id }}" data-track>
        {% for i in (1..6) %}
          {% liquid
            assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
            assign slide_type_key = 'slide_' | append: i | append: '_type'
            assign slide_image_key = 'slide_' | append: i | append: '_image'
            assign slide_video_key = 'slide_' | append: i | append: '_video'
            assign slide_title_key = 'slide_' | append: i | append: '_title'
            assign slide_text_key = 'slide_' | append: i | append: '_text'

            assign slide_enabled = block.settings[slide_enabled_key]
            assign slide_type = block.settings[slide_type_key]
            assign slide_image = block.settings[slide_image_key]
            assign slide_video = block.settings[slide_video_key]
            assign slide_title = block.settings[slide_title_key]
            assign slide_text = block.settings[slide_text_key]
          %}

          {% if slide_enabled %}
            <div class="ai-carousel-slide-{{ ai_gen_id }}" data-slide>
              <div class="ai-carousel-media-{{ ai_gen_id }}">
                {% if slide_type == 'image' %}
                  {% if slide_image %}
                    <img
                      src="{{ slide_image | image_url: width: 800 }}"
                      alt="{{ slide_image.alt | escape }}"
                      loading="lazy"
                      width="800"
                      height="{{ 800 | divided_by: slide_image.aspect_ratio | round }}"
                    >
                  {% else %}
                    <div class="ai-carousel-media-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                {% elsif slide_type == 'video' %}
                  {% if slide_video %}
                    {{ slide_video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
                  {% else %}
                    <div class="ai-carousel-media-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                {% endif %}
              </div>

              {% if slide_title != blank or slide_text != blank %}
                <div class="ai-carousel-content-{{ ai_gen_id }}">
                  {% if slide_title != blank %}
                    <h3 class="ai-carousel-slide-title-{{ ai_gen_id }}">{{ slide_title }}</h3>
                  {% endif %}
                  {% if slide_text != blank %}
                    <p class="ai-carousel-slide-text-{{ ai_gen_id }}">{{ slide_text }}</p>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ai-carousel-controls-{{ ai_gen_id }}">
      <button
        class="ai-carousel-button-{{ ai_gen_id }}"
        data-prev
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-carousel-dots-{{ ai_gen_id }}" data-dots></div>

      <button
        class="ai-carousel-button-{{ ai_gen_id }}"
        data-next
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</media-carousel-{{ ai_gen_id }}>

<script>
(function() {
  class MediaCarousel{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.currentIndex = 0;
      this.slidesPerView = {{ block.settings.slides_per_view_desktop }};
      this.autoplayEnabled = {{ block.settings.autoplay }};
      this.autoplayInterval = {{ block.settings.autoplay_speed }} * 1000;
      this.autoplayTimer = null;
    }

    connectedCallback() {
      this.track = this.querySelector('[data-track]');
      this.slides = Array.from(this.querySelectorAll('[data-slide]'));
      this.prevButton = this.querySelector('[data-prev]');
      this.nextButton = this.querySelector('[data-next]');
      this.dotsContainer = this.querySelector('[data-dots]');

      if (this.slides.length === 0) return;

      this.updateSlidesPerView();
      this.createDots();
      this.updateCarousel();
      this.setupEventListeners();

      if (this.autoplayEnabled) {
        this.startAutoplay();
      }
    }

    disconnectedCallback() {
      this.stopAutoplay();
      window.removeEventListener('resize', this.handleResize);
    }

    setupEventListeners() {
      this.prevButton.addEventListener('click', () => this.prev());
      this.nextButton.addEventListener('click', () => this.next());

      this.handleResize = () => {
        this.updateSlidesPerView();
        this.updateCarousel();
      };
      window.addEventListener('resize', this.handleResize);

      if (this.autoplayEnabled) {
        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
      }
    }

    updateSlidesPerView() {
      const width = window.innerWidth;
      if (width <= 749) {
        this.slidesPerView = 1;
      } else if (width <= 989) {
        this.slidesPerView = {{ block.settings.slides_per_view_tablet }};
      } else {
        this.slidesPerView = {{ block.settings.slides_per_view_desktop }};
      }
    }

    createDots() {
      this.dotsContainer.innerHTML = '';
      const totalDots = Math.ceil(this.slides.length / this.slidesPerView);

      for (let i = 0; i < totalDots; i++) {
        const dot = document.createElement('button');
        dot.classList.add('ai-carousel-dot-{{ ai_gen_id }}');
        dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
        dot.addEventListener('click', () => this.goToSlide(i * this.slidesPerView));
        this.dotsContainer.appendChild(dot);
      }
    }

    updateCarousel() {
      const slideWidth = this.slides[0].offsetWidth;
      const gap = {{ block.settings.slide_gap }};
      const offset = -(this.currentIndex * (slideWidth + gap));

      this.track.style.transform = `translateX(${offset}px)`;

      this.updateButtons();
      this.updateDots();
    }

    updateButtons() {
      const maxIndex = Math.max(0, this.slides.length - this.slidesPerView);
      this.prevButton.disabled = this.currentIndex === 0;
      this.nextButton.disabled = this.currentIndex >= maxIndex;
    }

    updateDots() {
      const dots = this.dotsContainer.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');
      const activeDotIndex = Math.floor(this.currentIndex / this.slidesPerView);

      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === activeDotIndex);
      });
    }

    prev() {
      if (this.currentIndex > 0) {
        this.currentIndex = Math.max(0, this.currentIndex - this.slidesPerView);
        this.updateCarousel();
        this.resetAutoplay();
      }
    }

    next() {
      const maxIndex = Math.max(0, this.slides.length - this.slidesPerView);
      if (this.currentIndex < maxIndex) {
        this.currentIndex = Math.min(maxIndex, this.currentIndex + this.slidesPerView);
        this.updateCarousel();
        this.resetAutoplay();
      }
    }

    goToSlide(index) {
      const maxIndex = Math.max(0, this.slides.length - this.slidesPerView);
      this.currentIndex = Math.min(index, maxIndex);
      this.updateCarousel();
      this.resetAutoplay();
    }

    startAutoplay() {
      if (!this.autoplayEnabled) return;
      this.stopAutoplay();
      this.autoplayTimer = setInterval(() => {
        const maxIndex = Math.max(0, this.slides.length - this.slidesPerView);
        if (this.currentIndex >= maxIndex) {
          this.currentIndex = 0;
        } else {
          this.currentIndex = Math.min(maxIndex, this.currentIndex + this.slidesPerView);
        }
        this.updateCarousel();
      }, this.autoplayInterval);
    }

    stopAutoplay() {
      if (this.autoplayTimer) {
        clearInterval(this.autoplayTimer);
        this.autoplayTimer = null;
      }
    }

    resetAutoplay() {
      if (this.autoplayEnabled) {
        this.stopAutoplay();
        this.startAutoplay();
      }
    }
  }

  customElements.define('media-carousel-{{ ai_gen_id }}', MediaCarousel{{ ai_gen_id }});
})();
</script>

{% schema %}
{
  "name": "Media carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
