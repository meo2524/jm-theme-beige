{% doc %}
  @prompt
    I need a 1:1 before and after section with a horizontal scroll to scroll between the. before and after image.
    
    On mobile, i should be able to scroll through it, only horizontal movements should trigger the scroll.
    
    It should also have a heading on the top left and right of each image defaulted to Before and After but i should be able to set it dynamically via the edtior, The before and after should disappear if i slide over it if you know what I mean. Also, make sure the section scales with mobile, The Before and AFter block needs to disappear when i slide over it then reappear when i slide back
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-before-after-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-before-after-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    touch-action: pan-y pinch-zoom;
  }

  .ai-before-after-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
    pointer-events: none;
  }

  .ai-before-after-after-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    clip-path: inset(0 50% 0 0);
  }

  .ai-before-after-divider-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 50%;
    width: {{ block.settings.divider_width }}px;
    height: 100%;
    background-color: {{ block.settings.divider_color }};
    transform: translateX(-50%);
    cursor: ew-resize;
    z-index: 10;
  }

  .ai-before-after-handle-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    width: {{ block.settings.handle_size }}px;
    height: {{ block.settings.handle_size }}px;
    background-color: {{ block.settings.handle_color }};
    border: {{ block.settings.handle_border_width }}px solid {{ block.settings.handle_border_color }};
    border-radius: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .ai-before-after-handle-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    color: {{ block.settings.handle_icon_color }};
  }

  .ai-before-after-label-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.label_position_top }}px;
    padding: {{ block.settings.label_padding_vertical }}px {{ block.settings.label_padding_horizontal }}px;
    background-color: {{ block.settings.label_bg_color }};
    color: {{ block.settings.label_text_color }};
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: 600;
    border-radius: {{ block.settings.label_border_radius }}px;
    z-index: 5;
    pointer-events: none;
    user-select: none;
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }

  .ai-before-after-label-before-{{ ai_gen_id }} {
    left: {{ block.settings.label_position_side }}px;
  }

  .ai-before-after-label-after-{{ ai_gen_id }} {
    right: {{ block.settings.label_position_side }}px;
  }

  .ai-before-after-label-{{ ai_gen_id }}.hidden {
    opacity: 0;
    visibility: hidden;
  }

  .ai-before-after-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-before-after-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  @media screen and (min-width: 750px) {
    .ai-before-after-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-before-after-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_font_size | times: 0.85 }}px;
      padding: {{ block.settings.label_padding_vertical | times: 0.75 }}px {{ block.settings.label_padding_horizontal | times: 0.75 }}px;
    }

    .ai-before-after-handle-{{ ai_gen_id }} {
      width: {{ block.settings.handle_size | times: 0.8 }}px;
      height: {{ block.settings.handle_size | times: 0.8 }}px;
    }

    .ai-before-after-label-{{ ai_gen_id }} {
      top: {{ block.settings.label_position_top | times: 0.75 }}px;
    }

    .ai-before-after-label-before-{{ ai_gen_id }} {
      left: {{ block.settings.label_position_side | times: 0.75 }}px;
    }

    .ai-before-after-label-after-{{ ai_gen_id }} {
      right: {{ block.settings.label_position_side | times: 0.75 }}px;
    }
  }

  .ai-before-after-header-{{ ai_gen_id }} {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 2rem;
    padding: 0 1rem;
  }
  .ai-before-after-heading-{{ ai_gen_id }} {
    font-family: var(--font-heading, 'JetBrains Mono', ui-monospace, monospace);
    font-size: clamp(1.7rem, 3.4vw, 2.6rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--color-black, #1f1d1a);
    margin: 0;
  }
  .ai-before-after-subtitle-{{ ai_gen_id }} {
    font-family: var(--font-body, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--char-soft, #5a4a3a);
    margin: 0.75rem auto 0;
    max-width: 46ch;
  }

  .ai-before-after-toggle-{{ ai_gen_id }} {
    display: flex;
    width: max-content;
    gap: 4px;
    margin: 0 auto 1.5rem;
    padding: 4px;
    border-radius: 999px;
    background: rgba(138, 98, 64, 0.10);
    border: 1px solid rgba(138, 98, 64, 0.22);
  }
  .ai-ba-toggle-btn-{{ ai_gen_id }} {
    font-family: var(--font-body, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--char-soft, #5a4a3a);
    background: transparent;
    border: none;
    border-radius: 999px;
    padding: 0.5rem 1.4rem;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .ai-ba-toggle-btn-{{ ai_gen_id }}.is-active {
    background: var(--color-walnut, #8a6240);
    color: #f8f3ea;
  }
{% endstyle %}

{% if block.settings.heading != blank or block.settings.subtitle != blank %}
  <div class="ai-before-after-header-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-before-after-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}
    {% if block.settings.subtitle != blank %}
      <p class="ai-before-after-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}
  </div>
{% endif %}

{%- liquid
  assign f_before = block.settings.before_image | image_url: width: 2000
  assign f_after  = block.settings.after_image  | image_url: width: 2000
  if block.settings.before_image_male != blank
    assign m_before = block.settings.before_image_male | image_url: width: 2000
  else
    assign m_before = 'before-after-male-before.jpg' | asset_url
  endif
  if block.settings.after_image_male != blank
    assign m_after = block.settings.after_image_male | image_url: width: 2000
  else
    assign m_after = 'before-after-male-after.jpg' | asset_url
  endif
-%}

{% if block.settings.show_toggle %}
  <div class="ai-before-after-toggle-{{ ai_gen_id }}" role="tablist" aria-label="Choose hair type">
    <button class="ai-ba-toggle-btn-{{ ai_gen_id }} is-active" data-ba-variant="female" type="button" role="tab" aria-selected="true">{{ block.settings.female_label | default: 'Women' }}</button>
    <button class="ai-ba-toggle-btn-{{ ai_gen_id }}" data-ba-variant="male" type="button" role="tab" aria-selected="false">{{ block.settings.male_label | default: 'Men' }}</button>
  </div>
{% endif %}

<before-after-slider-{{ ai_gen_id }}
  class="ai-before-after-{{ ai_gen_id }}"
  data-f-before="{{ f_before }}"
  data-f-after="{{ f_after }}"
  data-m-before="{{ m_before }}"
  data-m-after="{{ m_after }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-before-after-container-{{ ai_gen_id }}">
    {% if block.settings.before_image %}
      <img
        src="{{ block.settings.before_image | image_url: width: 2000 }}"
        alt="{{ block.settings.before_image.alt | escape }}"
        class="ai-before-after-image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.before_image.width }}"
        height="{{ block.settings.before_image.height }}"
      >
    {% else %}
      <div class="ai-before-after-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
      </div>
    {% endif %}

    <div class="ai-before-after-after-wrapper-{{ ai_gen_id }}">
      {% if block.settings.after_image %}
        <img
          src="{{ block.settings.after_image | image_url: width: 2000 }}"
          alt="{{ block.settings.after_image.alt | escape }}"
          class="ai-before-after-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.after_image.width }}"
          height="{{ block.settings.after_image.height }}"
        >
      {% else %}
        <div class="ai-before-after-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-before-after-divider-{{ ai_gen_id }}">
      <div class="ai-before-after-handle-{{ ai_gen_id }}">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </div>
    </div>

    {% if block.settings.before_label != blank %}
      <div class="ai-before-after-label-{{ ai_gen_id }} ai-before-after-label-before-{{ ai_gen_id }}">
        {{ block.settings.before_label }}
      </div>
    {% endif %}

    {% if block.settings.after_label != blank %}
      <div class="ai-before-after-label-{{ ai_gen_id }} ai-before-after-label-after-{{ ai_gen_id }}">
        {{ block.settings.after_label }}
      </div>
    {% endif %}
  </div>
</before-after-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class BeforeAfterSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.isDragging = false;
        this.currentPosition = 50;
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-before-after-container-{{ ai_gen_id }}');
        this.divider = this.querySelector('.ai-before-after-divider-{{ ai_gen_id }}');
        this.afterWrapper = this.querySelector('.ai-before-after-after-wrapper-{{ ai_gen_id }}');
        this.beforeLabel = this.querySelector('.ai-before-after-label-before-{{ ai_gen_id }}');
        this.afterLabel = this.querySelector('.ai-before-after-label-after-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.divider.addEventListener('mousedown', this.handleStart.bind(this));
        this.divider.addEventListener('touchstart', this.handleStart.bind(this), { passive: false });

        document.addEventListener('mousemove', this.handleMove.bind(this));
        document.addEventListener('touchmove', this.handleMove.bind(this), { passive: false });

        document.addEventListener('mouseup', this.handleEnd.bind(this));
        document.addEventListener('touchend', this.handleEnd.bind(this));
      }

      handleStart(e) {
        this.isDragging = true;
        e.preventDefault();
      }

      handleMove(e) {
        if (!this.isDragging) return;

        const clientX = e.type.includes('mouse') ? e.clientX : e.touches[0].clientX;
        const rect = this.container.getBoundingClientRect();
        const x = clientX - rect.left;
        const percentage = Math.max(0, Math.min(100, (x / rect.width) * 100));

        this.currentPosition = percentage;
        this.updatePosition(percentage);
        this.updateLabels(percentage);

        e.preventDefault();
      }

      handleEnd() {
        this.isDragging = false;
      }

      updatePosition(percentage) {
        this.divider.style.left = percentage + '%';
        this.afterWrapper.style.clipPath = `inset(0 ${100 - percentage}% 0 0)`;
      }

      updateLabels(percentage) {
        if (this.beforeLabel) {
          if (percentage < 15) {
            this.beforeLabel.classList.add('hidden');
          } else {
            this.beforeLabel.classList.remove('hidden');
          }
        }

        if (this.afterLabel) {
          if (percentage > 85) {
            this.afterLabel.classList.add('hidden');
          } else {
            this.afterLabel.classList.remove('hidden');
          }
        }
      }
    }

    customElements.define('before-after-slider-{{ ai_gen_id }}', BeforeAfterSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
