                  {% for n in (1..full_stars) %}
                    {% render 'a-icon-star-small', color: mini_review_stars_color, size: star_size %}
                  {% endfor %}
                  {% if half_star == 1 %}
                    {% render 'a-icon-star-half-small', color: mini_review_stars_color, size: star_size %}
                  {% endif %}
                  {% for n in (1..empty_stars) %}
                    {% render 'a-icon-star-empty-small', color: mini_review_stars_color, size: star_size %}
                  {% endfor %}
                </div>
              </div>
            </div>
            <p class="review-text">{{ block.settings.item_text_10 | default: default_review_text }}</p>
          </div>
        </div>
      {% endif %}
      {% if block.settings.item_image_11 != blank
        or block.settings.item_author_11 != blank
        or block.settings.item_author_location_11 != blank
        or block.settings.item_text_11 != blank
      %}
        {% assign count_reviews = count_reviews | plus: 1 %}
        <div class="swiper-slide" role="group">
          <div class="review-card">
            <div class="review-card-content">
              {% if block.settings.item_image_11 != blank %}
                <img
                  class="profile-image"
                  src="{{ block.settings.item_image_11 | image_url: width: 122, height: 122 }}"
                  alt="{{ block.settings.item_author_11 }}"
                  width="61"
                  height="61"
                >
              {% else %}
                {% render 'a-icon-anonymous-avatar', width: 61, height: 61, class: 'profile-image' %}
              {% endif %}

              <div class="review-content">
                <div class="reviewer-info">
                  <span class="reviewer-name">
                    {{- block.settings.item_author_11 | default: default_author_text -}}
                  </span>
                  {% render 'a-icon-verified-badge' %}
                </div>
                {% if block.settings.item_author_location_11 != blank %}
                  <div class="location">
                    {{ block.settings.item_author_location_11 | default: default_author_location_text }}
                  </div>
                {% endif %}
                {% assign rating_value = block.settings.item_rating_11 | default: 5 %}
                {% assign full_stars = rating_value | floor %}
                {% assign half_star = 0 %}
                {% assign decimal_part = rating_value | modulo: 1 %}
                {% if decimal_part >= 0.3 and decimal_part < 0.8 -%}
                  {%- assign half_star = 1 -%}
                {%- elsif decimal_part >= 0.8 -%}
                  {%- assign full_stars = full_stars | plus: 1 -%}
                {%- endif %}
                {% assign empty_stars = 5 | minus: full_stars | minus: half_star %}
                <div class="stars">
                  {% for n in (1..full_stars) %}
                    {% render 'a-icon-star-small', color: mini_review_stars_color, size: star_size %}
                  {% endfor %}
                  {% if half_star == 1 %}
                    {% render 'a-icon-star-half-small', color: mini_review_stars_color, size: star_size %}
                  {% endif %}
                  {% for n in (1..empty_stars) %}
                    {% render 'a-icon-star-empty-small', color: mini_review_stars_color, size: star_size %}
                  {% endfor %}
                </div>
              </div>
            </div>
            <p class="review-text">{{ block.settings.item_text_11 | default: default_review_text }}</p>
          </div>
        </div>
      {% endif %}
      {% if block.settings.item_image_12 != blank
        or block.settings.item_author_12 != blank
        or block.settings.item_author_location_12 != blank
        or block.settings.item_text_12 != blank
      %}
        {% assign count_reviews = count_reviews | plus: 1 %}
        <div class="swiper-slide" role="group">
          <div class="review-card">
            <div class="review-card-content">
              {% if block.settings.item_image_12 != blank %}
