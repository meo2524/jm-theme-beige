                  alt="{{ block.settings.item_author_12 }}"
                  width="61"
                  height="61"
                >
              {% else %}
                {% render 'a-icon-anonymous-avatar', width: 61, height: 61, class: 'profile-image' %}
              {% endif %}

              <div class="review-content">
                <div class="reviewer-info">
                  <span class="reviewer-name">
                    {{- block.settings.item_author_12 | default: default_author_text -}}
                  </span>
                  {% render 'a-icon-verified-badge' %}
                </div>
                {% if block.settings.item_author_location_12 != blank %}
                  <div class="location">
                    {{ block.settings.item_author_location_12 | default: default_author_location_text }}
                  </div>
                {% endif %}
                {% assign rating_value = block.settings.item_rating_12 | default: 5 %}
                {% assign full_stars = rating_value | floor %}
                {% assign half_star = 0 %}
                {% assign decimal_part = rating_value | modulo: 1 %}
                {% if decimal_part >= 0.3 and decimal_part < 0.8 -%}
                  {%- assign half_star = 1 -%}
                {%- elsif decimal_part >= 0.8 -%}
                  {%- assign full_stars = full_stars | plus: 1 -%}
                {%- endif %}
                {% assign empty_stars = 5 | minus: full_stars | minus: half_star %}
                <div class="stars">
                  {% for n in (1..full_stars) %}
                    {% render 'a-icon-star-small', color: mini_review_stars_color, size: star_size %}
                  {% endfor %}
                  {% if half_star == 1 %}
                    {% render 'a-icon-star-half-small', color: mini_review_stars_color, size: star_size %}
                  {% endif %}
                  {% for n in (1..empty_stars) %}
                    {% render 'a-icon-star-empty-small', color: mini_review_stars_color, size: star_size %}
                  {% endfor %}
                </div>
              </div>
            </div>
            <p class="review-text">{{ block.settings.item_text_12 | default: default_review_text }}</p>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
  <div class="review-footer">
    {% if show_review_count %}
      <div class="review-count">
        <strong>{{ count_reviews }}</strong> New Reviews
      </div>
    {% endif %}
    <div class="review-divider"></div>
    <!-- pagination dots rendered by swiper -->
    <div class="swiper-pagination reviews-swiper-pagination-{{ block.id }}"></div>
  </div>
</reviews-swiper>

