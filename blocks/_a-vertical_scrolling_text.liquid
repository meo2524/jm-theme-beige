<a class="scrolling-text-item-{{ section.id }}" {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% else %}role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
    {{ block.settings.title }}
</a><!--@#$%-->
{% schema %}
{
  "name": "Vertical scrolling text",
  "tag": null,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Vertical scrolling text"
    }
  ]
}
{% endschema %}
