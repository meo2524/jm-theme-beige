{%- if request.page_type == 'product' -%}
  <link rel="stylesheet" href="{{ 'component-sticky-atc.css' | asset_url }}" media="print" onload="this.media='all'">

  {%- liquid
    assign current_variant = product.selected_or_first_available_variant
    assign thumb_url = current_variant.featured_media.preview_image | default: product.featured_image
  -%}

  <mc-sticky-atc
    class="sticky-atc"
    data-position="{{ block.settings.position }}"
    data-show-on="{{ block.settings.show_on }}"
    {{ block.shopify_attributes }}
  >
    <div class="sticky-atc__bar" aria-label="Quick add to cart" role="complementary">
      <div class="container sticky-atc__inner">

        <div class="sticky-atc__left">
          {%- if thumb_url != blank -%}
            {{ thumb_url | image_url: width: 120 | image_tag:
              class: 'sticky-atc__img',
              loading: 'lazy',
              widths: '60, 120',
              alt: product.title
            }}
          {%- endif -%}
          <div class="sticky-atc__info">
            <p class="sticky-atc__title">{{ product.title }}</p>
            <p class="sticky-atc__price">{{ current_variant.price | money }}</p>
          </div>
        </div>

        <div class="sticky-atc__right">
          {%- form 'product', product, id: 'mc-sticky-atc-form', data-type: 'add-to-cart-form' -%}

            {%- unless product.has_only_default_variant -%}
              <div class="sticky-atc__select-wrap">
                <select name="id" class="sticky-atc__select" aria-label="Select variant">
                  {%- for variant in product.variants -%}
                    <option
                      value="{{ variant.id }}"
                      {%- if variant.id == current_variant.id %} selected{%- endif -%}
                      {%- unless variant.available %} disabled{%- endunless -%}
                    >
                      {{ variant.title }}{%- unless variant.available %} - {{ block.settings.sold_out_label | default: 'Sold Out' | escape }}{%- endunless -%}
                    </option>
                  {%- endfor -%}
                </select>
                <svg class="sticky-atc__caret" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {%- else -%}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
            {%- endunless -%}

            <button
              type="submit"
              name="add"
              class="sticky-atc__btn"
              {%- unless current_variant.available %} disabled{%- endunless -%}
              aria-label="Add {{ product.title }} to cart"
            >
              <span class="sticky-atc__btn-text">
                {%- if current_variant.available -%}
                  {{ block.settings.atc_label | default: 'Add to Cart' | escape }}
                {%- else -%}
                  {{ block.settings.sold_out_label | default: 'Sold Out' | escape }}
                {%- endif -%}
              </span>
            </button>

          {%- endform -%}
        </div>

      </div>
    </div>
  </mc-sticky-atc>

  <script src="{{ 'component-sticky-atc.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "Sticky Add to Cart",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "show_on",
      "label": "Show on",
      "default": "both",
      "options": [
        { "value": "desktop-only", "label": "Desktop only" },
        { "value": "mobile-only", "label": "Mobile only" },
        { "value": "both", "label": "All devices" }
      ]
    },
    {
      "type": "select",
      "id": "position",
      "label": "Bar position",
      "default": "bottom",
      "options": [
        { "value": "bottom", "label": "Bottom" },
        { "value": "top", "label": "Top" }
      ]
    },
    {
      "type": "text",
      "id": "atc_label",
      "label": "Add to cart label",
      "default": "Add to Cart"
    },
    {
      "type": "text",
      "id": "sold_out_label",
      "label": "Sold out label",
      "default": "Sold Out"
    }
  ],
  "presets": [
    {
      "name": "Sticky Add to Cart"
    }
  ]
}
{% endschema %}
