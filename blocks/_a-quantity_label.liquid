{% assign product = closest.product %}
{% style %}
  .atlas-isolation-wrapper .atlas-quantity-label {
    font-family: var(--atlas-font-body-family);
    font-size: {{ block.settings.quantity_label_font_size | default: 14 }}px;
    font-weight: 600;
    color: {{ block.settings.quantity_label_color | default: 'rgb(var(--atlas-color-base-text))' }};
    margin: 0;
  }
  .atlas-isolation-wrapper .subtotal-text {
    font-family: var(--atlas-font-body-family);
    font-size: {{ block.settings.subtotal_font_size | default: 12 }}px;
    font-weight: 400;
    color: {{ block.settings.subtotal_color | default: '#666666' }};
    line-height: calc({{ block.settings.subtotal_font_size | default: 12 }}px + 6px);
    margin: 0;
  }
{% endstyle %}
<div class="product-info-left" {{ block.shopify_attributes }}>
  <h3 class="atlas-quantity-label">Quantity :</h3>
  <p class="subtotal-text" id="subtotal-{{ section.id }}">
    Subtotal:
    <span class="subtotal-amount" price="{{ product.selected_or_first_available_variant.price }}">
      {{- product.selected_or_first_available_variant.price | money -}}
    </span>
  </p>
</div>
{% schema %}
{
  "name": "Quantity label",
  "tag": null,
  "blocks": [],
  "settings": [
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "quantity_label_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Quantity label font size",
      "default": 14
    },
    {
      "type": "color",
      "id": "quantity_label_color",
      "label": "Quantity label color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "subtotal_font_size",
      "min": 8,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Subtotal font size",
      "default": 12
    },
    {
      "type": "color",
      "id": "subtotal_color",
      "label": "Subtotal color",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Quantity label"
    }
  ]
}
{% endschema %}
