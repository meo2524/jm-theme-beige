{% doc %}
  @prompt
    I want to create a carousel of video or image reviews. It needs to be optimised for mobile as well
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign cpr = block.settings.cards_per_row_desktop | default: 3 %}
{% assign gap_total_desktop = cpr | minus: 1 | times: block.settings.card_gap %}
{% assign max_width = block.settings.max_width | default: 1200 %}

{% style %}
  .ai-review-carousel-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-review-carousel__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 auto 32px;
    padding: 0 20px;
    max-width: {{ max_width }}px;
  }

  /* Match the other section headings: JetBrains Mono, bold, brand sizing */
  .ai-review-carousel__title-{{ ai_gen_id }} {
    font-family: var(--font-heading, 'JetBrains Mono', ui-monospace, monospace);
    font-size: clamp(1.7rem, 3.4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: {{ block.settings.heading_color }};
    margin: 0 0 0.75rem;
  }

  .ai-review-carousel__subtitle-{{ ai_gen_id }} {
    font-family: var(--font-body, 'JetBrains Mono', ui-monospace, monospace);
    font-size: clamp(0.85rem, 2.4vw, 0.95rem);
    line-height: 1.7;
    color: var(--char-soft, #5a4a3a);
    text-align: center;
    margin: 0 auto;
    max-width: 46ch;
  }

  .ai-review-carousel__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    padding: 0 20px;
    max-width: {{ max_width }}px;
    margin: 0 auto;
  }

  .ai-review-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.4s ease;
    touch-action: pan-y pinch-zoom;
  }

  .ai-review-carousel__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ gap_total_desktop }}px) / {{ cpr }});
    min-width: 0;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.card_shadow }};
  }

  .ai-review-carousel__media-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.media_aspect_ratio }}%;
    background-color: #f4f4f4;
    overflow: hidden;
  }

  .ai-review-carousel__media-{{ ai_gen_id }} img,
  .ai-review-carousel__media-{{ ai_gen_id }} video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .ai-review-carousel__media-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-review-carousel__media-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-review-carousel__play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    background-color: rgba(0, 0, 0, 0.7);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, transform 0.3s ease;
    z-index: 2;
  }

  .ai-review-carousel__play-button-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.9);
    transform: translate(-50%, -50%) scale(1.1);
  }

  .ai-review-carousel__play-button-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    fill: #ffffff;
    margin-left: 3px;
  }

  .ai-review-carousel__play-button-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-review-carousel__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-review-carousel__rating-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 12px;
  }

  .ai-review-carousel__star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    fill: {{ block.settings.star_color }};
  }

  .ai-review-carousel__star-{{ ai_gen_id }}.empty {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-review-carousel__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_text_size }}px;
    color: {{ block.settings.review_text_color }};
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .ai-review-carousel__author-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_text_size }}px;
    color: {{ block.settings.author_text_color }};
    font-weight: 600;
  }

  .ai-review-carousel__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin: 32px auto 0;
    padding: 0 20px;
    max-width: {{ max_width }}px;
  }

  .ai-review-carousel__button-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ block.settings.button_background }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, opacity 0.3s ease;
  }

  .ai-review-carousel__button-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-review-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-review-carousel__button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    fill: {{ block.settings.button_icon_color }};
  }

  .ai-review-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-review-carousel__dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-review-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.3);
  }

  @media screen and (max-width: 749px) {
    /* scale the cards down on mobile so they don't dominate the screen:
       narrower card (peek of the next), shorter media, tighter content */
    .ai-review-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc(82% - {{ block.settings.card_gap }}px);
    }

    .ai-review-carousel__media-{{ ai_gen_id }} {
      padding-bottom: 125%;
    }

    .ai-review-carousel__content-{{ ai_gen_id }} {
      padding: 16px;
    }

    .ai-review-carousel__text-{{ ai_gen_id }} {
      font-size: clamp(12px, 3.4vw, {{ block.settings.review_text_size }}px);
    }

    .ai-review-carousel__header-{{ ai_gen_id }} {
      margin-bottom: 24px;
    }

    /* title + subtitle sizes are handled by clamp() in the base rules */
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-review-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc(50% - {{ block.settings.card_gap }}px);
    }
  }
{% endstyle %}

<review-carousel-{{ ai_gen_id }}
  class="ai-review-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank or block.settings.subtitle != blank %}
    <div class="ai-review-carousel__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-review-carousel__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-review-carousel__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-review-carousel__container-{{ ai_gen_id }}">
    <div class="ai-review-carousel__track-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign media_type_key = 'review_' | append: i | append: '_media_type'
          assign image_key = 'review_' | append: i | append: '_image'
          assign video_key = 'review_' | append: i | append: '_video'
          assign rating_key = 'review_' | append: i | append: '_rating'
          assign text_key = 'review_' | append: i | append: '_text'
          assign author_key = 'review_' | append: i | append: '_author'

          assign media_type = block.settings[media_type_key]
          assign image = block.settings[image_key]
          assign video = block.settings[video_key]
          assign rating = block.settings[rating_key]
          assign text = block.settings[text_key]
          assign author = block.settings[author_key]
        %}

        <div class="ai-review-carousel__card-{{ ai_gen_id }}" data-review-index="{{ i }}">
          <div class="ai-review-carousel__media-{{ ai_gen_id }}">
            {% if media_type == 'video' and video != blank %}
              <video
                class="ai-review-carousel__video-{{ ai_gen_id }}"
                data-video-id="{{ i }}"
                loop
                muted
                playsinline
              >
                <source src="{{ video }}" type="video/mp4">
              </video>
              <button
                class="ai-review-carousel__play-button-{{ ai_gen_id }}"
                data-play-button="{{ i }}"
                aria-label="Play video"
              >
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
            {% elsif media_type == 'image' and image != blank %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ author | escape }}"
                loading="lazy"
                width="800"
                height="{{ 800 | times: block.settings.media_aspect_ratio | divided_by: 100 }}"
              >
            {% else %}
              <div class="ai-review-carousel__media-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-review-carousel__content-{{ ai_gen_id }}">
            {% if block.settings.show_rating %}
              <div class="ai-review-carousel__rating-{{ ai_gen_id }}">
                {% for star in (1..5) %}
                  <svg
                    class="ai-review-carousel__star-{{ ai_gen_id }} {% if star > rating %}empty{% endif %}"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endfor %}
              </div>
            {% endif %}

            {% if text != blank %}
              <p class="ai-review-carousel__text-{{ ai_gen_id }}">{{ text }}</p>
            {% endif %}

            {% if author != blank %}
              <div class="ai-review-carousel__author-{{ ai_gen_id }}">{{ author }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="ai-review-carousel__controls-{{ ai_gen_id }}">
    <button
      class="ai-review-carousel__button-{{ ai_gen_id }} ai-review-carousel__prev-{{ ai_gen_id }}"
      aria-label="Previous review"
    >
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>

    <div class="ai-review-carousel__dots-{{ ai_gen_id }}"></div>

    <button
      class="ai-review-carousel__button-{{ ai_gen_id }} ai-review-carousel__next-{{ ai_gen_id }}"
      aria-label="Next review"
    >
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
  </div>
</review-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ReviewCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.isDragging = false;
        this.startPos = 0;
        this.currentTranslate = 0;
        this.prevTranslate = 0;
        this.animationID = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-review-carousel__track-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-review-carousel__card-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-review-carousel__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-review-carousel__next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-review-carousel__dots-{{ ai_gen_id }}');

        this.cardsPerView = this.getCardsPerView();
        this.totalSlides = Math.ceil(this.cards.length / this.cardsPerView);

        this.createDots();
        this.setupEventListeners();
        this.updateCarousel();
      }

      getCardsPerView() {
        if (window.innerWidth < 750) {
          return 1;
        } else if (window.innerWidth < 990) {
          return 2;
        } else {
          return {{ block.settings.cards_per_row_desktop | default: 3 }};
        }
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        for (let i = 0; i < this.totalSlides; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-review-carousel__dot-{{ ai_gen_id }}');
          if (i === 0) dot.classList.add('active');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
        this.dots = this.querySelectorAll('.ai-review-carousel__dot-{{ ai_gen_id }}');
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        this.track.addEventListener('touchstart', this.touchStart.bind(this));
        this.track.addEventListener('touchend', this.touchEnd.bind(this));
        this.track.addEventListener('touchmove', this.touchMove.bind(this), { passive: false });

        this.track.addEventListener('mousedown', this.touchStart.bind(this));
        this.track.addEventListener('mouseup', this.touchEnd.bind(this));
        this.track.addEventListener('mouseleave', this.touchEnd.bind(this));
        this.track.addEventListener('mousemove', this.touchMove.bind(this));

        this.querySelectorAll('[data-play-button]').forEach(button => {
          button.addEventListener('click', (e) => {
            const videoId = button.getAttribute('data-play-button');
            const video = this.querySelector(`[data-video-id="${videoId}"]`);
            if (video) {
              if (video.paused) {
                video.play();
                button.classList.add('hidden');
              } else {
                video.pause();
                button.classList.remove('hidden');
              }
            }
          });
        });

        this.querySelectorAll('.ai-review-carousel__video-{{ ai_gen_id }}').forEach(video => {
          video.addEventListener('click', () => {
            const videoId = video.getAttribute('data-video-id');
            const button = this.querySelector(`[data-play-button="${videoId}"]`);
            if (video.paused) {
              video.play();
              if (button) button.classList.add('hidden');
            } else {
              video.pause();
              if (button) button.classList.remove('hidden');
            }
          });
        });

        window.addEventListener('resize', () => {
          const newCardsPerView = this.getCardsPerView();
          if (newCardsPerView !== this.cardsPerView) {
            this.cardsPerView = newCardsPerView;
            this.totalSlides = Math.ceil(this.cards.length / this.cardsPerView);
            this.currentIndex = Math.min(this.currentIndex, this.totalSlides - 1);
            this.createDots();
            this.updateCarousel();
          }
        });
      }

      touchStart(event) {
        this.isDragging = true;
        this.axisLock = null;
        this.startPos = this.getPositionX(event);
        this.startPosY = this.getPositionY(event);
        this.animationID = requestAnimationFrame(this.animation.bind(this));
        this.track.style.cursor = 'grabbing';
      }

      touchMove(event) {
        if (!this.isDragging) return;
        const currentPosition = this.getPositionX(event);

        // Lock to one axis on the first meaningful touch move so a vertical
        // page scroll never drags the carousel (and vice versa).
        if (this.axisLock === null && event.type.includes('touch')) {
          const dx = Math.abs(currentPosition - this.startPos);
          const dy = Math.abs(this.getPositionY(event) - this.startPosY);
          if (dx < 8 && dy < 8) return; // below threshold — wait for intent
          this.axisLock = dx > dy ? 'x' : 'y';
          if (this.axisLock === 'y') {
            // vertical intent: release the carousel, let the page scroll
            this.isDragging = false;
            cancelAnimationFrame(this.animationID);
            return;
          }
        }

        // horizontal swipe (or mouse drag): drive the carousel, block page pan
        if (event.cancelable) event.preventDefault();
        this.currentTranslate = this.prevTranslate + currentPosition - this.startPos;
      }

      touchEnd() {
        this.isDragging = false;
        cancelAnimationFrame(this.animationID);

        const movedBy = this.currentTranslate - this.prevTranslate;

        if (movedBy < -100 && this.currentIndex < this.totalSlides - 1) {
          this.currentIndex += 1;
        }

        if (movedBy > 100 && this.currentIndex > 0) {
          this.currentIndex -= 1;
        }

        this.updateCarousel();
        this.track.style.cursor = 'grab';
      }

      getPositionX(event) {
        return event.type.includes('mouse') ? event.pageX : event.touches[0].clientX;
      }

      getPositionY(event) {
        return event.type.includes('mouse') ? event.pageY : event.touches[0].clientY;
      }

      animation() {
        this.track.style.transform = `translateX(${this.currentTranslate}px)`;
        if (this.isDragging) requestAnimationFrame(this.animation.bind(this));
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex -= 1;
          this.updateCarousel();
        }
      }

      next() {
        if (this.currentIndex < this.totalSlides - 1) {
          this.currentIndex += 1;
          this.updateCarousel();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
      }

      updateCarousel() {
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * (cardWidth + gap) * this.cardsPerView);

        this.currentTranslate = offset;
        this.prevTranslate = offset;
        this.track.style.transform = `translateX(${offset}px)`;

        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex === this.totalSlides - 1;

        this.dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentIndex);
        });
      }
    }

    customElements.define('review-carousel-{{ ai_gen_id }}', ReviewCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Review carousel",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Real reviews from real people"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n4"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2D2D2D"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#7A8471"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "cards_per_row_desktop",
      "label": "Cards per row on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F2EDE4"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "card_shadow",
      "label": "Card shadow",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "0 2px 8px rgba(0,0,0,0.1)",
          "label": "Light"
        },
        {
          "value": "0 4px 16px rgba(0,0,0,0.15)",
          "label": "Medium"
