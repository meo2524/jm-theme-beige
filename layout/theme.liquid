<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <!-- ============================================================
       SEO & META
       ============================================================ -->

  {%- comment -%} ── Page title ──────────────────────────────────── {%- endcomment -%}
  {%- comment -%}
    Title-format hardening:
    - On the home page Shopify's `page_title` already returns the shop
      name, so appending `shop.name` again produced "Mend&Co – Mend&Co".
    - On product pages with an SEO title that already references the
      brand ("… | Mend & Co"), the unless-contains check could still
      miss because the brand mark in SEO ("Mend & Co") differs from the
      Shopify shop name ("Mend&Co"). We normalize both sides for the
      contains check (lowercase, strip ampersand spaces) so the dedupe
      catches both variants.
  {%- endcomment -%}
  {%- assign _norm_title = page_title | downcase | replace: ' & ', '&' | replace: ' ', '' -%}
  {%- assign _norm_shop  = shop.name  | downcase | replace: ' & ', '&' | replace: ' ', '' -%}
  <title>{{ page_title -}}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless _norm_title contains _norm_shop %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {%- comment -%} ── Meta description ────────────────────────────── {%- endcomment -%}
  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- elsif settings.seo_meta_description != blank -%}
    <meta name="description" content="{{ settings.seo_meta_description | escape }}">
  {%- endif -%}

  {%- comment -%} ── Robots control ──────────────────────────────── {%- endcomment -%}
  {%- if template.name == 'search' or template.suffix == 'password'
      or current_tags.size > 0 and current_page > 1 -%}
    <meta name="robots" content="noindex, follow">
  {%- else -%}
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
  {%- endif -%}

  {%- comment -%} ── Canonical ───────────────────────────────────── {%- endcomment -%}
  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} ── Theme colour (browser chrome on mobile) ─────── {%- endcomment -%}
  <meta name="theme-color" content="#1f1d1a">

  {%- comment -%} ── Open Graph ──────────────────────────────────── {%- endcomment -%}
  {%- assign og_title       = page_title | default: shop.name -%}
  {%- assign og_description = page_description | default: settings.seo_meta_description | default: shop.description -%}
  {%- assign og_url         = canonical_url -%}
  {%- assign og_type        = 'website' -%}
  {%- if template.name == 'product' -%}
    {%- assign og_type = 'product' -%}
    {%- assign og_image = product.featured_image | image_url: width: 1200 -%}
  {%- elsif template.name == 'article' -%}
    {%- assign og_type = 'article' -%}
    {%- assign og_image = article.image | image_url: width: 1200 -%}
  {%- else -%}
    {%- assign og_image = settings.og_image | image_url: width: 1200 -%}
  {%- endif -%}

  <meta property="og:site_name"   content="{{ shop.name }}">
  <meta property="og:url"         content="{{ og_url }}">
  <meta property="og:title"       content="{{ og_title | escape }}">
  <meta property="og:type"        content="{{ og_type }}">
  {%- if og_description != blank -%}
    <meta property="og:description" content="{{ og_description | escape }}">
  {%- endif -%}
  {%- if og_image -%}
    <meta property="og:image"        content="https:{{ og_image }}">
    <meta property="og:image:width"  content="1200">
    <meta property="og:image:height" content="630">
  {%- endif -%}
  {%- if template.name == 'product' -%}
    {%- assign og_price = product.price | money_without_currency -%}
    <meta property="product:price:amount"   content="{{ og_price }}">
    <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
  {%- endif -%}

  {%- comment -%} ── Twitter / X card ────────────────────────────── {%- endcomment -%}
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:site"        content="@mendandco_">
  <meta name="twitter:title"       content="{{ og_title | escape }}">
  {%- if og_description != blank -%}
    <meta name="twitter:description" content="{{ og_description | escape }}">
  {%- endif -%}
  {%- if og_image -%}
    <meta name="twitter:image" content="https:{{ og_image }}">
  {%- endif -%}

  {%- comment -%} ── JSON-LD structured data ─────────────────────── {%- endcomment -%}

  {%- comment -%} Organisation + WebSite (every page) {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "{{ shop.url }}/#organization",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | json }},
        "logo": {
          "@type": "ImageObject",
          "url": {{ settings.logo | image_url: width: 400 | prepend: 'https:' | json }}
        },
        "sameAs": [
          {%- if settings.social_instagram_link != blank -%}{{ settings.social_instagram_link | json }},{%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}{{ settings.social_tiktok_link | json }},{%- endif -%}
          {%- if settings.social_facebook_link != blank -%}{{ settings.social_facebook_link | json }},{%- endif -%}
          {%- if settings.social_youtube_link != blank -%}{{ settings.social_youtube_link | json }},{%- endif -%}
          ""
        ]
      },
      {
        "@type": "WebSite",
        "@id": "{{ shop.url }}/#website",
        "url": {{ shop.url | json }},
        "name": {{ shop.name | json }},
        "publisher": { "@id": "{{ shop.url }}/#organization" },
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "{{ shop.url }}/search?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
      {%- if template.name == 'product' -%}
      ,{
        "@type": "Product",
        "@id": "{{ canonical_url }}/#product",
        "name": {{ product.title | json }},
        "url": {{ canonical_url | json }},
        "description": {{ product.description | strip_html | truncate: 500 | json }},
        "brand": {
          "@type": "Brand",
          "name": {{ product.vendor | default: shop.name | json }}
        },
        "image": [
          {%- for img in product.images limit: 5 -%}
            "https:{{ img | image_url: width: 1200 }}"{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ],
        "sku": {{ product.selected_or_first_available_variant.sku | default: product.id | json }},
        "offers": [
          {%- for variant in product.variants -%}
          {
            "@type": "Offer",
            "url": "{{ canonical_url }}?variant={{ variant.id }}",
            "priceCurrency": {{ cart.currency.iso_code | json }},
            "price": "{{ variant.price | money_without_currency }}",
            "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "itemCondition": "https://schema.org/NewCondition",
            "seller": { "@id": "{{ shop.url }}/#organization" }
          }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
        {%- if product.metafields.reviews.rating.value != blank -%}
        ,"aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "{{ product.metafields.reviews.rating.value }}",
          "reviewCount": "{{ product.metafields.reviews.rating_count.value }}"
        }
        {%- endif -%}
      }
      {%- endif -%}
      {%- if template.name == 'index' -%}
      ,{
        "@type": "WebPage",
        "@id": "{{ canonical_url }}/#webpage",
        "url": {{ canonical_url | json }},
        "name": {{ og_title | json }},
        "isPartOf": { "@id": "{{ shop.url }}/#website" },
        "about": { "@id": "{{ shop.url }}/#organization" }
      }
      {%- endif -%}
      {%- if template.name == 'collection' -%}
      ,{
        "@type": "CollectionPage",
        "@id": "{{ canonical_url }}/#webpage",
        "url": {{ canonical_url | json }},
        "name": {{ collection.title | json }},
        "description": {{ collection.description | strip_html | truncate: 300 | json }},
        "isPartOf": { "@id": "{{ shop.url }}/#website" }
      }
      {%- endif -%}
    ]
  }
  </script>

  <!-- ============================================================
       PERFORMANCE — resource hints
       ============================================================ -->

  {%- comment -%} DNS prefetch for third-party domains we load later {%- endcomment -%}
  <link rel="dns-prefetch" href="//cdn.judge.me">
  <link rel="dns-prefetch" href="//fonts.googleapis.com">
  <link rel="dns-prefetch" href="//fonts.gstatic.com">

  {%- comment -%}
    Preload the hero featured image so the browser fetches it
    immediately — critical for Largest Contentful Paint (LCP).
  {%- endcomment -%}
  {%- if template.name == 'index' -%}
    {%- assign hero_section = sections['hero'] -%}
    {%- assign hero_img = hero_section.settings.bg_image -%}
    {%- if hero_img != blank -%}
      <link rel="preload" as="image"
            href="{{ hero_img | image_url: width: 1200 }}"
            imagesrcset="{{ hero_img | image_url: width: 750 }} 750w, {{ hero_img | image_url: width: 1200 }} 1200w"
            imagesizes="100vw">
    {%- endif -%}
  {%- endif -%}
  {%- if template.name == 'product' -%}
    {%- if product.featured_image -%}
      <link rel="preload" as="image"
            href="{{ product.featured_image | image_url: width: 900 }}"
            imagesrcset="{{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w"
            imagesizes="(max-width: 767px) 100vw, 50vw">
    {%- endif -%}
  {%- endif -%}

  <!-- ============================================================
       GOOGLE FONTS
       ============================================================ -->

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  >

  <!-- ============================================================
       FAVICON
       ============================================================ -->

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <!-- ============================================================
       STYLES
       ============================================================ -->

  {{ 'base.css' | asset_url | stylesheet_tag }}

  {%- if template.name == 'index' or template.name == 'collection' or template.name == 'product' or template.name == 'search' -%}
    {{ 'component-card.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {{- 'component-cart-drawer.css' | asset_url | stylesheet_tag -}}

  {%- if template.name == 'product' and settings.motion_enabled -%}
    {{- 'component-sticky-atc.css' | asset_url | stylesheet_tag -}}
    {{- 'motion.css' | asset_url | stylesheet_tag -}}
  {%- endif -%}

  {{ content_for_header }}

  {%- comment -%} ── Google Analytics 4 ──────────────────────────── {%- endcomment -%}
  {%- if settings.google_analytics_id != blank -%}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.google_analytics_id }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ settings.google_analytics_id }}', {
        page_path: window.location.pathname
      });
    </script>
  {%- endif -%}

  <!-- ============================================================
       THEME SETTINGS — CSS OVERRIDES
       Allows merchant to adjust brand tokens via theme editor.
       ============================================================ -->
  <style>
    :root {
      {%- if settings.color_espresso != blank -%}
        --color-black: {{ settings.color_espresso }};
      {%- endif -%}
      {%- if settings.color_amber != blank -%}
        --color-walnut: {{ settings.color_amber }};
      {%- endif -%}
      {%- if settings.color_linen != blank -%}
        --color-bone: {{ settings.color_linen }};
        --color-bg:    {{ settings.color_linen }};
      {%- endif -%}
    }
  </style>


  <!-- Judge.me review widget — global mobile containment
       Applies to both the homepage app block widget and the product page
       auto-injected widget. Must live in theme.liquid, not in the
       judgeme-reviews section, so it loads on every page. -->
  <style>
    /* Wrapper that we control */
    .judgeme-reviews-wrapper {
      overflow: hidden;
      box-sizing: border-box;
      width: 100%;
      max-width: 100%;
    }

    @media (max-width: 767px) {
      /* Wrapper padding → 20px sides = visible gap from screen edge */
      .judgeme-reviews-wrapper {
        padding: 60px 20px 40px !important;
      }

      /* Direct padding on the widget itself — covers homepage app block
         which renders without .judgeme-reviews-wrapper */
      .jdgm-widget {
        padding-left: 20px !important;
        padding-right: 20px !important;
        box-sizing: border-box !important;
        width: 100% !important;
        max-width: 100% !important;
      }

      /* Force every jdgm container to respect the viewport */
      .jdgm-widget,
      .jdgm-rev-widg,
      .jdgm-rev-widg__body,
      .jdgm-rev-widg__header,
      .jdgm-rev-widg__reviews,
      .jdgm-rev,
      .jdgm-all-reviews-page,
      .jdgm-all-reviews-text-area {
        max-width: 100% !important;
        box-sizing: border-box !important;
        overflow-x: hidden !important;
      }

      /* Review cards */
      .jdgm-rev {
        padding-left: 0 !important;
        padding-right: 0 !important;
      }

      /* Photo/media gallery — let it scroll horizontally within its own box */
      .jdgm-carousel-wrapper,
      .jdgm-carousel,
      .jdgm-media-preview-container,
      .jdgm-media-gallery {
        max-width: 100% !important;
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch;
      }

      /* Summary / rating header */
      .jdgm-summary,
      .jdgm-summary__ratings,
      .jdgm-histogram {
        max-width: 100% !important;
        box-sizing: border-box !important;
      }

      /* Write-review / load-more buttons */
      .jdgm-rev-widg__btn-container {
        flex-wrap: wrap !important;
        gap: 8px;
      }

      /* Reviewer name + date row */
      .jdgm-rev__header {
        flex-wrap: wrap;
      }

      /* Judge.me v2 widget uses jm-* class names instead of jdgm-*.
         These inner elements have hardcoded 1200px widths and must
         be explicitly constrained so they don't expand the iOS
         layout viewport and shift the entire page. */
      .jm-review-widget,
      .jm-review-widget__header-and-body,
      .jm-stack,
      .jm-media-preview,
      .jm-media-grid {
        width: 100% !important;
        max-width: 100% !important;
        box-sizing: border-box !important;
        overflow-x: hidden !important;
      }
    }

    /* Replace the KaChing Bundles title text. Hide the original glyphs and
       overlay our own copy via pseudo-elements — original markup stays for app JS.
       ::before = small low-stock urgency, ::after = brand tagline. */
    .kaching-bundles__block-title {
      font-size: 0 !important;
      line-height: 1 !important;
      position: relative;
      text-align: center;
    }
    .kaching-bundles__block-title::before {
      content: "● Only 9 left in stock";
      display: block;
      font-family: var(--font-label, 'Inter', monospace);
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: #b91c1c;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }
    .kaching-bundles__block-title::after {
      content: "THE QUIET FLEX";
      font-family: var(--font-label, 'Inter', monospace);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      color: var(--color-walnut, #8a6240);
      display: inline-block;
      line-height: 1.2;
    }

    /* Spoof 5.0 → 4.9 in Judge.me widget */
    .jm-average-rating-display .jm-cluster > p.jm-text:first-child {
      visibility: hidden;
      position: relative;
    }
    .jm-average-rating-display .jm-cluster > p.jm-text:first-child::after {
      content: "4.9";
      visibility: visible;
      position: absolute;
      left: 0;
      top: 0;
    }

    /* Desktop: let Judge.me widget breathe */
    @media (min-width: 1024px) {
      .jdgm-widget,
      .jdgm-widget.jdgm-review-widget {
        max-width: 1280px !important;
      }
    }

  </style>

</head>

<body class="template-{{ template.name | replace: '/', '-' }}{% if customer %} customer-logged-in{% endif %}{% if settings.motion_enabled %} motion-on{% endif %}">

  {%- if template.name == 'product' and settings.motion_enabled -%}
    <div data-scroll-progress aria-hidden="true"></div>

    {%- comment -%}
      Top-of-page Mother's Day banner. Was previously "Only 47 left" —
      a static fake-scarcity number that doesn't reflect real inventory
      and erodes trust on refresh. Replaced with a real shipping-cutoff
      message that creates legitimate urgency without lying. Matches
      the Mday strip's deadline (11 May 2026 23:59 NZT, hidden after).
    {%- endcomment -%}
    <div class="mc-scarcity-banner" role="status" aria-live="polite">
      <div class="mc-scarcity-banner__inner">
        <span class="mc-scarcity-banner__dot" aria-hidden="true"></span>
        <span class="mc-scarcity-banner__text">
          <strong>Sale ending tonight</strong> &mdash; free shipping &middot; order before midnight
        </span>
      </div>
    </div>
  {%- endif -%}


  <!-- ============================================================
       ANNOUNCEMENT BAR
       ============================================================ -->
  {%- section 'announcement-bar' -%}

  <!-- ============================================================
       HEADER
       ============================================================ -->
  {%- section 'header' -%}

  <!-- ============================================================
       MAIN CONTENT
       ============================================================ -->
  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- ============================================================
       FOOTER
       ============================================================ -->
  {%- section 'footer' -%}

  <!-- ============================================================
       CART DRAWER
       ============================================================ -->
  {%- render 'cart-drawer' -%}

  <!-- ============================================================
       SCRIPTS
       ============================================================ -->

  <!-- Cart drawer + interactions -->
  <script src="{{ 'component-cart-drawer.js' | asset_url }}" defer></script>

  <!-- Core theme — mobile menu, quantity, variant switching -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

  <!-- Motion layer — reveals, counters, scroll progress (product page) -->
  {%- if template.name == 'product' and settings.motion_enabled -%}
    <script src="{{ 'motion.js' | asset_url }}" defer></script>
    <script src="{{ 'component-sticky-atc.js' | asset_url }}" defer></script>
  {%- endif -%}

  <!-- Back to top button — mobile only -->
  <button id="back-to-top" class="back-to-top" aria-label="Back to top" hidden>
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M8 13V3M3 8l5-5 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <style>
    /* ---- Variant selectors (Color / Size) — hidden everywhere ---- */
    .variant-fieldset { display: none !important; }

    /* ---- Mobile: hero info panel above gallery ---- */
    @media (max-width: 767px) {
      .product-info-above-gallery {
        padding: 20px 20px 0;
      }
      .product-info-above-gallery .product-eyebrow {
        margin-bottom: 6px;
      }
    }

    /* KaChing — free gift / perk text legibility */
    .kaching-bundles__free-gift__text {
      color: var(--color-black, #1f1d1a) !important;
    }

    /* KaChing — unselected card: warm bone instead of white */
    .kaching-bundles__bar-container {
      background: #ede8de !important;
    }
    /* Selected card stays lighter so the selection reads clearly */
    .kaching-bundles__bar--selected .kaching-bundles__bar-container {
      background: #f8f5f0 !important;
    }

    .back-to-top {
      position: fixed;
      bottom: 24px;
      right: 20px;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--char, #1f1d1a);
      color: var(--cream, #f5efe4);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 16px rgba(0,0,0,0.2);
      z-index: 900;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.25s ease, transform 0.25s ease;
      pointer-events: none;
    }
    .back-to-top.is-visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: all;
    }
    .back-to-top:hover {
      background: #2d2b28;
    }
    /* Desktop — hide it */
    @media (min-width: 768px) {
      .back-to-top { display: none !important; }
    }
  </style>

  <script>
  (function () {
    var btn = document.getElementById('back-to-top');
    if (!btn) return;
    btn.removeAttribute('hidden');
    window.addEventListener('scroll', function () {
      if (window.scrollY > 400) {
        btn.classList.add('is-visible');
      } else {
        btn.classList.remove('is-visible');
      }
    }, { passive: true });
    btn.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();
  </script>

  <!-- No-JS fallback: make data-reveal elements visible if JS is blocked -->
  <noscript><style>[data-reveal]{opacity:1!important;transform:none!important}</style></noscript>

  <!-- Reveal observer -->
  <script>
  (function () {
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var els = document.querySelectorAll('[data-reveal]');
    if (!els.length) return;
    if (reduced || !('IntersectionObserver' in window)) {
      els.forEach(function (el) { el.classList.add('is-visible'); });
      return;
    }
    els.forEach(function (el) {
      var d = el.dataset.revealDelay;
      if (d) el.style.transitionDelay = d + 'ms';
    });
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.12 });
    els.forEach(function (el) { observer.observe(el); });
  })();
  </script>


  <script>
  /* Mobile: move eyebrow/title/reviews above the gallery, and when
     motion is on, wrap them in a full-bleed video hero (Apple/Oura
     product-page style) using the smart-band hero clip. */
  (function () {
    if (!window.matchMedia('(max-width: 767px)').matches) return;
    var gallery = document.querySelector('.product-gallery');
    if (!gallery) return;

    var motionOn = document.body.classList.contains('motion-on');
    var isSmartBand = !!document.querySelector('[data-section-type="main-product"]') &&
                      /smart[-_]?band/i.test(window.location.pathname);

    var toMove = ['.product-eyebrow', '.product-title', '.product-rating'];
    var wrapper = document.createElement('div');
    wrapper.className = (motionOn && isSmartBand)
      ? 'product-info-above-gallery mc-mobile-hero'
      : 'product-info-above-gallery';

    /* Build hero video first so it sits BEHIND the moved text */
    if (motionOn && isSmartBand) {
      var video = document.createElement('video');
      video.className = 'mc-mobile-hero__video';
      video.autoplay = true;
      video.muted = true;
      video.loop = true;
      video.playsInline = true;
      video.setAttribute('playsinline', '');
      video.setAttribute('width', '390');
      video.setAttribute('height', '844');
      video.preload = 'metadata';
      video.poster = 'https://cdn.shopify.com/s/files/1/0996/2451/7925/files/preview_images/291540b377714ee29b2d878d6fa6ebf1.thumbnail.0000000000.jpg?v=1777888782';
      video.innerHTML =
        '<source src="https://cdn.shopify.com/videos/c/vp/291540b377714ee29b2d878d6fa6ebf1/291540b377714ee29b2d878d6fa6ebf1.SD-480p-0.9Mbps-83318428.mp4" type="video/mp4" media="(max-width: 750px)">' +
        '<source src="https://cdn.shopify.com/videos/c/vp/291540b377714ee29b2d878d6fa6ebf1/291540b377714ee29b2d878d6fa6ebf1.HD-720p-1.6Mbps-83318428.mp4" type="video/mp4">';
      wrapper.appendChild(video);

      /* iOS Low Power Mode (and some Android browsers) block autoplay
         even on muted+playsinline videos. Try to play immediately, and
         retry on the first user interaction so the video kicks in as
         soon as the user touches the screen. */
      var tryPlay = function () {
        var p = video.play();
        if (p && typeof p.catch === 'function') p.catch(function () {});
      };
      tryPlay();
      var resumeOnce = function () {
        tryPlay();
        document.removeEventListener('touchstart', resumeOnce);
        document.removeEventListener('click', resumeOnce);
        document.removeEventListener('scroll', resumeOnce);
      };
      document.addEventListener('touchstart', resumeOnce, { passive: true });
      document.addEventListener('click', resumeOnce);
      document.addEventListener('scroll', resumeOnce, { passive: true });

      var overlay = document.createElement('div');
      overlay.className = 'mc-mobile-hero__overlay';
      overlay.setAttribute('aria-hidden', 'true');
      wrapper.appendChild(overlay);

      var content = document.createElement('div');
      content.className = 'mc-mobile-hero__content';
      toMove.forEach(function (sel) {
        var el = document.querySelector(sel);
        if (el) content.appendChild(el);
      });
      wrapper.appendChild(content);

      /* Soft scroll cue at the bottom of the hero */
      var scrollCue = document.createElement('div');
      scrollCue.className = 'mc-mobile-hero__cue';
      scrollCue.setAttribute('aria-hidden', 'true');
      scrollCue.innerHTML = '<span></span>';
      wrapper.appendChild(scrollCue);
    } else {
      toMove.forEach(function (sel) {
        var el = document.querySelector(sel);
        if (el) wrapper.appendChild(el);
      });
    }

    if (wrapper.children.length) {
      gallery.parentElement.insertBefore(wrapper, gallery);
    }
  })();
  </script>

  <script>
  /* Global autoplay rescue: iOS Low Power Mode and some Android
     browsers block muted-autoplay. Retry .play() on every <video
     autoplay> on the page on first user interaction. */
  (function () {
    var nudge = function () {
      document.querySelectorAll('video[autoplay]').forEach(function (v) {
        if (v.paused) {
          var p = v.play();
          if (p && typeof p.catch === 'function') p.catch(function () {});
        }
      });
    };
    nudge();
    var once = function () {
      nudge();
      document.removeEventListener('touchstart', once);
      document.removeEventListener('click', once);
      document.removeEventListener('scroll', once);
    };
    document.addEventListener('touchstart', once, { passive: true });
    document.addEventListener('click', once);
    document.addEventListener('scroll', once, { passive: true });
  })();
  </script>

