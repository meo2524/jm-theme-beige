{%- comment -%}
  Floating mini orbs — site-wide ambient background.
  Position: fixed behind all content. Pointer-events: none so they never block clicks.
  Reduced motion: animations disabled, orbs static.
  Brand rule: real 3D sphere via radial-gradient + box-shadow. Never filter:blur.
{%- endcomment -%}

<div class="mc-orbs" aria-hidden="true">
  <span class="mc-orb mc-orb--1"></span>
  <span class="mc-orb mc-orb--2"></span>
  <span class="mc-orb mc-orb--3"></span>
  <span class="mc-orb mc-orb--4"></span>
  <span class="mc-orb mc-orb--5"></span>
  <span class="mc-orb mc-orb--6"></span>
  <span class="mc-orb mc-orb--7"></span>
  <span class="mc-orb mc-orb--8"></span>
  <span class="mc-orb mc-orb--9"></span>
  <span class="mc-orb mc-orb--10"></span>
  <span class="mc-orb mc-orb--11"></span>
  <span class="mc-orb mc-orb--12"></span>
  <span class="mc-orb mc-orb--13"></span>
  <span class="mc-orb mc-orb--14"></span>
</div>

<style>
  .mc-orbs {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: multiply;
  }

  .mc-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    background: radial-gradient(circle at 38% 32%,
      #fbeede 0%, #f1d4a5 22%, #d9a874 50%, #b3804f 80%, #6a3a1f 94%, rgba(106,58,31,0) 100%
    );
    box-shadow:
      inset 0 0 0 1px rgba(255,250,240,0.18),
      inset 0 0 12px 2px rgba(239,232,220,0.10),
      0 8px 24px -6px rgba(168,129,79,0.25),
      0 0 30px 4px rgba(217,160,95,0.18);
    opacity: 0.18;
    will-change: transform;
  }

  /* Drift animation — slow vertical fall + slight horizontal sway */
  @keyframes mc-orb-drift {
    0%   { transform: translate3d(0, -10vh, 0); }
    50%  { transform: translate3d(8px, 50vh, 0); }
    100% { transform: translate3d(-6px, 110vh, 0); }
  }

  /* Each orb: random size, start position, duration, delay */
  .mc-orb--1  { width: 32px; height: 32px; left:  6%; animation: mc-orb-drift 32s linear infinite;        animation-delay:  -2s; opacity: 0.16; }
  .mc-orb--2  { width: 18px; height: 18px; left: 14%; animation: mc-orb-drift 24s linear infinite;        animation-delay:  -8s; opacity: 0.12; }
  .mc-orb--3  { width: 44px; height: 44px; left: 22%; animation: mc-orb-drift 40s linear infinite;        animation-delay: -14s; opacity: 0.20; }
  .mc-orb--4  { width: 24px; height: 24px; left: 30%; animation: mc-orb-drift 28s linear infinite;        animation-delay: -20s; opacity: 0.14; }
  .mc-orb--5  { width: 36px; height: 36px; left: 38%; animation: mc-orb-drift 36s linear infinite;        animation-delay:  -5s; opacity: 0.18; }
  .mc-orb--6  { width: 20px; height: 20px; left: 46%; animation: mc-orb-drift 26s linear infinite;        animation-delay: -11s; opacity: 0.12; }
  .mc-orb--7  { width: 50px; height: 50px; left: 54%; animation: mc-orb-drift 44s linear infinite;        animation-delay: -17s; opacity: 0.22; }
  .mc-orb--8  { width: 28px; height: 28px; left: 62%; animation: mc-orb-drift 30s linear infinite;        animation-delay: -23s; opacity: 0.15; }
  .mc-orb--9  { width: 40px; height: 40px; left: 70%; animation: mc-orb-drift 38s linear infinite;        animation-delay:  -3s; opacity: 0.18; }
  .mc-orb--10 { width: 22px; height: 22px; left: 78%; animation: mc-orb-drift 27s linear infinite;        animation-delay: -10s; opacity: 0.13; }
  .mc-orb--11 { width: 34px; height: 34px; left: 84%; animation: mc-orb-drift 34s linear infinite;        animation-delay: -16s; opacity: 0.17; }
  .mc-orb--12 { width: 16px; height: 16px; left: 90%; animation: mc-orb-drift 22s linear infinite;        animation-delay: -25s; opacity: 0.10; }
  .mc-orb--13 { width: 46px; height: 46px; left: 96%; animation: mc-orb-drift 42s linear infinite;        animation-delay:  -7s; opacity: 0.20; }
  .mc-orb--14 { width: 26px; height: 26px; left:  2%; animation: mc-orb-drift 29s linear infinite;        animation-delay: -19s; opacity: 0.14; }

  /* Mobile: fewer, smaller orbs */
  @media (max-width: 767px) {
    .mc-orb { transform: scale(0.7); }
    .mc-orb--1, .mc-orb--3, .mc-orb--5, .mc-orb--7, .mc-orb--9, .mc-orb--11, .mc-orb--13 {
      display: none;
    }
  }

  /* Respect reduced motion: keep orbs visible but static */
  @media (prefers-reduced-motion: reduce) {
    .mc-orb { animation: none !important; }
  }
</style>
