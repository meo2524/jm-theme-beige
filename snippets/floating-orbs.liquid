{%- comment -%}
  Floating mini orbs — site-wide ambient background.
  Position: fixed above content with mix-blend-mode multiply, very low opacity.
  Each orb drifts in a slow 2D loop (not falling). Pointer-events: none.
  Brand rule: real 3D sphere via radial-gradient + box-shadow. Never filter:blur.
{%- endcomment -%}

<div class="mc-orbs" aria-hidden="true">
  <span class="mc-orb mc-orb--1"></span>
  <span class="mc-orb mc-orb--2"></span>
  <span class="mc-orb mc-orb--3"></span>
  <span class="mc-orb mc-orb--4"></span>
  <span class="mc-orb mc-orb--5"></span>
  <span class="mc-orb mc-orb--6"></span>
  <span class="mc-orb mc-orb--7"></span>
  <span class="mc-orb mc-orb--8"></span>
  <span class="mc-orb mc-orb--9"></span>
  <span class="mc-orb mc-orb--10"></span>
  <span class="mc-orb mc-orb--11"></span>
  <span class="mc-orb mc-orb--12"></span>
</div>

<style>
  .mc-orbs {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: multiply;
  }

  .mc-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    background: radial-gradient(circle at 38% 32%,
      #fbeede 0%, #f1d4a5 22%, #d9a874 50%, #b3804f 80%, #6a3a1f 94%, rgba(106,58,31,0) 100%
    );
    box-shadow:
      inset 0 0 0 1px rgba(255,250,240,0.18),
      inset 0 0 12px 2px rgba(239,232,220,0.10),
      0 8px 24px -6px rgba(168,129,79,0.25),
      0 0 30px 4px rgba(217,160,95,0.18);
    opacity: 0.06;
    will-change: transform;
  }

  /* Six different drift loops — orbs roam in 2D rather than fall */
  @keyframes mc-orb-roam-a {
    0%   { transform: translate3d(0,    0,    0); }
    25%  { transform: translate3d(60px, -80px, 0); }
    50%  { transform: translate3d(-40px, -30px, 0); }
    75%  { transform: translate3d(30px, 50px, 0); }
    100% { transform: translate3d(0,    0,    0); }
  }
  @keyframes mc-orb-roam-b {
    0%   { transform: translate3d(0,    0,    0); }
    33%  { transform: translate3d(-70px, 60px, 0); }
    66%  { transform: translate3d(40px, -50px, 0); }
    100% { transform: translate3d(0,    0,    0); }
  }
  @keyframes mc-orb-roam-c {
    0%   { transform: translate3d(0,    0,    0); }
    25%  { transform: translate3d(-50px, -70px, 0); }
    50%  { transform: translate3d(80px, 20px, 0); }
    75%  { transform: translate3d(-20px, 60px, 0); }
    100% { transform: translate3d(0,    0,    0); }
  }
  @keyframes mc-orb-roam-d {
    0%   { transform: translate3d(0,    0,    0); }
    50%  { transform: translate3d(50px, 70px, 0); }
    100% { transform: translate3d(0,    0,    0); }
  }

  /* Each orb: position pinned to a viewport %, slow roam loop, varied delays */
  .mc-orb--1  { width: 28px; height: 28px; top: 12%; left:  8%; animation: mc-orb-roam-a 38s ease-in-out infinite; animation-delay:  -2s; }
  .mc-orb--2  { width: 18px; height: 18px; top: 28%; left: 18%; animation: mc-orb-roam-b 32s ease-in-out infinite; animation-delay:  -8s; }
  .mc-orb--3  { width: 44px; height: 44px; top: 44%; left: 28%; animation: mc-orb-roam-c 46s ease-in-out infinite; animation-delay: -14s; }
  .mc-orb--4  { width: 22px; height: 22px; top: 64%; left: 12%; animation: mc-orb-roam-d 36s ease-in-out infinite; animation-delay: -20s; }
  .mc-orb--5  { width: 32px; height: 32px; top: 82%; left: 22%; animation: mc-orb-roam-a 42s ease-in-out infinite; animation-delay:  -5s; }
  .mc-orb--6  { width: 24px; height: 24px; top: 18%; left: 46%; animation: mc-orb-roam-b 34s ease-in-out infinite; animation-delay: -11s; }
  .mc-orb--7  { width: 38px; height: 38px; top: 38%; left: 56%; animation: mc-orb-roam-c 48s ease-in-out infinite; animation-delay: -17s; }
  .mc-orb--8  { width: 20px; height: 20px; top: 58%; left: 48%; animation: mc-orb-roam-d 30s ease-in-out infinite; animation-delay: -23s; }
  .mc-orb--9  { width: 36px; height: 36px; top: 76%; left: 64%; animation: mc-orb-roam-a 44s ease-in-out infinite; animation-delay:  -3s; }
  .mc-orb--10 { width: 26px; height: 26px; top: 14%; left: 78%; animation: mc-orb-roam-b 33s ease-in-out infinite; animation-delay: -10s; }
  .mc-orb--11 { width: 30px; height: 30px; top: 42%; left: 86%; animation: mc-orb-roam-c 40s ease-in-out infinite; animation-delay: -16s; }
  .mc-orb--12 { width: 16px; height: 16px; top: 70%; left: 90%; animation: mc-orb-roam-d 28s ease-in-out infinite; animation-delay: -25s; }

  /* Mobile: half the orbs, smaller */
  @media (max-width: 767px) {
    .mc-orb { transform: scale(0.7); }
    .mc-orb--1, .mc-orb--3, .mc-orb--5, .mc-orb--7, .mc-orb--9, .mc-orb--11 {
      display: none;
    }
  }

  /* Respect reduced motion: keep orbs visible but static */
  @media (prefers-reduced-motion: reduce) {
    .mc-orb { animation: none !important; }
  }
</style>
