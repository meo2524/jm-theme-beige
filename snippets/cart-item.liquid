{% comment %}
  cart-item.liquid -- Mend & Co
  Parameters: item {object}, context {string} 'page' | 'drawer'
{% endcomment %}

{%- assign ctx = context | default: 'page' -%}

{%- comment -%} Use compare_at_price (product discount) or original_line_price (code discount), whichever is higher {%- endcomment -%}
{%- assign compare_at_total = item.variant.compare_at_price | times: item.quantity -%}
{%- assign display_compare  = item.original_line_price -%}
{%- if compare_at_total > item.original_line_price -%}
  {%- assign display_compare = compare_at_total -%}
{%- endif -%}
{%- assign savings = display_compare | minus: item.final_line_price -%}

<div
  class="cart-item cart-item--{{ ctx }}"
  data-cart-item="{{ item.key }}"
  data-variant-id="{{ item.variant_id }}"
>

  <a href="{{ item.url }}" class="cart-item__img-link" tabindex="-1" aria-hidden="true">
    <div class="cart-item__img-wrap">
      {%- if item.image -%}
        <img
          src="{{ item.image | image_url: width: 80 }}"
          alt="{{ item.image.alt | default: item.title | escape }}"
          width="80" height="80"
          loading="lazy"
          class="cart-item__img"
        >
      {%- else -%}
        <div class="cart-item__img-placeholder"></div>
      {%- endif -%}
    </div>
  </a>

  <div class="cart-item__body">

    <div class="cart-item__top">
      <div class="cart-item__meta">
        <a href="{{ item.url }}" class="cart-item__title-link">
          <span class="cart-item__title">{{ item.product.title }}</span>
        </a>
        {%- unless item.product.has_only_default_variant -%}
          <p class="cart-item__variant">{{ item.variant.title }}</p>
        {%- endunless -%}
        {%- if item.selling_plan_allocation -%}
          <p class="cart-item__sub">{{ item.selling_plan_allocation.selling_plan.name }}</p>
        {%- endif -%}
      </div>
      <button
        class="cart-item__remove"
        type="button"
        aria-label="Remove {{ item.title | escape }} from cart"
        data-item-remove="{{ item.key }}"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
        </svg>
      </button>
    </div>

    <div class="cart-item__bottom">
      {%- unless item.product.handle == 'shipping-protection' -%}
        <div class="cart-item__qty qty-stepper" role="group" aria-label="Quantity for {{ item.title | escape }}">
          <button class="qty-btn" type="button" aria-label="Decrease quantity" data-qty-change="-1">-</button>
          <input
            class="qty-input"
            type="number"
            name="updates[]"
            value="{{ item.quantity }}"
            min="0"
            aria-label="Quantity"
            data-item-qty
          >
          <button class="qty-btn" type="button" aria-label="Increase quantity" data-qty-change="1">+</button>
        </div>
      {%- endunless -%}

      <div class="cart-item__price-group">
        {%- if savings > 0 -%}
          <span class="cart-item__price-compare">{{ display_compare | money }}</span>
        {%- endif -%}
        <span class="cart-item__price" data-item-price>{{ item.final_line_price | money }}</span>
        {%- if savings > 0 -%}
          <span class="cart-item__save-badge">Save {{ savings | money }}</span>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>
