{% comment %} Dropmagic Asset | Version: 1.0.0 {% endcomment %}
{%- comment -%}
  DropMagic Utility Functions
  This file contains various utility functions for styling and layout.

  Usage:
  - For media: {% render 'dm_classname_utils', type: 'media', media_style: 'default' %}
  - For button: {% render 'dm_classname_utils', type: 'button', button_style: 'default' %}
  - For card: {% render 'dm_classname_utils', type: 'card', card_style: 'default' %}
  - For accordion: {% render 'dm_classname_utils', type: 'accordion', accordion_style: 'default' %}
  - For variant_button: {% render 'dm_classname_utils', type: 'variant_button', variant_button_style: 'default' %}
{%- endcomment -%}

{%- if type == 'media' -%}
  {%- liquid
    assign media_style = media_style | default: 'none'
    assign media_variant_key = media_style
  -%}

  {%- capture media_class -%}
  {%- case media_variant_key -%}
    {%- when 'none' -%}
      rounded-md
    {%- when 'brick' -%}
      rounded-md border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,0.8)]
    {%- when 'light' -%}
      rounded-md border border-gray-200
    {%- when 'solid' -%}
      rounded-md border-2 border-black
    {%- when 'polaroid' -%}
      rounded-sm border-[12px] border-white !border-b-[1.5rem] shadow-md bg-white relative
    {%- when 'shadow' -%}
      rounded-md shadow-md
  {%- endcase -%}
  {%- endcapture -%}
  {{ media_class }}
  
{%- elsif type == 'button' -%}
