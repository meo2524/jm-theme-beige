    assign button_size = button_size | default: 'xs'
    assign button_width = button_width | default: 'full'
    assign button_variant = button_variant | default: 'primary'
    assign button_style = button_style | default: 'classic'
    assign button_variant_key = button_size | append: '_' | append: button_width | append: '_' | append: button_variant | append: '_' | append: button_style
