{% comment %}
  cart-drawer.liquid -- Mend & Co
{% endcomment %}

{%- liquid
  assign cart_product_ids = cart.items | map: 'product_id'

  assign cart_savings = cart.original_total_price | minus: cart.total_price
  for item in cart.items
    if item.variant.compare_at_price > item.variant.price
      assign compare_delta = item.variant.compare_at_price | minus: item.variant.price | times: item.quantity
      assign cart_savings = cart_savings | plus: compare_delta
    endif
  endfor

  assign m1_cents = 0
  assign m1_label = ''
  assign m1_icon  = ''
  assign m2_cents = 0
  assign m2_label = ''
  assign m2_icon  = ''
  assign milestone_count = 0

  if settings.goal_shipping_enabled and settings.goal_shipping_amount > 0
    assign m1_cents = settings.goal_shipping_amount | times: 100
    assign m1_label = 'Free shipping'
    assign m1_icon  = 'truck'
    assign milestone_count = 1
  endif

  if settings.goal_gift_enabled and settings.goal_gift_amount > 0
    assign gift_cents = settings.goal_gift_amount | times: 100
    if milestone_count == 0
      assign m1_cents = gift_cents
      assign m1_label = 'Free gift'
      assign m1_icon  = 'gift'
      assign milestone_count = 1
    else
      assign m2_cents = gift_cents
      assign m2_label = 'Free gift'
      assign m2_icon  = 'gift'
      assign milestone_count = 2
    endif
  endif
-%}

<div
  id="CartDrawer"
  class="cart-drawer"
  aria-hidden="true"
  aria-label="Shopping cart"
  role="dialog"
  aria-modal="true"
  data-cart-drawer
>
  <div class="cart-drawer__overlay" data-cart-overlay aria-hidden="true"></div>

  <div class="cart-drawer__panel">

    {%- comment -%} Header {%- endcomment -%}
    <div class="cart-drawer__header">
      <p class="cart-drawer__heading">
        Your cart
        <span class="cart-drawer__item-count" data-cart-count-label>
          {%- if cart.item_count > 0 -%}
            ({{ cart.item_count }} item{%- if cart.item_count != 1 -%}s{%- endif -%})
          {%- endif -%}
        </span>
      </p>
      <button class="cart-drawer__close" type="button" aria-label="Close cart" data-cart-close>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M1 1l14 14M15 1L1 15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%} Social proof bar {%- endcomment -%}
    <div class="cart-drawer__proof">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      JOIN OVER 5,000 HAPPY CUSTOMERS
    </div>

    {%- comment -%} Savings banner (always in DOM; JS toggles [hidden]) {%- endcomment -%}
    <div
      class="cart-drawer__savings"
      data-cart-savings
      {% if cart_savings <= 0 or cart.item_count == 0 %}hidden{% endif %}
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
      </svg>
      <span>You&rsquo;re saving <strong data-cart-savings-amount>{{ cart_savings | money }}</strong> on this order</span>
    </div>

    {%- comment -%} Cart goals progress bar (0, 1, or 2 milestones) — always in DOM; JS toggles [hidden] {%- endcomment -%}
    {%- if milestone_count > 0 -%}
      {%- liquid
        assign m1_reached = false
        assign m2_reached = false
        if cart.total_price >= m1_cents
          assign m1_reached = true
        endif
        if milestone_count == 2 and cart.total_price >= m2_cents
          assign m2_reached = true
        endif

        if milestone_count == 1
          assign fill1_pct = cart.total_price | times: 100 | divided_by: m1_cents | at_most: 100
          assign fill2_pct = 0
        else
          assign fill1_pct = cart.total_price | times: 100 | divided_by: m1_cents | at_most: 100
          assign right_raw = cart.total_price | minus: m1_cents | at_least: 0
          assign gap_cents  = m2_cents | minus: m1_cents
          assign fill2_pct = right_raw | times: 100 | divided_by: gap_cents | at_most: 100
        endif

        assign m1_dollars = m1_cents | divided_by: 100
        assign m2_dollars = m2_cents | divided_by: 100
      -%}

      {%- capture icon_truck -%}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/>
          <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
      {%- endcapture -%}
      {%- capture icon_gift -%}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5" rx="1"/>
          <line x1="12" y1="22" x2="12" y2="7"/>
          <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
          <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
        </svg>
      {%- endcapture -%}

      <div
        class="cart-goals{% if milestone_count == 1 %} cart-goals--single{% endif %}"
        id="CartGoals"
        data-milestones="{{ milestone_count }}"
        data-goal1="{{ m1_cents }}"
        data-goal2="{{ m2_cents }}"
        {% if cart.item_count == 0 %}hidden{% endif %}
      >
        <div class="cart-goals__row">

          <div class="cart-goals__segment">
            <div class="cart-goals__track">
              <div class="cart-goals__fill" id="CartGoalsFill1" data-pct="{{ fill1_pct }}" style="width: 0%"></div>
            </div>
            <div class="cart-goals__node{% if m1_reached %} is-reached{% endif %}">
              {%- if m1_icon == 'truck' -%}{{ icon_truck }}{%- else -%}{{ icon_gift }}{%- endif -%}
            </div>
          </div>

          {%- if milestone_count == 2 -%}
            <div class="cart-goals__segment">
              <div class="cart-goals__track">
                <div class="cart-goals__fill" id="CartGoalsFill2" data-pct="{{ fill2_pct }}" style="width: 0%"></div>
              </div>
              <div class="cart-goals__node{% if m2_reached %} is-reached{% endif %}">
                {%- if m2_icon == 'truck' -%}{{ icon_truck }}{%- else -%}{{ icon_gift }}{%- endif -%}
              </div>
            </div>
          {%- endif -%}

        </div>
        <div class="cart-goals__labels">
          <div class="cart-goals__label{% if m1_reached %} is-reached{% endif %}">
            <span class="cart-goals__label-name">{{ m1_label }}</span>
            <span class="cart-goals__label-sub">Spend <span class="money">{{ m1_cents | money_without_trailing_zeros }}</span></span>
          </div>
          {%- if milestone_count == 2 -%}
            <div class="cart-goals__label{% if m2_reached %} is-reached{% endif %}">
              <span class="cart-goals__label-name">{{ m2_label }}</span>
              <span class="cart-goals__label-sub">Spend <span class="money">{{ m2_cents | money_without_trailing_zeros }}</span></span>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Scrollable body {%- endcomment -%}
    <div class="cart-drawer__body">

      <div data-cart-items>
        {%- if cart.item_count > 0 -%}
          {%- for item in cart.items -%}
            {%- render 'cart-item', item: item, context: 'drawer' -%}
          {%- endfor -%}
        {%- else -%}
          <div class="cart-drawer__empty">
            <div class="cart-drawer__empty-rule"></div>
            <p class="cart-drawer__empty-text">Your cart is empty</p>
            <a href="{{ routes.all_products_collection_url }}" class="cart-drawer__shop-link" data-cart-close>
              Start shopping
            </a>
          </div>
        {%- endif -%}
      </div>

      {%- if collections.all.products.size > 0 -%}
        <div class="cart-upsells" data-cart-upsells {% if cart.item_count == 0 %}hidden{% endif %}>
          <p class="cart-upsells__heading">Trending this month</p>
          <div class="cart-upsells__list">
            {%- for upsell in collections.all.products limit: 4 -%}
              {%- unless cart_product_ids contains upsell.id -%}
                <div class="cart-upsell">
                  <a href="{{ upsell.url }}" class="cart-upsell__img-wrap" tabindex="-1" aria-hidden="true">
                    {%- if upsell.featured_media -%}
                      <img
                        src="{{ upsell.featured_media | image_url: width: 80 }}"
                        alt="{{ upsell.featured_media.alt | default: upsell.title | escape }}"
                        width="80" height="80"
                        loading="lazy"
                        class="cart-upsell__img"
                      >
                    {%- else -%}
                      <div class="cart-upsell__img-placeholder"></div>
                    {%- endif -%}
                  </a>
                  <div class="cart-upsell__info">
                    <a href="{{ upsell.url }}" class="cart-upsell__name">{{ upsell.title }}</a>
                    <form action="/cart/add" method="post" data-type="add-to-cart-form">
                      <input type="hidden" name="id" value="{{ upsell.selected_or_first_available_variant.id }}">
                      <button type="submit" class="cart-upsell__btn" name="add" data-atc-btn>
                        Add to cart &ndash; {{ upsell.price | money }}
                      </button>
                    </form>
                  </div>
                </div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

    </div>

    {%- comment -%} Footer (always in DOM; hidden via .is-hidden when empty) {%- endcomment -%}
    <div class="cart-drawer__footer{% if cart.item_count == 0 %} is-hidden{% endif %}" data-cart-footer>

      <label class="cart-drawer__protection" for="CartProtectionToggle">
        <div class="cart-drawer__protection-left">
          <svg class="cart-drawer__protection-icon" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
          <div class="cart-drawer__protection-text">
            <p class="cart-drawer__protection-name">Shipping protection &ndash; <span class="money">{{ 350 | money }}</span></p>
            <p class="cart-drawer__protection-desc">Covers damage, loss or theft during shipping.</p>
          </div>
        </div>
        <div class="cart-drawer__toggle">
          <input type="checkbox" id="CartProtectionToggle" class="cart-drawer__toggle-input" aria-label="Add shipping protection">
          <span class="cart-drawer__toggle-track"></span>
        </div>
      </label>

      <a href="/checkout" class="cart-drawer__checkout" id="CartDrawerCheckout">
        CHECKOUT &bull; <span data-cart-total>{{ cart.total_price | money }}</span>
      </a>

      <div class="cart-drawer__payments" aria-label="Accepted payment methods">
        {%- assign payment_types = 'visa,master,american_express,apple_pay,shopify_pay,paypal,google_pay' | split: ',' -%}
        {%- for type in payment_types -%}
          <span class="payment-badge">
            {{ type | payment_type_svg_tag: class: 'payment-badge__icon' }}
          </span>
        {%- endfor -%}
      </div>

    </div>

  </div>
</div>
