<div
  id="cart-drawer"
  class="cart-drawer"
  aria-hidden="true"
  aria-label="Cart"
  role="dialog"
  data-cart-drawer
>
  <div class="cart-drawer__overlay" data-cart-overlay></div>
  <div class="cart-drawer__panel">
    <div class="cart-drawer__header">
      <p class="t-label">Cart ({{ cart.item_count }})</p>
      <button class="header__icon-btn" aria-label="Close cart" data-cart-close>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="cart-drawer__body" data-cart-items>
      {%- if cart.item_count == 0 -%}
        <p class="cart-drawer__empty">Your cart is empty.</p>
      {%- else -%}
        {%- for item in cart.items -%}
          {%- render 'cart-item', item: item -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__total">
        <span class="t-label">Total</span>
        <span class="price price--large">{{ cart.total_price | money }}</span>
      </div>
      <a href="{{ routes.checkout }}" class="btn btn--primary btn--lg" style="width:100%;">Checkout</a>
      <a href="{{ routes.cart_url }}" class="btn btn--secondary" style="width:100%;margin-top:0.5rem;">View cart</a>
    </div>
  </div>
</div>
