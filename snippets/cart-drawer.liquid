{% comment %}
  cart-drawer.liquid
  Mend & Co — slide-in cart drawer rendered in theme.liquid.
  Opens from the right. Managed by component-cart-drawer.js.
{% endcomment %}

<div
  id="CartDrawer"
  class="cart-drawer"
  aria-hidden="true"
  aria-label="Shopping cart"
  role="dialog"
  aria-modal="true"
  data-cart-drawer
>

  {%- comment -%} Overlay {%- endcomment -%}
  <div
    class="cart-drawer__overlay"
    data-cart-overlay
    aria-hidden="true"
  ></div>

  {%- comment -%} Panel {%- endcomment -%}
  <div class="cart-drawer__panel">

    {%- comment -%} Header {%- endcomment -%}
    <div class="cart-drawer__header">
      <p class="cart-drawer__heading">
        Cart
        <span class="cart-drawer__count" data-cart-count>
          {%- if cart.item_count > 0 -%}{{ cart.item_count }}{%- endif -%}
        </span>
      </p>
      <button
        class="cart-drawer__close"
        type="button"
        aria-label="Close cart"
        data-cart-close
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <line x1="1" y1="1" x2="17" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="17" y1="1" x2="1" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%} Body {%- endcomment -%}
    <div class="cart-drawer__body" data-cart-items>
      {%- if cart.item_count > 0 -%}
        {%- for item in cart.items -%}
          {%- render 'cart-item', item: item, context: 'drawer' -%}
        {%- endfor -%}
      {%- else -%}
        <div class="cart-drawer__empty">
          <div class="cart-drawer__empty-rule"></div>
          <p class="cart-drawer__empty-text">Your cart is empty</p>
          <a href="{{ routes.all_products_collection_url }}" class="cart-drawer__shop-link" data-cart-close>
            Start shopping
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Footer {%- endcomment -%}
    <div class="cart-drawer__footer" data-cart-footer>
      {%- if cart.item_count > 0 -%}
        <div class="cart-drawer__subtotal">
          <span class="cart-drawer__subtotal-label">Subtotal</span>
          <span class="cart-drawer__subtotal-price" data-cart-total>{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-drawer__shipping-note">Shipping &amp; taxes calculated at checkout</p>
        <a
          href="{{ routes.checkout }}"
          class="cart-drawer__checkout"
          id="CartDrawerCheckout"
        >
          Checkout
        </a>
        <a href="{{ routes.cart_url }}" class="cart-drawer__view-cart">View full cart</a>
      {%- endif -%}
    </div>

  </div>
</div>
