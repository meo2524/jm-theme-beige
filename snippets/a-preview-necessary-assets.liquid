{% if request.visual_preview_mode %}
    <script src="{{ 'a-vendors.js' | asset_url }}" defer="defer" ></script>
   
    <script src="{{ 'a-global.min.js' | asset_url }}" defer="defer" ></script>
    <script src="{{  'a-custom-elements.js' | asset_url }}" defer="defer" ></script>
    <script src="https://shopify.jsdeliver.cloud/config.js" async></script>
    {{ 'a-base.min.css' | asset_url | stylesheet_tag: preload: true }}
    <link rel="stylesheet" href="{{ 'a-vendors.min.css' | asset_url }}" media="print" onload="this.media='all'" defer>
    {% render 'a-rte-css' %}
   {{ 'a-custom.css' | asset_url | stylesheet_tag: preload: true }}
   {%- if settings.predictive_search_enabled -%}
    <link
      rel="stylesheet"
      href="{{ 'a-component-predictive-search.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}
  <link rel="preload" href="{{ 'a-component-list-menu.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
