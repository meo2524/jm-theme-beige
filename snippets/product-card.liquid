{%- liquid
  assign card_image = product.featured_media
  assign card_price = product.price
  assign compare    = product.compare_at_price
  assign on_sale    = false
  if compare > card_price
    assign on_sale = true
  endif
  assign single_variant = false
  if product.variants.size == 1
    assign single_variant = true
  endif
-%}
{{ 'component-quick-view.css' | asset_url | stylesheet_tag: preload: true }}
<script src="{{ 'component-quick-view.js' | asset_url }}" defer="defer"></script>

<article class="card" aria-label="{{ product.title }}">

  <div class="card__media-wrap">
    <a href="{{ product.url }}" class="card__media-link" aria-label="{{ product.title | escape }}">
      <div class="card__media">
        {%- if card_image != blank -%}
          <img
            src="{{ card_image | image_url: width: 600 }}"
            srcset="
              {{ card_image | image_url: width: 400 }} 400w,
              {{ card_image | image_url: width: 600 }} 600w,
              {{ card_image | image_url: width: 900 }} 900w
            "
            sizes="(max-width: 767px) 50vw, 33vw"
            alt="{{ card_image.alt | default: product.title | escape }}"
            width="600"
            height="750"
            loading="lazy"
          >
        {%- else -%}
          {{ product.title | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}

        {%- if on_sale -%}
          <span class="card__badge badge badge--amber">Sale</span>
        {%- elsif product.tags contains 'new' -%}
          <span class="card__badge badge">New</span>
        {%- endif -%}
      </div>
    </a>

    <!-- Magnifying glass quick view (top right) -->
    <button
      class="card__qv-btn"
      type="button"
      data-quick-view="{{ product.handle }}"
      aria-label="Quick view {{ product.title | escape }}"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="6.5" cy="6.5" r="4" stroke="currentColor" stroke-width="1.5"/>
        <path d="M10 10l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Add to cart overlay (centred, appears on hover) -->
    {%- if single_variant and product.available -%}
      <button
        class="card__atc-overlay"
        type="button"
        data-card-atc="{{ product.variants.first.id }}"
        aria-label="Add {{ product.title | escape }} to cart"
      >
        <span class="card__atc-label">Add to Cart</span>
        <span class="card__atc-added" aria-hidden="true">Added!</span>
      </button>
    {%- elsif product.available -%}
      <a href="{{ product.url }}" class="card__atc-overlay">Select Options</a>
    {%- else -%}
      <span class="card__atc-overlay card__atc-overlay--soldout">Sold Out</span>
    {%- endif -%}
  </div>

  <div class="card__info">
    {%- if product.vendor != blank -%}
      <p class="card__vendor">{{ product.vendor }}</p>
    {%- endif -%}
    <a href="{{ product.url }}" class="card__title-link">
      <h3 class="card__title">{{ product.title }}</h3>
    </a>
    <div class="card__pricing">
      {%- if on_sale -%}
        <span class="price price--sale">{{ card_price | money }}</span>
        <span class="price price--compare">{{ compare | money }}</span>
      {%- else -%}
        <span class="price">{{ card_price | money }}</span>
      {%- endif -%}
    </div>
  </div>

</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    cursor: pointer;
  }

  /* ── MEDIA WRAP ─────────────────────────────────────────── */
  .card__media-wrap {
    position: relative;
  }

  .card__media-link {
    display: block;
    text-decoration: none;
  }

  .card__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: var(--color-bone-alt, #EDE8DF);
    border-radius: var(--radius-base);
  }

  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .card:hover .card__media img,
  .card:focus-within .card__media img {
    transform: scale(1.04);
  }

  .card__media .placeholder-svg {
    width: 100%;
    height: 100%;
    fill: var(--color-olive);
    opacity: 0.08;
  }

  .card__badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    z-index: 1;
  }

  /* ── MAGNIFYING GLASS BUTTON ────────────────────────────── */
  .card__qv-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: #fff;
    border: none;
    border-radius: 50%;
    color: #2D2D2D;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .card:hover .card__qv-btn,
  .card:focus-within .card__qv-btn {
    opacity: 1;
    transform: scale(1);
  }

  .card__qv-btn:hover {
    background: var(--color-bone, #F2EDE4);
  }

  /* ── ADD TO CART OVERLAY ────────────────────────────────── */
  .card__atc-overlay {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: calc(100% - 24px);
    padding: 12px 16px;
    background: #fff;
    border: none;
    border-radius: 6px;
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2D2D2D;
    text-decoration: none;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.22s ease, transform 0.22s ease, background 0.15s;
    white-space: nowrap;
    overflow: hidden;
  }

  .card:hover .card__atc-overlay,
  .card:focus-within .card__atc-overlay {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .card__atc-overlay:hover {
    background: var(--color-bone, #F2EDE4);
  }

  .card__atc-overlay--soldout {
    opacity: 0 !important;
    pointer-events: none;
  }

  /* "Added!" feedback state */
  .card__atc-added {
    display: none;
    color: var(--color-walnut, #8A6240);
  }

  .card__atc-overlay.is-added .card__atc-label { display: none; }
  .card__atc-overlay.is-added .card__atc-added { display: inline; }

  /* ── CARD INFO ──────────────────────────────────────────── */
  .card__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .card__vendor {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(43, 43, 43, 0.45);
    margin: 0;
  }

  .card__title-link {
    text-decoration: none;
    color: inherit;
  }

  .card__title-link:focus-visible {
    outline: 2px solid var(--color-walnut);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .card__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-md);
    font-weight: 400;
    color: var(--color-black);
    line-height: 1.3;
    margin: 0;
    transition: color var(--transition-fast);
  }

  .card__title-link:hover .card__title {
    color: var(--color-walnut);
  }

  .card__pricing {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: 2px;
  }
</style>

<script>
  (function () {
    document.querySelectorAll('[data-card-atc]').forEach(function (btn) {
      if (btn.dataset.cardAtcBound) return;
      btn.dataset.cardAtcBound = '1';
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        var variantId = btn.dataset.cardAtc;
        btn.disabled = true;
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ id: variantId, quantity: 1 })
        })
        .then(function (res) { return res.json(); })
        .then(function () {
          btn.classList.add('is-added');
          document.dispatchEvent(new CustomEvent('cart:refresh', { detail: { openDrawer: true } }));
          setTimeout(function () {
            btn.classList.remove('is-added');
            btn.disabled = false;
          }, 1800);
        })
        .catch(function () { btn.disabled = false; });
      });
    });
  })();
</script>
