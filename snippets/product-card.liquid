{%- liquid
  assign card_image   = product.featured_media
  assign card_price   = product.price
  assign compare      = product.compare_at_price
  assign on_sale      = false
  if compare > card_price
    assign on_sale = true
  endif
  assign single_variant = false
  if product.variants.size == 1
    assign single_variant = true
  endif
  if card_image != blank
    assign card_img_400 = card_image | image_url: width: 400
    assign card_img_600 = card_image | image_url: width: 600
    assign card_img_800 = card_image | image_url: width: 800
    assign card_img_alt = card_image.alt | default: product.title | escape
  endif
  assign card_subtitle = product.metafields.custom.card_tag
  if card_subtitle == blank
    assign card_subtitle = product.type
  endif
-%}

<article class="card{% if on_sale %} card--on-sale{% endif %}" aria-label="{{ product.title }}">

  <a href="{{ product.url }}" class="card__media-link" tabindex="-1" aria-hidden="true">
    <div class="card__media">
      {%- if card_image != blank -%}
        <img
          src="{{ card_img_600 }}"
          srcset="{{ card_img_400 }} 400w, {{ card_img_600 }} 600w, {{ card_img_800 }} 800w"
          sizes="(max-width: 767px) 50vw, 33vw"
          alt="{{ card_img_alt }}"
          width="600"
          height="600"
          loading="lazy"
        >
      {%- else -%}
        {{ product.title | placeholder_svg_tag: 'placeholder-svg card__placeholder' }}
      {%- endif -%}

      {%- if on_sale -%}
        <span class="card__badge">Sale</span>
      {%- endif -%}
    </div>
  </a>

  <div class="card__rule"></div>

  <div class="card__info">
    <a href="{{ product.url }}" class="card__title-link">
      <h3 class="card__title">{{ product.title }}</h3>
    </a>

    {%- if card_subtitle != blank -%}
      <p class="card__subtitle">{{ card_subtitle }}</p>
    {%- endif -%}

    <div class="card__meta">
      {%- if single_variant -%}
        <span class="card__size">{{ product.variants.first.title }}</span>
      {%- else -%}
        <span class="card__size">{{ product.variants.size }} options</span>
      {%- endif -%}

      <div class="card__price">
        {%- if on_sale -%}
          <span class="card__price-now">{{ card_price | money }}</span>
          <span class="card__price-was">{{ compare | money }}</span>
        {%- else -%}
          <span class="card__price-now">{{ card_price | money }}</span>
        {%- endif -%}
      </div>
    </div>

    {%- if single_variant and product.available -%}
      <button
        class="card__atc"
        type="button"
        data-card-atc="{{ product.variants.first.id }}"
        aria-label="Add {{ product.title | escape }} to cart"
      >
        <span class="card__atc-label">Add to cart</span>
        <span class="card__atc-added" aria-hidden="true">Added</span>
      </button>
    {%- elsif product.available -%}
      <a href="{{ product.url }}" class="card__atc">Select options</a>
    {%- else -%}
      <span class="card__atc card__atc--soldout">Sold out</span>
    {%- endif -%}
  </div>

</article>

<style>
.card {
  display: flex;
  flex-direction: column;
  background: transparent;
}

.card__media-link {
  display: block;
  text-decoration: none;
}

.card__media {
  position: relative;
  aspect-ratio: 1 / 1;
  background: var(--paper);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.card__media img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  padding: 2rem;
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.card__media-link:hover .card__media img {
  transform: scale(1.04);
}

.card__placeholder {
  width: 60%;
  height: 60%;
  opacity: 0.12;
  fill: var(--char);
}

.card__badge {
  position: absolute;
  top: 1rem;
  left: 1rem;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--cream);
  background: var(--char);
  padding: 4px 8px;
  border-radius: 2px;
}

.card__rule {
  height: 1px;
  background: var(--line);
  margin: 0;
}

.card__info {
  padding: 1.25rem 0 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

.card__title-link {
  text-decoration: none;
  color: inherit;
}

.card__title {
  font-family: var(--font-serif);
  font-size: 1.1rem;
  font-weight: 500;
  font-style: normal;
  color: var(--char);
  line-height: 1.25;
  margin: 0;
  transition: color 0.15s ease;
}

.card__title-link:hover .card__title {
  color: var(--gold-deep);
}

.card__subtitle {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--char-soft);
  margin: 0;
  line-height: 1.4;
}

.card__meta {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 0.5rem;
  margin-top: 0.25rem;
}

.card__size {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--char-soft);
}

.card__price {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
}

.card__price-now {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--char);
}

.card__price-was {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--char-soft);
  text-decoration: line-through;
}

.card--on-sale .card__price-now {
  color: var(--gold-deep);
}

.card__atc {
  display: block;
  width: 100%;
  margin-top: auto;
  padding: 0.75rem 1rem;
  background: var(--char);
  color: var(--cream);
  border: none;
  border-radius: 0;
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 500;
  letter-spacing: 0.02em;
  text-align: center;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.18s ease;
  margin-top: 0.875rem;
}

.card__atc:hover {
  background: var(--gold-deep);
}

.card__atc--soldout {
  opacity: 0.45;
  cursor: not-allowed;
  pointer-events: none;
}

.card__atc-added { display: none; }
.card__atc.is-added .card__atc-label { display: none; }
.card__atc.is-added .card__atc-added { display: inline; }

@media (max-width: 767px) {
  .card__media img { padding: 1.25rem; }
}
</style>

<script>
(function () {
  if (window.__mcCardAtcInit) return;
  window.__mcCardAtcInit = true;

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-card-atc]');
    if (!btn || btn.disabled) return;
    e.preventDefault();

    var variantId = btn.dataset.cardAtc;
    btn.disabled = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function (res) { return res.json(); })
    .then(function () {
      btn.classList.add('is-added');
      document.dispatchEvent(new CustomEvent('cart:refresh', { detail: { openDrawer: true } }));
      setTimeout(function () {
        btn.classList.remove('is-added');
        btn.disabled = false;
      }, 1800);
    })
    .catch(function () { btn.disabled = false; });
  });
}());
</script>
